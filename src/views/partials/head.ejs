<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0ea5e9" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-title" content="Bento Resort" />
  <meta name="application-name" content="Bento Resort" />
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" />
  <title><%= title %> · Bento Resort</title>
  <link rel="manifest" href="/manifest.webmanifest" />
  <link rel="icon" href="/icons/app-icon.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/icons/app-icon-192.png" />
  <link rel="stylesheet" href="/app.css" />
  <script>
    (() => {
      const token = document.querySelector('meta[name="csrf-token"]')?.getAttribute("content") || "";
      const nativeFetch = window.fetch;

      if (!token || !nativeFetch || window.__abcCsrfFetchReady) {
        return;
      }

      window.__abcCsrfFetchReady = true;
      window.fetch = (input, init = {}) => {
        const method = String(init.method || (input instanceof Request ? input.method : "GET")).toUpperCase();
        const sameOrigin = typeof input === "string"
          ? input.startsWith("/") || input.startsWith(window.location.origin)
          : input instanceof Request
            ? new URL(input.url, window.location.href).origin === window.location.origin
            : true;

        if (sameOrigin && ["POST", "PUT", "PATCH", "DELETE"].includes(method)) {
          const headers = new Headers(init.headers || (input instanceof Request ? input.headers : undefined));
          if (!headers.has("x-csrf-token")) {
            headers.set("x-csrf-token", token);
          }
          return nativeFetch(input, { ...init, headers });
        }

      return nativeFetch(input, init);
      };
    })();

    (() => {
      const formatDate = (date) => date.toLocaleDateString("vi-VN", {
        weekday: "short",
        day: "2-digit",
        month: "2-digit",
        year: "numeric"
      });
      const formatTime = (date) => date.toLocaleTimeString("vi-VN", {
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit"
      });

      window.addEventListener("DOMContentLoaded", () => {
        if (document.querySelector(".header-clock, .global-floating-clock")) return;

        const clock = document.createElement("div");
        clock.className = "global-floating-clock";
        clock.setAttribute("aria-label", "Đồng hồ và lịch");
        clock.innerHTML = "<span data-global-date>--/--/----</span><strong data-global-time>--:--:--</strong>";
        document.body.appendChild(clock);

        const dateEl = clock.querySelector("[data-global-date]");
        const timeEl = clock.querySelector("[data-global-time]");
        const update = () => {
          const now = new Date();
          dateEl.textContent = formatDate(now);
          timeEl.textContent = formatTime(now);
        };

        update();
        window.setInterval(update, 1000);
      });
    })();

    (() => {
      const standalone = window.matchMedia?.("(display-mode: standalone)")?.matches
        || window.navigator.standalone === true;
      const state = window.__abcPwaState = {
        supported: "serviceWorker" in navigator,
        installed: standalone,
        installAvailable: false,
        hasWaitingUpdate: false,
        online: navigator.onLine
      };
      let deferredInstallPrompt = null;
      let waitingWorker = null;

      const emitState = (eventName = "abc:pwa-state") => {
        window.dispatchEvent(new CustomEvent(eventName, { detail: { ...state } }));
      };

      window.__abcPwaInstall = async () => {
        if (!deferredInstallPrompt) return false;
        deferredInstallPrompt.prompt();
        const result = await deferredInstallPrompt.userChoice.catch(() => ({ outcome: "dismissed" }));
        deferredInstallPrompt = null;
        state.installAvailable = false;
        state.installed = result.outcome === "accepted" || state.installed;
        emitState();
        return state.installed;
      };

      window.__abcPwaApplyUpdate = () => {
        if (!waitingWorker) return false;
        waitingWorker.postMessage({ type: "SKIP_WAITING" });
        return true;
      };

      window.addEventListener("beforeinstallprompt", (event) => {
        event.preventDefault();
        deferredInstallPrompt = event;
        state.installAvailable = true;
        emitState("abc:pwa-install-available");
      });

      window.addEventListener("appinstalled", () => {
        deferredInstallPrompt = null;
        state.installAvailable = false;
        state.installed = true;
        emitState();
      });

      window.addEventListener("online", () => {
        state.online = true;
        emitState();
      });

      window.addEventListener("offline", () => {
        state.online = false;
        emitState();
      });

      if (!state.supported) {
        emitState();
        return;
      }

      window.addEventListener("load", () => {
        navigator.serviceWorker.register("/sw.js", { scope: "/" }).then((registration) => {
          const trackWaitingWorker = (worker) => {
            if (!worker) return;
            waitingWorker = worker;
            state.hasWaitingUpdate = true;
            emitState();
          };

          trackWaitingWorker(registration.waiting);

          registration.addEventListener("updatefound", () => {
            const newWorker = registration.installing;
            if (!newWorker) return;
            newWorker.addEventListener("statechange", () => {
              if (newWorker.state === "installed" && navigator.serviceWorker.controller) {
                trackWaitingWorker(newWorker);
              }
            });
          });

          emitState();
        }).catch(() => {
          state.supported = false;
          emitState();
        });

        navigator.serviceWorker.addEventListener("controllerchange", () => {
          if (window.__abcPwaRefreshing) return;
          window.__abcPwaRefreshing = true;
          window.location.reload();
        });
      });
    })();
  </script>
</head>
<body>
