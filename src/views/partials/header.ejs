<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="brand">
      <strong>Bento Resort</strong>
      <span>Hệ thống đặt phòng và vận hành resort</span>
    </a>

    <form class="header-search" action="/booking/search" method="get" role="search" id="headerSearchForm">
      <div class="header-search__shell" id="headerSearchShell" aria-label="Tìm phòng">
        <span class="header-search__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
            <circle cx="11" cy="11" r="6.5" stroke="currentColor" stroke-width="1.8"></circle>
            <path d="M16 16L21 21" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
          </svg>
        </span>
        <input
          class="header-search__input"
          type="text"
          name="hotel_name"
          value="<%= typeof query?.hotel_name === 'string' ? query.hotel_name : '' %>"
          placeholder="Tìm khách sạn, khu nghỉ dưỡng hoặc điểm đến"
          autocomplete="off"
          id="headerSearchInput"
        />
        <button class="header-search__submit" type="button" id="headerSearchToggle">Tìm kiếm</button>
      </div>

      <div class="header-search__panel" id="headerSearchPanel" hidden>
        <div class="header-search__grid">
          <div class="header-search__field">
            <label for="header_hotel_city">Điểm đến</label>
            <input
              id="header_hotel_city"
              type="text"
              name="hotel_city"
              value="<%= typeof query?.hotel_city === 'string' ? query.hotel_city : '' %>"
              placeholder="Ví dụ: Đà Nẵng"
            />
          </div>
          <div class="header-search__field">
            <label for="header_so_khach">Số khách</label>
            <input
              id="header_so_khach"
              type="number"
              name="so_khach"
              min="1"
              max="12"
              value="<%= typeof query?.so_khach === 'string' ? query.so_khach : '' %>"
              placeholder="2"
            />
          </div>
          <div class="header-search__field">
            <label for="header_ngay_nhan">Ngày nhận</label>
            <input
              id="header_ngay_nhan"
              type="date"
              name="ngay_nhan"
              value="<%= typeof query?.ngay_nhan === 'string' ? query.ngay_nhan : '' %>"
            />
          </div>
          <div class="header-search__field">
            <label for="header_ngay_tra">Ngày trả</label>
            <input
              id="header_ngay_tra"
              type="date"
              name="ngay_tra"
              value="<%= typeof query?.ngay_tra === 'string' ? query.ngay_tra : '' %>"
            />
          </div>
        </div>
        <div class="header-search__meta">
          <span class="header-search__hint">Nhập nhanh điểm đến hoặc mở bộ lọc để tìm theo ngày và số khách.</span>
          <div class="header-search__actions">
            <a class="header-search__link" href="/booking/search">Mở trang tìm phòng đầy đủ</a>
            <button class="header-search__submit header-search__submit--panel" type="submit">Tìm phòng</button>
          </div>
        </div>
      </div>
    </form>

    <nav class="nav-links">
      <% if (currentUser) { %>
        <% if (currentUser.maVaiTro === 1) { %>
          <a class="chip" href="/admin/users">Admin</a>
        <% } %>
        <% if (currentUser.maVaiTro === 1 || currentUser.maVaiTro === 6) { %>
          <a class="chip" href="/ai/analytics">AI Analytics</a>
        <% } %>
        <% if (currentUser.maVaiTro === 6) { %>
          <a class="chip" href="/dashboard/quanly">Quản lý</a>
        <% } %>
        <% if (currentUser.maVaiTro === 3) { %>
          <a class="chip" href="/accounting">Kế toán</a>
          <a class="chip" href="/accounting/cashflow">Thu chi</a>
          <a class="chip" href="/accounting/refunds">Hoàn tiền</a>
        <% } %>
        <% if (currentUser.maVaiTro === 5 || currentUser.maVaiTro === 6 || currentUser.maVaiTro === 1) { %>
          <a class="chip" href="/feedback/manage">Feedback</a>
        <% } %>
        <% if (currentUser.maVaiTro === 7) { %>
          <a class="chip" href="/customer/dashboard">Portal</a>
          <a class="chip" href="/customer/profile">Hồ sơ</a>
          <a class="chip" href="/customer/services">Dịch vụ</a>
          <a class="chip" href="/feedback/new">Phản hồi</a>
        <% } %>
        <span class="chip"><%= currentUser.displayName %> · <%= currentUser.tenVaiTro %></span>
        <form action="/auth/logout" method="post">
          <button class="button" type="submit">Đăng xuất</button>
        </form>
      <% } else { %>
        <a class="chip" href="/auth/login">Đăng nhập</a>
        <a class="button button--primary" href="/auth/register">Đăng ký</a>
      <% } %>
    </nav>
  </div>
</header>
<script>
  (() => {
    const form = document.getElementById("headerSearchForm");
    const shell = document.getElementById("headerSearchShell");
    const panel = document.getElementById("headerSearchPanel");
    const toggle = document.getElementById("headerSearchToggle");
    const input = document.getElementById("headerSearchInput");

    if (!form || !shell || !panel || !toggle || !input) return;

    const openPanel = () => {
      shell.classList.add("is-open");
      panel.hidden = false;
    };

    const closePanel = () => {
      shell.classList.remove("is-open");
      panel.hidden = true;
    };

    toggle.addEventListener("click", () => {
      if (panel.hidden) {
        openPanel();
        input.focus();
      } else {
        form.requestSubmit();
      }
    });

    input.addEventListener("focus", openPanel);
    input.addEventListener("click", openPanel);

    document.addEventListener("click", (event) => {
      if (!form.contains(event.target)) {
        closePanel();
      }
    });

    form.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closePanel();
      }
    });
  })();
</script>
