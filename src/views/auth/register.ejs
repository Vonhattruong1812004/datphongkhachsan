<%- include("../partials/head") %>
<style>
  .travel-auth {
    min-height: 100vh;
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at 10% 8%, rgba(125, 211, 252, 0.26), transparent 20%),
      radial-gradient(circle at 88% 10%, rgba(251, 191, 36, 0.18), transparent 18%),
      linear-gradient(180deg, #07111f, #092341 44%, #0b4f75 100%);
  }

  .travel-auth::before,
  .travel-auth::after {
    content: "";
    position: absolute;
    width: 440px;
    height: 440px;
    border-radius: 999px;
    filter: blur(24px);
    opacity: 0.55;
    pointer-events: none;
  }

  .travel-auth::before {
    top: -180px;
    right: -120px;
    background: radial-gradient(circle, rgba(56, 189, 248, 0.32), transparent 72%);
  }

  .travel-auth::after {
    left: -140px;
    bottom: -200px;
    background: radial-gradient(circle, rgba(45, 212, 191, 0.28), transparent 74%);
  }

  .travel-auth__shell {
    width: min(1220px, calc(100vw - 32px));
    margin: 0 auto;
    padding: 34px 0;
    min-height: 100vh;
    display: grid;
    align-items: center;
  }

  .travel-auth__back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
    color: #d6efff;
    font-size: 13px;
    font-weight: 800;
  }

  .travel-auth__layout {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(460px, 0.98fr);
    gap: 24px;
    align-items: stretch;
  }

  .travel-auth__hero,
  .travel-auth__card {
    position: relative;
    border-radius: 34px;
    border: 1px solid rgba(148, 163, 184, 0.18);
    backdrop-filter: blur(22px);
    box-shadow: 0 28px 80px rgba(2, 6, 23, 0.34);
    overflow: hidden;
  }

  .travel-auth__hero {
    min-height: 740px;
    padding: 30px;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.11), rgba(255,255,255,0.03)),
      linear-gradient(180deg, rgba(7, 89, 133, 0.82), rgba(8, 47, 73, 0.95));
  }

  .travel-auth__hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 82% 10%, rgba(253, 224, 71, 0.28), transparent 14%),
      radial-gradient(circle at 14% 14%, rgba(255,255,255,0.16), transparent 24%);
    pointer-events: none;
  }

  .travel-auth__eyebrow {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 12px;
    border-radius: 999px;
    background: rgba(255,255,255,0.14);
    border: 1px solid rgba(255,255,255,0.16);
    color: #dff8ff;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .travel-auth__eyebrow-dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: linear-gradient(135deg, #fde68a, #fb7185);
    box-shadow: 0 0 0 6px rgba(253, 224, 71, 0.14);
  }

  .travel-auth__hero h1 {
    position: relative;
    z-index: 1;
    margin: 22px 0 14px;
    max-width: 540px;
    font-size: clamp(40px, 6vw, 68px);
    line-height: 0.94;
    letter-spacing: -0.08em;
    color: #ffffff;
  }

  .travel-auth__hero p {
    position: relative;
    z-index: 1;
    max-width: 520px;
    color: rgba(239, 246, 255, 0.86);
    font-size: 15px;
    line-height: 1.75;
  }

  .travel-auth__chips,
  .travel-auth__mini-grid {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }

  .travel-auth__chip,
  .travel-auth__mini {
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.14);
    color: #eff6ff;
    font-size: 12px;
    font-weight: 800;
  }

  .travel-auth__scene {
    position: absolute;
    left: 20px;
    right: 20px;
    bottom: 20px;
    height: 360px;
    border-radius: 30px;
    overflow: hidden;
    background: linear-gradient(180deg, #8ee8ff 0%, #effcff 42%, #32c2d9 43%, #0f766e 100%);
  }

  .travel-auth__sun,
  .travel-auth__cloud,
  .travel-auth__rainbow,
  .travel-auth__mountain,
  .travel-auth__island,
  .travel-auth__palm,
  .travel-auth__wave,
  .travel-auth__dolphin {
    position: absolute;
  }

  .travel-auth__sun {
    top: 26px;
    right: 44px;
    width: 84px;
    height: 84px;
    border-radius: 999px;
    background: radial-gradient(circle at 34% 34%, #fff9be, #ffd664 56%, #f59e0b 100%);
    box-shadow: 0 0 0 16px rgba(251, 191, 36, 0.15);
    animation: travel-auth-sun 5.8s ease-in-out infinite;
  }

  .travel-auth__cloud {
    width: 118px;
    height: 38px;
    border-radius: 999px;
    background: rgba(255,255,255,0.9);
    animation: travel-auth-cloud 18s linear infinite;
  }

  .travel-auth__cloud::before,
  .travel-auth__cloud::after {
    content: "";
    position: absolute;
    border-radius: 999px;
    background: inherit;
  }

  .travel-auth__cloud::before {
    width: 56px;
    height: 56px;
    left: 14px;
    top: -20px;
  }

  .travel-auth__cloud::after {
    width: 62px;
    height: 62px;
    right: 12px;
    top: -24px;
  }

  .travel-auth__cloud--one {
    top: 56px;
    left: 34px;
  }

  .travel-auth__cloud--two {
    top: 88px;
    left: 180px;
    transform: scale(0.78);
    opacity: 0.82;
    animation-duration: 22s;
  }

  .travel-auth__rainbow {
    top: 54px;
    left: 232px;
    width: 160px;
    height: 88px;
    border-radius: 160px 160px 0 0;
    border-top: 10px solid #fb7185;
    border-left: 10px solid #fb7185;
    border-right: 10px solid #fb7185;
    opacity: 0.9;
  }

  .travel-auth__rainbow::before,
  .travel-auth__rainbow::after {
    content: "";
    position: absolute;
    inset: 8px;
    border-radius: inherit;
    border-top: 10px solid #f59e0b;
    border-left: 10px solid #f59e0b;
    border-right: 10px solid #f59e0b;
  }

  .travel-auth__rainbow::after {
    inset: 18px;
    border-top-color: #22c55e;
    border-left-color: #22c55e;
    border-right-color: #22c55e;
  }

  .travel-auth__mountain {
    bottom: 132px;
    width: 0;
    height: 0;
    border-left: 126px solid transparent;
    border-right: 126px solid transparent;
    border-bottom: 178px solid #3389ae;
  }

  .travel-auth__mountain--one {
    left: 18px;
  }

  .travel-auth__mountain--two {
    left: 152px;
    border-left-width: 150px;
    border-right-width: 150px;
    border-bottom-width: 208px;
    border-bottom-color: #236f93;
  }

  .travel-auth__island {
    bottom: 104px;
    right: 68px;
    width: 170px;
    height: 36px;
    border-radius: 999px;
    background: linear-gradient(180deg, #f0c982, #bb7c2f);
    box-shadow: inset 0 8px 14px rgba(255,255,255,0.2);
  }

  .travel-auth__palm {
    width: 10px;
    border-radius: 999px;
    background: linear-gradient(180deg, #8b5a2b, #5a3715);
  }

  .travel-auth__palm--left {
    left: 126px;
    bottom: 108px;
    height: 122px;
    transform: rotate(-10deg);
  }

  .travel-auth__palm--right {
    right: 118px;
    bottom: 116px;
    height: 102px;
    transform: rotate(8deg);
  }

  .travel-auth__palm::before,
  .travel-auth__palm::after {
    content: "";
    position: absolute;
    width: 88px;
    height: 18px;
    border-radius: 999px 0 999px 0;
    background: linear-gradient(90deg, #14b86a, #78e3aa);
    transform-origin: left center;
    animation: travel-auth-palm 4.2s ease-in-out infinite;
  }

  .travel-auth__palm::before {
    left: -6px;
    top: 14px;
    transform: rotate(-32deg);
  }

  .travel-auth__palm::after {
    left: -70px;
    top: 30px;
    transform: rotate(24deg);
  }

  .travel-auth__wave {
    left: -8%;
    width: 116%;
    border-radius: 50%;
  }

  .travel-auth__wave--one {
    bottom: 84px;
    height: 88px;
    background: rgba(255,255,255,0.32);
    animation: travel-auth-wave 7s ease-in-out infinite;
  }

  .travel-auth__wave--two {
    bottom: 28px;
    height: 116px;
    background: rgba(111, 231, 255, 0.24);
    animation: travel-auth-wave 9s ease-in-out infinite reverse;
  }

  .travel-auth__wave--three {
    bottom: -18px;
    height: 136px;
    background: linear-gradient(180deg, rgba(191,247,255,0.26), rgba(15,118,110,0.92));
    animation: travel-auth-wave 10.8s ease-in-out infinite;
  }

  .travel-auth__dolphin {
    right: 184px;
    bottom: 120px;
    width: 78px;
    height: 34px;
    border-radius: 60px 60px 24px 24px;
    background: linear-gradient(180deg, #7dd3fc, #2563eb);
    transform: rotate(-12deg);
    animation: travel-auth-dolphin 4.8s ease-in-out infinite;
  }

  .travel-auth__dolphin::before {
    content: "";
    position: absolute;
    right: -10px;
    top: 12px;
    width: 22px;
    height: 12px;
    background: #2563eb;
    clip-path: polygon(0 50%, 100% 0, 100% 100%);
  }

  .travel-auth__dolphin::after {
    content: "";
    position: absolute;
    left: 18px;
    top: -10px;
    width: 18px;
    height: 16px;
    background: #38bdf8;
    clip-path: polygon(50% 0, 100% 100%, 0 100%);
  }

  .travel-auth__card {
    padding: 28px;
    background: rgba(255,255,255,0.94);
    color: #0b3255;
  }

  .travel-auth__card h2 {
    margin: 10px 0 8px;
    font-size: clamp(28px, 4vw, 42px);
    line-height: 0.98;
    letter-spacing: -0.06em;
    color: #0b3255;
  }

  .travel-auth__card p {
    margin: 0 0 16px;
    color: #59748d;
    font-size: 14px;
    line-height: 1.7;
  }

  .travel-auth__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .travel-auth__field {
    display: grid;
    gap: 8px;
  }

  .travel-auth__field--full {
    grid-column: 1 / -1;
  }

  .travel-auth__field label {
    color: #0b3255;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .travel-auth__field input {
    min-height: 50px;
    padding: 0 16px;
    border-radius: 16px;
    border: 1px solid rgba(14, 73, 118, 0.16);
    background: rgba(255,255,255,0.92);
    color: #0b3255;
    font: inherit;
    outline: none;
  }

  .travel-auth__field input:focus {
    border-color: rgba(14, 165, 233, 0.48);
    box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.12);
  }

  .travel-auth__hint {
    margin-top: 6px;
    color: #688198;
    font-size: 12px;
    line-height: 1.6;
  }

  .travel-auth__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }

  .travel-auth__button,
  .travel-auth__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 12px 18px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 900;
  }

  .travel-auth__button {
    border: none;
    color: #ffffff;
    background: linear-gradient(135deg, #0ea5e9, #14b8a6 50%, #22c55e);
    box-shadow: 0 18px 32px rgba(20, 184, 166, 0.18);
    cursor: pointer;
  }

  .travel-auth__link {
    border: 1px solid rgba(14, 73, 118, 0.12);
    background: rgba(255,255,255,0.86);
    color: #0b3255;
  }

  .travel-auth__trust {
    display: grid;
    gap: 10px;
    margin-top: 18px;
  }

  .travel-auth__trust-item {
    border-radius: 18px;
    padding: 14px;
    background: rgba(15, 23, 42, 0.04);
    border: 1px solid rgba(14, 73, 118, 0.08);
  }

  .travel-auth__trust-item strong {
    display: block;
    color: #0b3255;
    font-size: 15px;
    line-height: 1.2;
  }

  .travel-auth__trust-item span {
    display: block;
    margin-top: 6px;
    color: #59748d;
    font-size: 13px;
    line-height: 1.6;
  }

  @keyframes travel-auth-sun {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.06); }
  }

  @keyframes travel-auth-wave {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(0, -10px, 0); }
  }

  @keyframes travel-auth-cloud {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(18px); }
  }

  @keyframes travel-auth-palm {
    0%, 100% { transform: rotate(24deg); }
    50% { transform: rotate(34deg); }
  }

  @keyframes travel-auth-dolphin {
    0%, 100% { transform: translate3d(0, 0, 0) rotate(-12deg); }
    50% { transform: translate3d(10px, -18px, 0) rotate(-18deg); }
  }

  @media (max-width: 980px) {
    .travel-auth__layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .travel-auth__shell {
      width: min(100vw - 18px, 100%);
      padding: 18px 0 34px;
    }

    .travel-auth__hero,
    .travel-auth__card {
      border-radius: 28px;
      padding: 22px;
    }

    .travel-auth__grid {
      grid-template-columns: 1fr;
    }

    .travel-auth__scene {
      position: relative;
      left: auto;
      right: auto;
      bottom: auto;
      margin-top: 18px;
      height: 280px;
    }

    .travel-auth__rainbow {
      left: 140px;
      transform: scale(0.78);
      transform-origin: top left;
    }

    .travel-auth__dolphin {
      right: 110px;
      bottom: 98px;
      transform: scale(0.8) rotate(-12deg);
    }
  }

  /* Register galaxy refresh: UI only, keep form fields and submit logic unchanged. */
  .travel-auth {
    min-height: 100vh;
    min-height: 100dvh;
    display: grid;
    color: #f8fbff;
    background:
      radial-gradient(circle at 18% 14%, rgba(56, 189, 248, 0.22), transparent 25%),
      radial-gradient(circle at 88% 9%, rgba(168, 85, 247, 0.22), transparent 28%),
      radial-gradient(circle at 52% 110%, rgba(20, 184, 166, 0.15), transparent 38%),
      linear-gradient(145deg, #020611 0%, #07152d 46%, #130821 100%);
  }

  .travel-auth::before {
    inset: -90px;
    width: auto;
    height: auto;
    border-radius: 0;
    filter: none;
    opacity: 0.72;
    background:
      radial-gradient(circle at 8% 16%, rgba(255,255,255,.88) 0 1px, transparent 2px),
      radial-gradient(circle at 18% 72%, rgba(255,255,255,.70) 0 1px, transparent 2px),
      radial-gradient(circle at 29% 38%, rgba(165,243,252,.80) 0 1px, transparent 2px),
      radial-gradient(circle at 41% 82%, rgba(255,255,255,.76) 0 1px, transparent 2px),
      radial-gradient(circle at 57% 24%, rgba(255,255,255,.82) 0 1px, transparent 2px),
      radial-gradient(circle at 68% 66%, rgba(191,219,254,.76) 0 1px, transparent 2px),
      radial-gradient(circle at 81% 34%, rgba(255,255,255,.84) 0 1px, transparent 2px),
      radial-gradient(circle at 94% 76%, rgba(255,255,255,.72) 0 1px, transparent 2px);
    background-size: 260px 260px, 310px 310px, 220px 220px, 360px 360px, 280px 280px, 330px 330px, 240px 240px, 390px 390px;
  }

  .travel-auth::after {
    inset: -140px;
    width: auto;
    height: auto;
    border-radius: 0;
    filter: blur(0.2px);
    opacity: 0.46;
    background:
      radial-gradient(ellipse at 18% 72%, rgba(34, 211, 238, .18), transparent 42%),
      radial-gradient(ellipse at 78% 18%, rgba(244, 114, 182, .16), transparent 40%),
      radial-gradient(ellipse at 50% 48%, rgba(99, 102, 241, .16), transparent 50%),
      linear-gradient(120deg, transparent 0 35%, rgba(125, 211, 252, .08) 46%, transparent 58% 100%);
    animation: travel-auth-nebula 24s ease-in-out infinite alternate;
  }

  .travel-auth__shell {
    position: relative;
    z-index: 1;
    width: min(1540px, calc(100vw - 72px));
    min-height: 100vh;
    min-height: 100dvh;
    padding: clamp(28px, 4.4vh, 54px) 0;
    align-items: center;
  }

  .travel-auth__back {
    position: absolute;
    left: 0;
    top: clamp(18px, 2.4vh, 30px);
    color: #dff8ff;
    width: max-content;
    padding: 8px 12px;
    border: 1px solid rgba(125, 211, 252, .18);
    border-radius: 999px;
    background: rgba(3, 10, 24, .38);
    backdrop-filter: blur(14px);
  }

  .travel-auth__layout {
    grid-template-columns: minmax(560px, .96fr) minmax(540px, .78fr);
    gap: clamp(32px, 4vw, 58px);
    align-items: center;
  }

  .travel-auth__hero,
  .travel-auth__card {
    border-color: rgba(148, 190, 255, .22);
    box-shadow: 0 30px 90px rgba(0, 0, 0, .36);
  }

  .travel-auth__hero--scene-only {
    min-height: clamp(620px, 76vh, 820px);
    max-height: 860px;
    padding: 0;
    background: transparent;
  }

  .travel-auth__hero--scene-only::before {
    display: none;
  }

  .travel-auth .travel-scene-card {
    position: absolute;
    inset: 0;
    min-height: 100%;
    border-radius: 32px;
    overflow: hidden;
    border: 1px solid rgba(125, 211, 252, 0.24);
    background:
      radial-gradient(ellipse at 46% 42%, rgba(30, 64, 175, 0.26), transparent 34%),
      radial-gradient(ellipse at 18% 18%, rgba(14, 116, 144, 0.2), transparent 28%),
      radial-gradient(ellipse at 86% 80%, rgba(88, 28, 135, 0.2), transparent 34%),
      linear-gradient(180deg, #01030b 0%, #040718 48%, #090416 100%);
    box-shadow:
      inset 0 0 80px rgba(0, 0, 0, 0.38),
      0 34px 110px rgba(2, 6, 23, 0.46),
      0 0 80px rgba(103, 232, 249, 0.12);
  }

  .travel-auth .travel-scene-card::before,
  .travel-auth .travel-scene-card::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .travel-auth .travel-scene-card::before {
    z-index: 0;
    background:
      radial-gradient(circle at 12% 18%, rgba(255, 255, 255, 0.92) 0 1px, transparent 2px),
      radial-gradient(circle at 28% 64%, rgba(125, 211, 252, 0.78) 0 1px, transparent 2px),
      radial-gradient(circle at 72% 22%, rgba(255, 255, 255, 0.78) 0 1px, transparent 2px),
      radial-gradient(circle at 86% 72%, rgba(196, 181, 253, 0.82) 0 1px, transparent 2px);
    background-size: 120px 120px, 160px 160px, 96px 96px, 140px 140px;
  }

  .travel-auth .travel-scene-card::after {
    z-index: 2;
    background:
      radial-gradient(ellipse at 50% 50%, transparent 0 42%, rgba(2, 6, 23, 0.28) 72%, rgba(0, 0, 0, 0.58) 100%),
      linear-gradient(112deg, rgba(255,255,255,0.08), transparent 26% 74%, rgba(56,189,248,0.08));
    opacity: 0.78;
  }

  .travel-auth .cosmic-scene {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 1;
  }

  .travel-auth .cosmic-scene::before,
  .travel-auth .cosmic-scene::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .travel-auth .cosmic-scene::before {
    z-index: 0;
    background:
      radial-gradient(circle at 18% 22%, rgba(255,255,255,0.9) 0 1px, transparent 2px),
      radial-gradient(circle at 34% 18%, rgba(125,211,252,0.55) 0 1px, transparent 2px),
      radial-gradient(circle at 68% 32%, rgba(255,255,255,0.78) 0 1px, transparent 2px),
      radial-gradient(circle at 84% 70%, rgba(186,230,253,0.72) 0 1px, transparent 2px),
      radial-gradient(ellipse at 50% 62%, rgba(30, 64, 175, 0.18), transparent 38%);
    background-size: 150px 130px, 220px 190px, 180px 160px, 260px 220px, 100% 100%;
    opacity: 0.78;
  }

  .travel-auth .cosmic-scene::after {
    z-index: 3;
    background:
      radial-gradient(ellipse at 35% 35%, rgba(255,255,255,0.08), transparent 18%),
      radial-gradient(ellipse at 50% 50%, transparent 0 54%, rgba(0,0,0,0.38) 100%);
    mix-blend-mode: screen;
  }

  .travel-auth .cosmic-depth-plane,
  .travel-auth .cosmic-star-dust,
  .travel-auth .cosmic-asteroid-belt,
  .travel-auth .solar-light-ray,
  .travel-auth .cosmic-core,
  .travel-auth .solar-orbit,
  .travel-auth .moon-orbit,
  .travel-auth .cosmic-asteroid {
    position: absolute;
    pointer-events: none;
  }

  .travel-auth .cosmic-depth-plane {
    left: 50%;
    top: 50%;
    border-radius: 50%;
    transform: translate(-50%, -50%) rotate(-10deg);
    z-index: 0;
  }

  .travel-auth .cosmic-depth-plane--one {
    width: 86%;
    height: 56%;
    border: 1px solid rgba(125, 211, 252, 0.12);
    box-shadow: inset 0 0 44px rgba(59, 130, 246, 0.08);
  }

  .travel-auth .cosmic-depth-plane--two {
    width: 112%;
    height: 72%;
    border: 1px solid rgba(196, 181, 253, 0.1);
    transform: translate(-50%, -50%) rotate(12deg);
  }

  .travel-auth .cosmic-depth-plane--three {
    width: 132%;
    height: 88%;
    border: 1px solid rgba(148, 163, 184, 0.08);
    transform: translate(-50%, -50%) rotate(-22deg);
  }

  .travel-auth .cosmic-star-dust {
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(circle at 12% 38%, rgba(255,255,255,0.78) 0 1px, transparent 2px),
      radial-gradient(circle at 23% 72%, rgba(125,211,252,0.55) 0 1px, transparent 2px),
      radial-gradient(circle at 44% 18%, rgba(255,255,255,0.7) 0 1px, transparent 2px),
      radial-gradient(circle at 58% 86%, rgba(196,181,253,0.62) 0 1px, transparent 2px),
      radial-gradient(circle at 82% 46%, rgba(255,255,255,0.74) 0 1px, transparent 2px);
    background-size: 180px 150px, 240px 190px, 160px 130px, 220px 170px, 280px 230px;
    opacity: 0.8;
  }

  .travel-auth .cosmic-asteroid-belt {
    left: 50%;
    top: 50%;
    width: 76%;
    height: 48%;
    border-radius: 50%;
    transform: translate(-50%, -50%) rotate(-16deg);
    z-index: 1;
    background:
      radial-gradient(circle at 8% 50%, rgba(226,232,240,0.65) 0 2px, transparent 3px),
      radial-gradient(circle at 18% 36%, rgba(148,163,184,0.52) 0 1px, transparent 2px),
      radial-gradient(circle at 32% 68%, rgba(226,232,240,0.48) 0 1px, transparent 2px),
      radial-gradient(circle at 48% 30%, rgba(148,163,184,0.54) 0 2px, transparent 3px),
      radial-gradient(circle at 63% 72%, rgba(226,232,240,0.5) 0 1px, transparent 2px),
      radial-gradient(circle at 78% 40%, rgba(148,163,184,0.58) 0 1px, transparent 2px),
      radial-gradient(circle at 92% 55%, rgba(226,232,240,0.52) 0 2px, transparent 3px);
    border-top: 1px solid rgba(226, 232, 240, 0.08);
    opacity: 0.62;
    animation: galaxy-belt-drift 42s linear infinite;
  }

  .travel-auth .solar-light-ray {
    left: 76%;
    top: 28%;
    width: 42%;
    height: 42%;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    z-index: 1;
    background:
      radial-gradient(circle, rgba(251,191,36,0.24), transparent 46%),
      conic-gradient(from 20deg, transparent 0 10%, rgba(251,191,36,0.12) 12%, transparent 18% 36%, rgba(250,204,21,0.1) 40%, transparent 46% 70%, rgba(249,115,22,0.1) 74%, transparent 82% 100%);
    filter: blur(1px);
    mix-blend-mode: screen;
    animation: galaxy-sun-rays 18s linear infinite;
  }

  .travel-auth .cosmic-core {
    left: 76%;
    top: 28%;
    width: 96px;
    height: 96px;
    border-radius: 50%;
    z-index: 2;
    transform: translate(-50%, -50%);
    background:
      radial-gradient(circle at 36% 30%, #fff 0 7%, #fff7c2 12%, transparent 18%),
      radial-gradient(circle at 42% 44%, #fff7ad 0 19%, #f97316 43%, #9a3412 70%, #1c0b04 100%);
    box-shadow:
      inset -18px -14px 28px rgba(67, 20, 7, 0.34),
      0 0 48px rgba(251, 191, 36, 0.72),
      0 0 116px rgba(249, 115, 22, 0.34);
    animation: galaxy-sun-pulse 5.5s ease-in-out infinite;
  }

  .travel-auth .solar-orbit {
    left: 50%;
    top: 50%;
    border: 1px solid rgba(148, 163, 184, 0.18);
    border-radius: 50%;
    transform: translate(-50%, -50%) rotate(-12deg);
    transform-origin: center;
    z-index: 1;
    animation: galaxy-solar-orbit 28s linear infinite;
  }

  .travel-auth .solar-orbit--mercury { width: 190px; height: 124px; animation-duration: 20s; animation-delay: -5s; }
  .travel-auth .solar-orbit--venus { width: 270px; height: 174px; animation-duration: 28s; animation-direction: reverse; animation-delay: -12s; }
  .travel-auth .solar-orbit--mars { width: 350px; height: 232px; animation-duration: 36s; animation-delay: -19s; }
  .travel-auth .solar-orbit--jupiter { width: 468px; height: 310px; animation-duration: 52s; animation-direction: reverse; animation-delay: -28s; }
  .travel-auth .solar-orbit--saturn { width: 584px; height: 390px; animation-duration: 68s; animation-delay: -43s; }

  .travel-auth .solar-planet {
    position: absolute;
    right: -8px;
    top: 50%;
    border-radius: 50%;
    transform: translateY(-50%);
    box-shadow:
      inset -12px -9px 18px rgba(2, 6, 23, 0.58),
      inset 5px 4px 10px rgba(255, 255, 255, 0.16),
      0 0 18px rgba(125, 211, 252, 0.12);
  }

  .travel-auth .solar-planet--mercury { width: 20px; height: 20px; background: linear-gradient(135deg, #9ca3af, #475569); }
  .travel-auth .solar-planet--venus { width: 34px; height: 34px; background: repeating-linear-gradient(165deg, rgba(254,243,199,0.18) 0 5px, rgba(161,98,7,0.18) 5px 12px), linear-gradient(135deg, #facc15, #a16207 58%, #3f2206); }
  .travel-auth .solar-planet--mars { width: 30px; height: 30px; background: radial-gradient(circle at 62% 64%, rgba(69,10,10,0.52), transparent 32%), linear-gradient(135deg, #f87171, #991b1b 62%, #2a0505); }
  .travel-auth .solar-planet--jupiter { width: 58px; height: 58px; right: -18px; background: repeating-linear-gradient(172deg, rgba(254,243,199,0.22) 0 5px, rgba(180,83,9,0.28) 5px 12px, rgba(69,26,3,0.18) 12px 18px), linear-gradient(135deg, #fbbf24, #92400e 62%, #2b1204); }
  .travel-auth .solar-planet--saturn { width: 48px; height: 48px; right: -16px; background: repeating-linear-gradient(170deg, rgba(254,243,199,0.18) 0 5px, rgba(146,64,14,0.22) 5px 11px), linear-gradient(135deg, #fde68a, #92400e 62%, #241004); }

  .travel-auth .solar-planet--saturn::before {
    content: "";
    position: absolute;
    left: -18px;
    right: -18px;
    top: 42%;
    height: 18%;
    border-radius: 50%;
    border-top: 4px solid rgba(254, 243, 199, 0.5);
    border-bottom: 2px solid rgba(146, 64, 14, 0.42);
    transform: rotate(-13deg);
  }

  .travel-auth .cosmic-earth {
    position: absolute;
    left: 50%;
    top: 50%;
    width: clamp(170px, 17vw, 260px);
    height: clamp(170px, 17vw, 260px);
    border-radius: 50%;
    z-index: 5;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle at 42% 42%, rgba(14, 165, 233, 0.18), rgba(2, 6, 23, 0.08) 70%);
    box-shadow: 0 0 52px rgba(56, 189, 248, 0.28), 0 0 120px rgba(14, 165, 233, 0.16);
    animation: galaxy-earth-center-drift 10s ease-in-out infinite;
  }

  .travel-auth .cosmic-earth::before,
  .travel-auth .cosmic-earth::after {
    content: "";
    position: absolute;
    pointer-events: none;
  }

  .travel-auth .cosmic-earth::before {
    inset: -18px;
    border-radius: 50%;
    background: radial-gradient(circle, transparent 58%, rgba(103, 232, 249, 0.18) 68%, transparent 74%);
    filter: blur(2px);
  }

  .travel-auth .cosmic-earth::after {
    left: -22px;
    right: -22px;
    top: 52px;
    height: 36px;
    border-radius: 50%;
    border-top: 3px solid rgba(191, 219, 254, 0.42);
    transform: rotate(-14deg);
    opacity: 0.5;
  }

  .travel-auth .cosmic-earth canvas {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: 100%;
  }

  .travel-auth .moon-orbit {
    left: 50%;
    top: 50%;
    width: 250px;
    height: 164px;
    border: 1px solid rgba(226, 232, 240, 0.18);
    border-radius: 50%;
    z-index: 4;
    transform: translate(-50%, -50%) rotate(-18deg);
    animation: galaxy-moon-orbit 15s linear infinite;
  }

  .travel-auth .cosmic-moon {
    position: absolute;
    right: -10px;
    top: 50%;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    transform: translateY(-50%);
    background: linear-gradient(135deg, #f8fafc, #94a3b8 68%, #334155);
    box-shadow: inset -8px -6px 12px rgba(15, 23, 42, 0.34), 0 0 18px rgba(226, 232, 240, 0.36);
  }

  .travel-auth .cosmic-asteroid {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    z-index: 2;
    opacity: 0.82;
    background: #cbd5e1;
    box-shadow: 0 0 10px rgba(203, 213, 225, 0.52);
  }

  .travel-auth .cosmic-asteroid--one { left: 17%; top: 24%; }
  .travel-auth .cosmic-asteroid--two { left: 31%; top: 76%; transform: scale(0.72); }
  .travel-auth .cosmic-asteroid--three { left: 78%; top: 58%; transform: scale(1.2); }
  .travel-auth .cosmic-asteroid--four { left: 88%; top: 37%; transform: scale(0.82); }
  .travel-auth .cosmic-asteroid--five { left: 22%; top: 58%; transform: scale(0.58); }
  .travel-auth .cosmic-asteroid--six { left: 68%; top: 79%; transform: scale(0.68); }

  .travel-auth__card {
    justify-self: center;
    width: 100%;
    max-width: 680px;
    padding: clamp(30px, 3vw, 44px);
    border-radius: 28px;
    background:
      linear-gradient(180deg, rgba(10, 22, 50, .90), rgba(5, 11, 28, .82)),
      radial-gradient(circle at 100% 0%, rgba(103, 232, 249, .14), transparent 36%);
    color: #f8fbff;
    border-color: rgba(148, 190, 255, .20);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, .08),
      0 28px 90px rgba(0, 0, 0, .42),
      0 0 54px rgba(103, 232, 249, .08);
  }

  .travel-auth__card::before {
    content: "";
    position: absolute;
    inset: 1px;
    border-radius: inherit;
    pointer-events: none;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, .08), transparent 30%),
      radial-gradient(circle at 14% 0%, rgba(103, 232, 249, .12), transparent 28%);
  }

  .travel-auth__card h2,
  .travel-auth__field label,
  .travel-auth__trust-item strong {
    color: #f8fbff;
  }

  .travel-auth__card h2 {
    position: relative;
    z-index: 1;
    margin-top: 0;
    letter-spacing: 0;
  }

  .travel-auth__card p,
  .travel-auth__hint,
  .travel-auth__trust-item span {
    color: rgba(214, 226, 255, .78);
  }

  .travel-auth .section-eyebrow {
    position: relative;
    z-index: 1;
    width: max-content;
    margin: 0 0 18px;
    padding: 8px 12px;
    border-radius: 999px;
    border: 1px solid rgba(253, 230, 138, .22);
    background: rgba(253, 230, 138, .08);
    color: #fde68a;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .16em;
    line-height: 1;
    text-transform: uppercase;
  }

  .travel-auth form,
  .travel-auth__trust {
    position: relative;
    z-index: 1;
  }

  .travel-auth__grid {
    gap: 16px;
  }

  .travel-auth__field {
    gap: 9px;
  }

  .travel-auth__field label {
    font-size: 11px;
    font-weight: 850;
    letter-spacing: .06em;
    color: rgba(226, 232, 240, .90);
  }

  .travel-auth__field input {
    min-height: 56px;
    border-radius: 16px;
    border-color: rgba(148, 190, 255, .22);
    background: rgba(2, 8, 23, .58);
    color: #f8fbff;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, .04);
    transition: border-color .18s ease, box-shadow .18s ease, background .18s ease;
  }

  .travel-auth__field input:focus {
    border-color: rgba(103, 232, 249, .56);
    box-shadow: 0 0 0 4px rgba(103, 232, 249, .12);
  }

  .travel-auth__button {
    color: #06101f;
    background: linear-gradient(135deg, #67e8f9, #fde68a);
    box-shadow: 0 18px 42px rgba(103, 232, 249, .22);
    min-width: 170px;
  }

  .travel-auth__link {
    color: #eef7ff;
    border-color: rgba(148, 190, 255, .22);
    background: rgba(3, 10, 24, .42);
    min-width: 150px;
  }

  .travel-auth__button:hover,
  .travel-auth__link:hover {
    transform: translateY(-2px);
  }

  .travel-auth__trust {
    margin-top: 18px;
    grid-template-columns: 1fr 1fr;
  }

  .travel-auth__trust-item {
    background: rgba(2, 8, 23, .42);
    border: 1px solid rgba(148, 190, 255, .18);
  }

  @keyframes travel-auth-nebula {
    from { transform: scale(.98); opacity: .30; }
    to { transform: scale(1.04); opacity: .50; }
  }

  @keyframes galaxy-sun-pulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1); filter: brightness(1); }
    50% { transform: translate(-50%, -50%) scale(1.08); filter: brightness(1.12); }
  }

  @keyframes galaxy-sun-rays {
    to { transform: translate(-50%, -50%) rotate(360deg); }
  }

  @keyframes galaxy-belt-drift {
    to { transform: translate(-50%, -50%) rotate(344deg); }
  }

  @keyframes galaxy-solar-orbit {
    to { transform: translate(-50%, -50%) rotate(348deg); }
  }

  @keyframes galaxy-moon-orbit {
    to { transform: translate(-50%, -50%) rotate(342deg); }
  }

  @keyframes galaxy-earth-center-drift {
    0%, 100% { transform: translate(-50%, -50%) scale(1); }
    50% { transform: translate(-50%, -51.5%) scale(1.025); }
  }

  @media (max-width: 1180px) {
    .travel-auth__shell {
      width: min(100vw - 36px, 980px);
      padding-top: 74px;
    }

    .travel-auth__back {
      top: 24px;
    }

    .travel-auth__layout {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .travel-auth__hero--scene-only {
      min-height: 430px;
      max-height: 520px;
    }

    .travel-auth__card {
      max-width: 760px;
    }
  }

  @media (max-width: 640px) {
    .travel-auth__shell {
      width: min(100vw - 24px, 100%);
      padding-top: 66px;
    }

    .travel-auth__hero--scene-only {
      min-height: 320px;
    }

    .travel-auth__card {
      padding: 24px;
    }

    .travel-auth__trust {
      grid-template-columns: 1fr;
    }

    .travel-auth__actions {
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .travel-auth__button,
    .travel-auth__link {
      width: 100%;
    }
  }
</style>

<main class="travel-auth">
  <div class="travel-auth__shell">
    <a class="travel-auth__back" href="/">← Về trang chủ</a>
    <section class="travel-auth__layout">
      <article class="travel-auth__hero travel-auth__hero--scene-only">
        <aside class="travel-scene-card" aria-label="Minh họa ngân hà Bento Resort">
          <div class="cosmic-scene" aria-hidden="true">
            <span class="cosmic-star-dust"></span>
            <span class="cosmic-depth-plane cosmic-depth-plane--one"></span>
            <span class="cosmic-depth-plane cosmic-depth-plane--two"></span>
            <span class="cosmic-depth-plane cosmic-depth-plane--three"></span>
            <span class="cosmic-asteroid-belt"></span>
            <span class="solar-light-ray"></span>
            <div class="cosmic-core"></div>
            <div class="solar-orbit solar-orbit--mercury"><span class="solar-planet solar-planet--mercury"></span></div>
            <div class="solar-orbit solar-orbit--venus"><span class="solar-planet solar-planet--venus"></span></div>
            <div class="solar-orbit solar-orbit--mars"><span class="solar-planet solar-planet--mars"></span></div>
            <div class="solar-orbit solar-orbit--jupiter"><span class="solar-planet solar-planet--jupiter"></span></div>
            <div class="solar-orbit solar-orbit--saturn"><span class="solar-planet solar-planet--saturn"></span></div>
            <div class="cosmic-earth" data-earth-3d>
              <canvas aria-label="Trái Đất 3D dùng texture vệ tinh"></canvas>
            </div>
            <div class="moon-orbit"><span class="cosmic-moon"></span></div>
            <span class="cosmic-asteroid cosmic-asteroid--one"></span>
            <span class="cosmic-asteroid cosmic-asteroid--two"></span>
            <span class="cosmic-asteroid cosmic-asteroid--three"></span>
            <span class="cosmic-asteroid cosmic-asteroid--four"></span>
            <span class="cosmic-asteroid cosmic-asteroid--five"></span>
            <span class="cosmic-asteroid cosmic-asteroid--six"></span>
          </div>
        </aside>
      </article>

      <article class="travel-auth__card">
        <div class="section-eyebrow">Đăng ký</div>
        <h2>Tạo tài khoản khách hàng</h2>
        <p>
          Điền đúng thông tin cá nhân để hệ thống hỗ trợ đặt phòng, xác minh khách lưu trú và liên hệ nhanh
          khi cần xác nhận booking hoặc dịch vụ.
        </p>

        <%- include("../partials/flash") %>

        <form method="post" action="/auth/register" class="travel-auth__grid" autocomplete="on">
          <div class="travel-auth__field travel-auth__field--full">
            <label for="fullname">Họ và tên</label>
            <input id="fullname" name="fullname" autocomplete="name" minlength="5" maxlength="80" required />
          </div>

          <div class="travel-auth__field">
            <label for="username">Tên đăng nhập</label>
            <input id="username" name="username" autocomplete="username" minlength="5" maxlength="30" pattern="[A-Za-z][A-Za-z0-9_]{4,29}" title="Tên đăng nhập dài 5-30 ký tự, bắt đầu bằng chữ và chỉ gồm chữ, số hoặc dấu gạch dưới." required />
          </div>

          <div class="travel-auth__field">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" autocomplete="email" required />
          </div>

          <div class="travel-auth__field">
            <label for="sdt">Số điện thoại</label>
            <input id="sdt" name="sdt" inputmode="tel" autocomplete="tel" pattern="(0|\+84|84)(3|5|7|8|9)[0-9]{8}" title="Số điện thoại Việt Nam gồm 10 số, bắt đầu bằng 03, 05, 07, 08 hoặc 09. Có thể nhập dạng +84." required />
          </div>

          <div class="travel-auth__field">
            <label for="cccd">CCCD / CMND</label>
            <input id="cccd" name="cccd" inputmode="numeric" pattern="([0-9]{9}|[0-9]{12})" title="CCCD/CMND phải gồm đúng 9 hoặc 12 chữ số." required />
          </div>

          <div class="travel-auth__field">
            <label for="password">Mật khẩu</label>
            <input id="password" name="password" type="password" autocomplete="new-password" minlength="8" maxlength="72" pattern="(?=.*[a-z])(?=.*[A-Z])(?=.*[0-9])(?=.*[^A-Za-z0-9]).{8,72}" title="Mật khẩu 8-72 ký tự, có chữ hoa, chữ thường, số và ký tự đặc biệt." required />
          </div>

          <div class="travel-auth__field">
            <label for="repass">Nhập lại mật khẩu</label>
            <input id="repass" name="repass" type="password" autocomplete="new-password" minlength="8" maxlength="72" required />
          </div>

          <div class="travel-auth__field travel-auth__field--full">
            <div class="travel-auth__hint">
              Thông tin này được dùng cho xác minh đặt phòng, hóa đơn, eKYC và liên hệ trước ngày nhận phòng khi cần.
            </div>
          </div>

          <div class="travel-auth__field travel-auth__field--full">
            <div class="travel-auth__actions">
              <button class="travel-auth__button" type="submit">Tạo tài khoản</button>
              <a class="travel-auth__link" href="/auth/login">Đã có tài khoản</a>
            </div>
          </div>
        </form>

      </article>
    </section>
  </div>
</main>

<script type="module" src="/js/home-galaxy-earth.js"></script>
<%- include("../partials/footer") %>
