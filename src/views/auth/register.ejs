<%- include("../partials/head") %>
<style>
  .travel-auth {
    min-height: 100vh;
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at 10% 8%, rgba(125, 211, 252, 0.26), transparent 20%),
      radial-gradient(circle at 88% 10%, rgba(251, 191, 36, 0.18), transparent 18%),
      linear-gradient(180deg, #07111f, #092341 44%, #0b4f75 100%);
  }

  .travel-auth::before,
  .travel-auth::after {
    content: "";
    position: absolute;
    width: 440px;
    height: 440px;
    border-radius: 999px;
    filter: blur(24px);
    opacity: 0.55;
    pointer-events: none;
  }

  .travel-auth::before {
    top: -180px;
    right: -120px;
    background: radial-gradient(circle, rgba(56, 189, 248, 0.32), transparent 72%);
  }

  .travel-auth::after {
    left: -140px;
    bottom: -200px;
    background: radial-gradient(circle, rgba(45, 212, 191, 0.28), transparent 74%);
  }

  .travel-auth__shell {
    width: min(1220px, calc(100vw - 32px));
    margin: 0 auto;
    padding: 34px 0;
    min-height: 100vh;
    display: grid;
    align-items: center;
  }

  .travel-auth__back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
    color: #d6efff;
    font-size: 13px;
    font-weight: 800;
  }

  .travel-auth__layout {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(460px, 0.98fr);
    gap: 24px;
    align-items: stretch;
  }

  .travel-auth__hero,
  .travel-auth__card {
    position: relative;
    border-radius: 34px;
    border: 1px solid rgba(148, 163, 184, 0.18);
    backdrop-filter: blur(22px);
    box-shadow: 0 28px 80px rgba(2, 6, 23, 0.34);
    overflow: hidden;
  }

  .travel-auth__hero {
    min-height: 740px;
    padding: 30px;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.11), rgba(255,255,255,0.03)),
      linear-gradient(180deg, rgba(7, 89, 133, 0.82), rgba(8, 47, 73, 0.95));
  }

  .travel-auth__hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 82% 10%, rgba(253, 224, 71, 0.28), transparent 14%),
      radial-gradient(circle at 14% 14%, rgba(255,255,255,0.16), transparent 24%);
    pointer-events: none;
  }

  .travel-auth__eyebrow {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 12px;
    border-radius: 999px;
    background: rgba(255,255,255,0.14);
    border: 1px solid rgba(255,255,255,0.16);
    color: #dff8ff;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .travel-auth__eyebrow-dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: linear-gradient(135deg, #fde68a, #fb7185);
    box-shadow: 0 0 0 6px rgba(253, 224, 71, 0.14);
  }

  .travel-auth__hero h1 {
    position: relative;
    z-index: 1;
    margin: 22px 0 14px;
    max-width: 540px;
    font-size: clamp(40px, 6vw, 68px);
    line-height: 0.94;
    letter-spacing: -0.08em;
    color: #ffffff;
  }

  .travel-auth__hero p {
    position: relative;
    z-index: 1;
    max-width: 520px;
    color: rgba(239, 246, 255, 0.86);
    font-size: 15px;
    line-height: 1.75;
  }

  .travel-auth__chips,
  .travel-auth__mini-grid {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }

  .travel-auth__chip,
  .travel-auth__mini {
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.14);
    color: #eff6ff;
    font-size: 12px;
    font-weight: 800;
  }

  .travel-auth__scene {
    position: absolute;
    left: 20px;
    right: 20px;
    bottom: 20px;
    height: 360px;
    border-radius: 30px;
    overflow: hidden;
    background: linear-gradient(180deg, #8ee8ff 0%, #effcff 42%, #32c2d9 43%, #0f766e 100%);
  }

  .travel-auth__sun,
  .travel-auth__cloud,
  .travel-auth__rainbow,
  .travel-auth__mountain,
  .travel-auth__island,
  .travel-auth__palm,
  .travel-auth__wave,
  .travel-auth__dolphin {
    position: absolute;
  }

  .travel-auth__sun {
    top: 26px;
    right: 44px;
    width: 84px;
    height: 84px;
    border-radius: 999px;
    background: radial-gradient(circle at 34% 34%, #fff9be, #ffd664 56%, #f59e0b 100%);
    box-shadow: 0 0 0 16px rgba(251, 191, 36, 0.15);
    animation: travel-auth-sun 5.8s ease-in-out infinite;
  }

  .travel-auth__cloud {
    width: 118px;
    height: 38px;
    border-radius: 999px;
    background: rgba(255,255,255,0.9);
    animation: travel-auth-cloud 18s linear infinite;
  }

  .travel-auth__cloud::before,
  .travel-auth__cloud::after {
    content: "";
    position: absolute;
    border-radius: 999px;
    background: inherit;
  }

  .travel-auth__cloud::before {
    width: 56px;
    height: 56px;
    left: 14px;
    top: -20px;
  }

  .travel-auth__cloud::after {
    width: 62px;
    height: 62px;
    right: 12px;
    top: -24px;
  }

  .travel-auth__cloud--one {
    top: 56px;
    left: 34px;
  }

  .travel-auth__cloud--two {
    top: 88px;
    left: 180px;
    transform: scale(0.78);
    opacity: 0.82;
    animation-duration: 22s;
  }

  .travel-auth__rainbow {
    top: 54px;
    left: 232px;
    width: 160px;
    height: 88px;
    border-radius: 160px 160px 0 0;
    border-top: 10px solid #fb7185;
    border-left: 10px solid #fb7185;
    border-right: 10px solid #fb7185;
    opacity: 0.9;
  }

  .travel-auth__rainbow::before,
  .travel-auth__rainbow::after {
    content: "";
    position: absolute;
    inset: 8px;
    border-radius: inherit;
    border-top: 10px solid #f59e0b;
    border-left: 10px solid #f59e0b;
    border-right: 10px solid #f59e0b;
  }

  .travel-auth__rainbow::after {
    inset: 18px;
    border-top-color: #22c55e;
    border-left-color: #22c55e;
    border-right-color: #22c55e;
  }

  .travel-auth__mountain {
    bottom: 132px;
    width: 0;
    height: 0;
    border-left: 126px solid transparent;
    border-right: 126px solid transparent;
    border-bottom: 178px solid #3389ae;
  }

  .travel-auth__mountain--one {
    left: 18px;
  }

  .travel-auth__mountain--two {
    left: 152px;
    border-left-width: 150px;
    border-right-width: 150px;
    border-bottom-width: 208px;
    border-bottom-color: #236f93;
  }

  .travel-auth__island {
    bottom: 104px;
    right: 68px;
    width: 170px;
    height: 36px;
    border-radius: 999px;
    background: linear-gradient(180deg, #f0c982, #bb7c2f);
    box-shadow: inset 0 8px 14px rgba(255,255,255,0.2);
  }

  .travel-auth__palm {
    width: 10px;
    border-radius: 999px;
    background: linear-gradient(180deg, #8b5a2b, #5a3715);
  }

  .travel-auth__palm--left {
    left: 126px;
    bottom: 108px;
    height: 122px;
    transform: rotate(-10deg);
  }

  .travel-auth__palm--right {
    right: 118px;
    bottom: 116px;
    height: 102px;
    transform: rotate(8deg);
  }

  .travel-auth__palm::before,
  .travel-auth__palm::after {
    content: "";
    position: absolute;
    width: 88px;
    height: 18px;
    border-radius: 999px 0 999px 0;
    background: linear-gradient(90deg, #14b86a, #78e3aa);
    transform-origin: left center;
    animation: travel-auth-palm 4.2s ease-in-out infinite;
  }

  .travel-auth__palm::before {
    left: -6px;
    top: 14px;
    transform: rotate(-32deg);
  }

  .travel-auth__palm::after {
    left: -70px;
    top: 30px;
    transform: rotate(24deg);
  }

  .travel-auth__wave {
    left: -8%;
    width: 116%;
    border-radius: 50%;
  }

  .travel-auth__wave--one {
    bottom: 84px;
    height: 88px;
    background: rgba(255,255,255,0.32);
    animation: travel-auth-wave 7s ease-in-out infinite;
  }

  .travel-auth__wave--two {
    bottom: 28px;
    height: 116px;
    background: rgba(111, 231, 255, 0.24);
    animation: travel-auth-wave 9s ease-in-out infinite reverse;
  }

  .travel-auth__wave--three {
    bottom: -18px;
    height: 136px;
    background: linear-gradient(180deg, rgba(191,247,255,0.26), rgba(15,118,110,0.92));
    animation: travel-auth-wave 10.8s ease-in-out infinite;
  }

  .travel-auth__dolphin {
    right: 184px;
    bottom: 120px;
    width: 78px;
    height: 34px;
    border-radius: 60px 60px 24px 24px;
    background: linear-gradient(180deg, #7dd3fc, #2563eb);
    transform: rotate(-12deg);
    animation: travel-auth-dolphin 4.8s ease-in-out infinite;
  }

  .travel-auth__dolphin::before {
    content: "";
    position: absolute;
    right: -10px;
    top: 12px;
    width: 22px;
    height: 12px;
    background: #2563eb;
    clip-path: polygon(0 50%, 100% 0, 100% 100%);
  }

  .travel-auth__dolphin::after {
    content: "";
    position: absolute;
    left: 18px;
    top: -10px;
    width: 18px;
    height: 16px;
    background: #38bdf8;
    clip-path: polygon(50% 0, 100% 100%, 0 100%);
  }

  .travel-auth__card {
    padding: 28px;
    background: rgba(255,255,255,0.94);
    color: #0b3255;
  }

  .travel-auth__card h2 {
    margin: 10px 0 8px;
    font-size: clamp(28px, 4vw, 42px);
    line-height: 0.98;
    letter-spacing: -0.06em;
    color: #0b3255;
  }

  .travel-auth__card p {
    margin: 0 0 16px;
    color: #59748d;
    font-size: 14px;
    line-height: 1.7;
  }

  .travel-auth__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .travel-auth__field {
    display: grid;
    gap: 8px;
  }

  .travel-auth__field--full {
    grid-column: 1 / -1;
  }

  .travel-auth__field label {
    color: #0b3255;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .travel-auth__field input {
    min-height: 50px;
    padding: 0 16px;
    border-radius: 16px;
    border: 1px solid rgba(14, 73, 118, 0.16);
    background: rgba(255,255,255,0.92);
    color: #0b3255;
    font: inherit;
    outline: none;
  }

  .travel-auth__field input:focus {
    border-color: rgba(14, 165, 233, 0.48);
    box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.12);
  }

  .travel-auth__hint {
    margin-top: 6px;
    color: #688198;
    font-size: 12px;
    line-height: 1.6;
  }

  .travel-auth__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }

  .travel-auth__button,
  .travel-auth__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 12px 18px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 900;
  }

  .travel-auth__button {
    border: none;
    color: #ffffff;
    background: linear-gradient(135deg, #0ea5e9, #14b8a6 50%, #22c55e);
    box-shadow: 0 18px 32px rgba(20, 184, 166, 0.18);
    cursor: pointer;
  }

  .travel-auth__link {
    border: 1px solid rgba(14, 73, 118, 0.12);
    background: rgba(255,255,255,0.86);
    color: #0b3255;
  }

  .travel-auth__trust {
    display: grid;
    gap: 10px;
    margin-top: 18px;
  }

  .travel-auth__trust-item {
    border-radius: 18px;
    padding: 14px;
    background: rgba(15, 23, 42, 0.04);
    border: 1px solid rgba(14, 73, 118, 0.08);
  }

  .travel-auth__trust-item strong {
    display: block;
    color: #0b3255;
    font-size: 15px;
    line-height: 1.2;
  }

  .travel-auth__trust-item span {
    display: block;
    margin-top: 6px;
    color: #59748d;
    font-size: 13px;
    line-height: 1.6;
  }

  @keyframes travel-auth-sun {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.06); }
  }

  @keyframes travel-auth-wave {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(0, -10px, 0); }
  }

  @keyframes travel-auth-cloud {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(18px); }
  }

  @keyframes travel-auth-palm {
    0%, 100% { transform: rotate(24deg); }
    50% { transform: rotate(34deg); }
  }

  @keyframes travel-auth-dolphin {
    0%, 100% { transform: translate3d(0, 0, 0) rotate(-12deg); }
    50% { transform: translate3d(10px, -18px, 0) rotate(-18deg); }
  }

  @media (max-width: 980px) {
    .travel-auth__layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .travel-auth__shell {
      width: min(100vw - 18px, 100%);
      padding: 18px 0 34px;
    }

    .travel-auth__hero,
    .travel-auth__card {
      border-radius: 28px;
      padding: 22px;
    }

    .travel-auth__grid {
      grid-template-columns: 1fr;
    }

    .travel-auth__scene {
      position: relative;
      left: auto;
      right: auto;
      bottom: auto;
      margin-top: 18px;
      height: 280px;
    }

    .travel-auth__rainbow {
      left: 140px;
      transform: scale(0.78);
      transform-origin: top left;
    }

    .travel-auth__dolphin {
      right: 110px;
      bottom: 98px;
      transform: scale(0.8) rotate(-12deg);
    }
  }
</style>

<main class="travel-auth">
  <div class="travel-auth__shell">
    <a class="travel-auth__back" href="/">← Về trang chủ</a>
    <section class="travel-auth__layout">
      <article class="travel-auth__hero">
        <div class="travel-auth__eyebrow">
          <span class="travel-auth__eyebrow-dot"></span>
          New guest journey
        </div>
        <h1>Tạo tài khoản để bắt đầu kỳ nghỉ thật mượt mà.</h1>
        <p>
          Tài khoản khách hàng giúp bạn đặt phòng nhanh hơn, xem lịch sử lưu trú, nhận ưu đãi thành viên
          và đồng bộ trải nghiệm từ đặt phòng đến check-in trong hệ thống resort.
        </p>

        <div class="travel-auth__chips">
          <span class="travel-auth__chip">Đặt phòng online chuẩn nghiệp vụ</span>
          <span class="travel-auth__chip">Quản lý hồ sơ & lưu trú</span>
          <span class="travel-auth__chip">Ưu đãi riêng cho khách thành viên</span>
        </div>

        <div class="travel-auth__mini-grid">
          <span class="travel-auth__mini">Cầu vồng nhỏ</span>
          <span class="travel-auth__mini">Biển xanh</span>
          <span class="travel-auth__mini">Cá heo vui</span>
          <span class="travel-auth__mini">Dễ dùng trên mobile</span>
        </div>

        <div class="travel-auth__scene" aria-hidden="true">
          <div class="travel-auth__sun"></div>
          <div class="travel-auth__cloud travel-auth__cloud--one"></div>
          <div class="travel-auth__cloud travel-auth__cloud--two"></div>
          <div class="travel-auth__rainbow"></div>
          <div class="travel-auth__mountain travel-auth__mountain--one"></div>
          <div class="travel-auth__mountain travel-auth__mountain--two"></div>
          <div class="travel-auth__island"></div>
          <div class="travel-auth__palm travel-auth__palm--left"></div>
          <div class="travel-auth__palm travel-auth__palm--right"></div>
          <div class="travel-auth__dolphin"></div>
          <div class="travel-auth__wave travel-auth__wave--one"></div>
          <div class="travel-auth__wave travel-auth__wave--two"></div>
          <div class="travel-auth__wave travel-auth__wave--three"></div>
        </div>
      </article>

      <article class="travel-auth__card">
        <div class="section-eyebrow">Đăng ký</div>
        <h2>Tạo tài khoản khách hàng</h2>
        <p>
          Điền đúng thông tin cá nhân để hệ thống hỗ trợ đặt phòng, xác minh khách lưu trú và liên hệ nhanh
          khi cần xác nhận booking hoặc dịch vụ.
        </p>

        <%- include("../partials/flash") %>

        <form method="post" action="/auth/register" class="travel-auth__grid" autocomplete="on">
          <div class="travel-auth__field travel-auth__field--full">
            <label for="fullname">Họ và tên</label>
            <input id="fullname" name="fullname" autocomplete="name" required />
          </div>

          <div class="travel-auth__field">
            <label for="username">Tên đăng nhập</label>
            <input id="username" name="username" autocomplete="username" required />
          </div>

          <div class="travel-auth__field">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" autocomplete="email" required />
          </div>

          <div class="travel-auth__field">
            <label for="sdt">Số điện thoại</label>
            <input id="sdt" name="sdt" inputmode="tel" autocomplete="tel" required />
          </div>

          <div class="travel-auth__field">
            <label for="cccd">CCCD / CMND</label>
            <input id="cccd" name="cccd" inputmode="numeric" required />
          </div>

          <div class="travel-auth__field">
            <label for="password">Mật khẩu</label>
            <input id="password" name="password" type="password" autocomplete="new-password" required />
          </div>

          <div class="travel-auth__field">
            <label for="repass">Nhập lại mật khẩu</label>
            <input id="repass" name="repass" type="password" autocomplete="new-password" required />
          </div>

          <div class="travel-auth__field travel-auth__field--full">
            <div class="travel-auth__hint">
              Thông tin này được dùng cho xác minh đặt phòng, hóa đơn, eKYC và liên hệ trước ngày nhận phòng khi cần.
            </div>
          </div>

          <div class="travel-auth__field travel-auth__field--full">
            <div class="travel-auth__actions">
              <button class="travel-auth__button" type="submit">Tạo tài khoản</button>
              <a class="travel-auth__link" href="/auth/login">Đã có tài khoản</a>
            </div>
          </div>
        </form>

        <div class="travel-auth__trust">
          <div class="travel-auth__trust-item">
            <strong>Bám sát hệ thống cũ nhưng giao diện mới sạch hơn</strong>
            <span>Form giữ đúng logic đăng ký khách hàng để không lệch nghiệp vụ hiện tại của resort.</span>
          </div>
          <div class="travel-auth__trust-item">
            <strong>Sẵn sàng cho booking, mobile hub và dịch vụ phát sinh</strong>
            <span>Tài khoản sau khi tạo có thể dùng xuyên suốt cho các bước đặt phòng và chăm sóc khách hàng.</span>
          </div>
        </div>
      </article>
    </section>
  </div>
</main>

<%- include("../partials/footer") %>
