<%- include("../partials/head") %>
<style>
  .travel-auth {
    min-height: 100vh;
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at 12% 8%, rgba(125, 211, 252, 0.28), transparent 22%),
      radial-gradient(circle at 90% 10%, rgba(251, 191, 36, 0.16), transparent 18%),
      linear-gradient(180deg, #07111f, #0a1b2e 42%, #0b3255 100%);
  }

  .travel-auth::before,
  .travel-auth::after {
    content: "";
    position: absolute;
    width: 420px;
    height: 420px;
    border-radius: 999px;
    filter: blur(20px);
    opacity: 0.55;
    pointer-events: none;
  }

  .travel-auth::before {
    top: -180px;
    right: -120px;
    background: radial-gradient(circle, rgba(56, 189, 248, 0.34), transparent 70%);
  }

  .travel-auth::after {
    left: -140px;
    bottom: -180px;
    background: radial-gradient(circle, rgba(20, 184, 166, 0.28), transparent 72%);
  }

  .travel-auth__shell {
    width: min(1180px, calc(100vw - 32px));
    margin: 0 auto;
    padding: 34px 0;
    min-height: 100vh;
    display: grid;
    align-items: center;
  }

  .travel-auth__back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
    color: #cbe7ff;
    font-size: 13px;
    font-weight: 800;
  }

  .travel-auth__layout {
    display: grid;
    grid-template-columns: minmax(0, 1.06fr) minmax(420px, 0.94fr);
    gap: 24px;
    align-items: stretch;
  }

  .travel-auth__hero,
  .travel-auth__card {
    position: relative;
    border-radius: 34px;
    border: 1px solid rgba(148, 163, 184, 0.18);
    backdrop-filter: blur(22px);
    box-shadow: 0 28px 80px rgba(2, 6, 23, 0.32);
    overflow: hidden;
  }

  .travel-auth__hero {
    min-height: 680px;
    padding: 30px;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.10), rgba(255,255,255,0.03)),
      linear-gradient(180deg, rgba(6, 78, 118, 0.76), rgba(8, 47, 73, 0.94));
  }

  .travel-auth__hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 82% 10%, rgba(253, 224, 71, 0.26), transparent 14%),
      radial-gradient(circle at 16% 16%, rgba(255,255,255,0.14), transparent 20%);
    pointer-events: none;
  }

  .travel-auth__eyebrow {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 12px;
    border-radius: 999px;
    background: rgba(255,255,255,0.14);
    border: 1px solid rgba(255,255,255,0.16);
    color: #dff8ff;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .travel-auth__eyebrow-dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: linear-gradient(135deg, #fde68a, #fb7185);
    box-shadow: 0 0 0 6px rgba(253, 224, 71, 0.14);
  }

  .travel-auth__hero h1 {
    position: relative;
    z-index: 1;
    margin: 22px 0 14px;
    max-width: 540px;
    font-size: clamp(40px, 6vw, 70px);
    line-height: 0.94;
    letter-spacing: -0.08em;
    color: #ffffff;
  }

  .travel-auth__hero p {
    position: relative;
    z-index: 1;
    max-width: 520px;
    color: rgba(239, 246, 255, 0.84);
    font-size: 15px;
    line-height: 1.75;
  }

  .travel-auth__chips,
  .travel-auth__mini-grid {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }

  .travel-auth__chip,
  .travel-auth__mini {
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.14);
    color: #eff6ff;
    font-size: 12px;
    font-weight: 800;
  }

  .travel-auth__scene {
    position: absolute;
    left: 24px;
    right: 24px;
    bottom: 22px;
    height: 310px;
    border-radius: 30px;
    overflow: hidden;
    background: linear-gradient(180deg, #89e7ff 0%, #dff8ff 46%, #26b7cf 47%, #0f766e 100%);
  }

  .travel-auth__sun {
    position: absolute;
    top: 30px;
    right: 54px;
    width: 82px;
    height: 82px;
    border-radius: 999px;
    background: radial-gradient(circle at 34% 34%, #fff8be, #ffd35a 56%, #f59e0b 100%);
    box-shadow: 0 0 0 16px rgba(251, 191, 36, 0.14);
    animation: travel-auth-sun 5s ease-in-out infinite;
  }

  .travel-auth__cloud,
  .travel-auth__wave,
  .travel-auth__mountain,
  .travel-auth__palm {
    position: absolute;
  }

  .travel-auth__cloud {
    top: 46px;
    left: 34px;
    width: 120px;
    height: 40px;
    border-radius: 999px;
    background: rgba(255,255,255,0.86);
    animation: travel-auth-cloud 18s linear infinite;
  }

  .travel-auth__cloud::before,
  .travel-auth__cloud::after {
    content: "";
    position: absolute;
    border-radius: 999px;
    background: inherit;
  }

  .travel-auth__cloud::before {
    width: 52px;
    height: 52px;
    left: 16px;
    top: -20px;
  }

  .travel-auth__cloud::after {
    width: 58px;
    height: 58px;
    right: 12px;
    top: -24px;
  }

  .travel-auth__mountain {
    bottom: 120px;
    width: 0;
    height: 0;
    border-left: 120px solid transparent;
    border-right: 120px solid transparent;
    border-bottom: 170px solid #2f82a9;
  }

  .travel-auth__mountain--one {
    left: 20px;
  }

  .travel-auth__mountain--two {
    left: 150px;
    border-left-width: 140px;
    border-right-width: 140px;
    border-bottom-width: 200px;
    border-bottom-color: #1f6f93;
  }

  .travel-auth__palm {
    left: 112px;
    bottom: 108px;
    width: 10px;
    height: 116px;
    border-radius: 999px;
    background: linear-gradient(180deg, #8b5a2b, #5a3715);
    transform: rotate(-10deg);
  }

  .travel-auth__palm::before,
  .travel-auth__palm::after {
    content: "";
    position: absolute;
    width: 86px;
    height: 18px;
    border-radius: 999px 0 999px 0;
    background: linear-gradient(90deg, #14b86a, #78e3aa);
    transform-origin: left center;
    animation: travel-auth-palm 4.2s ease-in-out infinite;
  }

  .travel-auth__palm::before {
    left: -6px;
    top: 12px;
    transform: rotate(-32deg);
  }

  .travel-auth__palm::after {
    left: -70px;
    top: 28px;
    transform: rotate(24deg);
  }

  .travel-auth__wave {
    left: -8%;
    width: 116%;
    border-radius: 50%;
  }

  .travel-auth__wave--one {
    bottom: 70px;
    height: 90px;
    background: rgba(255,255,255,0.30);
    animation: travel-auth-wave 7s ease-in-out infinite;
  }

  .travel-auth__wave--two {
    bottom: 0;
    height: 128px;
    background: linear-gradient(180deg, rgba(191,247,255,0.28), rgba(15,118,110,0.88));
    animation: travel-auth-wave 9s ease-in-out infinite reverse;
  }

  .travel-auth__card {
    padding: 28px;
    background: rgba(255,255,255,0.92);
    color: #0b3255;
  }

  .travel-auth__card h2 {
    margin: 10px 0 8px;
    font-size: clamp(28px, 4vw, 42px);
    line-height: 0.98;
    letter-spacing: -0.06em;
    color: #0b3255;
  }

  .travel-auth__card p {
    margin: 0 0 16px;
    color: #59748d;
    font-size: 14px;
    line-height: 1.7;
  }

  .travel-auth__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .travel-auth__field {
    display: grid;
    gap: 8px;
  }

  .travel-auth__field--full {
    grid-column: 1 / -1;
  }

  .travel-auth__field label {
    color: #0b3255;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .travel-auth__field input {
    min-height: 50px;
    padding: 0 16px;
    border-radius: 16px;
    border: 1px solid rgba(14, 73, 118, 0.16);
    background: rgba(255,255,255,0.92);
    color: #0b3255;
    font: inherit;
    outline: none;
  }

  .travel-auth__field input:focus {
    border-color: rgba(14, 165, 233, 0.48);
    box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.12);
  }

  .travel-auth__hint {
    margin-top: 6px;
    color: #688198;
    font-size: 12px;
    line-height: 1.6;
  }

  .travel-auth__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }

  .travel-auth__button,
  .travel-auth__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 12px 18px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 900;
  }

  .travel-auth__button {
    border: none;
    color: #ffffff;
    background: linear-gradient(135deg, #0ea5e9, #14b8a6 50%, #22c55e);
    box-shadow: 0 18px 32px rgba(20, 184, 166, 0.18);
    cursor: pointer;
  }

  .travel-auth__link {
    border: 1px solid rgba(14, 73, 118, 0.12);
    background: rgba(255,255,255,0.86);
    color: #0b3255;
  }

  .travel-auth__trust {
    display: grid;
    gap: 10px;
    margin-top: 18px;
  }

  .travel-auth__trust-item {
    border-radius: 18px;
    padding: 14px;
    background: rgba(15, 23, 42, 0.04);
    border: 1px solid rgba(14, 73, 118, 0.08);
  }

  .travel-auth__trust-item strong {
    display: block;
    color: #0b3255;
    font-size: 15px;
    line-height: 1.2;
  }

  .travel-auth__trust-item span {
    display: block;
    margin-top: 6px;
    color: #59748d;
    font-size: 13px;
    line-height: 1.6;
  }

  @keyframes travel-auth-sun {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.06); }
  }

  @keyframes travel-auth-wave {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(0, -9px, 0); }
  }

  @keyframes travel-auth-cloud {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(18px); }
  }

  @keyframes travel-auth-palm {
    0%, 100% { transform: rotate(24deg); }
    50% { transform: rotate(34deg); }
  }

  @media (max-width: 980px) {
    .travel-auth__layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .travel-auth__shell {
      width: min(100vw - 18px, 100%);
      padding: 18px 0 34px;
    }

    .travel-auth__hero,
    .travel-auth__card {
      border-radius: 28px;
      padding: 22px;
    }

    .travel-auth__grid {
      grid-template-columns: 1fr;
    }

    .travel-auth__scene {
      position: relative;
      left: auto;
      right: auto;
      bottom: auto;
      margin-top: 18px;
      height: 240px;
    }
  }
</style>

<main class="travel-auth">
  <div class="travel-auth__shell">
    <a class="travel-auth__back" href="/">← Về trang chủ</a>
    <section class="travel-auth__layout">
      <article class="travel-auth__hero">
        <div class="travel-auth__eyebrow">
          <span class="travel-auth__eyebrow-dot"></span>
          Resort access
        </div>
        <h1>Đăng nhập để trở lại hành trình nghỉ dưỡng của bạn.</h1>
        <p>
          Từ tài khoản này, bạn có thể đặt phòng online, theo dõi lịch sử lưu trú, dùng mobile hub,
          nhận hỗ trợ từ lễ tân và quản lý các dịch vụ phát sinh một cách gọn gàng hơn.
        </p>

        <div class="travel-auth__chips">
          <span class="travel-auth__chip">Đặt phòng online & trực tiếp</span>
          <span class="travel-auth__chip">eKYC, check-in, check-out</span>
          <span class="travel-auth__chip">Dịch vụ bổ sung & lịch sử booking</span>
        </div>

        <div class="travel-auth__mini-grid">
          <span class="travel-auth__mini">Biển xanh</span>
          <span class="travel-auth__mini">Mây nhẹ</span>
          <span class="travel-auth__mini">Travel mood</span>
          <span class="travel-auth__mini">PWA ready</span>
        </div>

        <div class="travel-auth__scene" aria-hidden="true">
          <div class="travel-auth__sun"></div>
          <div class="travel-auth__cloud"></div>
          <div class="travel-auth__mountain travel-auth__mountain--one"></div>
          <div class="travel-auth__mountain travel-auth__mountain--two"></div>
          <div class="travel-auth__palm"></div>
          <div class="travel-auth__wave travel-auth__wave--one"></div>
          <div class="travel-auth__wave travel-auth__wave--two"></div>
        </div>
      </article>

      <article class="travel-auth__card">
        <div class="section-eyebrow">Đăng nhập</div>
        <h2>Chào mừng bạn quay lại</h2>
        <p>Đăng nhập để tiếp tục đặt phòng, quản lý hồ sơ và theo dõi các dịch vụ đã sử dụng trong hệ thống.</p>

        <%- include("../partials/flash") %>

        <form method="post" action="/auth/login" autocomplete="on">
          <div class="travel-auth__grid">
            <div class="travel-auth__field travel-auth__field--full">
              <label for="username">Tên đăng nhập</label>
              <input id="username" name="username" autocomplete="username" required />
            </div>
            <div class="travel-auth__field travel-auth__field--full">
              <label for="password">Mật khẩu</label>
              <input id="password" name="password" type="password" autocomplete="current-password" required />
            </div>
          </div>

          <div class="travel-auth__hint">
            Tài khoản khách hàng sẽ đi vào portal và mobile hub. Tài khoản nội bộ được điều hướng về đúng dashboard theo vai trò.
          </div>

          <div class="travel-auth__actions">
            <button class="travel-auth__button" type="submit">Đăng nhập</button>
            <a class="travel-auth__link" href="/auth/register">Tạo tài khoản khách hàng</a>
          </div>
        </form>

        <div class="travel-auth__trust">
          <article class="travel-auth__trust-item">
            <strong>Đúng luồng nghiệp vụ</strong>
            <span>Đăng nhập xong, hệ thống điều hướng bạn về đúng dashboard theo vai trò hiện có.</span>
          </article>
          <article class="travel-auth__trust-item">
            <strong>Sẵn sàng cho kỳ nghỉ</strong>
            <span>Tài khoản khách có thể dùng ngay để đặt phòng, xem lịch sử, hồ sơ và dịch vụ bổ sung.</span>
          </article>
        </div>
      </article>
    </section>
  </div>
</main>
<%- include("../partials/footer") %>
