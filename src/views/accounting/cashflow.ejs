<%- include("../partials/head") %>
<%- include("../partials/header") %>
<%
  const filters = payload.filters || {};
  const rows = payload.rows || [];
  const summary = payload.summary || {};
  const typeOptions = payload.typeOptions || [];
  const groupOptions = payload.groupOptions || [];
  const statusOptions = payload.statusOptions || [];
  const typeBreakdown = payload.typeBreakdown || [];
  const groupBreakdown = payload.groupBreakdown || [];
  const statusBreakdown = payload.statusBreakdown || [];
  const dailyTrend = payload.dailyTrend || [];
  const methodBreakdown = payload.methodBreakdown || [];
  const hotelBreakdown = payload.hotelBreakdown || [];
  const riskBreakdown = payload.riskBreakdown || [];
  const actionItems = payload.actionItems || [];
  const reviewRows = payload.reviewRows || [];
  const chartPayload = payload.chartPayload || { trend: [], groups: [], methods: [], hotels: [], risks: [] };
  const hotelOptions = payload.hotelOptions || [];
  const page = Number(payload.currentPage || 1);
  const totalPages = Number(payload.totalPages || 1);
  const makeQuery = (overrides = {}) => new URLSearchParams({ ...filters, ...overrides }).toString();
  const csvQuery = makeQuery({ format: "csv" });
  const jsonQuery = makeQuery({ format: "json" });
  const pages = [];
  const firstPage = Math.max(1, page - 2);
  const lastPage = Math.min(totalPages, page + 2);
  for (let i = firstPage; i <= lastPage; i += 1) pages.push(i);
  const maxTrend = Math.max(...dailyTrend.map((item) => Math.max(Number(item.tongThu || 0), Number(item.tongChi || 0))), 1);
  const maxHotelNet = Math.max(...hotelBreakdown.map((item) => Math.abs(Number(item.net || 0))), 1);
%>

<style>
  .flow-home {
    --ink: #102033;
    --muted: #667085;
    --line: rgba(16, 32, 51, .10);
    --glass: rgba(255, 255, 255, .80);
    --strong: rgba(255, 255, 255, .94);
    --cyan: #12bff3;
    --mint: #20d6a3;
    --lime: #b7ef4a;
    --sun: #ffd166;
    --orange: #ff9f7a;
    --pink: #ff6aa2;
    --violet: #8068ff;
    --shadow: 0 18px 48px rgba(16, 32, 51, .11);
    min-height: calc(100vh - 84px);
    padding: 30px 18px 58px;
    color: var(--ink);
    background:
      linear-gradient(120deg, rgba(32, 214, 163, .20), transparent 32%),
      linear-gradient(250deg, rgba(255, 159, 122, .18), transparent 34%),
      repeating-linear-gradient(135deg, rgba(255,255,255,.72) 0 12px, rgba(240,253,250,.72) 12px 24px),
      linear-gradient(135deg, #fbfffd 0%, #eefcff 44%, #fff8eb 100%);
  }

  .flow-home *,
  .flow-home *::before,
  .flow-home *::after {
    box-sizing: border-box;
  }

  .flow-wrap {
    max-width: 1200px;
    margin: 0 auto;
  }

  .flow-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(360px, 420px);
    gap: 18px;
    align-items: stretch;
    margin-bottom: 18px;
  }

  .flow-hero-main,
  .flow-kpi,
  .flow-filter,
  .flow-panel,
  .flow-table-panel,
  .flow-alert {
    border: 1px solid var(--line);
    background: var(--glass);
    box-shadow: var(--shadow);
    backdrop-filter: blur(24px);
  }

  .flow-hero-main {
    position: relative;
    overflow: hidden;
    min-height: 318px;
    border-radius: 24px;
    padding: 28px;
  }

  .flow-hero-main::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(98deg, rgba(18, 191, 243, .20), transparent 34%),
      linear-gradient(164deg, transparent 0 53%, rgba(255, 209, 102, .24) 53% 68%, transparent 68%),
      linear-gradient(28deg, transparent 0 72%, rgba(255, 106, 162, .16) 72% 86%, transparent 86%);
  }

  .flow-hero-content {
    position: relative;
    z-index: 1;
  }

  .flow-chip,
  .flow-tag,
  .flow-pill,
  .flow-status,
  .flow-type,
  .flow-group {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-radius: 999px;
    max-width: 100%;
    white-space: nowrap;
  }

  .flow-chip {
    padding: 7px 12px;
    border: 1px solid rgba(18, 191, 243, .28);
    background: rgba(18, 191, 243, .13);
    color: #03657c;
    font-size: 12px;
    font-weight: 1000;
    text-transform: uppercase;
  }

  .flow-spark {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--cyan);
    box-shadow: 0 0 0 7px rgba(18, 191, 243, .13);
  }

  .flow-hero h1 {
    max-width: 760px;
    margin: 24px 0 12px;
    font-size: clamp(38px, 5vw, 54px);
    line-height: 1;
    letter-spacing: 0;
  }

  .flow-hero h1 span {
    color: transparent;
    background: linear-gradient(96deg, #0891b2 0%, #10b981 32%, #f59e0b 62%, #ec4899 100%);
    -webkit-background-clip: text;
    background-clip: text;
  }

  .flow-lead {
    max-width: 760px;
    margin: 0;
    color: var(--muted);
    font-size: 16px;
    line-height: 1.7;
