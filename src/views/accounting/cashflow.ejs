</style>

<main class="flow-home">
  <div class="flow-wrap">
    <section class="flow-hero" aria-label="Đối soát thu chi hợp nhất">
      <div class="flow-hero-main">
        <div class="flow-hero-content">
          <div class="flow-chip"><span class="flow-spark"></span> Unified cashflow</div>
          <h1>Đối soát <span>thu chi</span></h1>
          <p class="flow-lead">Một timeline duy nhất cho dòng thu từ giao dịch đặt phòng và dòng chi vận hành, hỗ trợ đối chiếu nhanh theo cơ sở, nhóm, trạng thái và kỳ kế toán.</p>
          <div class="flow-tags">
            <span class="flow-tag"><%= payload.rangeLabel %></span>
            <span class="flow-tag"><%= payload.hotelContext.label %></span>
            <span class="flow-tag"><%= payload.totalRecords %> dòng tiền</span>
            <span class="flow-tag">Cập nhật <%= payload.generatedAtLabel %></span>
          </div>
          <div class="flow-actions">
            <a class="flow-button flow-button--primary" href="/api/accounting/cashflow?<%= csvQuery %>">Xuất CSV</a>
            <a class="flow-button" href="/api/accounting/cashflow?<%= jsonQuery %>">JSON</a>
            <a class="flow-button flow-button--hot" href="/accounting/reports?loai_baocao=tonghop&tu_ngay=<%= filters.tu_ngay %>&den_ngay=<%= filters.den_ngay %>&hotel_id=<%= filters.hotel_id %>">Xem báo cáo tổng hợp</a>
          </div>
        </div>
      </div>

      <aside class="flow-kpi-grid" aria-label="KPI thu chi">
        <article class="flow-kpi is-green"><span>Thu đã ghi nhận</span><strong><%= summary.tongThuFormatted %></strong></article>
        <article class="flow-kpi is-orange"><span>Chi có hiệu lực</span><strong><%= summary.tongChiFormatted %></strong></article>
        <article class="flow-kpi is-cyan"><span>Dòng tiền thuần</span><strong><%= summary.dongTienThuanFormatted %></strong></article>
        <article class="flow-kpi is-violet"><span>Coverage đối soát</span><strong><%= summary.reconciledCoverageFormatted %></strong></article>
      </aside>
    </section>

    <% if (payload.warnings && payload.warnings.length) { %>
      <section class="flow-alert">
        <% payload.warnings.forEach((warning) => { %>
          <p><%= warning %></p>
        <% }) %>
      </section>
    <% } %>

    <section class="flow-insight-grid" aria-label="Tín hiệu đối soát">
      <article class="flow-insight is-green">
        <span>Thu đã chốt</span>
        <strong><%= summary.thuDaChotFormatted %></strong>
        <p><%= summary.soDongThu || 0 %> dòng thu, phần chờ đối soát <%= summary.thuChoDoiSoatFormatted %>.</p>
      </article>
      <article class="flow-insight is-sun">
        <span>Chi chờ duyệt</span>
        <strong><%= summary.chiChoDuyetFormatted %></strong>
        <p>Chi đã duyệt <%= summary.chiDaDuyetFormatted %>, cần khóa chứng từ trước khi chốt kỳ.</p>
      </article>
      <article class="flow-insight is-rose">
        <span>Cần rà soát</span>
        <strong><%= summary.needsReviewCount || 0 %> dòng</strong>
        <p><%= summary.missingEvidenceCount || 0 %> dòng thiếu chứng từ, <%= summary.negativeNetDays || 0 %> ngày âm dòng tiền.</p>
      </article>
      <article class="flow-insight is-cyan">
        <span>Net / thu</span>
        <strong><%= summary.cashflowRatioFormatted %></strong>
        <p>Chỉ số thanh khoản nhanh cho kỳ <%= payload.rangeLabel %>.</p>
      </article>
    </section>

    <section class="flow-layout">
      <aside class="flow-side-stack">
        <section class="flow-filter">
          <h2>Bộ lọc</h2>
          <form method="get" action="/accounting/cashflow">
            <div class="flow-field-grid">
              <div class="flow-field">
                <label for="tu_ngay">Từ ngày</label>
                <input id="tu_ngay" type="date" name="tu_ngay" value="<%= filters.tu_ngay %>" />
              </div>
              <div class="flow-field">
                <label for="den_ngay">Đến ngày</label>
                <input id="den_ngay" type="date" name="den_ngay" value="<%= filters.den_ngay %>" />
              </div>
              <div class="flow-field">
                <label for="loai_dong_tien">Loại dòng tiền</label>
                <select id="loai_dong_tien" name="loai_dong_tien">
                  <% typeOptions.forEach((option) => { %>
                    <option value="<%= option.value %>" <%= filters.loai_dong_tien === option.value ? "selected" : "" %>><%= option.label %></option>
                  <% }) %>
                </select>
              </div>
              <div class="flow-field">
                <label for="nhom">Nhóm</label>
                <select id="nhom" name="nhom">
                  <% groupOptions.forEach((option) => { %>
                    <option value="<%= option.value %>" <%= filters.nhom === option.value ? "selected" : "" %>><%= option.label %></option>
                  <% }) %>
                </select>
              </div>
              <div class="flow-field">
                <label for="trang_thai">Trạng thái</label>
                <select id="trang_thai" name="trang_thai">
                  <% statusOptions.forEach((option) => { %>
                    <option value="<%= option.value %>" <%= filters.trang_thai === option.value ? "selected" : "" %>><%= option.label %></option>
                  <% }) %>
                </select>
              </div>
              <div class="flow-field">
                <label for="limit">Hiển thị</label>
                <select id="limit" name="limit">
                  <% [15, 25, 50, 100].forEach((limit) => { %>
                    <option value="<%= limit %>" <%= Number(filters.limit) === limit ? "selected" : "" %>><%= limit %> dòng</option>
                  <% }) %>
                </select>
              </div>
              <div class="flow-field is-wide">
                <label for="hotel_id">Cơ sở</label>
                <select id="hotel_id" name="hotel_id">
                  <option value="0" <%= Number(filters.hotel_id || 0) === 0 ? "selected" : "" %>>Toàn bộ cơ sở</option>
                  <% hotelOptions.forEach((hotel) => { %>
                    <option value="<%= hotel.id %>" <%= Number(filters.hotel_id || 0) === Number(hotel.id) ? "selected" : "" %>>
                      <%= hotel.tenKhachSan %><%= hotel.tinhThanh ? ` · ${hotel.tinhThanh}` : "" %>
                    </option>
                  <% }) %>
                </select>
              </div>
              <div class="flow-field is-wide">
                <label for="search">Tìm kiếm</label>
                <input id="search" name="search" value="<%= filters.search %>" placeholder="Mã, khách hàng, chi phí, nội dung, cơ sở..." />
              </div>
            </div>
            <input type="hidden" name="page" value="1" />
            <div class="flow-form-actions">
              <button class="flow-button flow-button--primary" type="submit">Lọc thu chi</button>
              <a class="flow-button" href="/accounting/cashflow">Đặt lại</a>
            </div>
          </form>
        </section>

        <section class="flow-panel">
          <h2>Cơ cấu thu chi</h2>
          <div class="flow-breakdown">
            <% if (!typeBreakdown.length) { %>
              <div class="flow-empty">Chưa có dữ liệu thu chi trong kỳ này.</div>
            <% } %>
            <% typeBreakdown.forEach((item) => {
              const base = Math.max(Number(summary.tongThu || 0), Number(summary.tongChi || 0), 1);
              const pct = Math.round((Number(item.total || 0) / base) * 100);
            %>
              <div class="flow-break-row">
                <span class="flow-type flow-type--<%= item.meta.tone %>"><%= item.meta.label %></span>
                <div class="flow-meter"><span style="width:<%= Math.max(5, pct) %>%"></span></div>
                <span class="flow-pill"><%= item.count %> · <%= item.totalFormatted %></span>
              </div>
            <% }) %>
          </div>
        </section>

        <section class="flow-panel">
          <h2>Việc cần xử lý</h2>
          <div class="flow-review-list">
            <% if (!actionItems.length) { %>
              <div class="flow-empty">Không có cảnh báo lớn trong bộ lọc hiện tại.</div>
            <% } %>
            <% actionItems.forEach((item) => { %>
              <article class="flow-review">
                <div class="flow-review-head">
                  <strong><%= item.title %></strong>
                  <span class="flow-status flow-status--<%= item.tone %>">Ưu tiên</span>
                </div>
                <p><%= item.note %></p>
              </article>
            <% }) %>
          </div>
        </section>

        <section class="flow-panel">
          <h2>Trạng thái</h2>
          <div class="flow-breakdown">
            <% if (!statusBreakdown.length) { %>
              <div class="flow-empty">Chưa có dữ liệu trạng thái.</div>
            <% } %>
            <% statusBreakdown.slice(0, 6).forEach((item) => { %>
              <div class="flow-break-row">
                <span class="flow-status flow-status--<%= item.meta.tone %>"><%= item.meta.label %></span>
                <div class="flow-meter"><span style="width:<%= Math.max(5, Math.round((Number(item.total || 0) / Math.max(Number(summary.tongThu || 0), Number(summary.tongChi || 0), 1)) * 100)) %>%"></span></div>
                <span class="flow-pill"><%= item.count %> · <%= item.totalFormatted %></span>
              </div>
            <% }) %>
          </div>
        </section>
      </aside>

      <section class="flow-side-stack">
        <section class="flow-panel">
          <h2>Phân tích trực quan</h2>
          <div class="flow-chart-grid">
            <article class="flow-chart is-wide">
              <div class="flow-chart-head">
                <div>
                  <span>Daily cash position</span>
                  <h3>Thu, chi và net theo ngày</h3>
                </div>
                <span class="flow-pill"><%= dailyTrend.length %> ngày</span>
              </div>
              <canvas id="cashflowTrendChart" height="210"></canvas>
            </article>
            <article class="flow-chart">
              <div class="flow-chart-head">
                <div>
                  <span>Payment mix</span>
                  <h3>Phương thức thu chi</h3>
                </div>
              </div>
              <canvas id="cashflowMethodChart" height="210"></canvas>
            </article>
            <article class="flow-chart">
              <div class="flow-chart-head">
                <div>
                  <span>Exception map</span>
                  <h3>Cảnh báo đối soát</h3>
                </div>
              </div>
              <canvas id="cashflowRiskChart" height="210"></canvas>
            </article>
          </div>
        </section>

        <section class="flow-panel">
          <h2>Nhóm dòng tiền</h2>
          <div class="flow-groups">
            <% if (!groupBreakdown.length) { %>
              <div class="flow-empty">Chưa có dữ liệu nhóm.</div>
            <% } %>
            <% groupBreakdown.forEach((item) => { %>
              <article class="flow-group-row">
                <div>
                  <span class="flow-group flow-group--<%= item.meta.tone %>"><%= item.meta.label %></span>
                  <div class="flow-muted" style="margin-top:7px"><%= item.count %> dòng tiền</div>
                </div>
                <strong class="<%= item.nhom === 'datphong' ? 'flow-money is-in' : 'flow-money is-out' %>"><%= item.totalFormatted %></strong>
              </article>
            <% }) %>
          </div>
        </section>

        <section class="flow-panel">
          <h2>Xu hướng theo ngày</h2>
          <div class="flow-trend">
            <% if (!dailyTrend.length) { %>
              <div class="flow-empty">Không có xu hướng để hiển thị.</div>
            <% } %>
            <% dailyTrend.slice(-10).forEach((item) => { %>
              <div class="flow-trend-row">
                <strong><%= item.dateLabel %></strong>
                <div>
                  <div class="flow-meter"><span style="width:<%= Math.max(5, Math.round((Number(item.tongThu || 0) / maxTrend) * 100)) %>%"></span></div>
                  <div class="flow-meter" style="margin-top:5px"><span style="width:<%= Math.max(5, Math.round((Number(item.tongChi || 0) / maxTrend) * 100)) %>%; background:linear-gradient(90deg, var(--orange), var(--pink))"></span></div>
                </div>
                <span class="flow-money is-net"><%= item.dongTienThuanFormatted %></span>
              </div>
            <% }) %>
          </div>
          <% if (payload.bestNetDay) { %>
            <p class="flow-muted" style="margin:14px 0 0">Ngày net tốt nhất: <strong><%= payload.bestNetDay.dateLabel %></strong> với <strong><%= payload.bestNetDay.dongTienThuanFormatted %></strong>.</p>
          <% } %>
        </section>

        <section class="flow-panel">
          <h2>Net theo cơ sở</h2>
          <div class="flow-hotel-list">
            <% if (!hotelBreakdown.length) { %>
              <div class="flow-empty">Chưa có dữ liệu cơ sở để phân tích.</div>
            <% } %>
            <% hotelBreakdown.forEach((item) => {
              const width = Math.max(6, Math.round((Math.abs(Number(item.net || 0)) / maxHotelNet) * 100));
            %>
              <article class="flow-hotel-row">
                <div>
                  <strong><%= item.hotelLabel %></strong>
                  <div class="flow-muted" style="margin-top:5px">Thu <%= item.tongThuFormatted %> · Chi <%= item.tongChiFormatted %></div>
                  <div class="flow-hotel-meter"><span style="width:<%= width %>%; background:<%= Number(item.net || 0) >= 0 ? 'linear-gradient(90deg, var(--mint), var(--cyan))' : 'linear-gradient(90deg, var(--orange), var(--pink))' %>"></span></div>
                </div>
                <strong class="<%= Number(item.net || 0) >= 0 ? 'flow-money is-in' : 'flow-money is-out' %>"><%= item.netFormatted %></strong>
              </article>
            <% }) %>
          </div>
        </section>

        <section class="flow-panel">
          <h2>Dòng cần đối soát trước</h2>
          <div class="flow-review-list">
            <% if (!reviewRows.length) { %>
              <div class="flow-empty">Không có dòng rủi ro cao trong bộ lọc hiện tại.</div>
            <% } %>
            <% reviewRows.forEach((row) => { %>
              <article class="flow-review">
                <div class="flow-review-head">
                  <div>
                    <span class="flow-type flow-type--<%= row.typeMeta.tone %>"><%= row.typeMeta.label %></span>
                    <strong style="display:block;margin-top:8px"><%= row.maThamChieu %> · <%= row.doiTuong %></strong>
                  </div>
                  <strong class="<%= row.loaiDongTien === 'thu' ? 'flow-money is-in' : 'flow-money is-out' %>"><%= row.typeMeta.symbol %><%= row.soTienFormatted %></strong>
                </div>
                <p><span class="flow-status flow-status--<%= row.riskMeta.tone %>"><%= row.riskMeta.label %></span> <%= row.reconcileAction %></p>
              </article>
            <% }) %>
          </div>
        </section>

        <section class="flow-table-panel">
          <div class="flow-table-head">
            <div>
              <h2>Timeline thu chi</h2>
              <p>Trang <%= page %>/<%= totalPages %>, đang hiển thị <%= rows.length %> trên <%= payload.totalRecords %> dòng tiền.</p>
            </div>
            <span class="flow-pill">Thu: <%= summary.soDongThu %> · Chi: <%= summary.soDongChi %></span>
          </div>

          <% if (!payload.hasData) { %>
            <div class="flow-empty">Không có dòng thu chi phù hợp với bộ lọc hiện tại.</div>
          <% } else { %>
            <div class="flow-table-wrap">
              <table class="flow-table">
                <thead>
                  <tr>
                    <th>Loại</th>
                    <th>Mã</th>
                    <th>Ngày</th>
                    <th>Đối tượng</th>
                    <th>Nhóm</th>
                    <th>Cơ sở</th>
                    <th>Thanh toán</th>
                    <th>Chứng từ</th>
                    <th>Số tiền</th>
                    <th>Đối soát</th>
                  </tr>
                </thead>
                <tbody>
                  <% rows.forEach((row) => { %>
                    <tr>
                      <td><span class="flow-type flow-type--<%= row.typeMeta.tone %>"><%= row.typeMeta.symbol %> <%= row.typeMeta.label %></span></td>
                      <td>
                        <span class="flow-code">
                          <%= row.maThamChieu %>
                          <span class="flow-muted">#<%= row.maSo %></span>
                        </span>
                      </td>
                      <td><%= row.ngayLabel %></td>
                      <td>
                        <strong><%= row.doiTuong %></strong>
                        <div class="flow-muted"><%= row.noiDung %></div>
                      </td>
                      <td><span class="flow-group flow-group--<%= row.groupMeta.tone %>"><%= row.groupMeta.label %></span></td>
                      <td><%= row.hotelLabel %></td>
                      <td><%= row.paymentLabel %></td>
                      <td>
                        <strong><%= row.soChungTu %></strong>
                        <div class="flow-muted" style="margin-top:5px">
                          <span class="flow-status flow-status--<%= row.evidenceMeta.tone %>"><%= row.evidenceMeta.label %></span>
                        </div>
                      </td>
                      <td class="<%= row.loaiDongTien === 'thu' ? 'flow-money is-in' : 'flow-money is-out' %>"><%= row.signedAmountFormatted %></td>
                      <td>
                        <span class="flow-status flow-status--<%= row.statusMeta.tone %>"><%= row.statusMeta.label %></span>
                        <div class="flow-muted" style="margin-top:5px">
                          <span class="flow-status flow-status--<%= row.riskMeta.tone %>"><%= row.riskMeta.label %></span>
                        </div>
                        <div class="flow-muted" style="margin-top:5px"><%= row.reconcileAction %></div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>

            <% if (totalPages > 1) { %>
              <nav class="flow-pagination" aria-label="Phân trang thu chi">
                <% if (page > 1) { %>
                  <a class="flow-page" href="/accounting/cashflow?<%= makeQuery({ page: page - 1 }) %>">Trước</a>
                <% } %>
                <% if (firstPage > 1) { %>
                  <a class="flow-page" href="/accounting/cashflow?<%= makeQuery({ page: 1 }) %>">1</a>
                <% } %>
                <% pages.forEach((item) => { %>
                  <a class="flow-page <%= item === page ? "is-active" : "" %>" href="/accounting/cashflow?<%= makeQuery({ page: item }) %>"><%= item %></a>
                <% }) %>
                <% if (lastPage < totalPages) { %>
                  <a class="flow-page" href="/accounting/cashflow?<%= makeQuery({ page: totalPages }) %>"><%= totalPages %></a>
                <% } %>
                <% if (page < totalPages) { %>
                  <a class="flow-page" href="/accounting/cashflow?<%= makeQuery({ page: page + 1 }) %>">Tiếp</a>
                <% } %>
              </nav>
            <% } %>
          <% } %>
        </section>
      </section>
    </section>
  </div>
</main>

<script>
  (() => {
    const data = <%- JSON.stringify(chartPayload).replace(/</g, "\\u003c") %>;
    const palette = ["#12bff3", "#20d6a3", "#ffd166", "#ff6aa2", "#8068ff", "#f97316", "#14b8a6", "#84cc16"];
    const ink = "#102033";
    const muted = "#667085";

    const money = (value) => `${Math.round(Number(value || 0)).toLocaleString("vi-VN")} đ`;
    const setup = (id) => {
      const canvas = document.getElementById(id);
      if (!canvas) return null;
      const ratio = window.devicePixelRatio || 1;
      const rect = canvas.getBoundingClientRect();
      canvas.width = Math.max(1, Math.floor(rect.width * ratio));
      canvas.height = Math.max(1, Math.floor(rect.height * ratio));
      const ctx = canvas.getContext("2d");
      ctx.scale(ratio, ratio);
      ctx.clearRect(0, 0, rect.width, rect.height);
      ctx.font = "12px system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif";
      return { canvas, ctx, width: rect.width, height: rect.height };
    };
    const empty = (ctx, width, height, label) => {
      ctx.fillStyle = "rgba(16, 32, 51, .08)";
      ctx.fillRect(0, height / 2 - 1, width, 2);
      ctx.fillStyle = muted;
      ctx.textAlign = "center";
      ctx.fillText(label, width / 2, height / 2 - 10);
    };

    const drawTrend = () => {
      const chart = setup("cashflowTrendChart");
      if (!chart) return;
      const { ctx, width, height } = chart;
      const rows = (data.trend || []).slice(-14);
      if (!rows.length) return empty(ctx, width, height, "Chưa có dữ liệu xu hướng");
      const pad = { top: 16, right: 18, bottom: 30, left: 48 };
      const plotW = width - pad.left - pad.right;
      const plotH = height - pad.top - pad.bottom;
      const values = rows.flatMap((row) => [Number(row.tongThu || 0), Number(row.tongChi || 0), Math.abs(Number(row.dongTienThuan || 0))]);
      const max = Math.max(...values, 1);
      const x = (index) => pad.left + (rows.length === 1 ? plotW / 2 : (plotW / (rows.length - 1)) * index);
      const y = (value) => pad.top + plotH - (Number(value || 0) / max) * plotH;

      ctx.strokeStyle = "rgba(16, 32, 51, .08)";
      ctx.lineWidth = 1;
      for (let i = 0; i <= 4; i += 1) {
        const yy = pad.top + (plotH / 4) * i;
        ctx.beginPath();
        ctx.moveTo(pad.left, yy);
        ctx.lineTo(width - pad.right, yy);
        ctx.stroke();
      }

      const line = (key, color) => {
        ctx.beginPath();
        rows.forEach((row, index) => {
          const xx = x(index);
          const yy = y(row[key]);
          if (index === 0) ctx.moveTo(xx, yy);
          else ctx.lineTo(xx, yy);
        });
        ctx.strokeStyle = color;
        ctx.lineWidth = 3;
        ctx.lineJoin = "round";
        ctx.lineCap = "round";
        ctx.stroke();
        rows.forEach((row, index) => {
          ctx.beginPath();
          ctx.arc(x(index), y(row[key]), 3.5, 0, Math.PI * 2);
          ctx.fillStyle = "#fff";
          ctx.fill();
          ctx.strokeStyle = color;
          ctx.lineWidth = 2;
          ctx.stroke();
        });
      };
      line("tongThu", "#20d6a3");
      line("tongChi", "#ff6aa2");

      ctx.fillStyle = muted;
      ctx.textAlign = "left";
      ctx.fillText(money(max), 4, pad.top + 4);
      ctx.textAlign = "center";
      rows.forEach((row, index) => {
        if (index % Math.ceil(rows.length / 5) === 0 || index === rows.length - 1) {
          ctx.fillText(row.dateLabel || "", x(index), height - 9);
        }
      });
      ctx.textAlign = "left";
      ctx.fillStyle = ink;
      ctx.fillText("Thu", pad.left, 12);
      ctx.fillStyle = "#ff6aa2";
      ctx.fillText("Chi", pad.left + 42, 12);
    };

    const drawBars = (id, rows, valueKey, labelKey, emptyLabel) => {
      const chart = setup(id);
      if (!chart) return;
      const { ctx, width, height } = chart;
      const source = (rows || []).filter((item) => Number(item[valueKey] || 0) > 0).slice(0, 7);
      if (!source.length) return empty(ctx, width, height, emptyLabel);
      const max = Math.max(...source.map((item) => Number(item[valueKey] || 0)), 1);
      const pad = { top: 10, right: 18, bottom: 16, left: 112 };
      const rowH = Math.min(24, (height - pad.top - pad.bottom) / source.length - 7);
      source.forEach((item, index) => {
        const y = pad.top + index * (rowH + 9);
        const value = Number(item[valueKey] || 0);
        const barW = Math.max(8, ((width - pad.left - pad.right) * value) / max);
        ctx.fillStyle = muted;
        ctx.textAlign = "right";
        ctx.fillText(String(item[labelKey] || "Khác").slice(0, 18), pad.left - 10, y + rowH - 6);
        const gradient = ctx.createLinearGradient(pad.left, 0, pad.left + barW, 0);
        gradient.addColorStop(0, palette[index % palette.length]);
        gradient.addColorStop(1, palette[(index + 1) % palette.length]);
        ctx.fillStyle = gradient;
        ctx.beginPath();
        ctx.roundRect(pad.left, y, barW, rowH, 999);
        ctx.fill();
        ctx.fillStyle = ink;
        ctx.textAlign = "left";
        ctx.fillText(valueKey === "value" ? money(value) : value.toLocaleString("vi-VN"), pad.left + barW + 8, y + rowH - 6);
      });
    };

    drawTrend();
    drawBars("cashflowMethodChart", data.methods || [], "value", "label", "Chưa có dữ liệu phương thức");
    drawBars("cashflowRiskChart", data.risks || [], "value", "label", "Không có cảnh báo đối soát");
    window.addEventListener("resize", () => {
      drawTrend();
      drawBars("cashflowMethodChart", data.methods || [], "value", "label", "Chưa có dữ liệu phương thức");
      drawBars("cashflowRiskChart", data.risks || [], "value", "label", "Không có cảnh báo đối soát");
    });
  })();
</script>

<%- include("../partials/footer") %>
