<%- include("../partials/head") %>
<%- include("../partials/header") %>
<%
  const filters = payload.filters || {};
  const rows = payload.rows || [];
  const summary = payload.summary || {};
  const statusOptions = payload.statusOptions || [];
  const statusBreakdown = payload.statusBreakdown || [];
  const dailyTrend = payload.dailyTrend || [];
  const topHotels = payload.topHotels || [];
  const hotelOptions = payload.hotelOptions || [];
  const page = Number(payload.currentPage || 1);
  const totalPages = Number(payload.totalPages || 1);
  const makeQuery = (overrides = {}) => new URLSearchParams({ ...filters, ...overrides }).toString();
  const csvQuery = makeQuery({ format: "csv" });
  const jsonQuery = makeQuery({ format: "json" });
  const pages = [];
  const firstPage = Math.max(1, page - 2);
  const lastPage = Math.min(totalPages, page + 2);
  for (let i = firstPage; i <= lastPage; i += 1) pages.push(i);
  const maxTrend = Math.max(...dailyTrend.map((item) => Number(item.total || 0)), 1);
%>

<style>
  .rev-home {
    --ink: #102033;
    --muted: #637083;
    --line: rgba(16, 32, 51, .10);
    --glass: rgba(255, 255, 255, .80);
    --strong: rgba(255, 255, 255, .94);
    --cyan: #12bff3;
    --mint: #20d6a3;
    --lime: #b8f24b;
    --sun: #ffd166;
    --pink: #ff6aa2;
    --violet: #8068ff;
    --shadow: 0 24px 70px rgba(16, 32, 51, .14);
    min-height: calc(100vh - 84px);
    padding: 34px 18px 58px;
    color: var(--ink);
    background:
      linear-gradient(120deg, rgba(18, 191, 243, .18), transparent 31%),
      linear-gradient(250deg, rgba(255, 106, 162, .16), transparent 34%),
      repeating-linear-gradient(135deg, rgba(255,255,255,.70) 0 12px, rgba(239,253,255,.72) 12px 24px),
      linear-gradient(135deg, #fafffd 0%, #eefcff 42%, #fff7ea 100%);
  }

  .rev-wrap {
    max-width: 1260px;
    margin: 0 auto;
  }

  .rev-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.18fr) minmax(320px, .82fr);
    gap: 16px;
    align-items: stretch;
    margin-bottom: 16px;
  }

  .rev-hero-main,
  .rev-kpi,
  .rev-filter,
  .rev-panel,
  .rev-table-panel,
  .rev-alert {
    border: 1px solid var(--line);
    background: var(--glass);
    box-shadow: var(--shadow);
    backdrop-filter: blur(24px);
  }

  .rev-hero-main {
    position: relative;
    overflow: hidden;
    border-radius: 30px;
    padding: 30px;
  }

  .rev-hero-main::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(94deg, rgba(18, 191, 243, .22), transparent 36%),
      linear-gradient(172deg, transparent 0 52%, rgba(184, 242, 75, .25) 52% 67%, transparent 67%),
      linear-gradient(28deg, transparent 0 72%, rgba(255, 106, 162, .18) 72% 86%, transparent 86%);
  }

  .rev-hero-content {
    position: relative;
    z-index: 1;
  }

  .rev-chip,
  .rev-tag,
  .rev-pill,
  .rev-status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-radius: 999px;
    white-space: nowrap;
  }

  .rev-chip {
    padding: 7px 12px;
    border: 1px solid rgba(32, 214, 163, .28);
    background: rgba(32, 214, 163, .14);
    color: #087763;
    font-size: 12px;
    font-weight: 1000;
    text-transform: uppercase;
  }

  .rev-spark {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--mint);
    box-shadow: 0 0 0 7px rgba(32, 214, 163, .13);
  }

  .rev-hero h1 {
    max-width: 720px;
    margin: 24px 0 12px;
    font-size: 56px;
    line-height: 1;
    letter-spacing: 0;
  }

  .rev-hero h1 span {
    color: transparent;
    background: linear-gradient(96deg, #0891b2 0%, #10b981 35%, #f59e0b 68%, #ec4899 100%);
    -webkit-background-clip: text;
    background-clip: text;
  }

  .rev-lead {
    max-width: 760px;
    margin: 0;
    color: var(--muted);
    font-size: 16px;
    line-height: 1.7;
  }

  .rev-tags,
  .rev-actions,
  .rev-form-actions,
  .rev-pagination {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .rev-tags {
    margin-top: 20px;
  }

  .rev-tag {
    padding: 8px 11px;
    border: 1px solid rgba(16, 32, 51, .08);
    background: rgba(255, 255, 255, .70);
    color: var(--ink);
    font-size: 12px;
    font-weight: 950;
  }

  .rev-actions {
    margin-top: 22px;
  }

  .rev-button {
    min-height: 43px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(16, 32, 51, .12);
    border-radius: 999px;
    padding: 10px 17px;
    color: var(--ink);
    background: rgba(255, 255, 255, .78);
    font-size: 14px;
    font-weight: 950;
    text-decoration: none;
    cursor: pointer;
  }

  .rev-button--primary {
    color: #fff;
    border-color: transparent;
    background: linear-gradient(135deg, #08a5c8, #20d6a3);
    box-shadow: 0 16px 36px rgba(32, 214, 163, .26);
  }

  .rev-button--pink {
    color: #fff;
    border-color: transparent;
    background: linear-gradient(135deg, #ff6aa2, #8068ff);
    box-shadow: 0 16px 36px rgba(128, 104, 255, .22);
  }

  .rev-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 42px rgba(18, 191, 243, .16);
  }

  .rev-kpi-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    height: 100%;
  }

  .rev-kpi {
    min-height: 142px;
    border-radius: 24px;
    padding: 18px;
    background: var(--strong);
  }

  .rev-kpi strong {
    display: block;
    margin-top: 12px;
    font-size: 23px;
    line-height: 1.1;
  }

  .rev-kpi span {
    color: var(--muted);
    font-size: 12px;
    font-weight: 900;
    text-transform: uppercase;
  }

  .rev-kpi.is-cyan { border-color: rgba(18, 191, 243, .28); }
  .rev-kpi.is-green { border-color: rgba(32, 214, 163, .30); }
  .rev-kpi.is-sun { border-color: rgba(255, 209, 102, .40); }
  .rev-kpi.is-pink { border-color: rgba(255, 106, 162, .30); }

  .rev-layout {
    display: grid;
    grid-template-columns: minmax(0, .78fr) minmax(0, 1.22fr);
    gap: 16px;
    align-items: start;
  }

  .rev-filter,
  .rev-panel,
  .rev-table-panel,
  .rev-alert {
    border-radius: 26px;
  }

  .rev-filter {
    padding: 20px;
  }

  .rev-filter h2,
  .rev-panel h2,
  .rev-table-panel h2 {
    margin: 0;
    font-size: 20px;
  }

  .rev-filter-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin-top: 16px;
  }

  .rev-field {
    display: grid;
    gap: 7px;
  }

  .rev-field.is-wide {
    grid-column: 1 / -1;
  }

  .rev-field label {
    color: var(--muted);
    font-size: 12px;
    font-weight: 950;
    text-transform: uppercase;
  }

  .rev-field input,
  .rev-field select {
    width: 100%;
    min-height: 43px;
    border: 1px solid rgba(16, 32, 51, .12);
    border-radius: 14px;
    padding: 10px 12px;
    color: var(--ink);
    background: rgba(255, 255, 255, .88);
    font: inherit;
    font-size: 14px;
  }

  .rev-form-actions {
    margin-top: 16px;
  }

  .rev-alert {
    padding: 14px 16px;
    margin-bottom: 16px;
    background: rgba(255, 246, 214, .88);
    border-color: rgba(245, 158, 11, .25);
    color: #8a4b00;
    font-weight: 800;
  }

  .rev-alert p {
    margin: 0;
  }

  .rev-side-stack {
    display: grid;
    gap: 16px;
  }

  .rev-panel {
    padding: 20px;
  }

  .rev-breakdown {
    display: grid;
    gap: 10px;
    margin-top: 16px;
  }

  .rev-break-row {
    display: grid;
    grid-template-columns: minmax(90px, .7fr) minmax(0, 1fr) auto;
    gap: 10px;
    align-items: center;
  }

  .rev-meter {
    height: 9px;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(16, 32, 51, .08);
  }

  .rev-meter span {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--cyan), var(--mint), var(--sun));
  }

  .rev-pill {
    padding: 7px 10px;
    background: rgba(255, 255, 255, .72);
    border: 1px solid rgba(16, 32, 51, .08);
    font-size: 12px;
    font-weight: 950;
  }

  .rev-trend {
    display: grid;
    gap: 9px;
    margin-top: 16px;
  }

  .rev-trend-row {
    display: grid;
    grid-template-columns: 52px minmax(0, 1fr) minmax(96px, auto);
    gap: 10px;
    align-items: center;
    font-size: 13px;
  }

  .rev-hotels {
    display: grid;
    gap: 10px;
    margin-top: 16px;
  }

  .rev-hotel {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    padding: 12px;
    border-radius: 18px;
    border: 1px solid rgba(16, 32, 51, .08);
    background: rgba(255, 255, 255, .64);
  }

  .rev-hotel strong,
  .rev-hotel span {
    display: block;
  }

  .rev-hotel span,
  .rev-muted {
    color: var(--muted);
    font-size: 13px;
  }

  .rev-table-panel {
    padding: 20px;
  }

  .rev-table-head {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: flex-start;
    margin-bottom: 12px;
  }

  .rev-table-head p {
    margin: 6px 0 0;
    color: var(--muted);
    font-size: 13px;
  }

  .rev-table-wrap {
    overflow-x: auto;
  }

  .rev-table {
    width: 100%;
    min-width: 880px;
    border-collapse: separate;
    border-spacing: 0 9px;
  }

  .rev-table th {
    padding: 0 12px 6px;
    color: var(--muted);
    font-size: 12px;
    text-align: left;
    text-transform: uppercase;
  }

  .rev-table td {
    padding: 13px 12px;
    border-top: 1px solid rgba(16, 32, 51, .08);
    border-bottom: 1px solid rgba(16, 32, 51, .08);
    background: rgba(255, 255, 255, .75);
    font-size: 14px;
    vertical-align: middle;
  }

  .rev-table td:first-child {
    border-left: 1px solid rgba(16, 32, 51, .08);
    border-radius: 18px 0 0 18px;
  }

  .rev-table td:last-child {
    border-right: 1px solid rgba(16, 32, 51, .08);
    border-radius: 0 18px 18px 0;
  }

  .rev-code {
    display: grid;
    gap: 3px;
    font-weight: 950;
  }

  .rev-money {
    font-weight: 1000;
    color: #047857;
  }

  .rev-status {
    padding: 7px 10px;
    border: 1px solid rgba(16, 32, 51, .08);
    font-size: 12px;
    font-weight: 950;
  }

  .rev-status--sky { color: #0369a1; background: rgba(18, 191, 243, .14); }
  .rev-status--blue { color: #1d4ed8; background: rgba(59, 130, 246, .13); }
  .rev-status--violet { color: #6d28d9; background: rgba(128, 104, 255, .14); }
  .rev-status--green { color: #047857; background: rgba(32, 214, 163, .16); }
  .rev-status--rose { color: #be123c; background: rgba(255, 106, 162, .14); }
  .rev-status--slate { color: #475569; background: rgba(100, 116, 139, .14); }

  .rev-empty {
    border: 1px dashed rgba(16, 32, 51, .18);
    border-radius: 22px;
    padding: 22px;
    color: var(--muted);
    background: rgba(255, 255, 255, .62);
  }

  .rev-pagination {
    justify-content: center;
    margin-top: 18px;
  }

  .rev-page {
    min-width: 40px;
    min-height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid rgba(16, 32, 51, .10);
    color: var(--ink);
    background: rgba(255,255,255,.78);
    text-decoration: none;
    font-weight: 950;
  }

  .rev-page.is-active {
    color: #fff;
    border-color: transparent;
    background: linear-gradient(135deg, #08a5c8, #20d6a3);
  }

  @media (max-width: 1080px) {
    .rev-hero,
    .rev-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .rev-home {
      padding: 20px 12px 42px;
    }
    .rev-hero-main,
    .rev-filter,
    .rev-panel,
    .rev-table-panel {
      border-radius: 24px;
      padding: 18px;
    }
    .rev-hero h1 {
      font-size: 40px;
    }
    .rev-kpi-grid,
    .rev-filter-grid {
      grid-template-columns: 1fr;
    }
    .rev-table-head,
    .rev-hotel {
      display: block;
    }
    .rev-break-row,
    .rev-trend-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<main class="rev-home">
  <div class="rev-wrap">
    <section class="rev-hero" aria-label="Quản lý doanh thu">
      <div class="rev-hero-main">
        <div class="rev-hero-content">
          <div class="rev-chip"><span class="rev-spark"></span> Revenue control</div>
          <h1>Quản lý <span>doanh thu</span></h1>
          <p class="rev-lead">Theo dõi giao dịch phát sinh từ đặt phòng, lưu trú và dịch vụ; đối chiếu nhanh theo trạng thái, khách hàng, cơ sở và kỳ ngày.</p>
          <div class="rev-tags">
            <span class="rev-tag"><%= payload.rangeLabel %></span>
            <span class="rev-tag"><%= payload.hotelContext.label %></span>
            <span class="rev-tag"><%= payload.totalRecords %> giao dịch</span>
            <span class="rev-tag">Cập nhật <%= payload.generatedAtLabel %></span>
          </div>
          <div class="rev-actions">
            <a class="rev-button rev-button--primary" href="/api/accounting/revenue?<%= csvQuery %>">Xuất CSV</a>
            <a class="rev-button" href="/api/accounting/revenue?<%= jsonQuery %>">JSON</a>
            <a class="rev-button rev-button--pink" href="/accounting/reports?loai_baocao=doanhthu&tu_ngay=<%= filters.tu_ngay %>&den_ngay=<%= filters.den_ngay %>&hotel_id=<%= filters.hotel_id %>">Báo cáo doanh thu</a>
          </div>
        </div>
      </div>

      <aside class="rev-kpi-grid" aria-label="KPI doanh thu">
        <article class="rev-kpi is-cyan"><span>Doanh thu ghi nhận</span><strong><%= summary.totalRevenueFormatted %></strong></article>
        <article class="rev-kpi is-green"><span>Còn phải thu</span><strong><%= summary.outstandingRevenueFormatted %></strong></article>
        <article class="rev-kpi is-sun"><span>Đã thanh toán</span><strong><%= summary.paidRevenueFormatted %></strong></article>
        <article class="rev-kpi is-pink"><span>Tỷ lệ đã thu</span><strong><%= summary.paidCoverageFormatted %></strong></article>
      </aside>
    </section>

    <% if (payload.warnings && payload.warnings.length) { %>
      <section class="rev-alert">
        <% payload.warnings.forEach((warning) => { %>
          <p><%= warning %></p>
        <% }) %>
      </section>
    <% } %>

    <section class="rev-layout">
      <aside class="rev-side-stack">
        <section class="rev-filter">
          <h2>Bộ lọc</h2>
          <form method="get" action="/accounting/revenue">
            <div class="rev-filter-grid">
              <div class="rev-field">
                <label for="tu_ngay">Từ ngày</label>
                <input id="tu_ngay" type="date" name="tu_ngay" value="<%= filters.tu_ngay %>" />
              </div>
              <div class="rev-field">
                <label for="den_ngay">Đến ngày</label>
                <input id="den_ngay" type="date" name="den_ngay" value="<%= filters.den_ngay %>" />
              </div>
              <div class="rev-field">
                <label for="trang_thai">Trạng thái</label>
                <select id="trang_thai" name="trang_thai">
                  <% statusOptions.forEach((option) => { %>
                    <option value="<%= option.value %>" <%= filters.trang_thai === option.value ? "selected" : "" %>><%= option.label %></option>
                  <% }) %>
                </select>
              </div>
              <div class="rev-field">
                <label for="limit">Hiển thị</label>
                <select id="limit" name="limit">
                  <% [15, 25, 50, 100].forEach((limit) => { %>
                    <option value="<%= limit %>" <%= Number(filters.limit) === limit ? "selected" : "" %>><%= limit %> dòng</option>
                  <% }) %>
                </select>
              </div>
              <div class="rev-field is-wide">
                <label for="hotel_id">Cơ sở</label>
                <select id="hotel_id" name="hotel_id">
                  <option value="0" <%= Number(filters.hotel_id || 0) === 0 ? "selected" : "" %>>Toàn bộ cơ sở</option>
                  <% hotelOptions.forEach((hotel) => { %>
                    <option value="<%= hotel.id %>" <%= Number(filters.hotel_id || 0) === Number(hotel.id) ? "selected" : "" %>>
                      <%= hotel.tenKhachSan %><%= hotel.tinhThanh ? ` · ${hotel.tinhThanh}` : "" %>
                    </option>
                  <% }) %>
                </select>
              </div>
              <div class="rev-field is-wide">
                <label for="search">Tìm kiếm</label>
                <input id="search" name="search" value="<%= filters.search %>" placeholder="Mã giao dịch, mã đặt chỗ, tên khách, email, số điện thoại..." />
              </div>
            </div>
            <input type="hidden" name="page" value="1" />
            <div class="rev-form-actions">
              <button class="rev-button rev-button--primary" type="submit">Lọc doanh thu</button>
              <a class="rev-button" href="/accounting/revenue">Đặt lại</a>
            </div>
          </form>
        </section>

        <section class="rev-panel">
          <h2>Trạng thái giao dịch</h2>
          <div class="rev-breakdown">
            <% if (!statusBreakdown.length) { %>
              <div class="rev-empty">Chưa có dữ liệu trạng thái trong kỳ này.</div>
            <% } %>
            <% statusBreakdown.forEach((item) => {
              const pct = summary.totalRevenue > 0 ? Math.round((Number(item.total || 0) / Number(summary.totalRevenue || 1)) * 100) : 0;
            %>
              <div class="rev-break-row">
                <span class="rev-status rev-status--<%= item.meta.tone %>"><%= item.meta.label %></span>
                <div class="rev-meter"><span style="width:<%= Math.max(5, pct) %>%"></span></div>
                <span class="rev-pill"><%= item.count %> · <%= item.totalFormatted %></span>
              </div>
            <% }) %>
          </div>
        </section>

        <section class="rev-panel">
          <h2>Top cơ sở</h2>
          <div class="rev-hotels">
            <% if (!topHotels.length) { %>
              <div class="rev-empty">Chưa có dữ liệu theo cơ sở.</div>
            <% } %>
            <% topHotels.forEach((hotel) => { %>
              <article class="rev-hotel">
                <div>
                  <strong><%= hotel.hotelName %></strong>
                  <span><%= hotel.province || "Chưa có tỉnh thành" %> · <%= hotel.transactionCount %> giao dịch</span>
                </div>
                <strong class="rev-money"><%= hotel.revenueFormatted %></strong>
              </article>
            <% }) %>
          </div>
        </section>
      </aside>

      <section class="rev-side-stack">
        <section class="rev-panel">
          <h2>Xu hướng theo ngày</h2>
          <div class="rev-trend">
            <% if (!dailyTrend.length) { %>
              <div class="rev-empty">Không có xu hướng để hiển thị.</div>
            <% } %>
            <% dailyTrend.slice(-10).forEach((item) => { %>
              <div class="rev-trend-row">
                <strong><%= item.dateLabel %></strong>
                <div class="rev-meter"><span style="width:<%= Math.max(5, Math.round((Number(item.total || 0) / maxTrend) * 100)) %>%"></span></div>
                <span class="rev-money"><%= item.totalFormatted %></span>
              </div>
            <% }) %>
          </div>
          <% if (payload.bestDay) { %>
            <p class="rev-muted" style="margin:14px 0 0">Ngày nổi bật: <strong><%= payload.bestDay.dateLabel %></strong> với <strong><%= payload.bestDay.totalFormatted %></strong>.</p>
          <% } %>
        </section>

        <section class="rev-table-panel">
          <div class="rev-table-head">
            <div>
              <h2>Danh sách giao dịch</h2>
              <p>Trang <%= page %>/<%= totalPages %>, đang hiển thị <%= rows.length %> trên <%= payload.totalRecords %> bản ghi.</p>
            </div>
            <span class="rev-pill">Đã hủy: <%= summary.cancelledRevenueFormatted %></span>
          </div>

          <% if (!payload.hasData) { %>
            <div class="rev-empty">Không có giao dịch phù hợp với bộ lọc hiện tại.</div>
          <% } else { %>
            <div class="rev-table-wrap">
              <table class="rev-table">
                <thead>
                  <tr>
                    <th>Mã giao dịch</th>
                    <th>Ngày</th>
                    <th>Khách hàng</th>
                    <th>Phòng / Cơ sở</th>
                    <th>Thanh toán</th>
                    <th>Tổng tiền</th>
                    <th>Đã thu / còn thu</th>
                    <th>Trạng thái</th>
                  </tr>
                </thead>
                <tbody>
                  <% rows.forEach((row) => { %>
                    <tr>
                      <td>
                        <span class="rev-code">
                          <%= row.bookingCode || `GD-${row.id}` %>
                          <span class="rev-muted">#<%= row.id %></span>
                        </span>
                      </td>
                      <td><%= row.ngayGiaoDichLabel %></td>
                      <td>
                        <strong><%= row.tenKh || "Khách lẻ" %></strong>
                        <div class="rev-muted"><%= row.email || row.sdt || "Chưa có liên hệ" %></div>
                      </td>
                      <td>
                        <strong><%= row.roomLabel %></strong>
                        <div class="rev-muted"><%= row.hotelLabel %><%= row.provinceLabel ? ` · ${row.provinceLabel}` : "" %></div>
                      </td>
                      <td><%= row.phuongThucThanhToanLabel %></td>
                      <td class="rev-money"><%= row.tongTienFormatted %></td>
                      <td>
                        <strong class="rev-money"><%= row.paidAmountFormatted %></strong>
                        <div class="rev-muted">Còn thu: <%= row.outstandingAmountFormatted %></div>
                      </td>
                      <td>
                        <span class="rev-status rev-status--<%= row.statusMeta.tone %>"><%= row.statusMeta.label %></span>
                        <div class="rev-muted" style="margin-top:5px"><%= row.statusMeta.hint %></div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>

            <% if (totalPages > 1) { %>
              <nav class="rev-pagination" aria-label="Phân trang doanh thu">
                <% if (page > 1) { %>
                  <a class="rev-page" href="/accounting/revenue?<%= makeQuery({ page: page - 1 }) %>">Trước</a>
                <% } %>
                <% if (firstPage > 1) { %>
                  <a class="rev-page" href="/accounting/revenue?<%= makeQuery({ page: 1 }) %>">1</a>
                <% } %>
                <% pages.forEach((item) => { %>
                  <a class="rev-page <%= item === page ? "is-active" : "" %>" href="/accounting/revenue?<%= makeQuery({ page: item }) %>"><%= item %></a>
                <% }) %>
                <% if (lastPage < totalPages) { %>
                  <a class="rev-page" href="/accounting/revenue?<%= makeQuery({ page: totalPages }) %>"><%= totalPages %></a>
                <% } %>
                <% if (page < totalPages) { %>
                  <a class="rev-page" href="/accounting/revenue?<%= makeQuery({ page: page + 1 }) %>">Tiếp</a>
                <% } %>
              </nav>
            <% } %>
          <% } %>
        </section>
      </section>
    </section>
  </div>
</main>

<%- include("../partials/footer") %>
