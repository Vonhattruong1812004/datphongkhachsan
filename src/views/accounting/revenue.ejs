      radial-gradient(circle at 88% 10%, rgba(139, 92, 246, .20), transparent 28%),
      radial-gradient(circle at 52% 105%, rgba(251, 191, 36, .10), transparent 34%),
      linear-gradient(135deg, rgba(2, 6, 23, .88) 0%, rgba(8, 20, 38, .90) 46%, rgba(23, 11, 48, .90) 100%);
