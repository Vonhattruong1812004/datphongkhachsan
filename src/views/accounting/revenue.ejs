<%
  const filters = payload.filters || {};
  const rows = payload.rows || [];
  const summary = payload.summary || {};
  const statusOptions = payload.statusOptions || [];
  const statusBreakdown = payload.statusBreakdown || [];
  const dailyTrend = payload.dailyTrend || [];
  const topHotels = payload.topHotels || [];
  const topRooms = payload.topRooms || [];
  const paymentBreakdown = payload.paymentBreakdown || [];
  const sourceBreakdown = payload.sourceBreakdown || [];
  const weekdayPerformance = payload.weekdayPerformance || [];
  const actionItems = payload.actionItems || [];
  const comparisons = payload.comparisons || {};
  const previousPeriod = payload.previousPeriod || {};
  const hotelOptions = payload.hotelOptions || [];
  const page = Number(payload.currentPage || 1);
  const totalPages = Number(payload.totalPages || 1);
  const makeQuery = (overrides = {}) => new URLSearchParams({ ...filters, ...overrides }).toString();
  const csvQuery = makeQuery({ format: "csv" });
  const jsonQuery = makeQuery({ format: "json" });
  const pages = [];
  const firstPage = Math.max(1, page - 2);
  const lastPage = Math.min(totalPages, page + 2);
  for (let i = firstPage; i <= lastPage; i += 1) pages.push(i);
  const maxTrend = Math.max(...dailyTrend.map((item) => Number(item.total || 0)), 1);
  const revenueMix = [
    { label: "Tiền phòng", value: Number(summary.roomRevenue || 0), formatted: summary.roomRevenueFormatted || "0 đ" },
    { label: "Dịch vụ", value: Number(summary.serviceRevenue || 0), formatted: summary.serviceRevenueFormatted || "0 đ" },
    { label: "Phụ thu", value: Number(summary.surchargeRevenue || 0), formatted: summary.surchargeRevenueFormatted || "0 đ" },
    { label: "Bồi thường", value: Number(summary.damageRevenue || 0), formatted: summary.damageRevenueFormatted || "0 đ" }
  ];
  const maxMix = Math.max(...revenueMix.map((item) => Math.abs(item.value || 0)), 1);
  const compareCards = [
    { label: "Doanh thu", value: summary.totalRevenueFormatted, compare: comparisons.totalRevenue },
    { label: "Đã thu", value: summary.paidRevenueFormatted, compare: comparisons.paidRevenue },
    { label: "ADR", value: summary.adrFormatted, compare: comparisons.adr },
    { label: "RevPAR", value: summary.revparFormatted, compare: comparisons.revpar }
  ];
%>

