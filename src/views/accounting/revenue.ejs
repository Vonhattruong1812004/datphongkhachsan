      radial-gradient(circle at 24% 80%, rgba(255, 255, 255, .66) 0 1px, transparent 2px);
    background-size: 240px 190px;
    opacity: .58;
  }

  .rev-home::after {
    background:
      linear-gradient(90deg, transparent, rgba(125, 211, 252, .12), transparent) 0 18% / 100% 1px no-repeat,
      linear-gradient(90deg, transparent, rgba(251, 113, 133, .10), transparent) 0 68% / 100% 1px no-repeat;
  }

  .rev-wrap {
    display: flex;
    flex-direction: column;
    gap: 26px;
  }

  .rev-hero,
  .rev-score-strip,
  .rev-command,
  .rev-alert,
