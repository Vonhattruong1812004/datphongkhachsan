<%- include("../partials/head") %>
<%- include("../partials/header") %>
<%
  const filters = payload.filters || {};
  const rows = payload.rows || [];
  const summary = payload.summary || {};
  const statusOptions = payload.statusOptions || [];
  const statusBreakdown = payload.statusBreakdown || [];
  const page = Number(payload.currentPage || 1);
  const totalPages = Number(payload.totalPages || 1);
  const makeQuery = (overrides = {}) => new URLSearchParams({ ...filters, ...overrides }).toString();
  const csvQuery = makeQuery({ format: "csv" });
  const pages = [];
  const firstPage = Math.max(1, page - 2);
  const lastPage = Math.min(totalPages, page + 2);
  for (let i = firstPage; i <= lastPage; i += 1) pages.push(i);
%>

<style>
  .refund-home{
    --refund-ink:#102033;
    --refund-muted:#5c7084;
    --refund-line:#dbe7f1;
    --refund-card:#ffffff;
    --refund-soft:#f7fafc;
    --refund-blue:#0ea5e9;
    --refund-green:#10b981;
    --refund-amber:#f59e0b;
    --refund-rose:#e11d48;
    min-height:calc(100vh - 84px);
    padding:30px 18px 54px;
    color:var(--refund-ink);
    background:
      radial-gradient(circle at 10% 0%,rgba(14,165,233,.12),transparent 28%),
      radial-gradient(circle at 96% 8%,rgba(16,185,129,.10),transparent 28%),
      linear-gradient(180deg,#f7fbff 0%,#eef6fb 100%);
  }
  .refund-wrap{max-width:1320px;margin:0 auto;display:flex;flex-direction:column;gap:22px}
  .refund-hero,.refund-panel,.refund-table-panel,.refund-alert{border:1px solid var(--refund-line);background:var(--refund-card);box-shadow:0 14px 40px rgba(15,35,55,.09)}
  .refund-hero{display:grid;grid-template-columns:minmax(0,1.25fr) minmax(280px,.75fr);gap:22px;border-radius:28px;padding:28px;background:linear-gradient(135deg,rgba(255,255,255,.97),rgba(239,248,255,.94))}
  .refund-chip,.refund-tag,.refund-status{display:inline-flex;align-items:center;gap:8px;border-radius:999px;white-space:nowrap}
  .refund-chip{padding:7px 12px;border:1px solid #b7eef8;background:#e8fbff;color:#036672;font-size:12px;font-weight:1000;text-transform:uppercase}
  .refund-hero h1{margin:18px 0 10px;font-size:52px;line-height:.98;letter-spacing:-.04em;color:var(--refund-ink)}
  .refund-hero h1 span{color:transparent;background:linear-gradient(90deg,#0284c7,#10b981,#f59e0b);-webkit-background-clip:text;background-clip:text}
  .refund-lead{max-width:760px;margin:0;color:var(--refund-muted);font-size:15px;line-height:1.72}
  .refund-actions,.refund-tags,.refund-card-actions{display:flex;flex-wrap:wrap;gap:10px}.refund-tags{margin-top:18px}.refund-actions{margin-top:18px}
  .refund-tag{padding:8px 11px;background:#fff;border:1px solid var(--refund-line);color:#123047;font-size:12px;font-weight:950}
  .refund-button{display:inline-flex;align-items:center;justify-content:center;min-height:42px;border-radius:14px;padding:10px 14px;border:1px solid #cfe0ed;background:#fff;color:#123047;text-decoration:none;font:inherit;font-size:13px;font-weight:950;cursor:pointer;box-shadow:0 8px 20px rgba(15,35,55,.08);transition:transform .16s ease,box-shadow .16s ease}
  .refund-button:hover{transform:translateY(-1px);box-shadow:0 12px 24px rgba(15,35,55,.12)}
  .refund-button--primary{border-color:transparent;background:linear-gradient(135deg,#0284c7,#10b981);color:#fff}.refund-button--danger{border-color:transparent;background:linear-gradient(135deg,#fb7185,#e11d48);color:#fff}.refund-button--muted{background:#fff}
  .refund-kpis{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}.refund-kpi{min-height:104px;border-radius:20px;padding:16px;background:#fff;border:1px solid var(--refund-line);box-shadow:0 10px 28px rgba(15,35,55,.08)}
  .refund-kpi strong{display:block;font-size:22px;line-height:1.12;color:#0f2d42;overflow-wrap:anywhere}.refund-kpi span{display:block;margin-top:6px;color:#64748b;font-size:12px;font-weight:900;text-transform:uppercase}
  .refund-flow{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;margin:16px 0}.refund-flow__step{border:1px solid var(--refund-line);border-radius:18px;padding:12px;background:#fff;min-height:0}.refund-flow__step b{display:block;color:#102033;font-size:14px}.refund-flow__step span{display:block;margin-top:6px;color:#5f7183;font-size:12px;line-height:1.45;font-weight:750}
  .refund-layout{display:grid;grid-template-columns:300px minmax(0,1fr);gap:18px;align-items:start}.refund-panel,.refund-table-panel,.refund-card,.refund-alert{border-radius:24px;padding:18px}.refund-panel h2,.refund-table-panel h2{margin:0 0 12px;font-size:22px;color:#102033}
  .refund-field{display:flex;flex-direction:column;gap:7px;margin-bottom:12px}.refund-field label{font-size:12px;font-weight:950;color:#34495d}.refund-field input,.refund-field select,.refund-field textarea{width:100%;min-height:44px;border:1px solid #cfe0ed;border-radius:14px;padding:10px 12px;background:#fff;color:#102033;font:inherit;font-size:14px;font-weight:700;outline:none;box-sizing:border-box}.refund-field textarea{min-height:78px;resize:vertical}
  .refund-breakdown{display:grid;gap:10px;margin-top:12px}.refund-break,.refund-empty{border:1px solid var(--refund-line);border-radius:16px;padding:12px;background:#f8fbfd;color:#102033}.refund-break strong{display:block;font-size:19px;color:#102033}.refund-break span,.refund-sub{color:#607487}.refund-break span{font-size:12px;font-weight:900}
  .refund-alert{margin:0}.refund-alert--ok{background:#ecfdf5;color:#065f46;border-color:#b7efd6}.refund-alert--err{background:#fff1f2;color:#9f1239;border-color:#fecdd3}
  .refund-table-wrap{overflow:visible;border:0;background:transparent}.refund-table{display:block;width:100%;min-width:0;border-collapse:separate;border-spacing:0;font-size:14px}.refund-table thead{display:none}.refund-table tbody{display:grid;gap:16px}.refund-table tr{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;padding:14px;border:1px solid var(--refund-line);border-radius:22px;background:#fff;box-shadow:0 12px 34px rgba(15,35,55,.08)}.refund-table td{display:block;min-width:0;padding:14px;border:1px solid #e1ebf3;border-radius:16px;background:#f8fbfd;color:#102033;overflow-wrap:anywhere;vertical-align:top}.refund-table td:nth-child(6),.refund-table td:nth-child(7){grid-column:1/-1}.refund-table td:nth-child(7){background:#f0f7ff}.refund-table td::before{content:attr(data-label);display:block;margin-bottom:8px;color:#0f8ab8;font-size:11px;font-weight:1000;letter-spacing:.08em;text-transform:uppercase}
  .refund-main{font-weight:1000;color:#102033}.refund-sub{margin-top:4px;font-size:12px;line-height:1.45}.refund-status{padding:5px 9px;font-size:11px;font-weight:1000;border:1px solid #d7e2eb;background:#eef2f7;color:#334155}.refund-status--sun{background:#fff7df;color:#92400e;border-color:#f8df93}.refund-status--green{background:#e9fbf3;color:#047857;border-color:#b7efd6}.refund-status--rose{background:#fff1f2;color:#be123c;border-color:#fecdd3}
  .refund-paybox{display:grid;gap:12px;min-width:0;max-width:none;width:100%}.refund-qr{display:grid;grid-template-columns:104px minmax(0,1fr);gap:10px;align-items:center;border:1px solid #cfe0ed;border-radius:18px;padding:10px;background:#fff}.refund-qr img{width:104px;height:104px;border-radius:14px;border:1px solid #d7e2eb;background:#fff;padding:4px}.refund-qr__meta{display:grid;gap:6px;min-width:0}.refund-copy{border-radius:12px;padding:7px 9px;background:#fff;border:1px solid #d7e2eb;color:#102033;font-size:12px;font-weight:950;word-break:break-word}.refund-warning{border-radius:14px;padding:9px 10px;background:#fff7df;border:1px solid #f8df93;color:#92400e;font-size:12px;font-weight:850;line-height:1.45}.refund-mini-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px}
  .refund-pages{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-top:14px}.refund-page{min-width:38px;min-height:38px;border-radius:14px;border:1px solid #cfe0ed;display:inline-flex;align-items:center;justify-content:center;text-decoration:none;color:#102033;background:#fff;font-size:13px;font-weight:950}.refund-page.is-active{background:linear-gradient(135deg,#0284c7,#10b981);color:#fff;border-color:transparent}
  @media(max-width:1100px){.refund-hero,.refund-layout{grid-template-columns:1fr}.refund-table tr{grid-template-columns:repeat(2,minmax(0,1fr))}.refund-table td:nth-child(6),.refund-table td:nth-child(7){grid-column:1/-1}}
  @media(max-width:720px){.refund-home{padding:18px 10px 36px}.refund-hero,.refund-panel,.refund-table-panel{padding:16px;border-radius:20px}.refund-hero h1{font-size:36px}.refund-kpis,.refund-flow,.refund-table tr,.refund-mini-grid,.refund-qr{grid-template-columns:1fr}.refund-table td,.refund-table td:nth-child(6),.refund-table td:nth-child(7){grid-column:auto}.refund-table tr{padding:10px}.refund-table td{padding:12px}}
</style>

<main class="refund-home">
  <div class="refund-wrap">
    <section class="refund-hero">
      <div>
        <div class="refund-chip">Refund control</div>
        <h1>Xử lý <span>hoàn tiền</span></h1>
        <p class="refund-lead">Quản lý hoàn tiền của Kế toán nằm ở bước cuối workflow: Lễ tân tạo yêu cầu sau khi hủy đặt phòng, Quản lý duyệt thông tin, hệ thống sinh QR hoàn tiền và Kế toán xác nhận mã giao dịch ngân hàng trước khi đóng phiếu chi.</p>
        <div class="refund-tags">
          <span class="refund-tag">Chờ quản lý: <%= summary.managerPendingCount || 0 %></span>
          <span class="refund-tag">Chờ kế toán: <%= summary.pendingCount || 0 %></span>
          <span class="refund-tag">Đã hoàn: <%= summary.paidCount || 0 %></span>
          <span class="refund-tag">Kỳ lọc: <%= payload.rangeLabel %></span>
        </div>
        <div class="refund-actions">
          <a class="refund-button refund-button--primary" href="/accounting/expenses?search=Hoan%20coc">Đối chiếu phiếu chi hoàn</a>
          <a class="refund-button" href="/accounting/reports?loai_baocao=chiphi">Xem báo cáo chi phí</a>
          <a class="refund-button" href="/dashboard/ketoan">Dashboard</a>
        </div>
        <div class="refund-flow">
          <div class="refund-flow__step"><b>01 · Lễ tân</b><span>Hủy đặt phòng, tính policy và tạo yêu cầu hoàn cọc.</span></div>
          <div class="refund-flow__step"><b>02 · Quản lý</b><span>Duyệt thông tin khách, tài khoản nhận và tỷ lệ hoàn.</span></div>
          <div class="refund-flow__step"><b>03 · Kế toán</b><span>Quét QR, chuyển đúng nội dung, nhập mã giao dịch/chứng từ rồi hệ thống mới ghi nhận đã hoàn.</span></div>
        </div>
      </div>
      <div class="refund-kpis">
        <div class="refund-kpi"><strong><%= summary.managerPendingAmountFormatted || "0 đ" %></strong><span>Chờ quản lý duyệt</span></div>
        <div class="refund-kpi"><strong><%= summary.pendingAmountFormatted || "0 đ" %></strong><span>Đang chờ chi</span></div>
        <div class="refund-kpi"><strong><%= summary.paidAmountFormatted || "0 đ" %></strong><span>Đã hoàn</span></div>
        <div class="refund-kpi"><strong><%= summary.rejectedAmountFormatted || "0 đ" %></strong><span>Từ chối</span></div>
        <div class="refund-kpi"><strong><%= payload.totalRecords || 0 %></strong><span>Yêu cầu</span></div>
      </div>
    </section>

    <% if (notice?.success) { %><div class="refund-alert refund-alert--ok"><%= notice.success %></div><% } %>
    <% if (notice?.error) { %><div class="refund-alert refund-alert--err"><%= notice.error %></div><% } %>
    <% if (payload.warnings && payload.warnings.length) { %>
      <div class="refund-alert refund-alert--err"><%= payload.warnings.join(" ") %></div>
    <% } %>

    <section class="refund-layout">
      <aside>
        <section class="refund-panel">
          <h2>Bộ lọc</h2>
          <form method="get" action="/accounting/refunds">
            <div class="refund-field">
              <label for="tu_ngay">Từ ngày</label>
              <input id="tu_ngay" name="tu_ngay" type="date" value="<%= filters.tu_ngay %>" />
            </div>
            <div class="refund-field">
              <label for="den_ngay">Đến ngày</label>
              <input id="den_ngay" name="den_ngay" type="date" value="<%= filters.den_ngay %>" />
            </div>
            <div class="refund-field">
              <label for="trang_thai">Trạng thái</label>
              <select id="trang_thai" name="trang_thai">
                <% statusOptions.forEach((item) => { %>
                  <option value="<%= item.value %>" <%= item.value === filters.trang_thai ? "selected" : "" %>><%= item.label %></option>
                <% }) %>
              </select>
            </div>
            <div class="refund-field">
              <label for="search">Tìm kiếm</label>
              <input id="search" name="search" value="<%= filters.search || "" %>" placeholder="Mã refund, GD, khách, STK..." />
            </div>
            <div class="refund-actions">
              <button class="refund-button refund-button--primary" type="submit">Lọc</button>
              <a class="refund-button" href="/accounting/refunds">Đặt lại</a>
              <a class="refund-button" href="/api/accounting/refunds?<%= csvQuery %>">CSV</a>
            </div>
          </form>
        </section>

        <section class="refund-panel" style="margin-top:16px">
          <h2>Theo trạng thái</h2>
          <div class="refund-breakdown">
            <% if (!statusBreakdown.length) { %>
              <div class="refund-empty">Chưa có dữ liệu.</div>
            <% } %>
            <% statusBreakdown.forEach((item) => { %>
              <div class="refund-break">
                <strong><%= item.totalFormatted %></strong>
                <span><%= item.meta?.label || item.status %> · <%= item.count %> yêu cầu</span>
              </div>
            <% }) %>
          </div>
        </section>
      </aside>

      <section class="refund-table-panel">
        <h2>Yêu cầu hoàn tiền</h2>
        <% if (!rows.length) { %>
          <div class="refund-empty">Chưa có yêu cầu hoàn tiền phù hợp bộ lọc.</div>
        <% } else { %>
          <div class="refund-table-wrap">
            <table class="refund-table">
              <thead>
                <tr>
                  <th>Yêu cầu</th>
                  <th>Khách / giao dịch</th>
                  <th>Tài khoản nhận</th>
                  <th>Số tiền</th>
                  <th>Trạng thái</th>
                  <th>Ghi chú</th>
                  <th>Thao tác</th>
                </tr>
              </thead>
              <tbody>
                <% rows.forEach((row) => { %>
                  <tr>
                    <td data-label="Yêu cầu">
                      <div class="refund-main"><%= row.refundCode %></div>
                      <div class="refund-sub">Tạo lúc <%= row.createdAtLabel %></div>
                      <div class="refund-sub"><%= row.roomCount %> phòng · <%= row.scope === "partial" ? "Hủy một phần" : "Hủy toàn bộ" %></div>
                    </td>
                    <td data-label="Khách / giao dịch">
                      <div class="refund-main">GD-<%= row.maGiaoDich %></div>
                      <div class="refund-sub"><%= row.bookingCode || "Không có mã đặt chỗ" %> · <%= row.transactionStatus || "" %></div>
                      <div class="refund-sub"><%= row.customerName || "Khách" %> · <%= row.customerPhone || row.customerEmail || "Chưa có liên hệ" %></div>
                      <div class="refund-sub"><%= row.hotelLabel %></div>
                    </td>
                    <td data-label="Tài khoản nhận">
                      <div class="refund-main"><%= row.bankName %></div>
                      <div class="refund-sub"><%= row.bankAccountNo %></div>
                      <div class="refund-sub"><%= row.bankAccountName %></div>
                      <% if (row.paymentQrBankCode) { %><div class="refund-sub">Mã VietQR: <%= row.paymentQrBankCode %></div><% } %>
                    </td>
                    <td data-label="Số tiền">
                      <div class="refund-main"><%= row.amountRequestedFormatted %></div>
                      <div class="refund-sub">Policy: <%= row.cancellationPolicyLabel || row.refundRateLabel %> · <%= row.hoursBeforeCheckinLabel %></div>
                      <div class="refund-sub">Cọc xét hoàn: <%= row.refundableBaseFormatted %></div>
                      <div class="refund-sub">Cọc đã thu: <%= row.depositPaidFormatted %></div>
                      <div class="refund-sub">Giữ lại: <%= row.retainedDepositFormatted %></div>
                      <% if (row.amountPaid > 0) { %><div class="refund-sub">Đã chi: <%= row.amountPaidFormatted %></div><% } %>
                    </td>
                    <td data-label="Trạng thái">
                      <span class="refund-status refund-status--<%= row.statusMeta?.tone || "slate" %>"><%= row.statusMeta?.label || row.status %></span>
                      <% if (row.managerReviewedAtLabel) { %><div class="refund-sub">QL duyệt: <%= row.managerReviewedAtLabel %></div><% } %>
                      <% if (row.expenseId) { %><div class="refund-sub">Phiếu chi CP-<%= row.expenseId %></div><% } %>
                      <% if (row.refundBankTxnId) { %><div class="refund-sub">Mã GD NH: <%= row.refundBankTxnId %></div><% } %>
                      <% if (row.refundPaidAtLabel) { %><div class="refund-sub">Đã chuyển: <%= row.refundPaidAtLabel %></div><% } %>
                      <% if (row.processedAtLabel) { %><div class="refund-sub"><%= row.processedAtLabel %></div><% } %>
                    </td>
                    <td data-label="Ghi chú">
                      <div class="refund-sub"><strong>Lý do:</strong> <%= row.reason || "Không có" %></div>
                      <% if (row.cancellationPolicyNote) { %><div class="refund-sub"><strong>Policy:</strong> <%= row.cancellationPolicyNote %></div><% } %>
                      <% if (row.note) { %><div class="refund-sub"><strong>Lễ tân:</strong> <%= row.note %></div><% } %>
                      <% if (row.managerNote) { %><div class="refund-sub"><strong>Quản lý:</strong> <%= row.managerNote %><%= row.managerBy ? ` · ${row.managerBy}` : "" %></div><% } %>
                      <% if (row.accountingNote) { %><div class="refund-sub"><strong>Kế toán:</strong> <%= row.accountingNote %></div><% } %>
                    </td>
                    <td data-label="Thao tác">
                      <% if (row.canAccountingProcess) { %>
                        <div class="refund-paybox">
                          <% if (row.paymentQrReady) { %>
                            <div class="refund-qr">
                              <img src="<%= row.paymentQrImageUrl %>" alt="QR hoàn tiền <%= row.refundCode %>" />
                              <div class="refund-qr__meta">
                                <div class="refund-copy">Số tiền: <%= row.amountRequestedFormatted %></div>
                                <div class="refund-copy">Nội dung: <%= row.refundPaymentContent %></div>
                                <div class="refund-sub">QR chỉ hỗ trợ chuyển khoản, hệ thống chỉ đóng yêu cầu sau khi nhập mã giao dịch ngân hàng.</div>
                              </div>
                            </div>
                          <% } else { %>
                            <div class="refund-warning"><%= row.paymentQrWarning || "Chưa thể sinh QR, kế toán kiểm tra thông tin và chuyển thủ công." %></div>
                            <div class="refund-copy">Nội dung CK: <%= row.refundPaymentContent %></div>
                          <% } %>
                          <form method="post" action="/accounting/refunds/process" style="display:grid;gap:8px">
                            <input type="hidden" name="refund_id" value="<%= row.id %>" />
                            <input type="hidden" name="action" value="approve" />
                            <div class="refund-mini-grid">
                              <div class="refund-field" style="margin:0">
                                <label>Mã giao dịch NH</label>
                                <input name="payment_reference" placeholder="VD: FT2412345678" required minlength="4" />
                              </div>
                              <div class="refund-field" style="margin:0">
                                <label>Thời gian chuyển</label>
                                <input name="paid_at" type="datetime-local" />
                              </div>
                            </div>
                            <div class="refund-field" style="margin:0">
                              <label>Chứng từ / biên lai</label>
                              <input name="payment_proof" placeholder="Số biên lai hoặc đường dẫn ảnh chứng từ..." />
                            </div>
                            <div class="refund-field" style="margin:0">
                              <textarea name="accounting_note" placeholder="Ghi chú kế toán..."></textarea>
                            </div>
                            <button class="refund-button refund-button--primary" type="submit" onclick="return confirm('Xác nhận đã chuyển khoản đúng STK, số tiền và nội dung hoàn tiền?');">Xác nhận đã chuyển khoản</button>
                          </form>
                          <form method="post" action="/accounting/refunds/process" style="display:grid;gap:8px">
                            <input type="hidden" name="refund_id" value="<%= row.id %>" />
                            <input type="hidden" name="action" value="reject" />
                            <div class="refund-field" style="margin:0">
                              <textarea name="accounting_note" placeholder="Lý do từ chối chi hoàn..."></textarea>
                            </div>
                            <button class="refund-button refund-button--danger" type="submit" onclick="return confirm('Từ chối yêu cầu hoàn tiền này?');">Từ chối</button>
                          </form>
                        </div>
                      <% } else { %>
                        <% if (row.status === "ChoQuanLyDuyet") { %>
                          <span class="refund-sub">Đang chờ Quản lý duyệt, Kế toán chưa được chi.</span>
                        <% } else { %>
                          <% if (row.refundPaymentContent) { %><div class="refund-copy" style="margin-bottom:8px">Nội dung CK: <%= row.refundPaymentContent %></div><% } %>
                          <% if (row.refundPaymentProof) { %><div class="refund-sub" style="margin-bottom:8px"><strong>Chứng từ:</strong> <%= row.refundPaymentProof %></div><% } %>
                          <a class="refund-button refund-button--muted" href="/accounting/cashflow?search=<%= encodeURIComponent(row.expenseId ? `CP-${row.expenseId}` : row.refundCode) %>">Đối chiếu</a>
                        <% } %>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <div class="refund-pages">
            <% if (page > 1) { %><a class="refund-page" href="/accounting/refunds?<%= makeQuery({ page: page - 1 }) %>">Trước</a><% } %>
            <% pages.forEach((item) => { %>
              <a class="refund-page <%= item === page ? "is-active" : "" %>" href="/accounting/refunds?<%= makeQuery({ page: item }) %>"><%= item %></a>
            <% }) %>
            <% if (page < totalPages) { %><a class="refund-page" href="/accounting/refunds?<%= makeQuery({ page: page + 1 }) %>">Tiếp</a><% } %>
          </div>
        <% } %>
      </section>
    </section>
  </div>
</main>

<%- include("../partials/footer") %>
