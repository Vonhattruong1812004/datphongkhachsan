      rows.forEach((row, index) => {
        const col = index % cols;
        const line = Math.floor(index / cols);
        const x = pad.left + col * (cellW + boxGap);
        const y = pad.top + line * (cellH + boxGap);
        const intensity = Math.max(0, Math.min(1, Number(row.intensity || 0) / maxIntensity));
