        ctx.closePath();
        ctx.strokeStyle = "rgba(17,34,51,.1)";
        ctx.stroke();
      }
      ctx.beginPath();
      rows.forEach((row, index) => {
        const angle = -Math.PI / 2 + (index / rows.length) * Math.PI * 2;
        const x = cx + Math.cos(angle) * radius;
        const y = cy + Math.sin(angle) * radius;
        ctx.moveTo(cx, cy);
