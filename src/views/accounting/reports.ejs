            <span class="report-ai-insight__tone">Đang đọc</span>
          </div>
          <strong>Đang phân tích ${escapeHtml(title.toLowerCase())}...</strong>
          <ul><li>AI sẽ đọc số liệu, tìm điểm lệch và gợi ý hành động kế toán phù hợp.</li></ul>
        `;
        card.appendChild(panel);
      });
    };
    const loadAiInsights = async () => {
      attachAiInsightPanels();
      const endpoint = `/api/accounting/reports/ai-insights${window.location.search || ""}`;
      try {
        const response = await fetch(endpoint, { credentials: "same-origin" });
        const json = await response.json();
        if (!response.ok || !json.ok) throw new Error(json.message || "Không thể tải AI phân tích.");
        const insights = Array.isArray(json.data?.charts) ? json.data.charts : [];
        insights.forEach((insight) => {
          const chartId = String(insight.chartId || "");
          const safeChartId = window.CSS?.escape ? CSS.escape(chartId) : chartId.replace(/["\\]/g, "\\$&");
          const panel = document.querySelector(`.report-ai-insight[data-ai-chart="${safeChartId}"]`);
          if (panel) renderAiInsight(panel, insight);
        });
      } catch (error) {
        document.querySelectorAll(".report-ai-insight").forEach((panel) => {
          renderAiInsight(panel, {
            tone: "fallback",
            toneLabel: "Local",
            headline: "Chưa gọi được AI phân tích, hệ thống giữ chế độ đọc biểu đồ cơ bản.",
            bullets: ["Kiểm tra đăng nhập, quyền kế toán hoặc cấu hình provider AI nếu muốn phân tích nâng cao."],
            action: "Trang vẫn dùng được; biểu đồ và số liệu không bị ảnh hưởng."
          });
        });
      }
    };
    wireChartFilters();
    render();
    loadAiInsights();
    window.addEventListener("resize", () => window.requestAnimationFrame(render), { passive: true });
  })();
</script>

