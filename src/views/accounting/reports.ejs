<%- include("../partials/head") %>
<%- include("../partials/header") %>
<%
  const filters = payload.filters || {};
  const reportType = filters.loai_baocao || "tonghop";
  const hotelOptions = payload.hotelOptions || [];
  const statusOptions = payload.statusOptions || [{ value: "all", label: "Tất cả" }];
%>

<style>
  .report-home {
    --report-ink: #112233;
    --report-muted: #667085;
    --report-card: rgba(255, 255, 255, .76);
    --report-card-strong: rgba(255, 255, 255, .92);
    --report-line: rgba(17, 34, 51, .10);
    --report-mint: #21cfa6;
    --report-cyan: #18bff2;
    --report-yellow: #ffd166;
    --report-pink: #ff6fa3;
    --report-violet: #8b6bff;
    --report-shadow: 0 24px 56px rgba(15, 82, 112, .13);
    --report-card-shadow: 0 14px 32px rgba(15, 82, 112, .09);
    min-height: calc(100vh - 84px);
    position: relative;
    padding: 34px 18px 58px;
    color: var(--report-ink);
    background:
      linear-gradient(115deg, rgba(24, 191, 242, .22) 0%, rgba(255, 255, 255, 0) 32%),
      linear-gradient(245deg, rgba(33, 207, 166, .20) 0%, rgba(255, 255, 255, 0) 34%),
      linear-gradient(35deg, rgba(255, 111, 163, .12) 0%, rgba(255, 255, 255, 0) 28%),
      linear-gradient(180deg, #fbfffb 0%, #eafcff 42%, #fff7ed 100%);
  }

  .report-wrap {
    max-width: 1240px;
    margin: 0 auto;
    position: relative;
  }

  .report-hero,
  .report-card,
  .report-form-card,
  .report-table-card,
  .report-warning {
    border: 1px solid var(--report-line);
    background: var(--report-card);
    box-shadow: var(--report-shadow);
    backdrop-filter: blur(26px);
  }

  .report-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 18px;
    align-items: stretch;
    border-radius: 8px;
    padding: 28px;
    overflow: hidden;
    position: relative;
    margin-bottom: 18px;
  }

  .report-hero::before {
    content: "";
    position: absolute;
    inset: -1px;
    pointer-events: none;
    background: linear-gradient(120deg, rgba(255, 255, 255, .82), rgba(224, 242, 254, .42) 38%, rgba(255, 247, 237, .52));
  }

  .report-hero-main,
  .report-hero-side {
    position: relative;
    z-index: 1;
  }

  .report-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-radius: 8px;
    padding: 7px 12px;
    border: 1px solid rgba(33, 207, 166, .24);
    background: rgba(33, 207, 166, .12);
    color: #087763;
    font-size: 12px;
    font-weight: 1000;
    text-transform: uppercase;
  }

  .report-pulse {
    width: 8px;
    height: 8px;
    border-radius: 8px;
    background: var(--report-mint);
    box-shadow: 0 0 0 7px rgba(33, 207, 166, .14);
  }

  .report-hero h1 {
    max-width: 780px;
    margin: 24px 0 12px;
    color: var(--report-ink);
    font-size: 58px;
    line-height: .98;
  }

  .report-hero h1 span {
    color: transparent;
    background: linear-gradient(96deg, #0891b2 0%, #10b981 43%, #f59e0b 72%, #ec4899 100%);
    -webkit-background-clip: text;
    background-clip: text;
  }

  .report-lead {
    max-width: 720px;
    margin: 0;
    color: var(--report-muted);
    font-size: 16px;
    line-height: 1.7;
  }

  .report-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .report-actions {
    margin-top: 22px;
  }

  .report-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 43px;
    border-radius: 999px;
    padding: 10px 17px;
    border: 1px solid rgba(17, 34, 51, .12);
    background: rgba(255, 255, 255, .76);
    color: var(--report-ink);
    text-decoration: none;
    font-size: 14px;
    font-weight: 950;
    cursor: pointer;
  }

  .report-button--primary {
    color: #fff;
    border-color: transparent;
    background: linear-gradient(135deg, #08a5c8, #21cfa6);
    box-shadow: 0 18px 42px rgba(33, 207, 166, .24);
  }

  .report-button:hover {
    transform: translateY(-2px);
    border-color: rgba(24, 191, 242, .34);
    box-shadow: 0 18px 44px rgba(24, 191, 242, .16);
  }

  .report-form-card {
    border-radius: 8px;
    padding: 12px;
    margin-bottom: 18px;
    border: 1px solid rgba(17, 34, 51, .09);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, .88), rgba(236, 254, 255, .72)),
      radial-gradient(circle at 100% 0%, rgba(33, 207, 166, .14), transparent 34%);
    box-shadow: 0 18px 50px rgba(17, 34, 51, .08);
  }

  .report-filter-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .report-filter-title {
    display: inline-flex;
    align-items: center;
    min-height: 42px;
    border-radius: 999px;
    padding: 8px 13px;
    color: #075985;
    background: rgba(224, 242, 254, .78);
    border: 1px solid rgba(24, 191, 242, .20);
    font-size: 12px;
    font-weight: 1000;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .report-filter-control {
    display: inline-flex;
    align-items: center;
    min-height: 42px;
    border-radius: 999px;
    border: 1px solid rgba(17, 34, 51, .10);
    background: rgba(255, 255, 255, .78);
    overflow: hidden;
    box-shadow: 0 10px 28px rgba(17, 34, 51, .05);
  }

  .report-filter-control label {
    display: inline-flex;
    align-items: center;
    align-self: stretch;
    padding: 0 10px 0 12px;
    border-right: 1px solid rgba(17, 34, 51, .08);
    background: rgba(248, 250, 252, .72);
    color: var(--report-muted);
    font-size: 11px;
    font-weight: 1000;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .report-filter-control select,
  .report-filter-control input {
    min-width: 0;
    height: 40px;
    border: 0;
    outline: 0;
    background: transparent;
    color: var(--report-ink);
    padding: 0 12px;
    font: inherit;
    font-size: 13px;
    font-weight: 900;
  }

  .report-filter-control select {
    max-width: 190px;
  }

  .report-filter-control input[type="date"] {
    width: 138px;
  }

  .report-filter-control.is-search {
    flex: 1 1 270px;
    min-width: 240px;
  }

  .report-filter-control.is-search input {
    width: 100%;
  }

  .report-form-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-left: auto;
  }

  .report-warning {
    border-radius: 8px;
    padding: 14px 16px;
    margin-bottom: 14px;
    color: #92400e;
    background: rgba(255, 209, 102, .20);
  }

  .report-warning p {
    margin: 0;
    font-size: 13px;
    line-height: 1.5;
  }

  .report-kpis {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 14px;
    margin-bottom: 18px;
  }

  .report-card {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    padding: 18px;
    background: rgba(255, 255, 255, .72);
    box-shadow: var(--report-card-shadow);
  }

  .report-card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 4px;
    background: linear-gradient(90deg, var(--report-cyan), var(--report-mint), var(--report-yellow), var(--report-pink));
  }

  .report-card:nth-child(1) { background: linear-gradient(135deg, rgba(224, 242, 254, .92), rgba(255, 255, 255, .94)); }
  .report-card:nth-child(2) { background: linear-gradient(135deg, rgba(255, 247, 237, .92), rgba(255, 255, 255, .94)); }
  .report-card:nth-child(3) { background: linear-gradient(135deg, rgba(220, 252, 231, .92), rgba(255, 255, 255, .94)); }
  .report-card:nth-child(4) { background: linear-gradient(135deg, rgba(254, 243, 199, .92), rgba(255, 255, 255, .94)); }
  .report-card:nth-child(5) { background: linear-gradient(135deg, rgba(237, 233, 254, .90), rgba(255, 255, 255, .94)); }
  .report-card:nth-child(6) { background: linear-gradient(135deg, rgba(255, 228, 230, .86), rgba(255, 255, 255, .94)); }

  .report-card strong {
    display: block;
    color: var(--report-ink);
    font-size: 25px;
    line-height: 1.12;
    overflow-wrap: anywhere;
  }

  .report-card span {
    display: block;
    margin-top: 8px;
    color: var(--report-muted);
    font-size: 12px;
    font-weight: 950;
    text-transform: uppercase;
  }

  .report-table-card {
    border-radius: 8px;
    padding: 20px;
    overflow: hidden;
  }

  .report-table-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 14px;
    margin-bottom: 14px;
  }

  .report-table-head h2 {
    margin: 0;
    color: var(--report-ink);
    font-size: 25px;
  }

  .report-table-head p {
    margin: 5px 0 0;
    color: var(--report-muted);
    font-size: 13px;
  }

  .report-table-wrap {
    overflow-x: auto;
  }

  .report-table {
    width: 100%;
    min-width: 760px;
    border-collapse: separate;
    border-spacing: 0 8px;
  }

  .report-table th {
    padding: 0 12px 6px;
    color: var(--report-muted);
    font-size: 12px;
    text-align: left;
    text-transform: uppercase;
  }

  .report-table td {
    padding: 13px 12px;
    background: rgba(255, 255, 255, .72);
    border-top: 1px solid rgba(17, 34, 51, .08);
    border-bottom: 1px solid rgba(17, 34, 51, .08);
    color: var(--report-ink);
    font-size: 14px;
  }

  .report-table tbody tr:nth-child(odd) td {
    background: rgba(240, 249, 255, .82);
  }

  .report-table tbody tr:nth-child(even) td {
    background: rgba(240, 253, 244, .78);
  }

  .report-table td:first-child {
    border-left: 1px solid rgba(17, 34, 51, .08);
    border-radius: 8px 0 0 8px;
    font-weight: 950;
  }

  .report-table td:last-child {
    border-right: 1px solid rgba(17, 34, 51, .08);
    border-radius: 0 8px 8px 0;
  }

  .report-money {
    font-weight: 950;
  }

  .report-money.is-profit {
    color: #0f766e;
  }

  .report-money.is-loss {
    color: #be123c;
  }

  .report-empty {
    border: 1px dashed rgba(17, 34, 51, .16);
    border-radius: 8px;
    padding: 24px;
    color: var(--report-muted);
    background: rgba(255, 255, 255, .58);
  }

  .report-insights {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin-bottom: 18px;
  }

  .report-insight {
    border-radius: 8px;
    padding: 16px;
    border: 1px solid rgba(17, 34, 51, .10);
    background: rgba(255, 255, 255, .76);
    box-shadow: var(--report-card-shadow);
  }

  .report-insight:nth-child(1) { background: linear-gradient(135deg, rgba(224, 242, 254, .92), rgba(255, 255, 255, .94)); }
  .report-insight:nth-child(2) { background: linear-gradient(135deg, rgba(255, 247, 237, .92), rgba(255, 255, 255, .94)); }
  .report-insight:nth-child(3) { background: linear-gradient(135deg, rgba(220, 252, 231, .92), rgba(255, 255, 255, .94)); }

  .report-insight span {
    display: block;
    color: var(--report-muted);
    font-size: 12px;
    font-weight: 950;
    text-transform: uppercase;
  }

  .report-insight strong {
    display: block;
    margin-top: 8px;
    color: var(--report-ink);
    font-size: 20px;
    overflow-wrap: anywhere;
  }

  .report-insight small {
    display: block;
    margin-top: 6px;
    color: var(--report-muted);
    font-weight: 800;
    line-height: 1.5;
  }

  .report-chart-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(320px, .65fr);
    gap: 14px;
    margin-bottom: 18px;
  }

  .report-chart-grid.is-even {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .report-chart-grid.is-three {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .report-chart-stack {
    display: grid;
    gap: 14px;
  }

  .report-chart-card {
    border: 1px solid rgba(17, 34, 51, .10);
    border-radius: 8px;
    padding: 18px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, .92), rgba(255, 255, 255, .72)),
      radial-gradient(circle at 92% 0%, rgba(24, 191, 242, .16), transparent 34%),
      radial-gradient(circle at 10% 100%, rgba(33, 207, 166, .12), transparent 32%);
    box-shadow: var(--report-shadow);
    backdrop-filter: blur(24px);
  }

  .report-chart-card h2,
  .report-chart-card h3 {
    margin: 0;
    color: var(--report-ink);
    font-size: 21px;
  }

  .report-chart-card p {
    margin: 6px 0 0;
    color: var(--report-muted);
    font-size: 13px;
    line-height: 1.5;
  }

  .report-chart-box {
    position: relative;
    min-height: 315px;
    margin-top: 14px;
    border: 1px solid rgba(17, 34, 51, .08);
    border-radius: 8px;
    background: linear-gradient(180deg, rgba(255, 255, 255, .62), rgba(248, 250, 252, .52));
    overflow: hidden;
  }

  .report-chart-box.is-compact {
    min-height: 230px;
  }

  .report-chart-box.is-mini {
    min-height: 205px;
  }

  .report-chart-box canvas {
    display: block;
    width: 100%;
    height: 100%;
    min-height: inherit;
  }

  .report-chart-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
  }

  .report-legend-item {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    border-radius: 999px;
    padding: 7px 10px;
    border: 1px solid rgba(17, 34, 51, .08);
    background: rgba(255, 255, 255, .74);
    color: var(--report-muted);
    font-size: 12px;
    font-weight: 900;
  }

  .report-legend-dot {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    background: var(--legend, #18bff2);
  }

  .report-chart-note {
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
    margin-top: 12px;
  }

  .report-chart-note span {
    border-radius: 8px;
    padding: 8px 10px;
    background: rgba(255, 255, 255, .72);
    color: var(--report-muted);
    font-size: 12px;
    font-weight: 900;
  }

  .report-ai-insight {
    margin-top: 14px;
    border: 1px solid rgba(24, 191, 242, .18);
    border-radius: 8px;
    padding: 13px;
    background:
      linear-gradient(135deg, rgba(236, 254, 255, .84), rgba(255, 255, 255, .86)),
      radial-gradient(circle at 100% 0%, rgba(139, 107, 255, .12), transparent 38%);
  }

  .report-ai-insight__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 8px;
  }

  .report-ai-insight__label {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    color: #075985;
    font-size: 12px;
    font-weight: 1000;
    text-transform: uppercase;
  }

  .report-ai-insight__label::before {
    content: "";
    width: 9px;
    height: 9px;
    border-radius: 999px;
    background: linear-gradient(135deg, #18bff2, #21cfa6);
    box-shadow: 0 0 0 5px rgba(24, 191, 242, .12);
  }

  .report-ai-insight__tone {
    border-radius: 999px;
    padding: 5px 9px;
    background: rgba(255, 255, 255, .74);
    color: var(--report-muted);
    font-size: 11px;
    font-weight: 950;
  }

  .report-ai-insight strong {
    display: block;
    color: var(--report-ink);
    font-size: 14px;
    line-height: 1.35;
  }

  .report-ai-insight ul {
    margin: 9px 0 0;
    padding-left: 18px;
    color: var(--report-muted);
    font-size: 12px;
    line-height: 1.55;
  }

  .report-ai-insight li + li {
    margin-top: 4px;
  }

  .report-ai-insight__action {
    margin-top: 9px;
    border-top: 1px solid rgba(17, 34, 51, .08);
    padding-top: 9px;
    color: #0f766e;
    font-size: 12px;
    font-weight: 950;
    line-height: 1.45;
  }

  .report-ai-insight.is-loading {
    border-color: rgba(17, 34, 51, .08);
    background: rgba(255, 255, 255, .66);
  }

  @media (max-width: 1080px) {
    .report-hero,
    .report-chart-grid {
      grid-template-columns: 1fr;
    }
    .report-chart-grid.is-even,
    .report-chart-grid.is-three {
      grid-template-columns: 1fr;
    }
    .report-field,
    .report-field.is-small {
      grid-column: span 3;
    }
    .report-kpis {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .report-insights {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .report-home {
      padding: 20px 12px 42px;
    }
    .report-hero {
      border-radius: 8px;
      padding: 22px;
    }
    .report-hero h1 {
      font-size: 42px;
    }
    .report-form-grid,
    .report-kpis {
      grid-template-columns: 1fr;
    }
    .report-filter-bar {
      align-items: stretch;
    }
    .report-filter-title,
    .report-filter-control,
    .report-filter-control.is-search,
    .report-form-actions {
      width: 100%;
      flex: 1 1 100%;
    }
    .report-filter-control select,
    .report-filter-control input,
    .report-filter-control input[type="date"] {
      width: 100%;
      max-width: none;
    }
    .report-form-actions {
      margin-left: 0;
    }
    .report-form-actions .report-button {
      flex: 1 1 0;
    }
    .report-table-head {
      display: block;
    }
  }
</style>

<main class="report-home">
  <div class="report-wrap">
    <section class="report-hero" aria-label="Thống kê tài chính">
      <div class="report-hero-main">
        <div class="report-chip"><span class="report-pulse"></span> Financial statistics</div>
        <h1>Thống kê <span>tài chính</span></h1>
        <p class="report-lead">Trực quan hóa doanh thu, chi phí, lợi nhuận và dòng tiền theo ngày, kỳ thống kê và phạm vi cơ sở.</p>
        <div class="report-actions">
          <a class="report-button report-button--primary" href="/accounting/revenue">Mở doanh thu</a>
          <a class="report-button" href="/accounting/expenses">Mở chi phí</a>
        </div>
      </div>
    </section>

    <section class="report-form-card">
      <form method="get" action="/accounting/reports">
        <div class="report-filter-bar" aria-label="Thanh lọc dữ liệu biểu đồ">
          <span class="report-filter-title">Lọc biểu đồ</span>

          <div class="report-filter-control">
            <label for="loai_baocao">Nhóm</label>
            <select id="loai_baocao" name="loai_baocao">
              <option value="doanhthu" <%= reportType === "doanhthu" ? "selected" : "" %>>Doanh thu</option>
              <option value="chiphi" <%= reportType === "chiphi" ? "selected" : "" %>>Chi phí</option>
              <option value="tonghop" <%= reportType === "tonghop" ? "selected" : "" %>>Tổng hợp</option>
            </select>
          </div>

          <div class="report-filter-control">
            <label for="ky_han">Kỳ</label>
            <select id="ky_han" name="ky_han">
              <option value="ngay" <%= filters.ky_han === "ngay" ? "selected" : "" %>>Ngày</option>
              <option value="thang" <%= filters.ky_han === "thang" ? "selected" : "" %>>Tháng</option>
              <option value="khoang" <%= filters.ky_han === "khoang" ? "selected" : "" %>>Khoảng</option>
            </select>
          </div>

          <div class="report-filter-control">
            <label for="tu_ngay">Từ</label>
            <input id="tu_ngay" type="date" name="tu_ngay" value="<%= filters.tu_ngay %>" />
          </div>

          <div class="report-filter-control">
            <label for="den_ngay">Đến</label>
            <input id="den_ngay" type="date" name="den_ngay" value="<%= filters.den_ngay %>" />
          </div>

          <div class="report-filter-control">
            <label for="hotel_id">Cơ sở</label>
            <select id="hotel_id" name="hotel_id">
              <option value="0" <%= Number(filters.hotel_id || 0) === 0 ? "selected" : "" %>>Toàn bộ cơ sở</option>
              <% hotelOptions.forEach((hotel) => { %>
                <option value="<%= hotel.id %>" <%= Number(filters.hotel_id || 0) === Number(hotel.id) ? "selected" : "" %>>
                  <%= hotel.tenKhachSan %><%= hotel.tinhThanh ? ` · ${hotel.tinhThanh}` : "" %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="report-filter-control">
            <label for="trang_thai">Trạng thái</label>
            <select id="trang_thai" name="trang_thai">
              <% statusOptions.forEach((option) => { %>
                <option value="<%= option.value %>" <%= filters.trang_thai === option.value ? "selected" : "" %>><%= option.label %></option>
              <% }) %>
            </select>
          </div>

          <div class="report-filter-control is-search">
            <label for="search">Tìm</label>
            <input id="search" name="search" value="<%= filters.search || "" %>" placeholder="Mã giao dịch, khách hàng, phiếu chi..." />
          </div>

          <div class="report-form-actions">
          <button class="report-button report-button--primary" type="submit">Cập nhật</button>
          <a class="report-button" href="/accounting/reports">Đặt lại</a>
          </div>
        </div>
      </form>
    </section>

    <% if (payload.warnings && payload.warnings.length) { %>
      <section class="report-warning">
        <% payload.warnings.forEach((warning) => { %>
          <p><%= warning %></p>
        <% }) %>
      </section>
    <% } %>

    <section class="report-chart-grid" aria-label="Biểu đồ phân tích tài chính">
      <article class="report-chart-card">
        <h2>Xu hướng tài chính theo kỳ</h2>
        <p>So sánh doanh thu ghi nhận, đã thu, chi phí, lợi nhuận và lợi nhuận đã thu.</p>
        <div class="report-chart-box">
          <canvas id="reportTrendChart" aria-label="Xu hướng tài chính"></canvas>
        </div>
        <div class="report-chart-legend">
          <span class="report-legend-item"><span class="report-legend-dot" style="--legend:#18bff2"></span>Doanh thu</span>
          <span class="report-legend-item"><span class="report-legend-dot" style="--legend:#21cfa6"></span>Đã thu</span>
          <span class="report-legend-item"><span class="report-legend-dot" style="--legend:#ffd166"></span>Chi phí</span>
          <span class="report-legend-item"><span class="report-legend-dot" style="--legend:#8b6bff"></span>Lợi nhuận</span>
          <span class="report-legend-item"><span class="report-legend-dot" style="--legend:#ff6fa3"></span>Lợi nhuận đã thu</span>
        </div>
      </article>

      <div class="report-chart-stack">
        <article class="report-chart-card">
          <h3>Cơ cấu dòng tiền</h3>
          <p>Tỷ trọng đã thu, còn phải thu, chi phí và lãi/lỗ.</p>
          <div class="report-chart-box is-compact">
            <canvas id="reportStructureChart" aria-label="Cơ cấu dòng tiền"></canvas>
          </div>
        </article>
        <article class="report-chart-card">
          <h3>Ngày nổi bật</h3>
          <p>Top ngày có doanh thu hoặc chi phí lớn trong kỳ lọc.</p>
          <div class="report-chart-box is-compact">
            <canvas id="reportDailyBarChart" aria-label="Top ngày tài chính"></canvas>
          </div>
          <div class="report-chart-note" id="reportChartNotes">
            <span>Đang tải dữ liệu biểu đồ</span>
          </div>
        </article>
      </div>
    </section>

    <section class="report-chart-grid is-even" aria-label="Biểu đồ cột và waterfall tài chính">
      <article class="report-chart-card">
        <h2>Cột chồng thu tiền</h2>
        <p>Đọc nhanh phần đã thu và còn phải thu theo từng ngày.</p>
        <div class="report-chart-box">
          <canvas id="reportStackedChart" aria-label="Cột chồng đã thu và còn phải thu"></canvas>
        </div>
        <div class="report-chart-legend">
          <span class="report-legend-item"><span class="report-legend-dot" style="--legend:#21cfa6"></span>Đã thu</span>
          <span class="report-legend-item"><span class="report-legend-dot" style="--legend:#ff6fa3"></span>Còn phải thu</span>
        </div>
      </article>
      <article class="report-chart-card">
        <h2>Waterfall lợi nhuận</h2>
        <p>Từ doanh thu ghi nhận, trừ chi phí và ra kết quả lợi nhuận.</p>
        <div class="report-chart-box">
          <canvas id="reportWaterfallChart" aria-label="Waterfall lợi nhuận"></canvas>
        </div>
      </article>
    </section>

    <section class="report-chart-grid is-three" aria-label="Biểu đồ sức khỏe tài chính">
      <article class="report-chart-card">
        <h3>Gauge đã thu</h3>
        <p>Tỷ lệ doanh thu đã thu trong kỳ.</p>
        <div class="report-chart-box is-mini">
          <canvas id="reportGaugeChart" aria-label="Gauge tỷ lệ đã thu"></canvas>
        </div>
      </article>
      <article class="report-chart-card">
        <h3>Radar sức khỏe</h3>
        <p>Cân bằng thu tiền, lợi nhuận, kiểm soát chi và hoạt động.</p>
        <div class="report-chart-box is-mini">
          <canvas id="reportRadarChart" aria-label="Radar sức khỏe tài chính"></canvas>
        </div>
      </article>
      <article class="report-chart-card">
        <h3>Heatmap cường độ</h3>
        <p>Màu đậm hơn là ngày có biến động tài chính mạnh hơn.</p>
        <div class="report-chart-box is-mini">
          <canvas id="reportHeatmapChart" aria-label="Heatmap cường độ tài chính"></canvas>
        </div>
      </article>
    </section>

    <section class="report-chart-grid is-even" aria-label="Biểu đồ phân tán và vùng">
      <article class="report-chart-card">
        <h2>Scatter thu - chi</h2>
        <p>Mỗi điểm là một ngày, trục ngang doanh thu và trục dọc chi phí.</p>
        <div class="report-chart-box">
          <canvas id="reportScatterChart" aria-label="Scatter doanh thu chi phí"></canvas>
        </div>
      </article>
      <article class="report-chart-card">
        <h2>Area lợi nhuận đã thu</h2>
        <p>Vùng biểu diễn lợi nhuận thực thu sau khi trừ chi phí.</p>
        <div class="report-chart-box">
          <canvas id="reportAreaChart" aria-label="Area lợi nhuận đã thu"></canvas>
        </div>
      </article>
    </section>

    <section class="report-chart-grid is-even" aria-label="Biểu đồ cột dọc và tròn tài chính">
      <article class="report-chart-card">
        <h2>Cột dọc so sánh</h2>
        <p>So sánh doanh thu, chi phí và lợi nhuận thực thu theo từng ngày.</p>
        <div class="report-chart-box">
          <canvas id="reportColumnChart" aria-label="Biểu đồ cột dọc tài chính"></canvas>
        </div>
        <div class="report-chart-legend">
          <span class="report-legend-item"><span class="report-legend-dot" style="--legend:#18bff2"></span>Doanh thu</span>
          <span class="report-legend-item"><span class="report-legend-dot" style="--legend:#ffd166"></span>Chi phí</span>
          <span class="report-legend-item"><span class="report-legend-dot" style="--legend:#21cfa6"></span>LN thực thu</span>
        </div>
      </article>
      <article class="report-chart-card">
        <h2>Pie cơ cấu</h2>
        <p>Biểu đồ tròn đầy cho tỷ trọng các nhóm tiền trong kỳ.</p>
        <div class="report-chart-box">
          <canvas id="reportPieChart" aria-label="Biểu đồ tròn cơ cấu tài chính"></canvas>
        </div>
      </article>
    </section>

    <section class="report-chart-grid is-three" aria-label="Biểu đồ điểm và cực tài chính">
      <article class="report-chart-card">
        <h3>Line có chấm</h3>
        <p>Tỷ lệ đã thu theo ngày, mỗi chấm là một mốc dữ liệu.</p>
        <div class="report-chart-box is-mini">
          <canvas id="reportDotLineChart" aria-label="Biểu đồ line có chấm tỷ lệ đã thu"></canvas>
        </div>
      </article>
      <article class="report-chart-card">
        <h3>Lollipop ngày nổi bật</h3>
        <p>Nhấn mạnh ngày có tổng biến động thu chi lớn nhất.</p>
        <div class="report-chart-box is-mini">
          <canvas id="reportLollipopChart" aria-label="Biểu đồ lollipop ngày nổi bật"></canvas>
        </div>
      </article>
      <article class="report-chart-card">
        <h3>Polar rose</h3>
        <p>Cánh tròn biểu diễn doanh thu theo các ngày trong kỳ.</p>
        <div class="report-chart-box is-mini">
          <canvas id="reportPolarChart" aria-label="Biểu đồ polar rose doanh thu"></canvas>
        </div>
      </article>
    </section>
  </div>
</main>

<script>
  (() => {
    const data = <%- JSON.stringify(payload.chartPayload || {}).replace(/</g, "\\u003c") %>;
    const chartMode = data.mode || "tonghop";
    const colors = ["#18bff2", "#21cfa6", "#ffd166", "#8b6bff", "#ff6fa3", "#f97316"];
    const money = (value) => `${Number(value || 0).toLocaleString("vi-VN")} đ`;
    const shortMoney = (value) => {
      const amount = Number(value || 0);
      if (Math.abs(amount) >= 1000000000) return `${(amount / 1000000000).toLocaleString("vi-VN", { maximumFractionDigits: 1 })} tỷ`;
      if (Math.abs(amount) >= 1000000) return `${(amount / 1000000).toLocaleString("vi-VN", { maximumFractionDigits: 1 })} tr`;
      if (Math.abs(amount) >= 1000) return `${(amount / 1000).toLocaleString("vi-VN", { maximumFractionDigits: 0 })}k`;
      return amount.toLocaleString("vi-VN");
    };
    const aiChartTitles = {
      reportTrendChart: "Xu hướng tài chính",
      reportStructureChart: "Cơ cấu dòng tiền",
      reportDailyBarChart: "Ngày nổi bật",
      reportStackedChart: "Cột chồng thu tiền",
      reportWaterfallChart: "Waterfall lợi nhuận",
      reportGaugeChart: "Gauge đã thu",
      reportRadarChart: "Radar sức khỏe",
      reportHeatmapChart: "Heatmap cường độ",
      reportScatterChart: "Scatter thu - chi",
      reportAreaChart: "Area lợi nhuận đã thu",
      reportColumnChart: "Cột dọc so sánh",
      reportPieChart: "Pie cơ cấu",
      reportDotLineChart: "Line có chấm",
      reportLollipopChart: "Lollipop ngày nổi bật",
      reportPolarChart: "Polar rose"
    };
    const escapeHtml = (value) => String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
    const setup = (id) => {
      const canvas = document.getElementById(id);
      if (!canvas) return null;
      const parent = canvas.parentElement;
      const width = Math.max(parent.clientWidth, 280);
      const height = Math.max(parent.clientHeight, 220);
      const ratio = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = Math.floor(width * ratio);
      canvas.height = Math.floor(height * ratio);
      canvas.style.width = `${width}px`;
      canvas.style.height = `${height}px`;
      const ctx = canvas.getContext("2d");
      ctx.setTransform(ratio, 0, 0, ratio, 0, 0);
      ctx.clearRect(0, 0, width, height);
      return { canvas, ctx, width, height };
    };
    const wireChartFilters = () => {
      const form = document.querySelector(".report-form-card form");
      if (!form) return;
      const submitButton = form.querySelector('button[type="submit"]');
      const submit = () => {
        if (submitButton) {
          submitButton.textContent = "Đang lọc...";
          submitButton.disabled = true;
        }
        form.requestSubmit();
      };

      form.querySelectorAll("select, input[type='date']").forEach((control) => {
        control.addEventListener("change", submit);
      });

      const search = form.querySelector("input[name='search']");
      if (search) {
        search.addEventListener("keydown", (event) => {
          if (event.key === "Enter") {
            event.preventDefault();
            submit();
          }
        });
      }
    };
    const text = (ctx, value, x, y, size = 12, color = "#667085", weight = 800, align = "left") => {
      ctx.fillStyle = color;
      ctx.font = `${weight} ${size}px system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif`;
      ctx.textAlign = align;
      ctx.textBaseline = "middle";
      ctx.fillText(String(value), x, y);
    };
    const rounded = (ctx, x, y, width, height, radius) => {
      const r = Math.min(radius, width / 2, height / 2);
      ctx.beginPath();
      ctx.moveTo(x + r, y);
      ctx.arcTo(x + width, y, x + width, y + height, r);
      ctx.arcTo(x + width, y + height, x, y + height, r);
      ctx.arcTo(x, y + height, x, y, r);
      ctx.arcTo(x, y, x + width, y, r);
      ctx.closePath();
    };
    const empty = (ctx, width, height) => {
      rounded(ctx, 18, 18, width - 36, height - 36, 8);
      ctx.fillStyle = "rgba(255,255,255,.66)";
      ctx.fill();
      ctx.strokeStyle = "rgba(17,34,51,.12)";
      ctx.stroke();
      text(ctx, "Chưa có dữ liệu biểu đồ", width / 2, height / 2, 13, "#667085", 900, "center");
    };
    const niceMax = (value) => {
      const raw = Math.max(1, Number(value || 1));
      const exponent = Math.floor(Math.log10(raw));
      const base = Math.pow(10, exponent);
      const normalized = raw / base;
      return (normalized <= 2 ? 2 : normalized <= 5 ? 5 : 10) * base;
    };
    const smoothLine = (ctx, points) => {
      if (!points.length) return;
      ctx.beginPath();
      ctx.moveTo(points[0].x, points[0].y);
      for (let i = 1; i < points.length; i += 1) {
        const previous = points[i - 1];
        const current = points[i];
        ctx.quadraticCurveTo(previous.x, previous.y, (previous.x + current.x) / 2, (previous.y + current.y) / 2);
      }
      const last = points[points.length - 1];
      ctx.lineTo(last.x, last.y);
    };
    const drawTrend = () => {
      const chart = setup("reportTrendChart");
      if (!chart) return;
      const { ctx, width, height } = chart;
      const rows = Array.isArray(data.trend) ? data.trend : [];
      if (!rows.length) return empty(ctx, width, height);
      const series = chartMode === "doanhthu"
        ? [
            ["revenue", "Doanh thu", "#18bff2"],
            ["paidRevenue", "Đã thu", "#21cfa6"],
            ["outstandingRevenue", "Còn phải thu", "#ff6fa3"]
          ]
        : chartMode === "chiphi"
          ? [
              ["expense", "Chi phí", "#ffd166"]
            ]
          : [
              ["revenue", "Doanh thu", "#18bff2"],
              ["paidRevenue", "Đã thu", "#21cfa6"],
              ["expense", "Chi phí", "#ffd166"],
              ["profit", "Lợi nhuận", "#8b6bff"],
              ["realizedProfit", "LN đã thu", "#ff6fa3"]
            ];
      const pad = { left: 74, right: 24, top: 28, bottom: 44 };
      const plotW = width - pad.left - pad.right;
      const plotH = height - pad.top - pad.bottom;
      const values = rows.flatMap((row) => series.map(([key]) => Math.abs(Number(row[key] || 0))));
      const max = niceMax(Math.max(1, ...values));
      const zeroY = pad.top + plotH / 2;
      const y = (value) => zeroY - (Number(value || 0) / max) * (plotH / 2);
      const x = (index) => pad.left + (rows.length === 1 ? plotW / 2 : (index / (rows.length - 1)) * plotW);
      rounded(ctx, pad.left - 10, pad.top - 10, plotW + 20, plotH + 20, 8);
      ctx.fillStyle = "rgba(255,255,255,.56)";
      ctx.fill();
      ctx.strokeStyle = "rgba(17,34,51,.08)";
      ctx.lineWidth = 1;
      for (let i = -2; i <= 2; i += 1) {
        const lineY = zeroY - (i / 2) * (plotH / 2);
        ctx.beginPath();
        ctx.moveTo(pad.left, lineY);
        ctx.lineTo(pad.left + plotW, lineY);
        ctx.stroke();
        text(ctx, shortMoney((max / 2) * i), pad.left - 12, lineY, 10, "#667085", 800, "right");
      }
      rows.forEach((row, index) => {
        if (index % Math.ceil(rows.length / 6) === 0 || index === rows.length - 1) {
          text(ctx, row.label, x(index), height - 20, 11, "#667085", 800, "center");
        }
      });
      series.forEach(([key, label, color], seriesIndex) => {
        const points = rows.map((row, index) => ({ x: x(index), y: y(row[key]) }));
        ctx.strokeStyle = color;
        ctx.lineWidth = seriesIndex === 0 ? 4 : 3;
        ctx.lineJoin = "round";
        ctx.lineCap = "round";
        ctx.shadowColor = `${color}44`;
        ctx.shadowBlur = 10;
        smoothLine(ctx, points);
        ctx.stroke();
        ctx.shadowBlur = 0;
        const last = points[points.length - 1];
        if (last) text(ctx, label, Math.min(width - 72, last.x + 8), last.y, 11, color, 950);
      });
    };
    const drawDonut = () => {
      const chart = setup("reportStructureChart");
      if (!chart) return;
      const { ctx, width, height } = chart;
      const rows = (Array.isArray(data.structure) ? data.structure : []).filter((row) => Number(row.value || 0) > 0);
      if (!rows.length) return empty(ctx, width, height);
      const total = rows.reduce((sum, row) => sum + Number(row.value || 0), 0);
      const cx = width < 420 ? width / 2 : Math.min(width * .34, 126);
      const cy = height / 2;
      const radius = Math.min(width * .22, height * .34, 78);
      const inner = radius * .62;
      ctx.lineWidth = radius - inner;
      ctx.lineCap = "round";
      let start = -Math.PI / 2;
      rows.forEach((row, index) => {
        const share = Number(row.value || 0) / total;
        const end = start + share * Math.PI * 2;
        ctx.beginPath();
        ctx.arc(cx, cy, (radius + inner) / 2, start + .025, end - .025);
        ctx.strokeStyle = colors[index % colors.length];
        ctx.stroke();
        start = end;
      });
      text(ctx, "Tổng", cx, cy - 10, 11, "#667085", 900, "center");
      text(ctx, shortMoney(total), cx, cy + 12, 16, "#112233", 1000, "center");
      const legendX = width < 420 ? 24 : cx + radius + 30;
      const legendY = width < 420 ? height - rows.length * 25 - 10 : Math.max(34, cy - rows.length * 14);
      rows.forEach((row, index) => {
        const y = legendY + index * 28;
        ctx.fillStyle = colors[index % colors.length];
        ctx.beginPath();
        ctx.arc(legendX, y, 5, 0, Math.PI * 2);
        ctx.fill();
        text(ctx, row.label, legendX + 14, y - 5, 12, "#112233", 900);
        text(ctx, `${Math.round((Number(row.value || 0) / total) * 100)}% · ${shortMoney(row.value)}`, legendX + 14, y + 10, 11);
      });
    };
    const drawBars = () => {
      const chart = setup("reportDailyBarChart");
      if (!chart) return;
      const { ctx, width, height } = chart;
      const rows = Array.isArray(data.dailyBars) ? data.dailyBars : [];
      if (!rows.length) return empty(ctx, width, height);
      const pad = { left: 70, right: 34, top: 24, bottom: 28 };
      const max = niceMax(Math.max(1, ...rows.flatMap((row) => [row.revenue, row.expense])));
      const rowH = Math.min(34, (height - pad.top - pad.bottom) / rows.length);
      rows.forEach((row, index) => {
        const y = pad.top + index * rowH + 5;
        const trackW = width - pad.left - pad.right;
        text(ctx, row.label, pad.left - 12, y + rowH / 2 - 2, 11, "#112233", 900, "right");
        rounded(ctx, pad.left, y, trackW, 10, 999);
        ctx.fillStyle = "rgba(17,34,51,.07)";
        ctx.fill();
        rounded(ctx, pad.left, y, Math.max(0, trackW * Number(row.revenue || 0) / max), 10, 999);
        ctx.fillStyle = "#18bff2";
        ctx.fill();
        rounded(ctx, pad.left, y + 14, Math.max(0, trackW * Number(row.expense || 0) / max), 10, 999);
        ctx.fillStyle = "#ffd166";
        ctx.fill();
        text(ctx, shortMoney(Math.max(Number(row.revenue || 0), Number(row.expense || 0))), width - pad.right, y + rowH / 2 - 2, 11, "#667085", 850, "right");
      });
      const note = document.getElementById("reportChartNotes");
      if (note) {
        note.innerHTML = chartMode === "doanhthu"
          ? `<span>Doanh thu màu xanh</span><span>Đã thu nằm trong biểu đồ xu hướng</span>`
          : chartMode === "chiphi"
            ? `<span>Chi phí màu vàng</span><span>Đang lọc theo phiếu chi</span>`
            : `<span>Doanh thu màu xanh</span><span>Chi phí màu vàng</span>`;
      }
    };
    const drawStackedBars = () => {
      const chart = setup("reportStackedChart");
      if (!chart) return;
      const { ctx, width, height } = chart;
      const rows = Array.isArray(data.trend) ? data.trend.filter((row) => Number(row.revenue || 0) > 0).slice(-10) : [];
      if (!rows.length) return empty(ctx, width, height);
      const pad = { left: 62, right: 22, top: 30, bottom: 44 };
      const plotW = width - pad.left - pad.right;
      const plotH = height - pad.top - pad.bottom;
      const max = niceMax(Math.max(1, ...rows.map((row) => Number(row.revenue || 0))));
      const gap = Math.max(8, plotW / rows.length * .18);
      const barW = Math.max(16, (plotW - gap * (rows.length - 1)) / rows.length);
      text(ctx, shortMoney(max), pad.left - 12, pad.top, 10, "#667085", 800, "right");
      text(ctx, "0", pad.left - 12, pad.top + plotH, 10, "#667085", 800, "right");
      ctx.strokeStyle = "rgba(17,34,51,.1)";
      ctx.beginPath();
      ctx.moveTo(pad.left, pad.top);
      ctx.lineTo(pad.left, pad.top + plotH);
      ctx.lineTo(pad.left + plotW, pad.top + plotH);
      ctx.stroke();
      rows.forEach((row, index) => {
        const x = pad.left + index * (barW + gap);
        const total = Math.max(0, Number(row.revenue || 0));
        const paid = Math.min(total, Math.max(0, Number(row.paidRevenue || 0)));
        const outstanding = Math.max(0, total - paid);
        const totalH = Math.max(2, total / max * plotH);
        const paidH = total ? paid / total * totalH : 0;
        const outstandingH = total ? outstanding / total * totalH : 0;
        const baseY = pad.top + plotH;
        rounded(ctx, x, baseY - totalH, barW, totalH, 8);
        ctx.fillStyle = "rgba(17,34,51,.07)";
        ctx.fill();
        rounded(ctx, x, baseY - paidH, barW, paidH, 8);
        ctx.fillStyle = "#21cfa6";
        ctx.fill();
        if (outstandingH > 1) {
          rounded(ctx, x, baseY - paidH - outstandingH, barW, outstandingH + 2, 8);
          ctx.fillStyle = "#ff6fa3";
          ctx.fill();
        }
        if (index % Math.ceil(rows.length / 5) === 0 || index === rows.length - 1) {
          text(ctx, row.label, x + barW / 2, height - 20, 10, "#667085", 850, "center");
        }
      });
    };
