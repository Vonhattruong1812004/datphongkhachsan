      ctx.stroke();
      ctx.beginPath();
      rows.forEach((row, index) => {
        const angle = -Math.PI / 2 + (index / rows.length) * Math.PI * 2;
        const score = Math.max(0, Math.min(100, Number(row.score ?? row.value ?? 0))) / 100;
        const x = cx + Math.cos(angle) * radius * score;
        const y = cy + Math.sin(angle) * radius * score;
        if (index === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      });
      ctx.closePath();
      ctx.fillStyle = "rgba(24,191,242,.2)";
      ctx.strokeStyle = "#18bff2";
      ctx.lineWidth = 3;
      ctx.fill();
      ctx.stroke();
