<%- include("../partials/head") %>
<%- include("../partials/header") %>
<%
  const data = payload || {};
  const netPositive = Number(data.netCashflow || 0) >= 0;
  const overdueDebtCount = Number(data.overdueDebtCount || 0);
  const pendingRefundCount = Number(data.pendingRefundCount || 0);
  const urgentCount = overdueDebtCount + pendingRefundCount;
  const navItems = [
    {
      href: "/accounting/reports",
      code: "01",
      title: "Thống kê tài chính",
      note: "Trực quan hóa doanh thu, chi phí, lợi nhuận và dòng tiền theo kỳ.",
      tone: "cyan"
    },
    {
      href: "/accounting/revenue",
      code: "02",
      title: "Quản lý doanh thu",
      note: "Theo dõi giao dịch thu, khoản đã thu, còn phải thu và công nợ khách hàng.",
      tone: "mint"
    },
    {
      href: "/accounting/expenses",
      code: "03",
      title: "Quản lý chi phí",
      note: "Quản lý phiếu chi, nhóm chi phí, trạng thái duyệt và chứng từ.",
      tone: "sun"
    },
    {
      href: "/accounting/refunds",
      code: "04",
      title: "Xử lý hoàn tiền",
      note: "Nhận yêu cầu đã được quản lý duyệt, hiện QR hoàn tiền, xác nhận chứng từ và ghi phiếu chi.",
      tone: "pink"
    }
  ];
  const kpis = [
    { label: `Doanh thu tháng ${data.periodLabel || ""}`, value: data.monthlyRevenueFormatted || "0 đ", note: `${data.revenueTransactionCount || 0} giao dịch đã thanh toán` },
    { label: "Chi phí tháng", value: data.monthlyExpenseFormatted || "0 đ", note: `${data.expenseVoucherCount || 0} phiếu chi còn hiệu lực` },
    { label: "Dòng tiền ròng", value: data.netCashflowFormatted || "0 đ", note: `Trạng thái: ${netPositive ? "Dương" : "Âm"}` },
    { label: "Công nợ cần thu", value: data.outstandingDebtFormatted || "0 đ", note: `${overdueDebtCount} khoản quá hạn` },
    { label: "Hoàn tiền chờ chi", value: data.pendingRefundAmountFormatted || "0 đ", note: `${pendingRefundCount} yêu cầu chờ xử lý` },
    { label: "Hóa đơn đã lập", value: data.totalInvoices || 0, note: "Trong kỳ hiện tại" }
  ];
%>

<style>
  .manager-dash{
    --mgr-ink:#102033;
    --mgr-muted:#64748b;
    --mgr-line:rgba(16,32,51,.11);
    --mgr-card:rgba(255,255,255,.78);
    --mgr-cyan:#0ea5e9;
    --mgr-mint:#10b981;
    --mgr-green:#65a30d;
    --mgr-sun:#f59e0b;
    --mgr-pink:#ec4899;
    --mgr-violet:#7c3aed;
    --mgr-shadow:0 28px 86px rgba(15,23,42,.16);
    min-height:calc(100vh - 84px);
    position:relative;
    isolation:isolate;
    overflow:hidden;
    padding:34px 18px 58px;
    color:var(--mgr-ink);
    background:
      radial-gradient(circle at 8% 12%, rgba(245,158,11,.26), transparent 27%),
      radial-gradient(circle at 82% 8%, rgba(14,165,233,.24), transparent 30%),
      radial-gradient(circle at 48% 104%, rgba(16,185,129,.22), transparent 39%),
      radial-gradient(circle at 18% 82%, rgba(236,72,153,.16), transparent 27%),
      linear-gradient(135deg,#fffdf7 0%,#effaff 42%,#f5fff7 100%);
  }
  .manager-dash::before,
  .manager-dash::after{content:"";position:absolute;pointer-events:none;z-index:-1}
  .manager-dash::before{
    width:640px;height:640px;right:-230px;top:-310px;border-radius:46% 54% 40% 60%;
    opacity:.48;background:conic-gradient(from 140deg,rgba(245,158,11,.42),rgba(14,165,233,.32),rgba(16,185,129,.30),rgba(236,72,153,.22),rgba(245,158,11,.42));
    animation:mgr-blob 16s ease-in-out infinite alternate;
  }
  .manager-dash::after{
    width:520px;height:520px;left:-240px;bottom:-270px;border-radius:999px;
    opacity:.36;background:conic-gradient(from 20deg,rgba(14,165,233,.30),rgba(16,185,129,.28),rgba(245,158,11,.26),rgba(124,58,237,.20),rgba(14,165,233,.30));
    animation:mgr-orbit 14s ease-in-out infinite alternate;
  }
  .manager-shell{max-width:1240px;margin:0 auto;position:relative}
  .manager-hero{display:grid;grid-template-columns:minmax(0,1.05fr) 360px;gap:22px;align-items:stretch;margin-bottom:20px}
  .manager-hero-main,
  .manager-visual-card,
  .manager-action,
  .manager-live-panel,
  .manager-alert{border:1px solid var(--mgr-line);background:var(--mgr-card);box-shadow:var(--mgr-shadow);backdrop-filter:blur(26px)}
  .manager-hero-main{position:relative;overflow:hidden;min-height:300px;border-radius:36px;padding:36px}
  .manager-hero-main::before{
    content:"";position:absolute;inset:-1px;pointer-events:none;
    background:
      linear-gradient(120deg,rgba(255,255,255,.74),transparent 28%),
      radial-gradient(circle at 86% 18%,rgba(245,158,11,.22),transparent 30%),
      radial-gradient(circle at 18% 88%,rgba(14,165,233,.18),transparent 28%);
  }
  .manager-chip{position:relative;z-index:1;display:inline-flex;align-items:center;gap:8px;border-radius:999px;padding:7px 12px;border:1px solid rgba(245,158,11,.24);background:rgba(245,158,11,.12);color:#92400e;font-size:12px;font-weight:1000;letter-spacing:.08em;text-transform:uppercase}
  .manager-dot{width:8px;height:8px;border-radius:999px;background:var(--mgr-sun);box-shadow:0 0 0 7px rgba(245,158,11,.16);animation:dash-pulse 1.8s ease-in-out infinite}
  .manager-hero h1{position:relative;z-index:1;max-width:760px;margin:26px 0 14px;color:var(--mgr-ink);font-size:clamp(42px,6.2vw,76px);line-height:.90;letter-spacing:0}
  .manager-hero h1 span{color:transparent;background:linear-gradient(96deg,#0ea5e9 0%,#10b981 38%,#f59e0b 70%,#ec4899 100%);-webkit-background-clip:text;background-clip:text}
  .manager-lead{position:relative;z-index:1;max-width:690px;margin:0;color:var(--mgr-muted);font-size:16px;line-height:1.72}
  .manager-actions{position:relative;z-index:1;display:flex;flex-wrap:wrap;gap:10px;margin-top:28px}
  .manager-button{display:inline-flex;align-items:center;justify-content:center;min-height:45px;border-radius:999px;padding:10px 18px;border:1px solid rgba(16,32,51,.12);background:rgba(255,255,255,.76);color:var(--mgr-ink);text-decoration:none;font-size:14px;font-weight:950;transition:transform .18s ease,box-shadow .18s ease,border-color .18s ease}
  .manager-button:hover{transform:translateY(-2px);border-color:rgba(14,165,233,.36);box-shadow:0 18px 44px rgba(14,165,233,.16)}
  .manager-button--primary{color:#fff;border-color:transparent;background:linear-gradient(135deg,#0ea5e9,#10b981 52%,#f59e0b);box-shadow:0 18px 42px rgba(14,165,233,.20)}
  .manager-visual-card{position:relative;overflow:hidden;border-radius:36px;min-height:300px;background:linear-gradient(160deg,rgba(255,255,255,.90),rgba(255,247,237,.68))}
  .manager-visual-scene{position:absolute;inset:24px;border-radius:32px;overflow:hidden;background:linear-gradient(145deg,rgba(8,47,73,.90),rgba(120,53,15,.72))}
  .manager-visual-scene::before{content:"";position:absolute;inset:24px;border:1px dashed rgba(226,232,240,.26);border-radius:999px;animation:dash-spin 22s linear infinite}
  .manager-visual-core{position:absolute;width:150px;height:150px;left:calc(50% - 75px);top:calc(50% - 75px);border-radius:42px;background:linear-gradient(135deg,#0ea5e9,#10b981 48%,#f59e0b);box-shadow:0 24px 70px rgba(245,158,11,.24);transform:rotate(14deg);animation:dash-breathe 4.5s ease-in-out infinite}
  .manager-visual-chip{position:absolute;z-index:2;display:inline-flex;align-items:center;gap:8px;border-radius:999px;padding:9px 12px;color:#eff6ff;background:rgba(15,23,42,.50);border:1px solid rgba(255,255,255,.18);backdrop-filter:blur(14px);font-size:12px;font-weight:1000}
  .manager-visual-chip::before{content:"";width:8px;height:8px;border-radius:999px;background:#facc15;box-shadow:0 0 0 6px rgba(250,204,21,.14)}
  .manager-visual-chip:nth-child(2){left:26px;top:34px;animation:dash-drift-a 5.8s ease-in-out infinite}
  .manager-visual-chip:nth-child(3){right:28px;top:82px;animation:dash-drift-b 6.2s ease-in-out infinite}
  .manager-visual-chip:nth-child(4){left:40px;bottom:54px;animation:dash-drift-b 5.8s ease-in-out infinite reverse}
  .manager-visual-chip:nth-child(5){right:34px;bottom:42px;animation:dash-drift-a 6.4s ease-in-out infinite reverse}
  .manager-visual-wave{position:absolute;left:-20%;right:-20%;bottom:-18px;height:74px;border-radius:50% 50% 0 0;background:linear-gradient(180deg,rgba(125,211,252,.32),rgba(20,184,166,.24));animation:dash-wave-sway 7s ease-in-out infinite}
  .manager-section{margin-top:22px}
  .manager-section-head{display:flex;align-items:flex-end;justify-content:space-between;gap:14px;margin-bottom:14px}
  .manager-section-head h2{margin:0;color:var(--mgr-ink);font-size:25px;letter-spacing:0}
  .manager-section-head p{margin:4px 0 0;color:var(--mgr-muted);font-size:13px}
  .manager-action-grid{display:grid;grid-template-columns:repeat(12,1fr);gap:16px}
  .manager-action{--mgr-action:#0ea5e9;--mgr-glow:rgba(14,165,233,.24);position:relative;overflow:hidden;min-height:222px;grid-column:span 3;border-radius:30px;padding:22px;text-decoration:none;color:var(--mgr-ink);background:linear-gradient(180deg,rgba(255,255,255,.94),rgba(255,255,255,.72)),radial-gradient(circle at 100% 0%,var(--mgr-glow),transparent 35%);transition:transform .2s ease,box-shadow .2s ease,border-color .2s ease}
  .manager-action[data-tone="mint"]{--mgr-action:#10b981;--mgr-glow:rgba(16,185,129,.24)}
  .manager-action[data-tone="sun"]{--mgr-action:#f59e0b;--mgr-glow:rgba(245,158,11,.24)}
  .manager-action[data-tone="violet"]{--mgr-action:#7c3aed;--mgr-glow:rgba(124,58,237,.22)}
  .manager-action[data-tone="green"]{--mgr-action:#65a30d;--mgr-glow:rgba(101,163,13,.22)}
  .manager-action[data-tone="pink"]{--mgr-action:#ec4899;--mgr-glow:rgba(236,72,153,.22)}
  .manager-action:hover{transform:translateY(-6px);border-color:var(--mgr-action);box-shadow:0 34px 90px rgba(15,23,42,.22)}
  .manager-action::before{content:"";position:absolute;width:56px;height:56px;right:26px;top:24px;border-radius:20px;background:linear-gradient(135deg,var(--mgr-action),rgba(255,255,255,.34));box-shadow:0 18px 42px var(--mgr-glow)}
  .manager-action::after{content:"";position:absolute;left:22px;right:22px;bottom:18px;height:5px;border-radius:999px;background:linear-gradient(90deg,var(--mgr-action),transparent);opacity:.80}
  .manager-code{display:inline-flex;border-radius:999px;padding:6px 10px;background:rgba(255,255,255,.82);border:1px solid rgba(16,32,51,.09);color:var(--mgr-action);font-size:12px;font-weight:1000;letter-spacing:.06em}
  .manager-action h3{position:relative;z-index:1;margin:56px 0 10px;color:var(--mgr-ink);font-size:27px;line-height:1.04;letter-spacing:0}
  .manager-action p{position:relative;z-index:1;max-width:520px;margin:0;color:#5f6b7d;font-size:14px;line-height:1.58;font-weight:720}
  .manager-open{position:absolute;z-index:1;right:22px;bottom:28px;color:var(--mgr-action);font-size:13px;font-weight:1000}
  .manager-live-grid{display:grid;grid-template-columns:1fr;gap:16px}
  .manager-live-panel{border-radius:30px;padding:20px;background:rgba(255,255,255,.72)}
  .dash-grid{display:grid;grid-template-columns:repeat(12,1fr);gap:14px}
  .dash-stat{grid-column:span 4;border:1px solid rgba(16,32,51,.10);border-radius:26px;padding:20px;background:rgba(255,255,255,.76);box-shadow:0 18px 44px rgba(15,23,42,.09)}
  .dash-stat strong{display:block;color:var(--mgr-ink);font-size:30px;line-height:1;letter-spacing:0;overflow-wrap:anywhere}
  .dash-stat h3{margin:12px 0 6px;color:var(--mgr-ink);font-size:17px}
  .dash-stat p{margin:0;color:var(--mgr-muted);font-size:13px;line-height:1.5}
  .manager-chart-grid{display:grid;grid-template-columns:minmax(0,1.42fr) minmax(320px,.58fr);gap:16px}
  .manager-chart-stack{display:grid;gap:16px}
  .manager-chart-card{
    position:relative;overflow:hidden;border:1px solid rgba(16,32,51,.10);border-radius:30px;padding:20px;
    background:
      linear-gradient(180deg,rgba(255,255,255,.94),rgba(255,255,255,.74)),
      radial-gradient(circle at 90% 0%,rgba(14,165,233,.18),transparent 34%),
      radial-gradient(circle at 10% 100%,rgba(16,185,129,.13),transparent 32%);
    box-shadow:0 24px 74px rgba(15,23,42,.14);backdrop-filter:blur(26px)
  }
  .manager-chart-card::before{content:"";position:absolute;inset:0;pointer-events:none;background:linear-gradient(120deg,rgba(255,255,255,.55),transparent 28%)}
  .manager-chart-card h3,.manager-chart-card p,.manager-chart-box,.manager-chart-legend,.manager-chart-note{position:relative;z-index:1}
  .manager-chart-card h3{margin:0;color:var(--mgr-ink);font-size:20px;letter-spacing:0}
  .manager-chart-card p{margin:6px 0 0;color:var(--mgr-muted);font-size:13px;line-height:1.55}
  .manager-chart-box{
    position:relative;min-height:320px;margin-top:16px;border:1px solid rgba(16,32,51,.08);border-radius:24px;
    background:linear-gradient(180deg,rgba(255,255,255,.58),rgba(248,250,252,.48));box-shadow:inset 0 1px 0 rgba(255,255,255,.80)
  }
  .manager-chart-box::before{
    content:"";position:absolute;inset:14px;border-radius:18px;pointer-events:none;
    background:
      linear-gradient(rgba(16,32,51,.045) 1px,transparent 1px) 0 0/100% 25%,
      linear-gradient(90deg,rgba(16,32,51,.035) 1px,transparent 1px) 0 0/12.5% 100%
  }
  .manager-chart-box.is-compact{min-height:235px}
  .manager-chart-box canvas{position:relative;z-index:1;display:block;width:100%;height:100%;min-height:inherit;cursor:crosshair}
  .manager-chart-legend{display:flex;flex-wrap:wrap;gap:9px;margin-top:14px}
  .manager-legend-item{display:inline-flex;align-items:center;gap:7px;border:1px solid rgba(16,32,51,.08);border-radius:999px;padding:7px 10px;background:rgba(255,255,255,.72);color:var(--mgr-muted);font-size:12px;font-weight:900}
  .manager-legend-dot{width:9px;height:9px;border-radius:999px;background:var(--legend,#0ea5e9)}
  .manager-chart-note{display:flex;flex-wrap:wrap;gap:10px;margin-top:14px}
  .manager-chart-note span{border-radius:14px;padding:9px 11px;background:rgba(255,255,255,.72);color:var(--mgr-muted);font-size:12px;font-weight:900}
  .manager-chart-actions{display:flex;flex-wrap:wrap;gap:9px;align-items:center;justify-content:flex-end}
  .manager-chart-actions a{display:inline-flex;align-items:center;justify-content:center;min-height:36px;border-radius:999px;padding:8px 12px;border:1px solid rgba(16,32,51,.10);background:rgba(255,255,255,.74);color:var(--mgr-ink);text-decoration:none;font-size:12px;font-weight:1000}
  .manager-chart-actions a:first-child{color:#fff;border-color:transparent;background:linear-gradient(135deg,#0ea5e9,#10b981)}
  .manager-chart-tooltip{
    position:fixed;z-index:50;pointer-events:none;min-width:164px;max-width:260px;padding:10px 12px;border-radius:16px;
    border:1px solid rgba(255,255,255,.22);background:rgba(15,23,42,.88);box-shadow:0 18px 54px rgba(15,23,42,.28);
    color:#fff;font-size:12px;font-weight:850;line-height:1.45;opacity:0;transform:translate3d(-50%,-116%,0) scale(.98);
    transition:opacity .12s ease,transform .12s ease;backdrop-filter:blur(18px)
  }
  .manager-chart-tooltip.is-visible{opacity:1;transform:translate3d(-50%,-124%,0) scale(1)}
  .manager-chart-tooltip strong{display:block;margin-bottom:4px;color:#f8fafc;font-size:13px}
  .manager-chart-tooltip span{display:block;color:#dbeafe}
  .manager-alert{display:grid;grid-template-columns:1fr auto;gap:14px;align-items:center;border-radius:30px;padding:18px 20px;background:rgba(255,255,255,.74)}
  .manager-alert strong{display:block;font-size:18px}
  .manager-alert p{margin:5px 0 0;color:var(--mgr-muted);font-size:13px;line-height:1.55}
  .manager-alert-actions{display:flex;flex-wrap:wrap;gap:9px;justify-content:flex-end}
  @keyframes mgr-blob{from{transform:translate3d(0,0,0) rotate(0)}to{transform:translate3d(-24px,28px,0) rotate(16deg)}}
  @keyframes mgr-orbit{from{transform:translate3d(0,0,0) scale(1)}to{transform:translate3d(32px,-18px,0) scale(1.04)}}
  @keyframes dash-pulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(.72);opacity:.68}}
  @keyframes dash-spin{to{transform:rotate(360deg)}}
  @keyframes dash-breathe{0%,100%{transform:rotate(14deg) scale(1);border-radius:42px}50%{transform:rotate(22deg) scale(1.06);border-radius:64px}}
  @keyframes dash-drift-a{0%,100%{transform:translate3d(0,0,0)}50%{transform:translate3d(12px,-10px,0)}}
  @keyframes dash-drift-b{0%,100%{transform:translate3d(0,0,0)}50%{transform:translate3d(-10px,12px,0)}}
  @keyframes dash-wave-sway{0%,100%{transform:translate3d(0,0,0)}50%{transform:translate3d(0,8px,0) scaleX(1.02)}}
  @media(max-width:1080px){.manager-hero,.manager-live-grid,.manager-chart-grid{grid-template-columns:1fr}.manager-visual-card{min-height:320px}.manager-action,.dash-stat{grid-column:span 6}.manager-alert{grid-template-columns:1fr}.manager-alert-actions{justify-content:flex-start}}
  @media(max-width:720px){.manager-dash{padding:20px 12px 42px}.manager-hero-main{min-height:auto;padding:24px;border-radius:28px}.manager-hero h1{font-size:42px}.manager-section-head{display:block}.manager-chart-actions{justify-content:flex-start;margin-top:10px}.manager-chart-box{min-height:250px}.manager-action,.dash-stat{grid-column:1/-1}.manager-visual-card{display:none}}
  @media(prefers-reduced-motion:reduce){.manager-dash::before,.manager-dash::after,.manager-dot,.manager-visual-scene::before,.manager-visual-core,.manager-visual-chip,.manager-visual-wave{animation:none}}
</style>

<main class="manager-dash is-ketoan">
  <div class="manager-shell">
    <section class="manager-hero" aria-label="Dashboard kế toán">
      <div class="manager-hero-main">
        <div class="manager-chip"><span class="manager-dot"></span> Kế toán command center</div>
        <h1>Kế toán vận hành <span>tài chính.</span></h1>
        <p class="manager-lead">Theo dõi thống kê, doanh thu, chi phí và hoàn tiền trong một màn điều hướng gọn.</p>
        <div class="manager-actions">
          <a class="manager-button manager-button--primary" href="/accounting/reports">Thống kê tài chính</a>
          <a class="manager-button" href="/accounting/revenue">Quản lý doanh thu</a>
          <a class="manager-button" href="/accounting/expenses">Quản lý chi phí</a>
        </div>
      </div>
      <aside class="manager-visual-card" aria-label="Minh họa dashboard kế toán">
        <div class="manager-visual-scene">
          <div class="manager-visual-core"></div>
          <span class="manager-visual-chip">Thống kê tài chính</span>
          <span class="manager-visual-chip">Quản lý doanh thu</span>
          <span class="manager-visual-chip">Quản lý chi phí</span>
          <span class="manager-visual-chip">Xử lý hoàn tiền</span>
          <div class="manager-visual-wave"></div>
        </div>
      </aside>
    </section>

    <section class="manager-section">
      <div class="manager-section-head">
        <div>
          <h2>UC chính của Kế toán</h2>
        </div>
      </div>
      <div class="manager-action-grid">
        <% navItems.forEach((item) => { %>
          <a class="manager-action" data-tone="<%= item.tone %>" href="<%= item.href %>">
            <span class="manager-code"><%= item.code %></span>
            <h3><%= item.title %></h3>
            <p><%= item.note %></p>
            <span class="manager-open">Mở chức năng</span>
          </a>
        <% }) %>
      </div>
    </section>

    <section class="manager-section">
      <div class="manager-section-head">
        <div>
          <h2>Tổng quan tài chính</h2>
        </div>
      </div>
      <div class="manager-live-grid">
        <section class="manager-live-panel" aria-label="KPI kế toán">
          <div class="dash-grid">
            <% kpis.forEach((item) => { %>
              <article class="dash-stat">
                <strong><%= item.value %></strong>
                <h3><%= item.label %></h3>
                <p><%= item.note %></p>
              </article>
            <% }) %>
          </div>
        </section>
      </div>
    </section>

    <% if (urgentCount > 0) { %>
      <section class="manager-section">
        <div class="manager-alert" aria-label="Việc cần xử lý">
          <div>
            <strong>Cần xử lý: <%= urgentCount %> mục</strong>
            <p><%= overdueDebtCount %> công nợ quá hạn và <%= pendingRefundCount %> yêu cầu hoàn tiền đang chờ xử lý.</p>
          </div>
          <div class="manager-alert-actions">
            <% if (overdueDebtCount > 0) { %><a class="manager-button" href="/accounting/revenue?trang_thai=Stayed">Mở doanh thu còn thu</a><% } %>
            <% if (pendingRefundCount > 0) { %><a class="manager-button" href="/accounting/refunds?trang_thai=ChoXuLy">Mở hoàn tiền</a><% } %>
          </div>
        </div>
