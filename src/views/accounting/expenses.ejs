<%- include("../partials/head") %>
<%- include("../partials/header") %>
<%
  const filters = payload.filters || {};
  const rows = payload.rows || [];
  const summary = payload.summary || {};
  const statusOptions = payload.statusOptions || [];
  const statusBreakdown = payload.statusBreakdown || [];
  const categoryOptions = payload.categoryOptions || [];
  const dailyTrend = payload.dailyTrend || [];
  const categoryBreakdown = payload.categoryBreakdown || [];
  const vendorBreakdown = payload.vendorBreakdown || [];
  const hotelBreakdown = payload.hotelBreakdown || [];
  const highValueRows = payload.highValueRows || [];
  const actionItems = payload.actionItems || [];
  const chartPayload = payload.chartPayload || {};
  const hotelOptions = payload.hotelOptions || [];
  const page = Number(payload.currentPage || 1);
  const totalPages = Number(payload.totalPages || 1);
  const makeQuery = (overrides = {}) => new URLSearchParams({ ...filters, ...overrides }).toString();
  const csvQuery = makeQuery({ format: "csv" });
  const jsonQuery = makeQuery({ format: "json" });
  const pages = [];
  const firstPage = Math.max(1, page - 2);
  const lastPage = Math.min(totalPages, page + 2);
  for (let i = firstPage; i <= lastPage; i += 1) pages.push(i);
  const maxTrend = Math.max(...dailyTrend.map((item) => Number(item.total || 0)), 1);
  const maxCategory = Math.max(...categoryBreakdown.map((item) => Number(item.total || 0)), 1);
  const maxVendor = Math.max(...vendorBreakdown.map((item) => Number(item.total || 0)), 1);
%>

<style>
  .exp-home {
    --ink: #132033;
    --muted: #667085;
    --line: rgba(19, 32, 51, .10);
    --glass: rgba(255, 255, 255, .80);
    --strong: rgba(255, 255, 255, .94);
    --cyan: #12bff3;
    --mint: #20d6a3;
    --lime: #b7ef4a;
    --sun: #ffd166;
    --orange: #ff9f7a;
    --pink: #ff6aa2;
    --violet: #8068ff;
    --shadow: 0 24px 70px rgba(19, 32, 51, .14);
    min-height: calc(100vh - 84px);
    padding: 34px 18px 58px;
    color: var(--ink);
    background:
      linear-gradient(115deg, rgba(255, 159, 122, .18), transparent 30%),
      linear-gradient(245deg, rgba(18, 191, 243, .16), transparent 36%),
      repeating-linear-gradient(45deg, rgba(255,255,255,.72) 0 13px, rgba(250,253,239,.72) 13px 26px),
      linear-gradient(135deg, #fffdf8 0%, #effcff 46%, #f9fff0 100%);
  }

  .exp-wrap {
    max-width: 1260px;
    margin: 0 auto;
  }

  .exp-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.14fr) minmax(320px, .86fr);
    gap: 16px;
    align-items: stretch;
    margin-bottom: 16px;
  }

  .exp-hero-main,
  .exp-kpi,
  .exp-form,
  .exp-panel,
  .exp-table-panel,
  .exp-alert {
    border: 1px solid var(--line);
    background: var(--glass);
    box-shadow: var(--shadow);
    backdrop-filter: blur(24px);
  }

  .exp-hero-main {
    position: relative;
    overflow: hidden;
    border-radius: 30px;
    padding: 30px;
  }

  .exp-hero-main::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(96deg, rgba(255, 209, 102, .26), transparent 34%),
      linear-gradient(164deg, transparent 0 54%, rgba(32, 214, 163, .20) 54% 68%, transparent 68%),
      linear-gradient(28deg, transparent 0 70%, rgba(128, 104, 255, .18) 70% 86%, transparent 86%);
  }

  .exp-hero-content {
    position: relative;
    z-index: 1;
  }

  .exp-chip,
  .exp-tag,
  .exp-pill,
  .exp-status,
  .exp-cat {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-radius: 999px;
    white-space: nowrap;
  }

  .exp-chip {
    padding: 7px 12px;
    border: 1px solid rgba(255, 159, 122, .30);
    background: rgba(255, 159, 122, .15);
    color: #9a3412;
    font-size: 12px;
    font-weight: 1000;
    text-transform: uppercase;
  }

  .exp-spark {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--orange);
    box-shadow: 0 0 0 7px rgba(255, 159, 122, .14);
  }

  .exp-hero h1 {
    max-width: 720px;
    margin: 24px 0 12px;
    font-size: 56px;
    line-height: 1;
    letter-spacing: 0;
  }

  .exp-hero h1 span {
    color: transparent;
    background: linear-gradient(96deg, #f97316 0%, #f59e0b 25%, #10b981 52%, #0891b2 76%, #8068ff 100%);
    -webkit-background-clip: text;
    background-clip: text;
  }

  .exp-lead {
    max-width: 760px;
    margin: 0;
    color: var(--muted);
    font-size: 16px;
    line-height: 1.7;
  }

  .exp-tags,
  .exp-actions,
  .exp-form-actions,
  .exp-pagination {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .exp-tags {
    margin-top: 20px;
  }

  .exp-tag {
    padding: 8px 11px;
    border: 1px solid rgba(19, 32, 51, .08);
    background: rgba(255, 255, 255, .70);
    color: var(--ink);
    font-size: 12px;
    font-weight: 950;
  }

  .exp-actions {
    margin-top: 22px;
  }

  .exp-button {
    min-height: 43px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(19, 32, 51, .12);
    border-radius: 999px;
    padding: 10px 17px;
    color: var(--ink);
    background: rgba(255, 255, 255, .78);
    font-size: 14px;
    font-weight: 950;
    text-decoration: none;
    cursor: pointer;
  }

  .exp-button--primary {
    color: #fff;
    border-color: transparent;
    background: linear-gradient(135deg, #f97316, #ff6aa2);
    box-shadow: 0 16px 36px rgba(255, 106, 162, .24);
  }

  .exp-button--mint {
    color: #fff;
    border-color: transparent;
    background: linear-gradient(135deg, #10b981, #12bff3);
    box-shadow: 0 16px 36px rgba(18, 191, 243, .20);
  }

  .exp-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 42px rgba(255, 159, 122, .16);
  }

  .exp-kpi-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    height: 100%;
  }

  .exp-kpi {
    min-height: 142px;
    border-radius: 24px;
    padding: 18px;
    background: var(--strong);
  }

  .exp-kpi strong {
    display: block;
    margin-top: 12px;
    font-size: 23px;
    line-height: 1.1;
  }

  .exp-kpi span {
    color: var(--muted);
    font-size: 12px;
    font-weight: 900;
    text-transform: uppercase;
  }

  .exp-kpi.is-orange { border-color: rgba(255, 159, 122, .34); }
  .exp-kpi.is-green { border-color: rgba(32, 214, 163, .30); }
  .exp-kpi.is-sun { border-color: rgba(255, 209, 102, .44); }
  .exp-kpi.is-violet { border-color: rgba(128, 104, 255, .30); }

  .exp-layout {
    display: grid;
    grid-template-columns: minmax(0, .78fr) minmax(0, 1.22fr);
    gap: 16px;
    align-items: start;
  }

  .exp-side-stack {
    display: grid;
    gap: 16px;
  }

  .exp-form,
  .exp-panel,
  .exp-table-panel,
  .exp-alert {
    border-radius: 26px;
    padding: 20px;
  }

  .exp-form h2,
  .exp-panel h2,
  .exp-table-panel h2 {
    margin: 0;
    font-size: 20px;
  }

  .exp-field-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin-top: 16px;
  }

  .exp-field {
    display: grid;
    gap: 7px;
  }

  .exp-field.is-wide {
    grid-column: 1 / -1;
  }

  .exp-field label {
    color: var(--muted);
    font-size: 12px;
    font-weight: 950;
    text-transform: uppercase;
  }

  .exp-field input,
  .exp-field select {
    width: 100%;
    min-height: 43px;
    border: 1px solid rgba(19, 32, 51, .12);
    border-radius: 14px;
    padding: 10px 12px;
    color: var(--ink);
    background: rgba(255, 255, 255, .88);
    font: inherit;
    font-size: 14px;
  }

  .exp-form-actions {
    margin-top: 16px;
  }

  .exp-alert {
    margin-bottom: 16px;
    background: rgba(255, 246, 214, .88);
    border-color: rgba(245, 158, 11, .25);
    color: #8a4b00;
    font-weight: 800;
  }

  .exp-alert p {
    margin: 0;
  }

  .exp-breakdown,
  .exp-trend,
  .exp-cats {
    display: grid;
    gap: 10px;
    margin-top: 16px;
  }

  .exp-break-row,
  .exp-trend-row {
    display: grid;
    grid-template-columns: minmax(96px, .7fr) minmax(0, 1fr) auto;
    gap: 10px;
    align-items: center;
  }

  .exp-meter {
    height: 9px;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(19, 32, 51, .08);
  }

  .exp-meter span {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--orange), var(--sun), var(--mint));
  }

  .exp-pill {
    padding: 7px 10px;
    background: rgba(255, 255, 255, .72);
    border: 1px solid rgba(19, 32, 51, .08);
    font-size: 12px;
    font-weight: 950;
  }

  .exp-cat-row {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    padding: 12px;
    border-radius: 18px;
    border: 1px solid rgba(19, 32, 51, .08);
    background: rgba(255, 255, 255, .64);
  }

  .exp-cat-row span {
    display: block;
  }

  .exp-muted,
  .exp-cat-row span {
    color: var(--muted);
    font-size: 13px;
  }

  .exp-status,
  .exp-cat {
    padding: 7px 10px;
    border: 1px solid rgba(19, 32, 51, .08);
    font-size: 12px;
    font-weight: 950;
  }

  .exp-status--sun { color: #92400e; background: rgba(255, 209, 102, .22); }
  .exp-status--green { color: #047857; background: rgba(32, 214, 163, .16); }
  .exp-status--rose { color: #be123c; background: rgba(255, 106, 162, .14); }
  .exp-status--slate { color: #475569; background: rgba(100, 116, 139, .14); }
  .exp-cat--cyan { color: #0369a1; background: rgba(18, 191, 243, .14); }
  .exp-cat--violet { color: #6d28d9; background: rgba(128, 104, 255, .14); }
  .exp-cat--orange { color: #9a3412; background: rgba(255, 159, 122, .18); }
  .exp-cat--lime { color: #3f6212; background: rgba(183, 239, 74, .20); }
  .exp-cat--pink { color: #be185d; background: rgba(255, 106, 162, .14); }
  .exp-cat--green { color: #047857; background: rgba(32, 214, 163, .16); }
  .exp-cat--sun { color: #92400e; background: rgba(255, 209, 102, .22); }
  .exp-cat--slate { color: #475569; background: rgba(100, 116, 139, .14); }

  .exp-insight-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin-bottom: 16px;
  }

  .exp-insight {
    border: 1px solid rgba(19, 32, 51, .10);
    border-radius: 24px;
    padding: 16px;
    background: rgba(255,255,255,.78);
    box-shadow: 0 16px 42px rgba(19,32,51,.09);
  }

  .exp-insight strong {
    display: block;
    margin-top: 8px;
    color: var(--ink);
    font-size: 18px;
    line-height: 1.2;
  }

  .exp-insight p {
    margin: 7px 0 0;
    color: var(--muted);
    font-size: 12px;
    line-height: 1.45;
  }

  .exp-chart-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(280px, .65fr);
    gap: 16px;
  }

  .exp-chart-card {
    border: 1px solid rgba(19,32,51,.10);
    border-radius: 26px;
    padding: 18px;
    background:
      linear-gradient(180deg, rgba(255,255,255,.92), rgba(255,255,255,.72)),
      radial-gradient(circle at 92% 0%, rgba(255,159,122,.18), transparent 34%),
      radial-gradient(circle at 10% 100%, rgba(32,214,163,.14), transparent 34%);
    box-shadow: var(--shadow);
    backdrop-filter: blur(24px);
  }

  .exp-chart-card h2 {
    margin: 0;
    font-size: 20px;
  }

  .exp-chart-card p {
    margin: 6px 0 0;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.5;
  }

  .exp-chart-box {
    position: relative;
    min-height: 300px;
    margin-top: 14px;
    border: 1px solid rgba(19,32,51,.08);
    border-radius: 22px;
    background: linear-gradient(180deg, rgba(255,255,255,.58), rgba(248,250,252,.48));
  }

  .exp-chart-box.is-compact {
    min-height: 250px;
  }

  .exp-chart-box::before {
    content: "";
    position: absolute;
    inset: 14px;
    border-radius: 16px;
    pointer-events: none;
    background:
      linear-gradient(rgba(19,32,51,.045) 1px, transparent 1px) 0 0 / 100% 25%,
      linear-gradient(90deg, rgba(19,32,51,.035) 1px, transparent 1px) 0 0 / 16.66% 100%;
