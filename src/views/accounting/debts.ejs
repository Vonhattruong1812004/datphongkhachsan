<%- include("../partials/head") %>
<%- include("../partials/header") %>
<%
  const filters = payload.filters || {};
  const rows = payload.rows || [];
  const summary = payload.summary || {};
  const statusOptions = payload.statusOptions || [];
  const statusBreakdown = payload.statusBreakdown || [];
  const hotelBreakdown = payload.hotelBreakdown || [];
  const dailyTrend = payload.dailyTrend || [];
  const hotelOptions = payload.hotelOptions || [];
  const page = Number(payload.currentPage || 1);
  const totalPages = Number(payload.totalPages || 1);
  const makeQuery = (overrides = {}) => new URLSearchParams({ ...filters, ...overrides }).toString();
  const csvQuery = makeQuery({ format: "csv" });
  const jsonQuery = makeQuery({ format: "json" });
  const pages = [];
  const firstPage = Math.max(1, page - 2);
  const lastPage = Math.min(totalPages, page + 2);
  for (let i = firstPage; i <= lastPage; i += 1) pages.push(i);
  const maxTrend = Math.max(...dailyTrend.map((item) => Number(item.total || 0)), 1);
%>

<style>
  .debt-home {
    --ink: #102033;
    --muted: #667085;
    --line: rgba(16, 32, 51, .10);
    --glass: rgba(255, 255, 255, .80);
    --strong: rgba(255, 255, 255, .94);
    --cyan: #12bff3;
    --mint: #20d6a3;
    --lime: #b7ef4a;
    --sun: #ffd166;
    --orange: #ff9f7a;
    --pink: #ff6aa2;
    --violet: #8068ff;
    --shadow: 0 24px 70px rgba(16, 32, 51, .14);
    min-height: calc(100vh - 84px);
    padding: 34px 18px 58px;
    color: var(--ink);
    background:
      linear-gradient(116deg, rgba(128, 104, 255, .17), transparent 31%),
      linear-gradient(250deg, rgba(255, 106, 162, .16), transparent 35%),
      repeating-linear-gradient(135deg, rgba(255,255,255,.72) 0 12px, rgba(242,248,255,.72) 12px 24px),
      linear-gradient(135deg, #fbfcff 0%, #eefcff 45%, #fff7ed 100%);
  }

  .debt-wrap {
    max-width: 1260px;
    margin: 0 auto;
  }

  .debt-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.14fr) minmax(320px, .86fr);
    gap: 16px;
    align-items: stretch;
    margin-bottom: 16px;
  }

  .debt-hero-main,
  .debt-kpi,
  .debt-filter,
  .debt-panel,
  .debt-table-panel,
  .debt-alert {
    border: 1px solid var(--line);
    background: var(--glass);
    box-shadow: var(--shadow);
    backdrop-filter: blur(24px);
  }

  .debt-hero-main {
    position: relative;
    overflow: hidden;
    border-radius: 30px;
    padding: 30px;
  }

  .debt-hero-main::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(96deg, rgba(128, 104, 255, .19), transparent 34%),
      linear-gradient(164deg, transparent 0 53%, rgba(18, 191, 243, .22) 53% 68%, transparent 68%),
      linear-gradient(28deg, transparent 0 72%, rgba(255, 209, 102, .20) 72% 86%, transparent 86%);
  }

  .debt-hero-content {
    position: relative;
    z-index: 1;
  }

  .debt-chip,
  .debt-tag,
  .debt-pill,
  .debt-status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-radius: 999px;
    white-space: nowrap;
  }

  .debt-chip {
    padding: 7px 12px;
    border: 1px solid rgba(128, 104, 255, .30);
    background: rgba(128, 104, 255, .13);
    color: #5b21b6;
    font-size: 12px;
    font-weight: 1000;
    text-transform: uppercase;
  }

  .debt-spark {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--violet);
    box-shadow: 0 0 0 7px rgba(128, 104, 255, .13);
  }

  .debt-hero h1 {
    max-width: 790px;
    margin: 24px 0 12px;
    font-size: 56px;
    line-height: 1;
    letter-spacing: 0;
  }

  .debt-hero h1 span {
    color: transparent;
    background: linear-gradient(96deg, #8068ff 0%, #0891b2 34%, #10b981 62%, #f59e0b 100%);
    -webkit-background-clip: text;
    background-clip: text;
  }

  .debt-lead {
    max-width: 760px;
    margin: 0;
    color: var(--muted);
    font-size: 16px;
    line-height: 1.7;
  }

  .debt-tags,
  .debt-actions,
  .debt-form-actions,
  .debt-pagination {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .debt-tags {
    margin-top: 20px;
  }

  .debt-tag {
    padding: 8px 11px;
    border: 1px solid rgba(16, 32, 51, .08);
    background: rgba(255, 255, 255, .70);
    color: var(--ink);
    font-size: 12px;
    font-weight: 950;
  }

  .debt-actions {
    margin-top: 22px;
  }

  .debt-button {
    min-height: 43px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(16, 32, 51, .12);
    border-radius: 999px;
    padding: 10px 17px;
    color: var(--ink);
    background: rgba(255, 255, 255, .78);
    font-size: 14px;
    font-weight: 950;
    text-decoration: none;
    cursor: pointer;
  }

  .debt-button--primary {
    color: #fff;
    border-color: transparent;
    background: linear-gradient(135deg, #8068ff, #12bff3);
    box-shadow: 0 16px 36px rgba(128, 104, 255, .24);
  }

  .debt-button--hot {
    color: #fff;
    border-color: transparent;
    background: linear-gradient(135deg, #ff6aa2, #ff9f7a);
    box-shadow: 0 16px 36px rgba(255, 106, 162, .22);
  }

  .debt-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 42px rgba(128, 104, 255, .16);
  }

  .debt-kpi-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    height: 100%;
  }

  .debt-kpi {
    min-height: 142px;
    border-radius: 24px;
    padding: 18px;
    background: var(--strong);
  }

  .debt-kpi strong {
    display: block;
    margin-top: 12px;
    font-size: 23px;
    line-height: 1.1;
  }

  .debt-kpi span {
    color: var(--muted);
    font-size: 12px;
    font-weight: 900;
    text-transform: uppercase;
  }

  .debt-kpi.is-rose { border-color: rgba(255, 106, 162, .32); }
  .debt-kpi.is-sun { border-color: rgba(255, 209, 102, .42); }
  .debt-kpi.is-green { border-color: rgba(32, 214, 163, .30); }
  .debt-kpi.is-violet { border-color: rgba(128, 104, 255, .30); }

  .debt-layout {
    display: grid;
    grid-template-columns: minmax(0, .78fr) minmax(0, 1.22fr);
    gap: 16px;
    align-items: start;
  }

  .debt-side-stack {
    display: grid;
    gap: 16px;
  }

  .debt-filter,
  .debt-panel,
  .debt-table-panel,
  .debt-alert {
    border-radius: 26px;
    padding: 20px;
  }

  .debt-filter h2,
  .debt-panel h2,
  .debt-table-panel h2 {
    margin: 0;
    font-size: 20px;
  }

  .debt-field-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin-top: 16px;
  }

  .debt-field {
    display: grid;
    gap: 7px;
  }

  .debt-field.is-wide {
    grid-column: 1 / -1;
  }

  .debt-field label {
    color: var(--muted);
    font-size: 12px;
    font-weight: 950;
    text-transform: uppercase;
  }

  .debt-field input,
  .debt-field select {
    width: 100%;
    min-height: 43px;
    border: 1px solid rgba(16, 32, 51, .12);
    border-radius: 14px;
    padding: 10px 12px;
    color: var(--ink);
    background: rgba(255, 255, 255, .88);
    font: inherit;
    font-size: 14px;
  }

  .debt-form-actions {
    margin-top: 16px;
  }

  .debt-alert {
    margin-bottom: 16px;
    background: rgba(255, 246, 214, .88);
    border-color: rgba(245, 158, 11, .25);
    color: #8a4b00;
    font-weight: 800;
  }

  .debt-alert p {
    margin: 0;
  }

  .debt-breakdown,
  .debt-hotels,
  .debt-trend {
    display: grid;
    gap: 10px;
    margin-top: 16px;
  }

  .debt-break-row,
  .debt-trend-row {
    display: grid;
    grid-template-columns: minmax(116px, .8fr) minmax(0, 1fr) auto;
    gap: 10px;
    align-items: center;
  }

  .debt-meter {
    height: 9px;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(16, 32, 51, .08);
  }

  .debt-meter span {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--violet), var(--cyan), var(--mint));
  }

  .debt-pill {
    padding: 7px 10px;
    background: rgba(255, 255, 255, .72);
    border: 1px solid rgba(16, 32, 51, .08);
    font-size: 12px;
    font-weight: 950;
  }

  .debt-hotel {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    padding: 12px;
    border-radius: 18px;
    border: 1px solid rgba(16, 32, 51, .08);
    background: rgba(255, 255, 255, .64);
  }

  .debt-hotel span,
  .debt-muted {
    color: var(--muted);
    font-size: 13px;
  }

  .debt-status {
    padding: 7px 10px;
    border: 1px solid rgba(16, 32, 51, .08);
    font-size: 12px;
    font-weight: 950;
  }

  .debt-status--rose { color: #be123c; background: rgba(255, 106, 162, .14); }
  .debt-status--orange { color: #9a3412; background: rgba(255, 159, 122, .18); }
  .debt-status--sun { color: #92400e; background: rgba(255, 209, 102, .22); }
  .debt-status--green { color: #047857; background: rgba(32, 214, 163, .16); }
  .debt-status--slate { color: #475569; background: rgba(100, 116, 139, .14); }

  .debt-table-head {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: flex-start;
    margin-bottom: 12px;
  }

  .debt-table-head p {
    margin: 6px 0 0;
    color: var(--muted);
    font-size: 13px;
  }

  .debt-table-wrap {
    overflow-x: auto;
  }

  .debt-table {
    width: 100%;
    min-width: 980px;
    border-collapse: separate;
    border-spacing: 0 9px;
  }

  .debt-table th {
    padding: 0 12px 6px;
    color: var(--muted);
    font-size: 12px;
    text-align: left;
    text-transform: uppercase;
  }

  .debt-table td {
    padding: 13px 12px;
    border-top: 1px solid rgba(16, 32, 51, .08);
    border-bottom: 1px solid rgba(16, 32, 51, .08);
    background: rgba(255, 255, 255, .75);
    font-size: 14px;
    vertical-align: middle;
  }

  .debt-table td:first-child {
    border-left: 1px solid rgba(16, 32, 51, .08);
    border-radius: 18px 0 0 18px;
  }

  .debt-table td:last-child {
    border-right: 1px solid rgba(16, 32, 51, .08);
    border-radius: 0 18px 18px 0;
  }

  .debt-code {
    display: grid;
    gap: 3px;
    font-weight: 950;
  }

  .debt-money {
    font-weight: 1000;
  }

  .debt-money.is-debt { color: #be123c; }
  .debt-money.is-paid { color: #047857; }
  .debt-money.is-total { color: #1d4ed8; }

  .debt-empty {
    border: 1px dashed rgba(16, 32, 51, .18);
    border-radius: 22px;
    padding: 22px;
    color: var(--muted);
    background: rgba(255, 255, 255, .62);
  }

  .debt-pagination {
    justify-content: center;
    margin-top: 18px;
  }

  .debt-page {
    min-width: 40px;
    min-height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid rgba(16, 32, 51, .10);
    color: var(--ink);
    background: rgba(255,255,255,.78);
    text-decoration: none;
    font-weight: 950;
  }

  .debt-page.is-active {
    color: #fff;
    border-color: transparent;
    background: linear-gradient(135deg, #8068ff, #12bff3);
  }

  @media (max-width: 1080px) {
    .debt-hero,
    .debt-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .debt-home {
      padding: 20px 12px 42px;
    }
    .debt-hero-main,
    .debt-filter,
    .debt-panel,
    .debt-table-panel {
      border-radius: 24px;
      padding: 18px;
    }
    .debt-hero h1 {
      font-size: 40px;
    }
    .debt-kpi-grid,
    .debt-field-grid {
      grid-template-columns: 1fr;
    }
    .debt-table-head,
    .debt-hotel {
      display: block;
    }
    .debt-break-row,
    .debt-trend-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<main class="debt-home">
  <div class="debt-wrap">
    <section class="debt-hero" aria-label="Công nợ phải thu và đối soát">
      <div class="debt-hero-main">
        <div class="debt-hero-content">
          <div class="debt-chip"><span class="debt-spark"></span> Receivable control</div>
          <h1>Công nợ & <span>đối soát</span></h1>
          <p class="debt-lead">Kiểm soát giao dịch chưa tất toán, thanh toán thiếu, khoản chờ đối soát và công nợ theo khách, đoàn, cơ sở.</p>
          <div class="debt-tags">
            <span class="debt-tag"><%= payload.rangeLabel %></span>
            <span class="debt-tag"><%= payload.hotelContext.label %></span>
            <span class="debt-tag"><%= payload.totalRecords %> giao dịch</span>
            <span class="debt-tag">Cập nhật <%= payload.generatedAtLabel %></span>
          </div>
          <div class="debt-actions">
            <a class="debt-button debt-button--primary" href="/api/accounting/debts?<%= csvQuery %>">Xuất CSV</a>
            <a class="debt-button" href="/api/accounting/debts?<%= jsonQuery %>">JSON</a>
            <a class="debt-button debt-button--hot" href="/accounting/cashflow?tu_ngay=<%= filters.tu_ngay %>&den_ngay=<%= filters.den_ngay %>&hotel_id=<%= filters.hotel_id %>">Đối chiếu thu chi</a>
          </div>
        </div>
      </div>

      <aside class="debt-kpi-grid" aria-label="KPI công nợ">
        <article class="debt-kpi is-rose"><span>Tổng công nợ</span><strong><%= summary.tongCongNoFormatted %></strong></article>
        <article class="debt-kpi is-sun"><span>Chưa đối soát</span><strong><%= summary.tongChuaDoiSoatFormatted %></strong></article>
        <article class="debt-kpi is-green"><span>Đã thanh toán</span><strong><%= summary.tongDaThanhToanFormatted %></strong></article>
        <article class="debt-kpi is-violet"><span>Tỷ lệ đã thu</span><strong><%= summary.doiSoatCoverageFormatted %></strong></article>
      </aside>
    </section>

    <% if (payload.warnings && payload.warnings.length) { %>
      <section class="debt-alert">
        <% payload.warnings.forEach((warning) => { %>
          <p><%= warning %></p>
        <% }) %>
      </section>
    <% } %>

    <section class="debt-layout">
      <aside class="debt-side-stack">
        <section class="debt-filter">
          <h2>Bộ lọc</h2>
          <form method="get" action="/accounting/debts">
            <div class="debt-field-grid">
              <div class="debt-field">
                <label for="tu_ngay">Từ ngày</label>
                <input id="tu_ngay" type="date" name="tu_ngay" value="<%= filters.tu_ngay %>" />
              </div>
              <div class="debt-field">
                <label for="den_ngay">Đến ngày</label>
                <input id="den_ngay" type="date" name="den_ngay" value="<%= filters.den_ngay %>" />
              </div>
              <div class="debt-field">
                <label for="trang_thai">Trạng thái</label>
                <select id="trang_thai" name="trang_thai">
                  <% statusOptions.forEach((option) => { %>
                    <option value="<%= option.value %>" <%= filters.trang_thai === option.value ? "selected" : "" %>><%= option.label %></option>
                  <% }) %>
                </select>
              </div>
              <div class="debt-field">
                <label for="limit">Hiển thị</label>
                <select id="limit" name="limit">
                  <% [10, 15, 25, 50, 100].forEach((limit) => { %>
                    <option value="<%= limit %>" <%= Number(filters.limit) === limit ? "selected" : "" %>><%= limit %> dòng</option>
                  <% }) %>
                </select>
              </div>
              <div class="debt-field is-wide">
                <label for="hotel_id">Cơ sở</label>
                <select id="hotel_id" name="hotel_id">
                  <option value="0" <%= Number(filters.hotel_id || 0) === 0 ? "selected" : "" %>>Toàn bộ cơ sở</option>
                  <% hotelOptions.forEach((hotel) => { %>
                    <option value="<%= hotel.id %>" <%= Number(filters.hotel_id || 0) === Number(hotel.id) ? "selected" : "" %>>
                      <%= hotel.tenKhachSan %><%= hotel.tinhThanh ? ` · ${hotel.tinhThanh}` : "" %>
                    </option>
                  <% }) %>
                </select>
              </div>
              <div class="debt-field is-wide">
                <label for="keyword">Từ khóa</label>
                <input id="keyword" name="keyword" value="<%= filters.keyword %>" placeholder="Mã giao dịch, mã đặt chỗ, khách, đoàn, email, số điện thoại..." />
              </div>
            </div>
            <input type="hidden" name="page" value="1" />
            <div class="debt-form-actions">
              <button class="debt-button debt-button--primary" type="submit">Lọc công nợ</button>
              <a class="debt-button" href="/accounting/debts">Đặt lại</a>
            </div>
          </form>
        </section>

        <section class="debt-panel">
          <h2>Phân bổ trạng thái</h2>
          <div class="debt-breakdown">
            <% if (!statusBreakdown.length) { %>
              <div class="debt-empty">Chưa có dữ liệu trạng thái trong kỳ này.</div>
            <% } %>
            <% statusBreakdown.forEach((item) => {
              const pct = summary.tongCongNo > 0 ? Math.round((Number(item.total || 0) / Number(summary.tongCongNo || 1)) * 100) : 0;
            %>
              <div class="debt-break-row">
                <span class="debt-status debt-status--<%= item.meta.tone %>"><%= item.meta.label %></span>
                <div class="debt-meter"><span style="width:<%= Math.max(5, pct) %>%"></span></div>
                <span class="debt-pill"><%= item.count %> · <%= item.totalFormatted %></span>
              </div>
            <% }) %>
          </div>
        </section>

        <section class="debt-panel">
          <h2>Cơ sở cần theo dõi</h2>
          <div class="debt-hotels">
            <% if (!hotelBreakdown.length) { %>
              <div class="debt-empty">Chưa có dữ liệu theo cơ sở.</div>
            <% } %>
            <% hotelBreakdown.forEach((hotel) => { %>
              <article class="debt-hotel">
                <div>
                  <strong><%= hotel.hotelLabel %></strong>
                  <div class="debt-muted"><%= hotel.count %> giao dịch</div>
                </div>
                <strong class="debt-money is-debt"><%= hotel.totalFormatted %></strong>
              </article>
            <% }) %>
          </div>
        </section>
      </aside>

      <section class="debt-side-stack">
        <section class="debt-panel">
          <h2>Xu hướng tồn nợ</h2>
          <div class="debt-trend">
            <% if (!dailyTrend.length) { %>
              <div class="debt-empty">Không có xu hướng để hiển thị.</div>
            <% } %>
            <% dailyTrend.slice(-10).forEach((item) => { %>
              <div class="debt-trend-row">
                <strong><%= item.dateLabel %></strong>
                <div class="debt-meter"><span style="width:<%= Math.max(5, Math.round((Number(item.total || 0) / maxTrend) * 100)) %>%"></span></div>
                <span class="debt-money is-debt"><%= item.totalFormatted %></span>
              </div>
            <% }) %>
          </div>
          <% if (payload.highestDebtDay) { %>
            <p class="debt-muted" style="margin:14px 0 0">Ngày tồn nợ cao nhất: <strong><%= payload.highestDebtDay.dateLabel %></strong> với <strong><%= payload.highestDebtDay.totalFormatted %></strong>.</p>
          <% } %>
        </section>

        <section class="debt-table-panel">
          <div class="debt-table-head">
            <div>
              <h2>Danh sách công nợ & đối soát</h2>
              <p>Trang <%= page %>/<%= totalPages %>, đang hiển thị <%= rows.length %> trên <%= payload.totalRecords %> giao dịch.</p>
            </div>
            <span class="debt-pill">Lệch/chờ xử lý: <%= summary.soGiaoDichLech %></span>
          </div>

          <% if (!payload.hasData) { %>
            <div class="debt-empty">Không có công nợ phù hợp với bộ lọc hiện tại.</div>
          <% } else { %>
            <div class="debt-table-wrap">
              <table class="debt-table">
                <thead>
                  <tr>
                    <th>Mã GD</th>
                    <th>Khách / Đoàn</th>
                    <th>Ngày</th>
                    <th>Cơ sở</th>
                    <th>Tổng tiền</th>
                    <th>Đã thanh toán</th>
                    <th>Còn lại</th>
                    <th>Trạng thái</th>
                  </tr>
                </thead>
                <tbody>
                  <% rows.forEach((row) => { %>
                    <tr>
                      <td>
                        <span class="debt-code">
                          <%= row.bookingCode || `GD-${row.maGiaoDich}` %>
                          <span class="debt-muted">#<%= row.maGiaoDich %></span>
                        </span>
                      </td>
                      <td>
                        <strong><%= row.customerName || row.groupName || "Khách lẻ" %></strong>
                        <div class="debt-muted"><%= row.doiTuongType %> · <%= row.contactLabel %></div>
                        <% if (row.groupName) { %><div class="debt-muted"><%= row.groupName %></div><% } %>
                      </td>
                      <td><%= row.ngayGiaoDichLabel %></td>
                      <td>
                        <strong><%= row.hotelLabel %></strong>
                        <div class="debt-muted"><%= row.roomCount %> phòng · Hạn: <%= row.ngayDenHanLabel %></div>
                      </td>
                      <td class="debt-money is-total"><%= row.tongTienFormatted %></td>
                      <td class="debt-money is-paid"><%= row.daThanhToanFormatted %></td>
                      <td class="debt-money is-debt"><%= row.conLaiFormatted %></td>
                      <td>
                        <span class="debt-status debt-status--<%= row.statusMeta.tone %>"><%= row.statusMeta.label %></span>
                        <div class="debt-muted" style="margin-top:5px"><%= row.statusMeta.hint %></div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>

            <% if (totalPages > 1) { %>
              <nav class="debt-pagination" aria-label="Phân trang công nợ">
                <% if (page > 1) { %>
                  <a class="debt-page" href="/accounting/debts?<%= makeQuery({ page: page - 1 }) %>">Trước</a>
                <% } %>
                <% if (firstPage > 1) { %>
                  <a class="debt-page" href="/accounting/debts?<%= makeQuery({ page: 1 }) %>">1</a>
                <% } %>
                <% pages.forEach((item) => { %>
                  <a class="debt-page <%= item === page ? "is-active" : "" %>" href="/accounting/debts?<%= makeQuery({ page: item }) %>"><%= item %></a>
                <% }) %>
                <% if (lastPage < totalPages) { %>
                  <a class="debt-page" href="/accounting/debts?<%= makeQuery({ page: totalPages }) %>"><%= totalPages %></a>
                <% } %>
                <% if (page < totalPages) { %>
                  <a class="debt-page" href="/accounting/debts?<%= makeQuery({ page: page + 1 }) %>">Tiếp</a>
                <% } %>
              </nav>
            <% } %>
          <% } %>
        </section>
      </section>
    </section>
  </div>
</main>

<%- include("../partials/footer") %>
