<%- include("../partials/head") %>
<%- include("../partials/header") %>
<%
  const room = preview.room;
  const booking = preview.booking;
  const summary = preview.summary;
  const searchQuery = new URLSearchParams(filters || {}).toString();
  const backSearchUrl = `/booking/search${searchQuery ? `?${searchQuery}` : ""}`;
  const roomDetailUrl = `/booking/rooms/${room.id}/detail${searchQuery ? `?${searchQuery}` : ""}`;
  const isCskhAssist = String((filters && filters.staff_mode) || "") === "cskh" || Number(currentUser?.maVaiTro || 0) === 5;
%>
<style>
  body{background:radial-gradient(circle at 10% 12%,rgba(45,212,191,.24),transparent 24%),radial-gradient(circle at 88% 10%,rgba(251,113,133,.16),transparent 26%),linear-gradient(160deg,#fffef5 0%,#effffd 34%,#eef8ff 68%,#fff4f8 100%);color:#14314b}
  .review-shell{position:relative;overflow:hidden;max-width:1080px;margin:0 auto;padding:34px 18px 64px}
  .review-shell::before{content:"";position:absolute;width:520px;height:520px;right:-180px;top:-230px;border-radius:999px;background:conic-gradient(from 130deg,rgba(14,165,233,.44),rgba(20,184,166,.34),rgba(250,204,21,.30),rgba(251,113,133,.24),rgba(14,165,233,.44));opacity:.48;z-index:-1;animation:review-float 12s ease-in-out infinite alternate}
  .review-card{border:1px solid rgba(19,48,74,.12);border-radius:32px;background:linear-gradient(180deg,rgba(255,255,255,.92),rgba(255,255,255,.74));box-shadow:0 26px 72px rgba(12,39,64,.14);backdrop-filter:blur(22px);padding:26px;margin-bottom:18px}
  .review-hero{display:grid;grid-template-columns:1fr 340px;gap:20px;align-items:stretch}
  .review-img{width:100%;height:100%;min-height:260px;object-fit:cover;border-radius:26px;background:#e0f2fe}
  .review-chip{display:inline-flex;border-radius:999px;padding:6px 11px;background:rgba(20,184,166,.12);border:1px solid rgba(20,184,166,.18);color:#0f766e;font-size:12px;font-weight:1000;letter-spacing:.08em;text-transform:uppercase}
  .review-card h1,.review-card h2{margin:14px 0 10px;color:#102033;letter-spacing:-.05em}
  .review-card h1{font-size:clamp(38px,5.4vw,66px);line-height:.94}
  .review-muted{color:#5f778f;line-height:1.65}
  .review-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px;margin-top:18px}
  .review-box{border-radius:22px;border:1px solid rgba(19,48,74,.10);background:rgba(255,255,255,.70);padding:16px}
  .review-box span{display:block;color:#5f778f;font-size:12px;font-weight:900;text-transform:uppercase;letter-spacing:.07em}
  .review-box strong{display:block;margin-top:8px;color:#102033;font-size:18px}
  .review-flow{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px;margin-top:18px}
  .review-flow div{border-radius:18px;border:1px solid rgba(20,184,166,.16);background:rgba(20,184,166,.09);padding:12px}
  .review-flow span{display:block;color:#0f766e;font-size:11px;font-weight:1000;text-transform:uppercase;letter-spacing:.06em}
  .review-flow strong{display:block;margin-top:5px;color:#102033;font-size:13px;line-height:1.25}
  .review-total{display:grid;gap:10px;margin-top:18px}
  .review-line{display:flex;justify-content:space-between;gap:12px;border-bottom:1px dashed rgba(19,48,74,.14);padding-bottom:10px;color:#5f778f}
  .review-line strong{color:#102033}
  .review-line--total{border-bottom:0;border-radius:22px;background:linear-gradient(135deg,rgba(14,165,233,.10),rgba(20,184,166,.12));padding:16px;color:#102033;font-size:18px;font-weight:1000}
  .review-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:20px}
  .review-button{display:inline-flex;align-items:center;justify-content:center;min-height:44px;border-radius:999px;border:1px solid rgba(19,48,74,.12);background:linear-gradient(135deg,rgba(255,255,255,.96),rgba(242,251,255,.86));color:#14314b;padding:10px 17px;font-size:14px;font-weight:900;text-decoration:none;cursor:pointer;box-shadow:0 14px 32px rgba(12,39,64,.08)}
  .review-button--primary{border-color:transparent;color:#fff;background:linear-gradient(135deg,#0ea5e9,#14b8a6 50%,#22c55e);box-shadow:0 18px 38px rgba(20,184,166,.18)}
  @keyframes review-float{from{transform:translate3d(0,0,0) rotate(0)}to{transform:translate3d(28px,22px,0) rotate(14deg)}}
  @media(max-width:860px){.review-hero,.review-grid,.review-flow{grid-template-columns:1fr}.review-img{min-height:220px}}
</style>

<main class="review-shell">
  <section class="review-card review-hero">
    <div>
      <span class="review-chip"><%= isCskhAssist ? "CSKH hỗ trợ · Bước 3" : "Bước 3 · Kiểm tra trước khi đặt" %></span>
      <h1>Xác nhận thông tin booking.</h1>
      <p class="review-muted">Kiểm tra lại phòng, ngày ở, thông tin liên hệ, khuyến mãi, tổng tiền và khoản cọc. Sau bước này hệ thống chỉ tạo mã giữ phòng, booking thật chờ SePay xác nhận.</p>
      <div class="review-flow" aria-label="Luồng cọc SePay">
        <div><span>Hold</span><strong>Giữ phòng 10 phút</strong></div>
        <div><span>Cọc</span><strong>Thanh toán 50%</strong></div>
        <div><span>Webhook</span><strong>Đối chiếu nội dung</strong></div>
        <div><span>Booking</span><strong>Tạo giao dịch thật</strong></div>
      </div>
    </div>
    <img class="review-img" src="<%= room.imageUrl %>" alt="<%= room.loaiPhong %> - phòng <%= room.soPhong %>" />
  </section>

  <section class="review-card">
    <span class="review-chip"><%= room.tinhThanh %> · <%= room.khachSan %></span>
    <h2><%= room.loaiPhong %> · Phòng <%= room.soPhong %></h2>
    <div class="review-grid">
      <div class="review-box"><span>Khách</span><strong><%= booking.ten_khach %></strong></div>
      <div class="review-box"><span>Liên hệ</span><strong><%= booking.sdt %></strong></div>
      <div class="review-box"><span>Email</span><strong><%= booking.email %></strong></div>
      <div class="review-box"><span>CCCD</span><strong><%= booking.cccd %></strong></div>
      <div class="review-box"><span>Số người</span><strong><%= booking.so_nguoi %> khách</strong></div>
      <div class="review-box"><span>Thời gian</span><strong><%= summary.checkinLabel %> → <%= summary.checkoutLabel %></strong></div>
    </div>
    <div class="review-total">
      <div class="review-line"><span>Đơn giá phòng</span><strong><%= Number(summary.unitPrice).toLocaleString("vi-VN") %> đ / đêm</strong></div>
      <div class="review-line"><span>Số đêm</span><strong><%= summary.nights %> đêm</strong></div>
      <div class="review-line"><span>Tạm tính</span><strong><%= summary.subtotalFormatted %></strong></div>
      <% if (preview.services && preview.services.length) { %>
        <% preview.services.forEach((service) => { %>
          <div class="review-line"><span>Dịch vụ: <%= service.name %> x <%= service.quantity %></span><strong><%= service.amountFormatted %></strong></div>
        <% }) %>
      <% } %>
      <div class="review-line"><span>Tổng dịch vụ</span><strong><%= summary.serviceAmountFormatted %></strong></div>
      <div class="review-line"><span>Khuyến mãi</span><strong><%= preview.promotion ? preview.promotion.tenChuongTrinh : "Không áp dụng" %> · -<%= summary.discountFormatted %></strong></div>
      <div class="review-line review-line--total"><span>Tổng cần xác nhận</span><strong><%= summary.totalFormatted %></strong></div>
      <div class="review-line review-line--total"><span>Cọc cần thanh toán</span><strong><%= summary.depositAmountFormatted %></strong></div>
    </div>

    <form method="post" action="/booking/rooms/<%= room.id %>">
      <% Object.entries(filters || {}).forEach(([key, value]) => { %>
        <% if (!["ngay_nhan", "ngay_tra"].includes(key)) { %>
          <input type="hidden" name="<%= key %>" value="<%= value %>" />
        <% } %>
      <% }) %>
      <input type="hidden" name="ten_khach" value="<%= booking.ten_khach %>" />
      <input type="hidden" name="cccd" value="<%= booking.cccd %>" />
      <input type="hidden" name="sdt" value="<%= booking.sdt %>" />
      <input type="hidden" name="email" value="<%= booking.email %>" />
      <input type="hidden" name="so_nguoi" value="<%= booking.so_nguoi %>" />
      <input type="hidden" name="ngay_nhan" value="<%= booking.ngay_nhan %>" />
      <input type="hidden" name="ngay_tra" value="<%= booking.ngay_tra %>" />
      <input type="hidden" name="ma_km" value="<%= booking.ma_km || "" %>" />
      <input type="hidden" name="use_existing_customer" value="<%= booking.use_existing_customer ? "1" : "" %>" />
      <input type="hidden" name="services_json" value="<%= JSON.stringify(booking.services || []) %>" />
      <div class="review-actions">
        <button class="review-button review-button--primary" type="submit" name="btn_action" value="confirm">Tạo QR cọc 50%</button>
        <button class="review-button" type="submit" name="btn_action" value="review">Tính lại</button>
        <a class="review-button" href="<%= roomDetailUrl %>">Xem chi tiết phòng</a>
        <a class="review-button" href="/booking/rooms/<%= room.id %>?<%= searchQuery %>">Quay lại chỉnh sửa</a>
        <a class="review-button" href="<%= backSearchUrl %>">Đổi phòng</a>
      </div>
    </form>
  </section>
</main>
<%- include("../partials/footer") %>
