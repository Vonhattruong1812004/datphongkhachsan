  .promo-hero-main{border-radius:38px;padding:34px;min-height:286px;color:var(--promo-ink);background:var(--promo-card);display:grid;grid-template-columns:minmax(0,1fr) 320px;gap:24px;align-items:stretch}
  .promo-hero-main::before{content:"";position:absolute;inset:-1px;pointer-events:none;background:linear-gradient(120deg,rgba(255,255,255,.72),transparent 28%),radial-gradient(circle at 86% 18%,rgba(24,191,242,.24),transparent 30%),radial-gradient(circle at 16% 88%,rgba(183,239,74,.20),transparent 28%);opacity:1}
  .promo-hero-main::after{content:"";position:absolute;right:22px;top:22px;bottom:22px;width:320px;border-radius:32px;background:linear-gradient(145deg,rgba(14,38,58,.90),rgba(12,86,110,.74));box-shadow:inset 0 0 0 1px rgba(255,255,255,.16)}
  .promo-hero-content{max-width:720px}
  .promo-chip{border-radius:999px;padding:7px 12px;border:1px solid rgba(33,207,166,.24);background:rgba(33,207,166,.12);color:#087763;font-size:12px;font-weight:1000;letter-spacing:.09em}
