<%
  const promotions = payload.promotions || [];
  const stats = payload.stats || {};
  const noticeState = notice || {};
  const draftData = (typeof promotionDraft !== "undefined" && promotionDraft) ? promotionDraft : {};
  const editPromotionId = Number(draftData.promotion_id || payload.editPromotionId || 0);
  const editingPromotion = editPromotionId ? promotions.find((item) => Number(item.id) === editPromotionId) : null;
  const promotionForm = {
    promotion_id: draftData.promotion_id || editingPromotion?.id || "",
    ten_chuong_trinh: draftData.ten_chuong_trinh || editingPromotion?.tenChuongTrinh || "",
    ngay_bat_dau: draftData.ngay_bat_dau || editingPromotion?.startDate || "",
    ngay_ket_thuc: draftData.ngay_ket_thuc || editingPromotion?.endDate || "",
    muc_uu_dai: draftData.muc_uu_dai || editingPromotion?.mucUuDai || "",
    doi_tuong: draftData.doi_tuong || editingPromotion?.doiTuong || "TatCa",
    trang_thai: draftData.trang_thai || editingPromotion?.trangThai || "DangApDung",
    loai_uu_dai: draftData.loai_uu_dai || editingPromotion?.loaiUuDai || "PERCENT",
    kenh_ap_dung: draftData.kenh_ap_dung || editingPromotion?.promotionMeta?.channel || "All",
    so_dem_toi_thieu: draftData.so_dem_toi_thieu || editingPromotion?.promotionMeta?.minNights || "",
    gia_tri_toi_thieu: draftData.gia_tri_toi_thieu || editingPromotion?.promotionMeta?.minAmount || "",
    gioi_han_luot_dung: draftData.gioi_han_luot_dung || editingPromotion?.promotionMeta?.usageLimit || "",
    ngay_chan: draftData.ngay_chan || (editingPromotion?.promotionMeta?.blackoutDates || []).join(", "),
    chinh_sach_cong_don: draftData.chinh_sach_cong_don || editingPromotion?.promotionMeta?.stackPolicy || "NoStack",
    muc_tieu_chien_dich: draftData.muc_tieu_chien_dich || editingPromotion?.promotionMeta?.campaignGoal || ""
  };
  const statusLabel = (status) => ({
    DangApDung: "Đang áp dụng",
    TamNgung: "Tạm ngưng",
    HetHan: "Hết hạn"
  }[status] || status || "Không rõ");
  const typeLabel = (type) => type === "PERCENT" ? "Phần trăm" : "Số tiền cố định";
  const channelLabel = (value) => ({
    Direct: "Booking trực tiếp",
    Website: "Website",
    Frontdesk: "Lễ tân",
    CSKH: "CSKH tư vấn",
    All: "Tất cả kênh"
  }[value] || "Tất cả kênh");
  const stackLabel = (value) => ({
    NoStack: "Không cộng dồn",
    AllowServiceOnly: "Chỉ cộng dịch vụ",
    ManualReview: "Cần duyệt thủ công"
  }[value] || "Không cộng dồn");
  const timelineLabel = (item) => item.isExpiredByDate ? "Đã quá hạn theo ngày" : (item.isUpcoming ? "Sắp bắt đầu" : (item.isActiveWindow ? "Đang nằm trong thời gian áp dụng" : "Ngoài khung ngày"));
  const moneyText = (value) => Number(value || 0).toLocaleString("vi-VN");
  const dateLabel = (value) => {
    const text = String(value || "").slice(0, 10);
    const parts = text.split("-");
    return parts.length === 3 ? `${parts[2]}/${parts[1]}/${parts[0]}` : text;
  };
  const attentionPromotions = promotions.filter((item) => item.trangThai !== "DangApDung" || item.isExpiredByDate || item.totalUsageCount > 0 || ["rose", "amber"].includes(item.health?.tone || "")).slice(0, 6);
%>

<style>
  .promo-home {
    --promo-ink: #172033;
    --promo-muted: #667085;
    --promo-line: rgba(23, 32, 51, .10);
    --promo-card: rgba(255, 255, 255, .88);
    --promo-cyan: #00a6d6;
    --promo-mint: #19b879;
    --promo-sun: #f5b700;
    --promo-coral: #ff6b6b;
    --promo-berry: #d946ef;
    --promo-shadow: 0 18px 44px rgba(23, 32, 51, .09);
    --promo-shadow-pop: 0 24px 56px rgba(0, 166, 214, .16);
    min-height: calc(100vh - 84px);
    position: relative;
    isolation: isolate;
    overflow: clip;
    padding: 24px 18px 54px;
    color: var(--promo-ink);
    background:
      linear-gradient(118deg, transparent 0 58%, rgba(217, 70, 239, .08) 58% 68%, transparent 68%),
      linear-gradient(64deg, transparent 0 18%, rgba(245, 183, 0, .10) 18% 27%, transparent 27%),
      linear-gradient(135deg, rgba(255, 107, 107, .10), transparent 32%),
      linear-gradient(225deg, rgba(0, 166, 214, .12), transparent 38%),
      repeating-linear-gradient(90deg, rgba(23, 32, 51, .035) 0 1px, transparent 1px 44px),
      linear-gradient(180deg, #fffefa 0%, #f5fcff 48%, #fff8fb 100%);
  }
  .promo-home::before,
  .promo-home::after { content:""; position:absolute; pointer-events:none; z-index:-1; }
  .promo-home::before {
    inset:0 0 auto;
    height:9px;
    background:linear-gradient(90deg,var(--promo-coral),var(--promo-sun),var(--promo-mint),var(--promo-cyan),var(--promo-berry));
  }
  .promo-home::after {
    inset:auto 18px 18px;
    height:1px;
    background:linear-gradient(90deg,transparent,rgba(23,32,51,.18),transparent);
  }
  .promo-shell{max-width:1540px;margin:0 auto;position:relative}
  .promo-panel,.promo-hero-main,.promo-table-panel{border:1px solid var(--promo-line);background:var(--promo-card);box-shadow:var(--promo-shadow)}
  .promo-hero{margin:12px 0 16px}
  .promo-hero-main{position:relative;overflow:hidden;border-radius:8px;padding:26px 28px;color:#fff;background:#14243d;box-shadow:var(--promo-shadow-pop)}
  .promo-hero-main::before{content:"";position:absolute;inset:0;background:linear-gradient(100deg,rgba(255,107,107,.90),rgba(245,183,0,.82),rgba(25,184,121,.72),rgba(0,166,214,.72),rgba(217,70,239,.66)),#14243d;opacity:.94}
  .promo-hero-main::after{content:"";position:absolute;inset:0;background:linear-gradient(90deg,rgba(20,36,61,.88),rgba(20,36,61,.50) 46%,rgba(20,36,61,.12)),repeating-linear-gradient(135deg,rgba(255,255,255,.18) 0 1px,transparent 1px 16px)}
  .promo-hero-content{position:relative;z-index:1;max-width:850px}
  .promo-chip{display:inline-flex;align-items:center;gap:8px;border-radius:8px;padding:7px 10px;border:1px solid rgba(255,255,255,.28);background:rgba(255,255,255,.18);color:#fff;font-size:12px;font-weight:900;text-transform:uppercase}
  .promo-dot{width:8px;height:8px;border-radius:2px;background:#67e8f9;box-shadow:0 0 0 4px rgba(103,232,249,.18)}
  .promo-hero h1{margin:22px 0 10px;color:#fff;font-size:54px;line-height:1;letter-spacing:0}
  .promo-hero h1 span{color:#fff2a8}
  .promo-lead{max-width:760px;margin:0;color:rgba(255,255,255,.82);font-size:16px;line-height:1.65}
  .promo-actions{display:flex;flex-wrap:wrap;gap:9px;margin-top:20px}
  .promo-button{display:inline-flex;align-items:center;justify-content:center;min-height:40px;border-radius:8px;padding:9px 14px;border:1px solid rgba(23,32,51,.12);background:#fff;color:var(--promo-ink);text-decoration:none;font-size:14px;font-weight:850;cursor:pointer;transition:transform .16s ease, box-shadow .16s ease, border-color .16s ease}
  .promo-button:hover{transform:translateY(-1px);box-shadow:0 10px 24px rgba(23,32,51,.10);border-color:rgba(0,166,214,.32)}
  .promo-button:disabled{cursor:not-allowed;opacity:.62;transform:none;box-shadow:none}
  .promo-button--primary{color:#fff;border-color:transparent;background:linear-gradient(135deg,#00a6d6,#19b879);box-shadow:0 14px 28px rgba(0,166,214,.18)}
  .promo-button--danger{color:#b42318;border-color:rgba(255,107,107,.28);background:#fff7f7}
  .promo-hero-main .promo-button{border-color:rgba(255,255,255,.25);background:rgba(255,255,255,.94)}
  .promo-hero-main .promo-button--primary{background:#fff;color:#075985;box-shadow:0 16px 34px rgba(5,16,31,.24)}
  .promo-hero-mark{position:absolute;z-index:1;right:28px;bottom:24px;width:min(290px,28vw);display:grid;gap:8px}
  .promo-mark-line{height:12px;border-radius:8px;background:rgba(255,255,255,.22);overflow:hidden}
  .promo-mark-line span{display:block;height:100%;border-radius:inherit;background:#fff}
  .promo-mark-line:nth-child(1) span{width:84%;background:#67e8f9}
  .promo-mark-line:nth-child(2) span{width:60%;background:#fff2a8}
  .promo-mark-line:nth-child(3) span{width:76%;background:#bbf7d0}
  .promo-mark-line:nth-child(4) span{width:56%;background:#fecdd3}
  .promo-alert{margin:0 0 12px;border-radius:8px;padding:12px 14px;border:1px solid rgba(23,32,51,.10);font-size:14px;font-weight:800;line-height:1.5}
  .promo-alert--error{color:#b42318;background:#fff4f4;border-color:rgba(255,107,107,.30)}
  .promo-alert--success{color:#047857;background:#effcf6;border-color:rgba(25,184,121,.28)}
  .promo-summary{display:grid;grid-template-columns:repeat(7,minmax(0,1fr));gap:12px;margin-bottom:16px}
  .promo-stat{border-radius:8px;padding:16px;background:rgba(255,255,255,.86);border:1px solid rgba(23,32,51,.10);box-shadow:var(--promo-shadow)}
  .promo-stat strong{display:block;font-size:30px;line-height:1}
  .promo-stat span{display:block;margin-top:8px;color:var(--promo-muted);font-size:12px;font-weight:850;text-transform:uppercase}
  .promo-layout{display:grid;grid-template-columns:minmax(0,1.42fr) 300px;gap:16px;align-items:start}
  .promo-panel,.promo-table-panel{border-radius:8px;padding:18px}
  .promo-panel h2,.promo-table-panel h2{margin:0;font-size:23px}
  .promo-muted{color:var(--promo-muted);font-size:13px;line-height:1.55}
  .promo-field-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px;margin-top:16px}
  .promo-field{display:grid;gap:7px}
  .promo-field.is-wide{grid-column:1 / -1}
  .promo-field label{color:#405066;font-size:12px;font-weight:850;text-transform:uppercase}
  .promo-field input,.promo-field select,.promo-field textarea{width:100%;min-height:42px;border-radius:8px;border:1px solid rgba(23,32,51,.12);background:#fff;color:var(--promo-ink);padding:10px 12px;outline:none;font:inherit}
  .promo-field textarea{min-height:84px;resize:vertical}
  .promo-field input:focus,.promo-field select:focus,.promo-field textarea:focus{border-color:rgba(0,166,214,.55);box-shadow:0 0 0 4px rgba(0,166,214,.12)}
  .promo-field-hint{color:var(--promo-muted);font-size:11px;font-weight:700;line-height:1.45}
  .promo-form-actions{display:flex;flex-wrap:wrap;gap:10px;margin-top:14px}
  .promo-filter-grid{display:grid;grid-template-columns:1.55fr repeat(5,minmax(0,1fr));gap:10px;margin-top:16px}
  .promo-live-pill{display:inline-flex;align-items:center;gap:8px;min-height:34px;border-radius:8px;padding:7px 10px;color:#087894;background:#effbff;border:1px solid rgba(0,166,214,.22);font-size:12px;font-weight:850}
  .promo-live-pill::before{content:"";width:8px;height:8px;border-radius:2px;background:var(--promo-mint)}
  .promo-table-panel{position:relative;overflow:hidden}
  .promo-table-panel::before{content:"";position:absolute;inset:0 0 auto;height:5px;background:linear-gradient(90deg,var(--promo-cyan),var(--promo-mint),var(--promo-sun),var(--promo-coral))}
  .promo-table-wrap{overflow:auto;margin-top:14px;border-radius:8px;border:1px solid rgba(23,32,51,.10);background:#fff}
  .promo-table{width:100%;min-width:1180px;border-collapse:collapse;table-layout:fixed}
  .promo-table th{position:sticky;top:0;z-index:1;padding:12px;color:#405066;font-size:12px;text-align:left;text-transform:uppercase;background:#f4fbff;border-bottom:1px solid rgba(23,32,51,.08)}
  .promo-table td{padding:12px;border-top:1px solid rgba(23,32,51,.07);vertical-align:top;word-break:break-word}
  .promo-table tbody tr:hover{background:#fffdf2;box-shadow:inset 5px 0 0 var(--promo-coral)}
  .promo-code{display:grid;gap:4px;min-width:0}
  .promo-code strong{font-size:17px}
  .promo-code span{color:var(--promo-muted);font-size:12px}
  .promo-status{display:inline-flex;align-items:center;border-radius:8px;padding:6px 9px;font-size:12px;font-weight:850}
  .promo-status--green{color:#047857;background:#effcf6;box-shadow:inset 0 0 0 1px rgba(25,184,121,.16)}
  .promo-status--cyan{color:#087894;background:#effbff;box-shadow:inset 0 0 0 1px rgba(0,166,214,.16)}
  .promo-status--amber{color:#8a5a00;background:#fff8d7;box-shadow:inset 0 0 0 1px rgba(245,183,0,.18)}
  .promo-status--rose{color:#b42318;background:#fff4f4;box-shadow:inset 0 0 0 1px rgba(255,107,107,.18)}
  .promo-status--berry{color:#9d174d;background:#fdf2f8;box-shadow:inset 0 0 0 1px rgba(217,70,239,.16)}
  .promo-status--slate{color:#475569;background:#f3f5f8;box-shadow:inset 0 0 0 1px rgba(71,85,105,.12)}
  .promo-value{font-weight:900;color:#047857}
  .promo-mini-grid{display:grid;gap:6px;margin-top:8px}
  .promo-condition{display:flex;flex-wrap:wrap;gap:6px;margin-top:8px}
  .promo-tag{display:inline-flex;align-items:center;border-radius:8px;padding:5px 7px;color:#405066;background:#f8fafc;border:1px solid rgba(23,32,51,.08);font-size:11px;font-weight:850}
  .promo-meter{height:8px;border-radius:999px;background:#edf2f7;overflow:hidden;margin-top:8px}
  .promo-meter span{display:block;height:100%;border-radius:inherit;background:linear-gradient(90deg,var(--promo-cyan),var(--promo-mint),var(--promo-sun))}
  .promo-health{margin-top:8px;border-radius:8px;padding:9px 10px;background:#f8fafc;border:1px solid rgba(23,32,51,.08)}
  .promo-health strong{display:block;font-size:13px}
  .promo-health p{margin:4px 0 0}
  .promo-row-actions{display:grid;grid-template-columns:repeat(2,minmax(68px,max-content));gap:7px}
  .promo-row-actions form{margin:0}
  .promo-row-actions .promo-button{min-height:34px;padding:7px 10px;font-size:12px}
  .promo-preview{margin-top:14px;display:grid;gap:12px;padding:14px;border-radius:8px;border:1px solid rgba(23,32,51,.10);background:linear-gradient(180deg,#ffffff,#f8fbff)}
  .promo-preview-meta{display:grid;gap:6px}
  .promo-preview-meta strong{font-size:17px}
  .promo-insight-list{display:grid;gap:10px;margin-top:14px}
  .promo-insight{border-radius:8px;padding:14px;background:#fff;border:1px solid rgba(23,32,51,.08);border-left:5px solid var(--promo-coral)}
  .promo-empty{border:1px dashed rgba(23,32,51,.14);border-radius:8px;padding:18px;color:var(--promo-muted);background:rgba(255,255,255,.78)}
  .promo-no-results{display:none}
  .promo-table th:nth-child(1), .promo-table td:nth-child(1){width:18%}
  .promo-table th:nth-child(2), .promo-table td:nth-child(2){width:14%}
  .promo-table th:nth-child(3), .promo-table td:nth-child(3){width:12%}
  .promo-table th:nth-child(4), .promo-table td:nth-child(4){width:18%}
  .promo-table th:nth-child(5), .promo-table td:nth-child(5){width:14%}
  .promo-table th:nth-child(6), .promo-table td:nth-child(6){width:14%}
  .promo-table th:nth-child(7), .promo-table td:nth-child(7){width:10%}
  @media(max-width:1280px){.promo-summary{grid-template-columns:repeat(3,minmax(0,1fr))}.promo-layout{grid-template-columns:1fr}.promo-filter-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.promo-field-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.promo-hero-mark{display:none}.promo-table{min-width:0;table-layout:auto}}
  @media(max-width:720px){.promo-home{padding:18px 12px 42px}.promo-hero-main{min-height:auto;padding:20px}.promo-hero h1{font-size:38px}.promo-summary{grid-template-columns:1fr 1fr}.promo-filter-grid,.promo-field-grid{grid-template-columns:1fr}.promo-field.is-wide{grid-column:auto}.promo-row-actions{grid-template-columns:1fr}}

  body{background:radial-gradient(circle at 7% 8%,rgba(33,207,166,.30),transparent 30%),radial-gradient(circle at 84% 10%,rgba(255,111,163,.20),transparent 32%),radial-gradient(circle at 50% 104%,rgba(183,239,74,.22),transparent 38%),linear-gradient(135deg,#fbfffb 0%,#eafcff 42%,#fff7ed 100%);color:#112233}
  .promo-home{--promo-ink:#112233;--promo-muted:#667085;--promo-line:rgba(17,34,51,.10);--promo-card:rgba(255,255,255,.76);--promo-card-strong:rgba(255,255,255,.92);--promo-cyan:#18bff2;--promo-mint:#21cfa6;--promo-lime:#b7ef4a;--promo-pink:#ff6fa3;--promo-violet:#8b6bff;--promo-sun:#ffd166;--promo-coral:#ff9f7a;--promo-shadow:0 28px 86px rgba(18,38,63,.17);min-height:auto;max-width:1240px;margin:0 auto;padding:34px 18px 62px;background:transparent;overflow:hidden}
  .promo-home::before,.promo-home::after{content:"";position:absolute;pointer-events:none;z-index:-1;border-radius:999px;opacity:.42;animation:promo-float 14s ease-in-out infinite alternate}
  .promo-home::before{width:580px;height:580px;right:-210px;top:-260px;background:conic-gradient(from 160deg,rgba(24,191,242,.48),rgba(33,207,166,.34),rgba(183,239,74,.30),rgba(255,111,163,.24),rgba(24,191,242,.48))}
  .promo-home::after{width:500px;height:500px;left:-220px;bottom:-260px;background:conic-gradient(from 20deg,rgba(255,159,122,.32),rgba(255,209,102,.30),rgba(24,191,242,.26),rgba(139,107,255,.22),rgba(255,159,122,.32));animation-delay:-4s}
  .promo-shell{max-width:1240px}
  .promo-panel,.promo-hero-main,.promo-table-panel,.promo-stat{border:1px solid var(--promo-line);background:var(--promo-card);box-shadow:var(--promo-shadow);backdrop-filter:blur(26px)}
