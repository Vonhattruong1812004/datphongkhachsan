  .promo-button:hover{transform:translateY(-2px);border-color:rgba(24,191,242,.34);box-shadow:0 18px 44px rgba(24,191,242,.16)}
  .promo-button--primary{color:#fff;border-color:transparent;background:linear-gradient(135deg,#08a5c8,#21cfa6);box-shadow:0 18px 42px rgba(33,207,166,.24)}
  .promo-button--danger{color:#fff;border-color:transparent;background:linear-gradient(135deg,#f43f5e,#ff9f7a)}
  .promo-hero-main .promo-button{border-color:rgba(17,34,51,.12);background:rgba(255,255,255,.78);color:var(--promo-ink)}
  .promo-hero-main .promo-button--primary{color:#fff;background:linear-gradient(135deg,#08a5c8,#21cfa6);box-shadow:0 18px 42px rgba(33,207,166,.24)}
  .promo-hero-mark{right:50px;top:50%;bottom:auto;transform:translateY(-50%);width:230px;z-index:2;gap:12px}
  .promo-mark-line{height:18px;border-radius:999px;background:rgba(255,255,255,.18);box-shadow:0 14px 34px rgba(2,8,23,.18)}
