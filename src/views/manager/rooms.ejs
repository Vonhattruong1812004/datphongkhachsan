<%- include("../partials/head") %>
<%- include("../partials/header") %>
<%
  const rooms = payload.rooms || [];
  const hotels = payload.hotels || [];
  const stats = payload.stats || {};
  const noticeState = notice || {};
  const roomDraftData = (typeof roomDraft !== "undefined" && roomDraft) ? roomDraft : {};
  const resolveRoomImageUrl = (rawPath) => {
    const value = String(rawPath || "").trim();
    if (!value) return "";
    if (/^https?:\/\//i.test(value) || value.startsWith("/uploads/phong/")) return value;

    const fileName = value
      .replace(/\\/g, "/")
      .replace(/^\/?public\/uploads\/phong\//i, "")
      .replace(/^\/?uploads\/phong\//i, "")
      .replace(/^\/?phong\//i, "")
      .replace(/^\/?rooms\//i, "")
      .split("/")
      .filter(Boolean)
      .pop();

    return fileName ? `/uploads/phong/${encodeURIComponent(fileName)}` : "";
  };
  const editRoomId = Number(roomDraftData.room_id || payload.editRoomId || 0);
  const focusedRoomId = Number(payload.focusedRoomId || 0);
  const editingRoom = editRoomId ? rooms.find((item) => Number(item.id) === editRoomId) : null;
  const roomForm = {
    room_id: roomDraftData.room_id || editingRoom?.id || "",
    hotel_id: Number(roomDraftData.hotel_id || editingRoom?.hotelId || 0),
    so_phong: roomDraftData.so_phong || editingRoom?.soPhong || "",
    loai_phong: roomDraftData.loai_phong || editingRoom?.loaiPhong || "Standard",
    dien_tich: roomDraftData.dien_tich || editingRoom?.dienTich || "",
    loai_giuong: roomDraftData.loai_giuong || editingRoom?.loaiGiuong || "",
    view_phong: roomDraftData.view_phong || editingRoom?.viewLabel || "Biển",
    gia: roomDraftData.gia || editingRoom?.gia || "",
    so_khach_toi_da: roomDraftData.so_khach_toi_da || editingRoom?.soKhachToiDa || "",
    tinh_trang_phong: roomDraftData.tinh_trang_phong || editingRoom?.tinhTrangPhong || "Tot",
    ghi_chu: roomDraftData.ghi_chu || editingRoom?.ghiChu || "",
    hinh_anh: roomDraftData.hinh_anh || editingRoom?.hinhAnh || ""
  };
  const previewImageUrl = resolveRoomImageUrl(roomForm.hinh_anh) || (editingRoom?.imageUrl || "");
  const attentionRooms = rooms.filter((item) => item.tinhTrangPhong !== "Tot" || item.trangThai === "BaoTri").slice(0, 6);
  const roomStatusLabel = (status) => ({
    Trong: "Trống",
    Booked: "Đã đặt",
    Stayed: "Đang ở",
    BaoTri: "Bảo trì"
  }[status] || status || "Không rõ");
  const roomConditionLabel = (status) => ({
    Tot: "Tốt",
    CanVeSinh: "Cần vệ sinh",
    HuHaiNhe: "Hư hại nhẹ",
    HuHaiNang: "Hư hại nặng",
    DangBaoTri: "Đang bảo trì"
  }[status] || status || "Không rõ");
  const roomRealtimeLabel = (status) => ({
    Available: "Sẵn sàng",
    Booked: "Đã giữ chỗ",
    Stayed: "Đang lưu trú",
    Cleaning: "Chờ vệ sinh",
    Maintenance: "Bảo trì"
  }[status] || status || "Không rõ");
%>

<style>
  .room-home {
    --room-ink: #f8fbff;
    --room-muted: #c8d8f4;
    --room-line: rgba(125, 211, 252, .22);
    --room-card: rgba(8, 13, 31, .82);
    --room-soft: rgba(15, 23, 42, .74);
    --room-surface: #f8fcff;
    --room-surface-strong: #ffffff;
    --room-form-ink: #102033;
    --room-form-muted: #5f6f83;
    --room-cyan: #22d3ee;
    --room-mint: #34d399;
    --room-sun: #fbbf24;
    --room-coral: #fb7185;
    --room-berry: #a78bfa;
    --room-shadow: 0 28px 90px rgba(0, 0, 0, .34);
    --room-shadow-pop: 0 30px 96px rgba(34, 211, 238, .18);
    min-height: calc(100vh - 84px);
    position: relative;
    isolation: isolate;
    overflow: clip;
    padding: 24px 18px 54px;
    color: var(--room-ink);
    background:
      radial-gradient(ellipse at 50% 118%, rgba(34,211,238,.14), transparent 42%),
      radial-gradient(ellipse at 13% 14%, rgba(37,99,235,.30), transparent 34%),
      radial-gradient(ellipse at 86% 10%, rgba(168,85,247,.22), transparent 32%),
      radial-gradient(ellipse at 74% 82%, rgba(20,184,166,.12), transparent 34%),
      linear-gradient(180deg, #020617 0%, #071126 48%, #140a2f 78%, #020617 100%);
  }
  .room-home::before,
  .room-home::after { content: ""; position: absolute; pointer-events: none; z-index: -1; }
  .room-home::before {
    inset: -18%;
    height: auto;
    opacity: .46;
    background:
      radial-gradient(circle, rgba(255,255,255,.92) 0 .8px, transparent 1.8px),
      radial-gradient(circle, rgba(125,211,252,.62) 0 1px, transparent 2.2px),
      radial-gradient(circle, rgba(196,181,253,.48) 0 .8px, transparent 1.9px);
    background-size: 118px 118px, 196px 196px, 310px 310px;
    animation: room-star-drift 130s linear infinite;
  }
  .room-home::after {
    inset: -10%;
    height: auto;
    opacity: .28;
    background:
      radial-gradient(ellipse at 18% 24%, rgba(59,130,246,.30), transparent 29%),
      radial-gradient(ellipse at 72% 18%, rgba(168,85,247,.24), transparent 30%),
      radial-gradient(ellipse at 70% 78%, rgba(20,184,166,.16), transparent 34%),
      radial-gradient(ellipse at 48% 52%, rgba(255,255,255,.12), transparent 18%);
    filter: blur(2px);
    animation: room-nebula-breathe 22s ease-in-out infinite alternate;
  }
  .room-shell { max-width: 1320px; margin: 0 auto; position: relative; }
  .room-panel,
  .room-hero-main,
  .room-table-panel {
    border: 1px solid var(--room-line);
    background: var(--room-card);
    box-shadow: var(--room-shadow);
    backdrop-filter: blur(24px);
  }
  .room-hero { margin: 12px 0 16px; }
  .room-hero-main {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    padding: 30px 32px;
    color: #fff;
    background: rgba(8,13,31,.88);
    box-shadow: var(--room-shadow-pop);
    border-color: rgba(125,211,252,.24);
    min-height: 260px;
  }
  .room-hero-main::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 82% 14%, rgba(34,211,238,.22), transparent 32%),
      radial-gradient(circle at 18% 88%, rgba(168,85,247,.18), transparent 30%),
      linear-gradient(145deg, rgba(8,13,31,.92), rgba(15,23,42,.74));
    opacity: 1;
  }
  .room-hero-main::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 18%, rgba(255,255,255,.76) 0 1px, transparent 2px),
      radial-gradient(circle at 68% 34%, rgba(125,211,252,.68) 0 1px, transparent 2px),
      radial-gradient(circle at 88% 74%, rgba(196,181,253,.70) 0 1px, transparent 2px);
    background-size: 160px 130px, 210px 170px, 250px 210px;
    opacity: .54;
  }
  .room-hero-content { position: relative; z-index: 1; max-width: 850px; }
  .room-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-radius: 999px;
    padding: 7px 12px;
    border: 1px solid rgba(125,211,252,.28);
    background: rgba(15,23,42,.72);
    color: #e6fbff;
    font-size: 12px;
    font-weight: 900;
    text-transform: uppercase;
  }
  .room-dot { width: 8px; height: 8px; border-radius: 999px; background: var(--room-cyan); box-shadow: 0 0 0 7px rgba(34,211,238,.16), 0 0 22px rgba(34,211,238,.46); }
  .room-hero h1 { margin: 22px 0 12px; color: #fff; font-size: clamp(42px, 6vw, 70px); line-height: .98; letter-spacing: 0; text-shadow: 0 0 30px rgba(103,232,249,.16); }
  .room-hero h1 span { color: transparent; background: linear-gradient(96deg, #22d3ee 0%, #38bdf8 32%, #a78bfa 66%, #f472b6 100%); -webkit-background-clip: text; background-clip: text; }
  .room-lead { max-width: 760px; margin: 0; color: #cfe8ff; font-size: 16px; line-height: 1.65; }
  .room-actions { display: flex; flex-wrap: wrap; gap: 9px; margin-top: 20px; }
  .room-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    border-radius: 999px;
    padding: 9px 16px;
    border: 1px solid rgba(125,211,252,.22);
    background: rgba(15,23,42,.72);
    color: #eef6ff;
    text-decoration: none;
    font-size: 14px;
    font-weight: 850;
    cursor: pointer;
    transition: transform .16s ease, box-shadow .16s ease, border-color .16s ease, background .16s ease;
  }
  .room-button:hover { transform: translateY(-1px); box-shadow: 0 14px 34px rgba(34,211,238,.14); border-color: rgba(34,211,238,.48); }
  .room-button:disabled { cursor: not-allowed; opacity: .62; transform: none; box-shadow: none; }
  .room-button--primary { color: #031827; border-color: transparent; background: linear-gradient(135deg, #67e8f9, #38bdf8 48%, #a78bfa); box-shadow: 0 16px 38px rgba(56,189,248,.20); }
  .room-button--danger { color: #fff; border-color: rgba(251,113,133,.34); background: linear-gradient(135deg, #fb7185, #ef4444); }
  .room-hero-main .room-button { color: #075985; border-color: rgba(255,255,255,.25); background: rgba(255,255,255,.94); }
  .room-hero-main .room-button--primary { background: #fff; color: #075985; box-shadow: 0 16px 34px rgba(5,16,31,.24); }
  .room-hero-mark { position: absolute; z-index: 1; right: 28px; bottom: 24px; width: min(320px, 28vw); height: 156px; border-radius: 8px; border: 1px solid rgba(125,211,252,.18); background: rgba(2,6,23,.36); overflow: hidden; }
  .room-hero-mark::before { content: ""; position: absolute; left: 50%; top: 52%; width: 126px; height: 126px; border-radius: 50%; transform: translate(-50%, -50%); background: radial-gradient(circle at 34% 34%, #67e8f9 0 12%, #2563eb 44%, #020617 78%); box-shadow: 0 0 38px rgba(34,211,238,.34), 0 0 90px rgba(37,99,235,.28); }
  .room-hero-mark::after { content: ""; position: absolute; left: 50%; top: 52%; width: 252px; height: 88px; border-radius: 50%; border: 1px solid rgba(125,211,252,.22); transform: translate(-50%, -50%) rotate(-15deg); }
  .room-mark-line { position: absolute; height: 2px; border-radius: 999px; background: linear-gradient(90deg, transparent, rgba(255,255,255,.92)); filter: drop-shadow(0 0 8px rgba(125,211,252,.48)); opacity: .72; }
  .room-mark-line span { display: none; }
  .room-mark-line:nth-child(1) { width: 92px; left: 18px; top: 34px; }
  .room-mark-line:nth-child(2) { width: 52px; right: 34px; top: 42px; transform: rotate(90deg); background: radial-gradient(circle, #fde68a, #fb923c); height: 22px; border-radius: 50%; }
  .room-mark-line:nth-child(3) { width: 26px; left: 54px; bottom: 38px; transform: rotate(90deg); background: radial-gradient(circle, #ffffff, #94a3b8); height: 26px; border-radius: 50%; }
  .room-mark-line:nth-child(4) { width: 96px; right: -16px; bottom: 36px; transform: rotate(180deg); }
  .room-alert { margin: 0 0 12px; border-radius: 8px; padding: 12px 14px; border: 1px solid rgba(23,32,51,.10); font-size: 14px; font-weight: 800; line-height: 1.5; }
  .room-alert--error { color: #b42318; background: #fff4f4; border-color: rgba(255,107,107,.30); }
  .room-alert--success { color: #047857; background: #effcf6; border-color: rgba(25,184,121,.28); }
  .room-summary { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 12px; margin-bottom: 16px; }
  .room-stat {
    border-radius: 8px;
    padding: 16px;
    color: #fff;
    background: linear-gradient(135deg, #2dd4bf 0%, #0ea5e9 56%, #2563eb 100%);
    border: 1px solid rgba(255,255,255,.24);
    box-shadow: 0 22px 64px rgba(14,165,233,.22), 0 18px 70px rgba(0,0,0,.20);
  }
  .room-stat:nth-child(2) { background: linear-gradient(135deg, #86efac 0%, #22c55e 46%, #14b8a6 100%); }
  .room-stat:nth-child(3) { background: linear-gradient(135deg, #fbbf24 0%, #fb7185 54%, #db2777 100%); }
  .room-stat:nth-child(4) { background: linear-gradient(135deg, #c084fc 0%, #6366f1 52%, #06b6d4 100%); }
  .room-stat:nth-child(5) { background: linear-gradient(135deg, #fde68a 0%, #fb923c 48%, #ef4444 100%); }
  .room-stat strong { display: block; font-size: 30px; line-height: 1; }
  .room-stat span { display: block; margin-top: 8px; color: rgba(255,255,255,.88); font-size: 12px; font-weight: 850; text-transform: uppercase; }
  .room-layout { display: grid; grid-template-columns: minmax(0, 1.15fr) 360px; gap: 16px; align-items: start; }
  .room-panel,
  .room-table-panel { border-radius: 8px; padding: 18px; }
  .room-panel h2,
  .room-table-panel h2 { margin: 0; color: #fff; font-size: 25px; letter-spacing: 0; }
  .room-section-head { display: flex; justify-content: space-between; gap: 14px; align-items: flex-end; flex-wrap: wrap; }
  .room-muted { color: var(--room-muted); font-size: 13px; line-height: 1.55; }
  .room-field-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; margin-top: 18px; }
  .room-field { position: relative; display: grid; gap: 7px; }
  .room-field.is-wide { grid-column: 1 / -1; }
  .room-field label { color: #e6fbff; font-size: 12px; font-weight: 850; text-transform: uppercase; }
  .room-field input,
  .room-field select,
  .room-field textarea {
    width: 100%;
    min-height: 46px;
    border-radius: 8px;
    border: 2px solid rgba(15,23,42,.12);
    background: #fff;
    color: var(--room-form-ink);
    padding: 10px 12px;
    outline: none;
    font: inherit;
    box-shadow: 0 12px 28px rgba(2,6,23,.16);
  }
  .room-field textarea { min-height: 104px; resize: vertical; }
  .room-field input:focus,
  .room-field select:focus,
  .room-field textarea:focus { border-color: rgba(34,211,238,.70); box-shadow: 0 0 0 4px rgba(34,211,238,.16), 0 16px 34px rgba(2,6,23,.18); }
  .room-stepper { display: grid; grid-template-columns: 42px minmax(0, 1fr) 42px; gap: 8px; align-items: center; }
  .room-stepper input { text-align: center; font-weight: 900; }
  .room-step-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 8px;
    border: 1px solid rgba(125,211,252,.28);
    background: rgba(15,23,42,.78);
    color: #e6fbff;
    font: inherit;
    font-size: 20px;
    font-weight: 950;
    line-height: 1;
    cursor: pointer;
    transition: transform .16s ease, box-shadow .16s ease, border-color .16s ease;
  }
  .room-step-button:hover { transform: translateY(-1px); box-shadow: 0 10px 22px rgba(23,32,51,.10); border-color: rgba(0,166,214,.34); }
  .room-step-button:active { transform: translateY(0); }
  .room-help { margin: 0; color: #bcd4f5; font-size: 12px; line-height: 1.45; }
  .room-field-error { display: none; margin: 0; color: #b42318; font-size: 12px; font-weight: 850; line-height: 1.45; }
  .room-field.is-invalid input,
  .room-field.is-invalid select,
  .room-field.is-invalid textarea { border-color: rgba(255,107,107,.70); background: #fff8f8; box-shadow: 0 0 0 4px rgba(255,107,107,.10); }
  .room-field.is-invalid .room-field-error { display: block; }
  .room-field.is-valid input,
  .room-field.is-valid select,
  .room-field.is-valid textarea { border-color: rgba(25,184,121,.48); box-shadow: 0 0 0 4px rgba(25,184,121,.09); }
  .room-form-actions { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 14px; }
  .room-filter-grid { display: grid; grid-template-columns: 1.5fr repeat(4, minmax(0, 1fr)); gap: 14px; margin-top: 18px; }
  .room-live-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 36px;
    border-radius: 999px;
    padding: 7px 12px;
    color: #e6fbff;
    background: rgba(34,211,238,.14);
    border: 1px solid rgba(125,211,252,.22);
    font-size: 12px;
    font-weight: 850;
  }
  .room-live-pill::before { content: ""; width: 8px; height: 8px; border-radius: 2px; background: var(--room-mint); }
  .room-table-panel { position: relative; overflow: hidden; border-color: rgba(125,211,252,.22); background: var(--room-card); }
  .room-table-panel::before { content: ""; position: absolute; inset: 0 0 auto; height: 5px; background: linear-gradient(90deg, var(--room-cyan), var(--room-mint), var(--room-sun), var(--room-coral)); }
  .room-table-wrap { overflow: auto; margin-top: 16px; border-radius: 8px; border: 1px solid rgba(125,211,252,.20); background: var(--room-surface-strong); box-shadow: inset 0 1px 0 rgba(255,255,255,.60); }
  .room-table { width: 100%; min-width: 1180px; border-collapse: collapse; }
  .room-table th {
    position: sticky;
    top: 0;
    z-index: 1;
    padding: 14px 16px;
    color: #0f2b42;
    font-size: 12px;
    text-align: left;
    text-transform: uppercase;
    background: linear-gradient(180deg, #e9f8ff, #dff5ff);
    border-bottom: 1px solid rgba(15,43,66,.12);
  }
  .room-table td { padding: 16px; border-top: 1px solid rgba(15,43,66,.08); vertical-align: top; color: var(--room-form-ink); }
  .room-table .room-muted { color: var(--room-form-muted); }
  .room-table tbody tr:hover { background: #f0fbff; box-shadow: inset 5px 0 0 var(--room-cyan); }
  .room-table tbody tr.is-focused { background: #ecfeff; box-shadow: inset 5px 0 0 var(--room-cyan); }
  .room-thumb {
    width: 84px;
    height: 62px;
    border-radius: 8px;
    object-fit: cover;
    border: 1px solid rgba(23,32,51,.10);
    background: #e9eef5;
    display: block;
  }
  .room-thumb--placeholder {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #405066;
    font-size: 13px;
    font-weight: 900;
    background: linear-gradient(135deg, rgba(0,166,214,.14), rgba(25,184,121,.16));
  }
  .room-code { display: grid; gap: 4px; min-width: 0; }
  .room-code strong { font-size: 18px; }
  .room-code span { color: var(--room-form-muted); font-size: 12px; }
  .room-status {
    display: inline-flex;
    align-items: center;
    border-radius: 8px;
    padding: 6px 9px;
    font-size: 12px;
    font-weight: 850;
  }
  .room-status--green { color: #047857; background: #effcf6; box-shadow: inset 0 0 0 1px rgba(25,184,121,.16); }
  .room-status--cyan { color: #087894; background: #effbff; box-shadow: inset 0 0 0 1px rgba(0,166,214,.16); }
  .room-status--amber { color: #8a5a00; background: #fff8d7; box-shadow: inset 0 0 0 1px rgba(245,183,0,.18); }
  .room-status--rose { color: #b42318; background: #fff4f4; box-shadow: inset 0 0 0 1px rgba(255,107,107,.18); }
  .room-status--slate { color: #475569; background: #f3f5f8; box-shadow: inset 0 0 0 1px rgba(71,85,105,.12); }
  .room-price { font-weight: 900; color: #047857; white-space: nowrap; }
  .room-row-actions { display: grid; grid-template-columns: repeat(2, minmax(74px, max-content)); gap: 7px; }
  .room-row-actions form { margin: 0; }
  .room-row-actions .room-button { min-height: 34px; padding: 7px 10px; font-size: 12px; }
  .room-row-actions .room-button { color: #102033; background: #e9f8ff; border-color: rgba(14,165,233,.20); }
  .room-row-actions .room-button--danger { color: #fff; border-color: transparent; background: linear-gradient(135deg, #fb7185, #ef4444); }
  .room-row-actions .room-button:disabled { color: #64748b; background: #f1f5f9; border-color: rgba(100,116,139,.18); }
  .room-preview {
    margin-top: 14px;
    display: grid;
    gap: 12px;
    padding: 14px;
    border-radius: 8px;
    border: 1px solid rgba(125,211,252,.18);
    background: var(--room-surface-strong);
    color: var(--room-form-ink);
  }
  .room-preview img {
    width: 100%;
    border-radius: 8px;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    background: #e9eef5;
    border: 1px solid rgba(23,32,51,.08);
  }
  .room-preview-meta { display: grid; gap: 6px; }
  .room-preview-meta strong { font-size: 17px; color: var(--room-form-ink); }
  .room-preview .room-muted,
  .room-preview-meta .room-muted { color: var(--room-form-muted); }
  .room-insight-list { display: grid; gap: 10px; margin-top: 14px; }
  .room-insight {
    border-radius: 8px;
    padding: 14px;
    background: var(--room-surface-strong);
    border: 1px solid rgba(125,211,252,.18);
    border-left: 5px solid var(--room-coral);
    color: var(--room-form-ink);
  }
  .room-insight .room-muted,
  .room-insight a { color: var(--room-form-muted); }
  .room-empty {
    border: 1px dashed rgba(125,211,252,.24);
    border-radius: 8px;
    padding: 18px;
    color: #dbeafe;
    background: rgba(15,23,42,.72);
  }
  .room-no-results { display: none; }

  /* Manager rooms cleanup: stars stay in the fixed global galaxy only. */
  .room-home {
    overflow: visible !important;
    background:
      linear-gradient(135deg, rgba(3,17,31,.86) 0%, rgba(7,22,52,.80) 48%, rgba(22,13,51,.84) 100%) !important;
  }

  .room-home::before,
  .room-home::after {
    display: none !important;
    content: none !important;
    animation: none !important;
  }

  .room-panel,
  .room-hero-main,
  .room-table-panel {
    -webkit-backdrop-filter: none !important;
    backdrop-filter: none !important;
    will-change: auto !important;
  }

  @keyframes room-star-drift { from { transform: translate3d(0,0,0); } to { transform: translate3d(-120px,90px,0); } }
  @keyframes room-nebula-breathe { from { transform: scale(.98); opacity: .18; } to { transform: scale(1.04); opacity: .34; } }
  @media (max-width: 1180px) {
    .room-summary { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .room-layout { grid-template-columns: 1fr; }
    .room-filter-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .room-field-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .room-hero-mark { display: none; }
  }
  @media (max-width: 720px) {
    .room-home { padding: 18px 12px 42px; }
    .room-hero-main { min-height: auto; padding: 20px; }
    .room-hero h1 { font-size: 38px; }
    .room-summary { grid-template-columns: 1fr 1fr; }
    .room-filter-grid,
    .room-field-grid { grid-template-columns: 1fr; }
    .room-field.is-wide { grid-column: auto; }
    .room-row-actions { grid-template-columns: 1fr; }
  }
</style>

<main class="room-home">
  <div class="room-shell">
    <section class="room-hero">
      <div class="room-hero-main">
        <div class="room-hero-content">
          <div class="room-chip"><span class="room-dot"></span> Quản lý phòng</div>
          <h1>Quản lý <span>phòng</span></h1>
          <p class="room-lead">Theo dõi phòng, ảnh, loại phòng, sức chứa, tình trạng thực tế và trạng thái khai thác theo từng cơ sở.</p>
          <div class="room-actions">
            <a class="room-button room-button--primary" href="/dashboard/quanly">Về dashboard</a>
            <% if (roomForm.room_id) { %>
              <a class="room-button" href="/manager/rooms">Tạo phòng mới</a>
            <% } %>
          </div>
        </div>
        <div class="room-hero-mark" aria-hidden="true">
          <div class="room-mark-line"><span></span></div>
          <div class="room-mark-line"><span></span></div>
          <div class="room-mark-line"><span></span></div>
          <div class="room-mark-line"><span></span></div>
        </div>
      </div>
    </section>

    <% if (noticeState.error) { %><div class="room-alert room-alert--error"><%= noticeState.error %></div><% } %>
    <% if (noticeState.success) { %><div class="room-alert room-alert--success"><%= noticeState.success %></div><% } %>

    <section class="room-summary" aria-label="Tóm tắt phòng">
      <article class="room-stat"><strong><%= stats.total || 0 %></strong><span>Tổng phòng</span></article>
      <article class="room-stat"><strong><%= stats.available || 0 %></strong><span>Đang trống</span></article>
      <article class="room-stat"><strong><%= stats.booked || 0 %></strong><span>Đã đặt</span></article>
      <article class="room-stat"><strong><%= stats.stayed || 0 %></strong><span>Đang ở</span></article>
      <article class="room-stat"><strong><%= stats.attention || 0 %></strong><span>Cần chú ý</span></article>
    </section>

    <section class="room-layout">
      <div style="display:grid;gap:16px">
        <section class="room-panel">
          <div class="room-section-head">
            <div>
              <h2><%= roomForm.room_id ? "Cập nhật phòng" : "Thêm phòng mới" %></h2>
              <p class="room-muted">Số phòng chỉ cần duy nhất trong cùng một cơ sở, không bắt buộc duy nhất toàn hệ thống.</p>
            </div>
            <span class="room-live-pill"><%= roomForm.room_id ? "Đang sửa phòng hiện có" : "Sẵn sàng thêm phòng mới" %></span>
          </div>
          <% if (editingRoom && !editingRoom.canEditStructure) { %>
            <div class="room-alert room-alert--error" style="margin-top:12px">
              Phòng này đang có booking hoặc khách ở. Bạn chỉ nên cập nhật ghi chú/ảnh; hệ thống sẽ chặn thay đổi cơ sở, số phòng, loại, giá, sức chứa hoặc tình trạng thực tế.
            </div>
          <% } %>

          <form method="post" action="/manager/rooms" enctype="multipart/form-data" id="roomForm" data-room-form novalidate>
            <input type="hidden" name="room_id" value="<%= roomForm.room_id %>" />
            <input type="hidden" name="hinh_anh" value="<%= roomForm.hinh_anh %>" />
            <div class="room-field-grid">
              <div class="room-field">
                <label for="room_hotel">Cơ sở</label>
                <select id="room_hotel" name="hotel_id" required>
                  <option value="">-- Chọn cơ sở --</option>
                  <% hotels.forEach((hotel) => { %>
                    <option value="<%= hotel.id %>" <%= Number(roomForm.hotel_id) === Number(hotel.id) ? "selected" : "" %>>
                      <%= hotel.tenKhachSan %><%= hotel.tinhThanh ? ` · ${hotel.tinhThanh}` : "" %>
                    </option>
                  <% }) %>
                </select>
              </div>
              <div class="room-field">
                <label for="so_phong">Số phòng</label>
                <input id="so_phong" name="so_phong" value="<%= roomForm.so_phong %>" maxlength="32" pattern="[A-Za-z0-9-]{1,32}" required />
                <p class="room-help">Ví dụ: 2101, A-120. Chỉ gồm chữ, số hoặc dấu gạch ngang.</p>
                <p class="room-field-error" id="err_so_phong"></p>
              </div>
              <div class="room-field">
                <label for="loai_phong">Loại phòng</label>
                <select id="loai_phong" name="loai_phong" required>
                  <% (payload.roomTypeOptions || []).forEach((option) => { %>
                    <option value="<%= option %>" <%= roomForm.loai_phong === option ? "selected" : "" %>><%= option %></option>
                  <% }) %>
                </select>
              </div>
              <div class="room-field">
                <label for="dien_tich">Diện tích (m²)</label>
                <input id="dien_tich" name="dien_tich" type="number" min="15" max="500" step="1" value="<%= roomForm.dien_tich %>" required />
                <p class="room-field-error" id="err_dien_tich"></p>
              </div>
              <div class="room-field">
                <label for="loai_giuong">Loại giường</label>
                <select id="loai_giuong" name="loai_giuong" required>
                  <option value="">-- Chọn loại giường --</option>
                  <% (payload.bedOptions || []).forEach((option) => { %>
                    <option value="<%= option %>" <%= roomForm.loai_giuong === option ? "selected" : "" %>><%= option %></option>
                  <% }) %>
                </select>
                <p class="room-field-error" id="err_loai_giuong"></p>
              </div>
              <div class="room-field">
                <label for="view_phong">View phòng</label>
                <select id="view_phong" name="view_phong" required>
                  <% (payload.roomViewOptions || []).forEach((option) => { %>
                    <option value="<%= option %>" <%= roomForm.view_phong === option ? "selected" : "" %>><%= option %></option>
                  <% }) %>
                </select>
              </div>
              <div class="room-field">
                <label for="gia">Giá niêm yết</label>
                <input id="gia" name="gia" type="number" min="1000" max="100000000" step="1000" value="<%= roomForm.gia %>" required />
                <p class="room-help">Giá phòng phải lớn hơn 0 để booking/check-out tính tiền đúng.</p>
                <p class="room-field-error" id="err_gia"></p>
              </div>
              <div class="room-field">
                <label for="so_khach_toi_da">Số khách tối đa</label>
                <div class="room-stepper" data-capacity-stepper>
                  <button class="room-step-button" type="button" data-step-capacity="-1" aria-label="Giảm số khách tối đa">-</button>
                  <input id="so_khach_toi_da" name="so_khach_toi_da" type="text" inputmode="numeric" pattern="[0-9]{1,2}" value="<%= roomForm.so_khach_toi_da %>" required />
                  <button class="room-step-button" type="button" data-step-capacity="1" aria-label="Tăng số khách tối đa">+</button>
                </div>
                <p class="room-help">Dùng nút -/+ hoặc nhập trực tiếp, hệ thống giữ trong khoảng 1-20 khách.</p>
                <p class="room-field-error" id="err_so_khach_toi_da"></p>
              </div>
              <div class="room-field">
                <label for="tinh_trang_phong">Tình trạng thực tế</label>
                <select id="tinh_trang_phong" name="tinh_trang_phong" required>
                  <% (payload.roomConditionOptions || []).forEach((option) => { %>
                    <option value="<%= option %>" <%= roomForm.tinh_trang_phong === option ? "selected" : "" %>><%= roomConditionLabel(option) %></option>
                  <% }) %>
                </select>
              </div>
              <div class="room-field is-wide">
                <label for="ghi_chu">Ghi chú vận hành</label>
                <textarea id="ghi_chu" name="ghi_chu" maxlength="500" placeholder="Lưu ý setup, bảo trì, mùi sơn, thay drap, thiết bị đang xử lý..."><%= roomForm.ghi_chu %></textarea>
                <p class="room-help">Tối đa 500 ký tự, dùng cho vận hành nội bộ.</p>
                <p class="room-field-error" id="err_ghi_chu"></p>
              </div>
              <div class="room-field is-wide">
                <label for="hinh_anh_file">Ảnh phòng</label>
                <input id="hinh_anh_file" name="hinh_anh_file" type="file" accept="image/jpeg,image/png,image/webp" />
                <div class="room-muted">Chấp nhận JPG, PNG, WEBP. Nếu bỏ trống khi sửa, hệ thống giữ ảnh hiện tại.</div>
              </div>
            </div>
            <div class="room-form-actions">
              <button class="room-button room-button--primary" type="submit"><%= roomForm.room_id ? "Lưu thay đổi" : "Tạo phòng" %></button>
              <% if (roomForm.room_id) { %><a class="room-button" href="/manager/rooms">Tạo mới</a><% } %>
            </div>
          </form>
        </section>

        <section class="room-panel">
          <div class="room-section-head">
            <div>
              <h2>Bộ lọc phòng</h2>
              <p class="room-muted">Lọc realtime theo số phòng, cơ sở, loại phòng, trạng thái booking và tình trạng thực tế.</p>
            </div>
            <span class="room-live-pill" data-room-live-state>Sẵn sàng lọc realtime</span>
          </div>
          <div class="room-filter-grid">
            <div class="room-field">
              <label for="room_keyword">Từ khóa</label>
              <input id="room_keyword" placeholder="Số phòng, cơ sở, giường, ghi chú..." />
            </div>
            <div class="room-field">
              <label for="room_filter_hotel">Cơ sở</label>
              <select id="room_filter_hotel">
                <option value="all">Tất cả cơ sở</option>
                <% hotels.forEach((hotel) => { %>
                  <option value="<%= hotel.id %>"><%= hotel.tenKhachSan %></option>
                <% }) %>
              </select>
            </div>
            <div class="room-field">
              <label for="room_filter_type">Loại phòng</label>
              <select id="room_filter_type">
                <option value="all">Tất cả loại</option>
                <% (payload.roomTypeOptions || []).forEach((option) => { %>
                  <option value="<%= option %>"><%= option %></option>
                <% }) %>
              </select>
            </div>
            <div class="room-field">
              <label for="room_filter_status">Trạng thái booking</label>
              <select id="room_filter_status">
                <option value="all">Tất cả trạng thái</option>
                <% (payload.roomStatusOptions || []).forEach((option) => { %>
                  <option value="<%= option %>"><%= roomStatusLabel(option) %></option>
                <% }) %>
              </select>
            </div>
            <div class="room-field">
              <label for="room_filter_condition">Tình trạng phòng</label>
              <select id="room_filter_condition">
                <option value="all">Tất cả tình trạng</option>
                <% (payload.roomConditionOptions || []).forEach((option) => { %>
                  <option value="<%= option %>"><%= roomConditionLabel(option) %></option>
                <% }) %>
              </select>
            </div>
          </div>
        </section>

        <section class="room-table-panel">
          <div class="room-section-head">
            <div>
              <h2>Danh sách phòng</h2>
              <p class="room-muted" data-room-caption>Đang hiển thị <%= rooms.length %>/<%= rooms.length %> phòng trong hệ thống.</p>
            </div>
            <div class="room-actions" style="margin:0">
              <a class="room-button" href="/dashboard/quanly">Dashboard</a>
            </div>
          </div>

          <div class="room-table-wrap">
            <table class="room-table">
              <thead>
                <tr>
                  <th>Ảnh</th>
                  <th>Phòng</th>
                  <th>Thông số</th>
                  <th>Giá & sức chứa</th>
                  <th>Khai thác</th>
                  <th>Tình trạng</th>
                  <th>Lịch sử</th>
                  <th>Thao tác</th>
                </tr>
              </thead>
              <tbody data-room-table-body>
                <% if (!rooms.length) { %>
                  <tr><td colspan="8" class="room-muted">Chưa có phòng nào trong hệ thống.</td></tr>
                <% } %>
                <% rooms.forEach((item) => { %>
                  <tr
                    data-room-row
                    data-room-id="<%= item.id %>"
                    data-hotel-id="<%= item.hotelId %>"
                    data-type="<%= item.loaiPhong %>"
                    data-status="<%= item.trangThai %>"
                    data-realtime="<%= item.trangThaiRealtime %>"
                    data-condition="<%= item.tinhTrangPhong %>"
                    data-keyword="<%= [item.soPhong, item.hotelName, item.loaiPhong, item.loaiGiuong, item.viewLabel, item.ghiChu || ''].join(' ').toLowerCase() %>"
                    class="<%= focusedRoomId === Number(item.id) ? "is-focused" : "" %>"
                  >
                    <td>
                      <% if (item.imageUrl) { %>
                        <img class="room-thumb" src="<%= item.imageUrl %>" alt="Ảnh phòng <%= item.soPhong %>" onerror="this.style.display='none'; this.nextElementSibling.style.display='inline-flex';" />
                        <span class="room-thumb room-thumb--placeholder" style="display:none">P<%= item.soPhong %></span>
                      <% } else { %>
                        <span class="room-thumb room-thumb--placeholder">P<%= item.soPhong %></span>
                      <% } %>
                    </td>
                    <td>
                      <div class="room-code">
                        <strong>P<%= item.soPhong %></strong>
                        <span><%= item.hotelName %></span>
                        <span>Mã phòng #<%= item.id %></span>
                      </div>
                    </td>
                    <td>
                      <strong><%= item.loaiPhong %></strong>
                      <div class="room-muted"><%= item.dienTich %> m² · <%= item.loaiGiuong %></div>
                      <div class="room-muted">View <%= item.viewLabel %></div>
                    </td>
                    <td>
                      <div class="room-price"><%= item.giaFormatted %></div>
                      <div class="room-muted">Tối đa <%= item.soKhachToiDa %> khách</div>
                    </td>
                    <td>
                      <span class="room-status room-status--<%= item.statusTone %>"><%= roomStatusLabel(item.trangThai) %></span>
                      <div style="margin-top:6px"><span class="room-status room-status--<%= item.realtimeTone %>"><%= roomRealtimeLabel(item.trangThaiRealtime) %></span></div>
                      <div class="room-muted" style="margin-top:6px"><%= item.trangThai === "Trong" ? "Sẵn sàng bán" : (item.trangThai === "Booked" ? "Đang giữ booking" : (item.trangThai === "Stayed" ? "Khách đang lưu trú" : "Khóa để bảo trì")) %></div>
                    </td>
                    <td>
                      <span class="room-status room-status--<%= item.conditionTone %>"><%= roomConditionLabel(item.tinhTrangPhong) %></span>
                      <div class="room-muted" style="margin-top:6px"><%= item.ghiChu || "Chưa có ghi chú nội bộ." %></div>
                    </td>
                    <td>
                      <strong><%= item.transactionCount || 0 %> giao dịch</strong>
                      <div class="room-muted"><%= item.activeBookingCount || 0 %> đang mở</div>
                    </td>
                    <td>
                      <div class="room-row-actions">
                        <a class="room-button" href="/manager/rooms?edit_room=<%= item.id %>">Sửa</a>
                        <form method="post" action="/manager/rooms/<%= item.id %>/delete" onsubmit="return confirm('Xóa phòng này? Phòng đã có lịch sử giao dịch sẽ bị khóa xóa.');">
                          <button class="room-button room-button--danger" type="submit" <%= item.canDelete ? "" : "disabled title='Phòng đã có lịch sử giao dịch nên không thể xóa.'" %>><%= item.canDelete ? "Xóa" : "Khóa xóa" %></button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
                <tr class="room-no-results" data-room-empty-row><td colspan="8" class="room-muted">Không có phòng phù hợp với bộ lọc hiện tại.</td></tr>
              </tbody>
            </table>
          </div>
        </section>
      </div>

      <aside style="display:grid;gap:16px">
        <section class="room-panel">
          <h2><%= roomForm.room_id ? "Snapshot phòng đang sửa" : "Snapshot thao tác" %></h2>
          <p class="room-muted">Preview nhanh ảnh, cơ sở, cấu hình và trạng thái của phòng đang thao tác.</p>
          <div class="room-preview">
            <img id="room-image-preview" src="<%= previewImageUrl || "data:image/gif;base64,R0lGODlhAQABAAAAACw=" %>" alt="Preview ảnh phòng" style="<%= previewImageUrl ? "" : "display:none" %>" />
            <div id="room-image-fallback" class="room-thumb room-thumb--placeholder" style="width:100%;height:180px;<%= previewImageUrl ? "display:none" : "display:inline-flex" %>">
              <%= roomForm.so_phong ? `P${roomForm.so_phong}` : "Chưa có ảnh" %>
            </div>
            <div class="room-preview-meta">
              <strong><%= roomForm.so_phong ? `Phòng ${roomForm.so_phong}` : "Tạo phòng mới" %></strong>
              <span class="room-muted"><%= editingRoom?.hotelName || "Chọn cơ sở để gắn phòng" %></span>
              <span class="room-muted"><%= roomForm.loai_phong %> · <%= roomForm.loai_giuong || "Chưa chọn giường" %> · <%= roomForm.so_khach_toi_da || 0 %> khách</span>
              <span class="room-muted"><%= roomForm.gia ? `${Number(roomForm.gia).toLocaleString("vi-VN")} VND` : "Chưa nhập giá" %></span>
              <% if (editingRoom) { %><span class="room-muted">Vận hành: <%= roomRealtimeLabel(editingRoom.trangThaiRealtime) %></span><% } %>
            </div>
          </div>
        </section>

        <section class="room-panel">
          <h2>Phòng cần chú ý</h2>
          <p class="room-muted">Những phòng đang cần vệ sinh, có hư hại hoặc bị khóa bảo trì để quản lý ưu tiên xử lý.</p>
          <% if (!attentionRooms.length) { %>
            <div class="room-empty">Hiện không có phòng nào trong trạng thái cần chú ý.</div>
          <% } else { %>
            <div class="room-insight-list">
              <% attentionRooms.forEach((item) => { %>
                <article class="room-insight">
                  <span class="room-status room-status--<%= item.conditionTone %>"><%= roomConditionLabel(item.tinhTrangPhong) %></span>
                  <h3 style="margin:10px 0 4px"><a href="/manager/rooms?edit_room=<%= item.id %>">Phòng <%= item.soPhong %></a></h3>
                  <p class="room-muted"><%= item.hotelName %> · <%= item.loaiPhong %> · <%= roomStatusLabel(item.trangThai) %></p>
                  <p class="room-muted"><%= item.ghiChu || "Chưa có ghi chú chi tiết." %></p>
                </article>
              <% }) %>
            </div>
          <% } %>
        </section>
      </aside>
    </section>
  </div>
</main>

<script>
  (() => {
    const keywordInput = document.getElementById("room_keyword");
    const hotelFilter = document.getElementById("room_filter_hotel");
    const typeFilter = document.getElementById("room_filter_type");
    const statusFilter = document.getElementById("room_filter_status");
    const conditionFilter = document.getElementById("room_filter_condition");
    const rows = Array.from(document.querySelectorAll("[data-room-row]"));
    const caption = document.querySelector("[data-room-caption]");
    const liveState = document.querySelector("[data-room-live-state]");
    const emptyRow = document.querySelector("[data-room-empty-row]");
    const imageInput = document.getElementById("hinh_anh_file");
    const imagePreview = document.getElementById("room-image-preview");
    const imageFallback = document.getElementById("room-image-fallback");
    const roomNumberInput = document.getElementById("so_phong");
    const roomForm = document.querySelector("[data-room-form]");
    const capacityInput = document.getElementById("so_khach_toi_da");
    const capacityButtons = Array.from(document.querySelectorAll("[data-step-capacity]"));
    const unsafeText = /[<>{}\[\]\\]/;
    const validators = {
      so_phong(value) {
        const raw = value.trim();
        if (!raw) return "Vui lòng nhập số phòng.";
        if (!/^[A-Za-z0-9-]{1,32}$/.test(raw)) return "Số phòng chỉ gồm chữ, số hoặc dấu gạch ngang, tối đa 32 ký tự.";
        return "";
      },
      dien_tich(value) {
        const number = Number(value);
        if (!Number.isFinite(number) || number < 15 || number > 500) return "Diện tích phải trong khoảng 15-500 m².";
        return "";
      },
      loai_giuong(value) {
        const raw = value.trim();
        if (!raw) return "Vui lòng nhập loại giường.";
        if (raw.length > 120 || unsafeText.test(raw)) return "Loại giường không hợp lệ hoặc chứa ký tự không an toàn.";
        return "";
      },
      gia(value) {
        const number = Number(value);
        if (!Number.isFinite(number) || number < 1000 || number > 100000000) return "Giá phòng phải từ 1.000 đến 100.000.000 VND.";
        return "";
      },
      so_khach_toi_da(value) {
        const number = Number(String(value || "").replace(/\D+/g, ""));
        if (!Number.isInteger(number) || number < 1 || number > 20) return "Sức chứa phải từ 1 đến 20 khách.";
        return "";
      },
      ghi_chu(value) {
        const raw = value.trim();
        if (raw.length > 500 || unsafeText.test(raw)) return "Ghi chú tối đa 500 ký tự và không chứa ký tự không an toàn.";
        return "";
      }
    };

    [keywordInput, hotelFilter, typeFilter, statusFilter, conditionFilter].forEach((element) => {
      if (!element) return;
      element.addEventListener("input", applyFilters);
      element.addEventListener("change", applyFilters);
    });

    roomNumberInput?.addEventListener("input", () => {
      if (imageFallback && imageFallback.style.display !== "none") {
        imageFallback.textContent = roomNumberInput.value.trim() ? `P${roomNumberInput.value.trim()}` : "Chưa có ảnh";
      }
    });

    imageInput?.addEventListener("change", () => {
      const [file] = imageInput.files || [];
      if (!file) return;
      if (!["image/jpeg", "image/png", "image/webp"].includes(file.type) || file.size > 3 * 1024 * 1024) {
        imageInput.value = "";
        alert("Ảnh phòng chỉ nhận JPG, PNG, WEBP và tối đa 3MB.");
        return;
      }
      const reader = new FileReader();
      reader.onload = () => {
        if (imagePreview) {
          imagePreview.src = String(reader.result || "");
          imagePreview.style.display = "";
        }
        if (imageFallback) imageFallback.style.display = "none";
      };
      reader.readAsDataURL(file);
    });

    capacityButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const delta = Number(button.getAttribute("data-step-capacity") || 0);
        setCapacityValue(readCapacityValue() + delta);
        if (capacityInput) {
          capacityInput.dispatchEvent(new Event("input", { bubbles: true }));
          capacityInput.focus();
        }
      });
    });

    capacityInput?.addEventListener("input", () => {
      const digits = String(capacityInput.value || "").replace(/\D+/g, "").slice(0, 2);
      capacityInput.value = digits;
    });

    capacityInput?.addEventListener("blur", () => {
      setCapacityValue(readCapacityValue());
    });

    Array.from(roomForm?.querySelectorAll("input[name], select[name], textarea[name]") || []).forEach((field) => {
      if (!validators[field.name]) return;
      field.addEventListener("input", () => validateField(field));
      field.addEventListener("blur", () => validateField(field));
      field.addEventListener("change", () => validateField(field));
    });

    roomForm?.addEventListener("submit", (event) => {
      if (capacityInput) {
        setCapacityValue(readCapacityValue());
      }
      const fields = Array.from(roomForm.querySelectorAll("input[name], select[name], textarea[name]")).filter((field) => validators[field.name]);
      const firstInvalid = fields.find((field) => !validateField(field));
      if (!firstInvalid) return;
      event.preventDefault();
      firstInvalid.focus();
      firstInvalid.scrollIntoView({ behavior: "smooth", block: "center" });
    });

    function applyFilters() {
      const keyword = String(keywordInput?.value || "").trim().toLowerCase();
      const hotel = String(hotelFilter?.value || "all");
      const type = String(typeFilter?.value || "all");
      const status = String(statusFilter?.value || "all");
      const condition = String(conditionFilter?.value || "all");

      let visibleCount = 0;
      rows.forEach((row) => {
        const matchesKeyword = !keyword || String(row.getAttribute("data-keyword") || "").includes(keyword);
        const matchesHotel = hotel === "all" || String(row.getAttribute("data-hotel-id") || "") === hotel;
        const matchesType = type === "all" || String(row.getAttribute("data-type") || "") === type;
        const matchesStatus = status === "all" || String(row.getAttribute("data-status") || "") === status;
        const matchesCondition = condition === "all" || String(row.getAttribute("data-condition") || "") === condition;
        const visible = matchesKeyword && matchesHotel && matchesType && matchesStatus && matchesCondition;
        row.style.display = visible ? "" : "none";
        if (visible) visibleCount += 1;
      });

      if (caption) {
        caption.textContent = `Đang hiển thị ${visibleCount}/${rows.length} phòng trong hệ thống.`;
      }
      if (liveState) {
        liveState.textContent = visibleCount ? `Đã lọc ${visibleCount} phòng phù hợp` : "Không có phòng phù hợp";
      }
      if (emptyRow) {
        emptyRow.style.display = visibleCount ? "none" : "";
      }
    }

    function validateField(field) {
      const validator = validators[field.name];
      if (!validator) return true;
      const message = validator(field.value || "");
      const wrapper = field.closest(".room-field");
      const error = wrapper?.querySelector(".room-field-error");
      if (wrapper) {
        wrapper.classList.toggle("is-invalid", Boolean(message));
        wrapper.classList.toggle("is-valid", !message && Boolean(String(field.value || "").trim()));
      }
      if (error) error.textContent = message || "";
      return !message;
    }

    function readCapacityValue() {
      const number = Number(String(capacityInput?.value || "").replace(/\D+/g, ""));
      return Number.isFinite(number) ? number : 1;
    }

    function setCapacityValue(value) {
      if (!capacityInput) return;
      const nextValue = Math.min(20, Math.max(1, Math.trunc(Number(value) || 1)));
      capacityInput.value = String(nextValue);
    }

    applyFilters();
  })();
</script>

