    color: #5b7184;
    font-weight: 800;
  }

  .care-broadcast__recipient strong,
  .care-broadcast__campaign strong {
    color: #0f2d42;
  }

  .care-broadcast__badge {
    background: rgba(14, 165, 233, .15);
    color: #075985;
    border: 1px solid rgba(14, 165, 233, .24);
    letter-spacing: 0;
  }

  .care-broadcast__token {
    border: 1px solid rgba(34, 211, 238, .28);
    background: rgba(34, 211, 238, .16);
    color: #cffafe;
  }

  .care-broadcast__count {
    color: #dbeafe;
  }

  .care-broadcast__flash {
    margin: 0 0 16px;
    border: 2px solid rgba(186, 230, 253, .70);
    background: rgba(255, 255, 255, .95);
    color: #0f2d42;
  }

  @media (max-width: 860px) {
    .care-broadcast {
      padding: 20px 12px 46px;
    }

    .care-broadcast__hero,
    .care-broadcast__section {
      gap: 18px;
    }

    .care-broadcast__card,
    .care-broadcast__side,
    .care-broadcast__panel {
      border-radius: 22px;
      padding: 18px;
    }

    .care-broadcast__card h1 {
      font-size: 42px;
    }

    .care-broadcast__button {
      width: 100%;
    }
  }
</style>

<main class="care-broadcast">
  <div class="care-broadcast__wrap">
    <% if (successMessage) { %>
      <div class="care-broadcast__flash care-broadcast__flash--success"><%= successMessage %></div>
    <% } %>
    <% if (errorMessage) { %>
      <div class="care-broadcast__flash care-broadcast__flash--error"><%= errorMessage %></div>
    <% } %>

    <section class="care-broadcast__hero">
      <div class="care-broadcast__card">
        <div class="care-broadcast__eyebrow"><span class="care-broadcast__pulse"></span> Broadcast CSKH</div>
        <h1>Gửi <span>tin nhắn hàng loạt</span> để giữ chân khách</h1>
        <p class="care-broadcast__lead">
          Chọn đúng tệp khách, đúng kênh liên hệ và gửi tự động cho các tình huống trước lưu trú,
          sau lưu trú, xác nhận booking hoặc chăm sóc lại khách cũ.
        </p>

        <div class="care-broadcast__chips">
          <span class="care-broadcast__chip"><%= Number(stats.contactableCustomers || 0).toLocaleString("vi-VN") %> khách có thể liên hệ</span>
          <span class="care-broadcast__chip"><%= Number(stats.upcomingCheckinCount || 0).toLocaleString("vi-VN") %> khách sắp check-in</span>
          <span class="care-broadcast__chip"><%= Number(stats.todayCheckoutCount || 0).toLocaleString("vi-VN") %> khách check-out hôm nay</span>
        </div>

        <div class="care-broadcast__hero-actions">
          <a class="care-broadcast__button care-broadcast__button--primary" href="#broadcast-form">Soạn chiến dịch</a>
          <a class="care-broadcast__button" href="/dashboard/cskh">Về dashboard CSKH</a>
          <a class="care-broadcast__button" href="/feedback/advisory/manage">Qua inbox tư vấn</a>
        </div>

        <div class="care-broadcast__stats">
          <div class="care-broadcast__stat"><strong><%= Number(stats.totalCustomers || 0).toLocaleString("vi-VN") %></strong><span>Tổng khách</span></div>
          <div class="care-broadcast__stat"><strong><%= Number(stats.withEmail || 0).toLocaleString("vi-VN") %></strong><span>Có email</span></div>
          <div class="care-broadcast__stat"><strong><%= Number(stats.withPhone || 0).toLocaleString("vi-VN") %></strong><span>Có số điện thoại</span></div>
        </div>
      </div>

      <aside class="care-broadcast__side">
        <h2>Tín hiệu outbound</h2>
        <p class="care-broadcast__meta">Các tệp có thể gửi ngay theo dữ liệu booking hiện tại.</p>
        <div class="care-broadcast__stack">
          <div class="care-broadcast__mini">
            <strong><%= Number(stats.winbackCount || 0).toLocaleString("vi-VN") %> khách cần chăm sóc lại</strong>
          </div>
          <div class="care-broadcast__mini">
            <strong><%= Number(stats.upcomingCheckinCount || 0).toLocaleString("vi-VN") %> khách sắp check-in</strong>
          </div>
          <div class="care-broadcast__mini">
            <strong><%= Number(stats.todayCheckoutCount || 0).toLocaleString("vi-VN") %> khách check-out hôm nay</strong>
          </div>
        </div>
      </aside>
    </section>

    <section class="care-broadcast__section">
      <div class="care-broadcast__panel" id="broadcast-form">
        <div class="care-broadcast__preview-head">
          <div>
            <h2>Soạn chiến dịch gửi hàng loạt</h2>
            <p class="care-broadcast__meta">Mẫu, tệp khách và kênh gửi quyết định số khách được hệ thống gửi tự động.</p>
          </div>
        </div>

        <div class="care-broadcast__template-grid">
          <% templates.forEach((item) => { %>
            <button
              class="care-broadcast__template <%= form.template_key === item.key ? "is-active" : "" %>"
              type="button"
              data-template-key="<%= item.key %>"
              data-audience-key="<%= item.key %>"
              data-channel="<%= item.channel %>"
              data-title="<%= item.title %>"
              data-message="<%= item.message %>"
            >
              <strong><%= item.label %></strong>
              <span><%= item.title %></span>
              <small><%= item.channel %></small>
            </button>
          <% }) %>
        </div>

        <form id="broadcast-compose" method="post" action="/feedback/broadcast/send" class="care-broadcast__grid">
          <div class="care-broadcast__field">
            <label for="template_key">Mẫu chiến dịch</label>
            <select id="template_key" name="template_key">
              <% templates.forEach((item) => { %>
                <option value="<%= item.key %>" <%= form.template_key === item.key ? "selected" : "" %>><%= item.label %></option>
              <% }) %>
            </select>
          </div>

          <div class="care-broadcast__field">
            <label for="audience_key">Tệp khách nhận tin</label>
            <select id="audience_key" name="audience_key">
              <% audiences.forEach((item) => { %>
                <option value="<%= item.value %>" <%= form.audience_key === item.value ? "selected" : "" %>><%= item.label %></option>
              <% }) %>
            </select>
          </div>

          <div class="care-broadcast__field">
            <label for="channel">Kênh gửi</label>
            <select id="channel" name="channel">
              <% channels.forEach((item) => { %>
                <option value="<%= item.value %>" <%= form.channel === item.value ? "selected" : "" %>><%= item.label %></option>
              <% }) %>
            </select>
          </div>

          <div class="care-broadcast__field">
            <label for="send_timing">Nhịp gửi</label>
            <select id="send_timing" name="send_timing">
              <option value="now" <%= form.send_timing === "now" ? "selected" : "" %>>Gửi tự động ngay</option>
              <option value="shift" <%= form.send_timing === "shift" ? "selected" : "" %>>Gửi tự động theo ca</option>
            </select>
          </div>

          <div class="care-broadcast__field">
            <label for="dedupe_days">Chống gửi trùng</label>
            <select id="dedupe_days" name="dedupe_days">
              <% [0, 1, 3, 7, 14, 30].forEach((days) => { %>
                <option value="<%= days %>" <%= Number(form.dedupe_days || 0) === days ? "selected" : "" %>><%= days === 0 ? "Không chặn" : `${days} ngày` %></option>
              <% }) %>
            </select>
          </div>

          <div class="care-broadcast__field care-broadcast__field--full">
            <label for="title">Tiêu đề chiến dịch</label>
            <input id="title" name="title" maxlength="140" value="<%= form.title || "" %>" />
          </div>

          <div class="care-broadcast__field care-broadcast__field--full">
            <label for="campaign_goal">Mục tiêu gửi</label>
            <input id="campaign_goal" name="campaign_goal" maxlength="180" value="<%= form.campaign_goal || "" %>" placeholder="Ví dụ: giảm no-show, nhắc hoàn tất eKYC, kéo khách cũ quay lại..." />
          </div>

          <div class="care-broadcast__field care-broadcast__field--full">
            <label for="message">Nội dung tin nhắn</label>
            <textarea id="message" name="message" maxlength="1200"><%= form.message || "" %></textarea>
            <div class="care-broadcast__tokens" aria-label="Biến cá nhân hóa">
              <span class="care-broadcast__token">{{ten_kh}}</span>
              <span class="care-broadcast__token">{{ma_giao_dich}}</span>
              <span class="care-broadcast__token">{{khach_san}}</span>
              <span class="care-broadcast__count" id="message-count">0/1200 ký tự</span>
            </div>
            <div class="care-broadcast__hint">Viết ngắn, rõ hành động cần khách thực hiện và cá nhân hóa vừa đủ.</div>
          </div>

          <div class="care-broadcast__field care-broadcast__field--full">
            <label for="internal_note">Ghi chú nội bộ</label>
            <textarea id="internal_note" name="internal_note" maxlength="500" style="min-height:92px"><%= form.internal_note || "" %></textarea>
            <div class="care-broadcast__hint">Dùng cho ca CSKH sau khi cần follow-up.</div>
          </div>

          <div class="care-broadcast__field care-broadcast__field--full">
            <div class="care-broadcast__actions">
              <button class="care-broadcast__button" type="submit" formmethod="get" formaction="/feedback/broadcast/manage">Cập nhật preview</button>
              <button class="care-broadcast__button care-broadcast__button--primary" type="submit">Gửi tự động</button>
            </div>
          </div>
        </form>
      </div>

      <aside class="care-broadcast__panel">
        <div class="care-broadcast__preview-head">
          <div>
            <h2>Preview tệp khách</h2>
            <p class="care-broadcast__meta"><%= preview.audienceLabel %> · <%= preview.channelLabel %> · <%= preview.channelRequirement %>.</p>
          </div>
        </div>

        <div class="care-broadcast__metrics">
          <div class="care-broadcast__metric"><strong><%= previewTotal.toLocaleString("vi-VN") %></strong><span>Trong tệp</span></div>
          <div class="care-broadcast__metric"><strong><%= previewSendable.toLocaleString("vi-VN") %></strong><span>Gửi được</span></div>
          <div class="care-broadcast__metric"><strong><%= previewBlocked.toLocaleString("vi-VN") %></strong><span>Lệch kênh</span></div>
          <div class="care-broadcast__metric"><strong><%= previewDeduped.toLocaleString("vi-VN") %></strong><span>Chống trùng</span></div>
        </div>

        <div class="care-broadcast__list">
          <% if (preview.items && preview.items.length) { %>
            <% preview.items.forEach((item) => { %>
              <article class="care-broadcast__recipient">
                <div class="care-broadcast__row">
                  <strong><%= item.customerName %></strong>
                  <span class="care-broadcast__badge"><%= item.bookingLabel %></span>
                </div>
                <div class="care-broadcast__meta"><%= item.target %></div>
                <div class="care-broadcast__meta"><%= item.reason || "Tệp outbound phù hợp" %></div>
                <div class="care-broadcast__row care-broadcast__meta">
                  <span><%= item.hotelLabel %></span>
                  <span><%= item.checkinLabel || "-" %> -> <%= item.checkoutLabel || "-" %></span>
                </div>
              </article>
            <% }) %>
          <% } else { %>
            <div class="care-broadcast__empty">Chưa có khách gửi được theo tệp, kênh và khoảng chống trùng hiện tại.</div>
          <% } %>
        </div>

        <div style="margin-top:16px">
          <h2>Lịch sử chiến dịch gần đây</h2>
          <p class="care-broadcast__meta">Không hiển thị dữ liệu smoke test; chiến dịch lưu trạng thái gửi tự động để CSKH đối soát.</p>
        </div>

        <div class="care-broadcast__list" style="margin-top:12px">
          <% if (recentCampaigns.length) { %>
            <% recentCampaigns.forEach((item) => { %>
              <article class="care-broadcast__campaign">
                <div class="care-broadcast__row">
                  <strong><%= item.title %></strong>
                  <span class="care-broadcast__badge"><%= item.statusLabel %></span>
                </div>
                <div class="care-broadcast__meta"><%= item.audienceLabel %> · <%= item.channelLabel %> · <%= item.recipientSummary %></div>
                <div class="care-broadcast__meta"><%= item.goalLabel %> · <%= item.sendTimingLabel %></div>
                <% if (item.skippedSummary) { %>
                  <div class="care-broadcast__meta"><%= item.skippedSummary %></div>
                <% } %>
                <div class="care-broadcast__row care-broadcast__meta">
                  <span><%= item.createdByName || "Hệ thống / CSKH" %></span>
                  <span><%= item.createdAtLabel %></span>
                </div>
              </article>
            <% }) %>
          <% } else { %>
            <div class="care-broadcast__empty">Chưa có chiến dịch outbound nào được tạo.</div>
          <% } %>
        </div>

      </aside>
    </section>
  </div>
</main>

<script>
  (() => {
    const templates = <%- templatesJson %>;
    const templateSelect = document.getElementById("template_key");
    const audienceSelect = document.getElementById("audience_key");
    const channelSelect = document.getElementById("channel");
    const titleInput = document.getElementById("title");
    const messageInput = document.getElementById("message");
    const count = document.getElementById("message-count");
    const cards = Array.from(document.querySelectorAll(".care-broadcast__template"));

    function updateCount() {
      if (!messageInput || !count) return;
      count.textContent = `${messageInput.value.length}/1200 ký tự`;
    }

    function applyTemplate(key) {
      const selected = templates.find((item) => item.key === key);
      if (!selected) return;
      if (templateSelect) templateSelect.value = selected.key;
      if (audienceSelect) audienceSelect.value = selected.key;
      if (channelSelect) channelSelect.value = selected.channel;
      if (titleInput) titleInput.value = selected.title;
      if (messageInput) messageInput.value = selected.message;
      cards.forEach((card) => card.classList.toggle("is-active", card.dataset.templateKey === selected.key));
      updateCount();
    }

    cards.forEach((card) => {
      card.addEventListener("click", () => applyTemplate(card.dataset.templateKey));
    });
    templateSelect?.addEventListener("change", () => applyTemplate(templateSelect.value));
    messageInput?.addEventListener("input", updateCount);
    updateCount();
  })();
</script>

<%- include("../partials/footer") %>
