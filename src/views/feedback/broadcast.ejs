<%- include("../partials/head") %>
<%- include("../partials/header") %>
<%
  const stats = payload.stats || {};
  const form = payload.form || {};
  const templates = payload.templates || [];
  const audiences = payload.audiences || [];
  const channels = payload.channels || [];
  const preview = payload.preview || { items: [], total: 0 };
  const recentCampaigns = payload.recentCampaigns || [];
  const selectedCampaign = payload.selectedCampaign || null;
  const previewTotal = Number(preview.total || 0);
  const previewSendable = Number(preview.sendableTotal || 0);
  const previewBlocked = Number(preview.blockedByChannel || 0);
  const previewDeduped = Number(preview.dedupedCount || 0);
  const templatesJson = JSON.stringify(templates).replace(/</g, "\\u003c");
%>

<style>
  .care-broadcast {
    --care-ink: #132238;
    --care-muted: #617086;
    --care-line: rgba(19, 34, 56, .10);
    --care-panel: rgba(255, 255, 255, .82);
    --care-shadow: 0 28px 86px rgba(18, 38, 63, .16);
    min-height: calc(100vh - 84px);
    padding: 34px 18px 58px;
    color: var(--care-ink);
    background:
      radial-gradient(circle at 10% 10%, rgba(24, 191, 242, .16), transparent 26%),
      radial-gradient(circle at 92% 12%, rgba(255, 111, 163, .18), transparent 24%),
      radial-gradient(circle at 50% 110%, rgba(255, 209, 102, .22), transparent 34%),
      linear-gradient(135deg, #fffdfb 0%, #f7fbff 52%, #fff6f8 100%);
  }

  .care-broadcast__wrap {
    max-width: 1240px;
    margin: 0 auto;
  }

  .care-broadcast__hero {
    display: grid;
    grid-template-columns: minmax(0, 1.04fr) 340px;
    gap: 18px;
    margin-bottom: 18px;
  }

  .care-broadcast__card,
  .care-broadcast__panel,
  .care-broadcast__side,
  .care-broadcast__stat,
  .care-broadcast__list,
  .care-broadcast__campaign {
    border: 1px solid var(--care-line);
    background: var(--care-panel);
    box-shadow: var(--care-shadow);
    backdrop-filter: blur(20px);
  }

  .care-broadcast__card {
    border-radius: 32px;
    padding: 30px;
    position: relative;
    overflow: hidden;
  }

  .care-broadcast__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-radius: 999px;
    padding: 8px 12px;
    color: #be185d;
    border: 1px solid rgba(236, 72, 153, .18);
    background: rgba(236, 72, 153, .08);
    font-size: 12px;
    font-weight: 1000;
    text-transform: uppercase;
    letter-spacing: .08em;
  }

  .care-broadcast__pulse {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: #ec4899;
    box-shadow: 0 0 0 7px rgba(236, 72, 153, .14);
  }

  .care-broadcast__card h1 {
    margin: 22px 0 12px;
    font-size: clamp(38px, 5vw, 64px);
    line-height: .94;
    letter-spacing: 0;
  }

  .care-broadcast__card h1 span {
    color: transparent;
    background: linear-gradient(95deg, #ec4899 0%, #f59e0b 40%, #14b8a6 76%, #0ea5e9 100%);
    -webkit-background-clip: text;
    background-clip: text;
  }

  .care-broadcast__lead {
    max-width: 760px;
    margin: 0;
    color: var(--care-muted);
    font-size: 15px;
    line-height: 1.72;
  }

  .care-broadcast__chips,
  .care-broadcast__hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .care-broadcast__chips {
    margin-top: 22px;
  }

  .care-broadcast__chip {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 8px 11px;
    background: rgba(255, 255, 255, .86);
    border: 1px solid rgba(19, 34, 56, .08);
    font-size: 12px;
    font-weight: 900;
  }

  .care-broadcast__hero-actions {
    margin-top: 26px;
  }

  .care-broadcast__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 10px 18px;
    border-radius: 999px;
    text-decoration: none;
    border: 1px solid rgba(19, 34, 56, .12);
    color: var(--care-ink);
    background: rgba(255, 255, 255, .86);
    font-size: 14px;
    font-weight: 900;
    cursor: pointer;
  }

  .care-broadcast__button--primary {
    color: #fff;
    border-color: transparent;
    background: linear-gradient(135deg, #ec4899, #f59e0b);
    box-shadow: 0 18px 42px rgba(236, 72, 153, .22);
  }

  .care-broadcast__stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-top: 30px;
  }

  .care-broadcast__stat {
    border-radius: 24px;
    padding: 16px;
  }

  .care-broadcast__stat strong {
    display: block;
    font-size: 28px;
    letter-spacing: -.05em;
  }

  .care-broadcast__stat span {
    display: block;
    margin-top: 8px;
    color: var(--care-muted);
    font-size: 12px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: .06em;
  }

  .care-broadcast__side {
    border-radius: 34px;
    padding: 22px;
    background:
      linear-gradient(155deg, rgba(255,255,255,.88), rgba(255,244,248,.68)),
      radial-gradient(circle at top right, rgba(236,72,153,.18), transparent 34%);
  }

  .care-broadcast__side h2,
  .care-broadcast__panel h2,
  .care-broadcast__section h2 {
    margin: 0;
    font-size: 20px;
    letter-spacing: -.03em;
  }

  .care-broadcast__side p,
  .care-broadcast__meta,
  .care-broadcast__hint,
  .care-broadcast__panel p {
    color: var(--care-muted);
    font-size: 13px;
    line-height: 1.62;
  }

  .care-broadcast__stack {
    display: grid;
    gap: 12px;
    margin-top: 16px;
  }

  .care-broadcast__mini {
    border-radius: 22px;
    padding: 14px;
    border: 1px solid rgba(19, 34, 56, .08);
    background: rgba(255, 255, 255, .84);
  }

  .care-broadcast__mini strong {
    display: block;
    font-size: 14px;
  }

  .care-broadcast__section {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 380px;
    gap: 18px;
    align-items: start;
  }

  .care-broadcast__panel {
    border-radius: 30px;
    padding: 24px;
  }

  .care-broadcast__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 18px;
  }

  .care-broadcast__field {
    display: grid;
    gap: 8px;
  }

  .care-broadcast__field--full {
    grid-column: 1 / -1;
  }

  .care-broadcast__field label {
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--care-muted);
  }

  .care-broadcast__field input,
  .care-broadcast__field select,
  .care-broadcast__field textarea {
    width: 100%;
    border-radius: 16px;
    border: 1px solid rgba(19, 34, 56, .12);
    padding: 12px 14px;
    background: rgba(255,255,255,.92);
    color: var(--care-ink);
    font: inherit;
  }

  .care-broadcast__field textarea {
    min-height: 160px;
    resize: vertical;
  }

  .care-broadcast__template-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 12px;
    margin-top: 16px;
  }

  .care-broadcast__template {
    border-radius: 22px;
    padding: 14px;
    border: 1px solid rgba(19, 34, 56, .10);
    background: rgba(255,255,255,.82);
    color: var(--care-ink);
    text-align: left;
    cursor: pointer;
    transition: transform .18s ease, border-color .18s ease, box-shadow .18s ease;
  }

  .care-broadcast__template:hover,
  .care-broadcast__template.is-active {
    transform: translateY(-2px);
    border-color: rgba(236, 72, 153, .28);
    box-shadow: 0 18px 42px rgba(236, 72, 153, .13);
  }

  .care-broadcast__template strong {
    display: block;
    font-size: 15px;
    margin-bottom: 6px;
  }

  .care-broadcast__template span {
    display: block;
    color: var(--care-muted);
    font-size: 12px;
    line-height: 1.55;
  }

  .care-broadcast__template small {
    display: inline-flex;
    margin-top: 10px;
    border-radius: 999px;
    padding: 5px 8px;
    background: rgba(20, 184, 166, .12);
    color: #0f766e;
    font-size: 11px;
    font-weight: 1000;
  }

  .care-broadcast__metrics {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
    margin: 14px 0;
  }

  .care-broadcast__metric {
    border-radius: 18px;
    padding: 12px;
    border: 1px solid rgba(19, 34, 56, .08);
    background: rgba(255, 255, 255, .74);
  }

  .care-broadcast__metric strong {
    display: block;
    font-size: 22px;
    letter-spacing: 0;
  }

  .care-broadcast__metric span {
    display: block;
    margin-top: 5px;
    color: var(--care-muted);
    font-size: 11px;
    font-weight: 900;
    text-transform: uppercase;
  }

  .care-broadcast__tokens,
  .care-broadcast__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
  }

  .care-broadcast__tokens {
    margin-top: 10px;
  }

  .care-broadcast__token {
    border-radius: 999px;
    padding: 6px 9px;
    background: rgba(14, 165, 233, .10);
    color: #0369a1;
    font-size: 11px;
    font-weight: 950;
  }

  .care-broadcast__actions {
    justify-content: space-between;
  }

  .care-broadcast__count {
    color: var(--care-muted);
    font-size: 12px;
    font-weight: 850;
  }

  .care-broadcast__preview-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 14px;
  }

  .care-broadcast__list {
    border-radius: 26px;
    padding: 10px;
  }

  .care-broadcast__recipient,
  .care-broadcast__campaign {
    display: grid;
    gap: 6px;
    border-radius: 20px;
    padding: 14px;
    background: rgba(255,255,255,.78);
    border: 1px solid rgba(19, 34, 56, .08);
  }

  .care-broadcast__recipient + .care-broadcast__recipient,
  .care-broadcast__campaign + .care-broadcast__campaign {
    margin-top: 10px;
  }

  .care-broadcast__row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 8px 12px;
  }

  .care-broadcast__badge {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 5px 9px;
    background: rgba(236, 72, 153, .11);
    color: #be185d;
    font-size: 11px;
    font-weight: 1000;
    letter-spacing: .04em;
  }

  .care-broadcast__empty {
    border: 1px dashed rgba(19, 34, 56, .16);
    border-radius: 24px;
    padding: 22px;
    text-align: center;
    color: var(--care-muted);
    background: rgba(255,255,255,.64);
  }

  .care-broadcast__flash {
    margin-bottom: 16px;
    padding: 14px 16px;
    border-radius: 18px;
    font-weight: 700;
  }

  .care-broadcast__flash--success {
    color: #0f766e;
    background: rgba(16, 185, 129, .12);
    border: 1px solid rgba(16, 185, 129, .20);
  }

  .care-broadcast__flash--error {
    color: #b91c1c;
    background: rgba(239, 68, 68, .10);
    border: 1px solid rgba(239, 68, 68, .18);
  }

  @media (max-width: 1200px) {
    .care-broadcast__hero,
    .care-broadcast__section {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 860px) {
    .care-broadcast__stats,
    .care-broadcast__grid,
    .care-broadcast__template-grid,
    .care-broadcast__metrics {
      grid-template-columns: 1fr;
    }

    .care-broadcast {
      padding: 22px 12px 42px;
    }

    .care-broadcast__card,
    .care-broadcast__side,
    .care-broadcast__panel {
      padding: 20px;
      border-radius: 24px;
    }
  }

  /* CSKH UC3 visual pass only: broadcast workspace color separation. */
  body {
    background:
      radial-gradient(circle at 12% 14%, rgba(34, 211, 238, .18), transparent 28%),
      radial-gradient(circle at 80% 8%, rgba(168, 85, 247, .22), transparent 32%),
      linear-gradient(135deg, #04111f 0%, #11153c 48%, #210c35 100%);
    color: #f8fafc;
  }

  .care-broadcast {
    --care-ink: #f8fafc;
    --care-muted: #dbeafe;
    --care-line: rgba(125, 211, 252, .36);
    --care-panel: rgba(8, 18, 36, .92);
    --care-shadow: 0 28px 78px rgba(0, 0, 0, .36);
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background:
      radial-gradient(circle at 8% 22%, rgba(255, 255, 255, .70) 0 1px, transparent 2px),
      radial-gradient(circle at 30% 64%, rgba(125, 211, 252, .72) 0 1px, transparent 2px),
      radial-gradient(circle at 54% 18%, rgba(255, 255, 255, .64) 0 1px, transparent 2px),
      radial-gradient(circle at 76% 36%, rgba(253, 230, 138, .72) 0 1px, transparent 2px),
      radial-gradient(circle at 92% 76%, rgba(255, 255, 255, .66) 0 1px, transparent 2px),
      radial-gradient(circle at 12% 12%, rgba(34, 211, 238, .18), transparent 30%),
      radial-gradient(circle at 84% 10%, rgba(168, 85, 247, .20), transparent 34%),
      radial-gradient(circle at 74% 92%, rgba(251, 113, 133, .14), transparent 34%),
      linear-gradient(135deg, #04111f 0%, #101843 52%, #220d35 100%);
  }

  .care-broadcast::after {
    content: "";
    position: absolute;
    right: -260px;
    bottom: -380px;
    z-index: -1;
    width: 780px;
    height: 780px;
    border-radius: 999px;
    background:
      radial-gradient(circle at 42% 45%, rgba(103, 232, 249, .24), transparent 0 24%, rgba(167, 139, 250, .18) 25% 42%, transparent 43%),
      conic-gradient(from 140deg, rgba(34, 211, 238, .24), rgba(251, 113, 133, .18), rgba(250, 204, 21, .14), rgba(34, 211, 238, .24));
    opacity: .46;
  }

  .care-broadcast__wrap {
    max-width: 1280px;
  }

