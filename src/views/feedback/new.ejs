<%- include("../partials/head") %>
<%- include("../partials/header") %>
<%
  const data = typeof payload !== "undefined" ? payload : {};
  const customer = data.customer || {};
  const form = data.form || {};
  const serviceTypes = data.serviceTypes || ["Lưu trú", "Nhà hàng", "SPA", "Giặt là", "Dịch vụ khác"];
  const recentFeedbacks = data.recentFeedbacks || [];
  const summary = data.summary || {};
  const success = typeof successMessage !== "undefined" ? successMessage : "";
  const error = typeof errorMessage !== "undefined" ? errorMessage : "";
  const pageMode = typeof mode !== "undefined" && mode ? mode : "feedback";
  const advisoryMode = pageMode === "advisory";
  const displayName = customer.tenKh || (typeof currentUser !== "undefined" && currentUser ? currentUser.displayName : "") || "Quý khách";
  const avgRating = Number(summary.avgRating || 0);
%>

<style>
  body{background:radial-gradient(circle at 7% 8%,rgba(33,207,166,.30),transparent 30%),radial-gradient(circle at 84% 10%,rgba(255,111,163,.20),transparent 32%),radial-gradient(circle at 50% 104%,rgba(183,239,74,.22),transparent 38%),linear-gradient(135deg,#fbfffb 0%,#eafcff 42%,#fff7ed 100%);color:#112233}
  .fb-shell{--ink:#112233;--muted:#667085;--line:rgba(17,34,51,.10);--card:rgba(255,255,255,.76);--card-strong:rgba(255,255,255,.91);--cyan:#18bff2;--mint:#21cfa6;--lime:#b7ef4a;--pink:#ff6fa3;--violet:#8b6bff;--yellow:#ffd166;--shadow:0 28px 86px rgba(18,38,63,.17);position:relative;isolation:isolate;overflow:hidden;max-width:1240px;margin:0 auto;padding:34px 18px 62px;color:var(--ink)}
  .fb-shell::before,.fb-shell::after{content:"";position:absolute;pointer-events:none;z-index:-1;border-radius:999px;opacity:.42;animation:fb-float 14s ease-in-out infinite alternate}
  .fb-shell::before{width:580px;height:580px;right:-210px;top:-260px;background:conic-gradient(from 160deg,rgba(24,191,242,.48),rgba(33,207,166,.34),rgba(183,239,74,.30),rgba(255,111,163,.24),rgba(24,191,242,.48))}
  .fb-shell::after{width:500px;height:500px;left:-220px;bottom:-260px;background:conic-gradient(from 20deg,rgba(255,159,122,.32),rgba(255,209,102,.30),rgba(24,191,242,.26),rgba(139,107,255,.22),rgba(255,159,122,.32));animation-delay:-4s}
  .fb-hero,.fb-panel,.fb-card,.fb-stat,.fb-side-card{border:1px solid var(--line);background:var(--card);box-shadow:var(--shadow);backdrop-filter:blur(26px)}
  .fb-hero{position:relative;overflow:hidden;border-radius:38px;padding:34px;margin-bottom:18px;display:grid;grid-template-columns:minmax(0,1.05fr) 360px;gap:22px;align-items:stretch}
  .fb-hero::before{content:"";position:absolute;inset:-1px;pointer-events:none;background:linear-gradient(120deg,rgba(255,255,255,.72),transparent 28%),radial-gradient(circle at 86% 18%,rgba(24,191,242,.24),transparent 30%),radial-gradient(circle at 16% 88%,rgba(183,239,74,.20),transparent 28%)}
  .fb-hero-main,.fb-orbit{position:relative;z-index:1}
  .fb-kicker{display:inline-flex;align-items:center;gap:8px;border-radius:999px;padding:7px 12px;border:1px solid rgba(33,207,166,.24);background:rgba(33,207,166,.12);color:#087763;font-size:12px;font-weight:1000;letter-spacing:.09em;text-transform:uppercase}
  .fb-dot{width:8px;height:8px;border-radius:999px;background:var(--mint);box-shadow:0 0 0 7px rgba(33,207,166,.14);animation:fb-pulse 1.8s ease-in-out infinite}
  .fb-hero h1{margin:25px 0 12px;color:var(--ink);font-size:clamp(40px,6vw,72px);line-height:.91;letter-spacing:-.075em}
  .fb-hero h1 span{color:transparent;background:linear-gradient(96deg,#0891b2 0%,#10b981 43%,#f59e0b 72%,#ec4899 100%);-webkit-background-clip:text;background-clip:text}
  .fb-muted{color:var(--muted);font-size:14px;line-height:1.66}
  .fb-lead{max-width:710px;margin:0;color:var(--muted);font-size:16px;line-height:1.72}
  .fb-actions{display:flex;flex-wrap:wrap;gap:10px;margin-top:24px}
  .fb-button{display:inline-flex;align-items:center;justify-content:center;min-height:45px;border-radius:999px;padding:10px 18px;border:1px solid rgba(17,34,51,.12);background:rgba(255,255,255,.78);color:var(--ink);text-decoration:none;font-size:14px;font-weight:950;cursor:pointer;transition:transform .18s ease,box-shadow .18s ease,border-color .18s ease}
  .fb-button:hover{transform:translateY(-2px);border-color:rgba(24,191,242,.34);box-shadow:0 18px 44px rgba(24,191,242,.16)}
  .fb-button--primary{color:#fff;border-color:transparent;background:linear-gradient(135deg,#08a5c8,#21cfa6);box-shadow:0 18px 42px rgba(33,207,166,.24)}
  .fb-orbit{min-height:270px;border-radius:32px;overflow:hidden;background:linear-gradient(145deg,rgba(14,38,58,.90),rgba(12,86,110,.74));box-shadow:inset 0 0 0 1px rgba(255,255,255,.16)}
  .fb-orbit-ring{position:absolute;inset:36px;border-radius:999px;border:1px dashed rgba(255,255,255,.26);animation:fb-spin 22s linear infinite}
  .fb-orbit-core{position:absolute;left:50%;top:50%;width:138px;height:138px;border-radius:44px;transform:translate(-50%,-50%) rotate(14deg);background:linear-gradient(135deg,rgba(103,232,249,.96),rgba(183,239,74,.86));box-shadow:0 26px 76px rgba(33,207,166,.34);animation:fb-core 4.8s ease-in-out infinite}
  .fb-orbit-word{position:absolute;z-index:2;border-radius:999px;padding:8px 11px;color:#f8fbff;background:rgba(15,23,42,.46);border:1px solid rgba(255,255,255,.18);backdrop-filter:blur(16px);font-size:12px;font-weight:1000}
  .fb-orbit-word:nth-child(3){left:28px;top:34px;animation:fb-drift-a 5.5s ease-in-out infinite}
  .fb-orbit-word:nth-child(4){right:28px;top:82px;animation:fb-drift-b 6.2s ease-in-out infinite}
  .fb-orbit-word:nth-child(5){left:38px;bottom:62px;animation:fb-drift-b 5.8s ease-in-out infinite reverse}
  .fb-orbit-word:nth-child(6){right:32px;bottom:38px;animation:fb-drift-a 6.5s ease-in-out infinite reverse}
  .fb-stats{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:14px;margin:18px 0}
  .fb-stat{border-radius:25px;padding:17px;background:linear-gradient(180deg,rgba(255,255,255,.90),rgba(255,255,255,.66))}
  .fb-stat span{display:block;color:var(--muted);font-size:12px;font-weight:950;text-transform:uppercase;letter-spacing:.07em}
  .fb-stat strong{display:block;margin-top:8px;color:var(--ink);font-size:30px;letter-spacing:-.055em;line-height:1}
  .fb-layout{display:grid;grid-template-columns:minmax(0,1fr) 390px;gap:18px;align-items:start}
  .fb-panel,.fb-side-card{border-radius:32px;padding:24px;background:linear-gradient(180deg,rgba(255,255,255,.92),rgba(255,255,255,.70))}
  .fb-panel h2,.fb-side-card h3{margin:0;color:var(--ink);letter-spacing:-.045em}
  .fb-panel h2{font-size:32px}
  .fb-form{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px;margin-top:18px}
  .fb-field{display:grid;gap:7px}
  .fb-field.is-wide{grid-column:1/-1}
  .fb-field label{font-size:12px;font-weight:1000;text-transform:uppercase;letter-spacing:.07em;color:#173651}
  .fb-field input,.fb-field select,.fb-field textarea{width:100%;border-radius:18px;border:1px solid rgba(18,48,71,.12);background:rgba(255,255,255,.92);color:var(--ink);padding:12px 13px;font:inherit;outline:none;box-sizing:border-box}
  .fb-field input,.fb-field select{min-height:49px}
  .fb-field textarea{min-height:152px;resize:vertical;line-height:1.55}
  .fb-field input:focus,.fb-field select:focus,.fb-field textarea:focus{border-color:rgba(24,191,242,.48);box-shadow:0 0 0 4px rgba(24,191,242,.12)}
  .fb-field input:disabled{background:rgba(226,232,240,.45);color:#64748b}
  .fb-error-text{min-height:17px;color:#be123c;font-size:12px;font-weight:850}
  .fb-note{font-size:12px;color:var(--muted);line-height:1.55}
  .fb-rating{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:8px}
  .fb-rating input{position:absolute;opacity:0;pointer-events:none}
  .fb-rating label{min-height:58px;border-radius:18px;border:1px solid rgba(18,48,71,.10);background:rgba(255,255,255,.72);display:grid;place-items:center;color:#94a3b8;font-size:22px;font-weight:1000;cursor:pointer;transition:.18s ease}
  .fb-rating input:checked + label{color:#b45309;border-color:rgba(245,158,11,.32);background:linear-gradient(135deg,rgba(255,209,102,.30),rgba(255,255,255,.86));box-shadow:0 16px 34px rgba(245,158,11,.14);transform:translateY(-2px)}
  .fb-upload{border:1px dashed rgba(24,191,242,.38);background:rgba(236,253,245,.45);border-radius:22px;padding:14px}
  .fb-upload-preview{display:none;margin-top:12px;border-radius:18px;overflow:hidden;border:1px solid rgba(17,34,51,.10);max-width:260px}
  .fb-upload-preview img{display:block;width:100%;height:auto}
  .fb-alert{border-radius:22px;padding:14px 16px;margin:0 0 16px;border:1px solid rgba(18,48,71,.10);font-weight:850}
  .fb-alert--success{background:rgba(16,185,129,.13);color:#047857;border-color:rgba(16,185,129,.22)}
  .fb-alert--error{background:rgba(251,113,133,.14);color:#be123c;border-color:rgba(251,113,133,.24)}
  .fb-side{display:grid;gap:14px}
  .fb-feedback-list{display:grid;gap:12px;margin-top:15px}
  .fb-feedback-item{border-radius:24px;padding:16px;background:rgba(255,255,255,.64);border:1px solid rgba(17,34,51,.08)}
  .fb-feedback-head{display:flex;justify-content:space-between;gap:12px;align-items:flex-start}
  .fb-badge{display:inline-flex;border-radius:999px;padding:6px 9px;font-size:11px;font-weight:1000;letter-spacing:.04em;background:rgba(148,163,184,.12);color:#475569}
  .fb-badge.is-done{background:rgba(34,197,94,.12);color:#047857}
  .fb-badge.is-processing{background:rgba(24,191,242,.13);color:#0369a1}
  .fb-badge.is-pending{background:rgba(245,158,11,.13);color:#b45309}
  .fb-sentiment.is-positive{background:rgba(34,197,94,.12);color:#047857}
  .fb-sentiment.is-neutral{background:rgba(148,163,184,.13);color:#475569}
  .fb-sentiment.is-negative{background:rgba(244,63,94,.13);color:#be123c}
  .fb-stars{color:#f59e0b;font-size:13px;letter-spacing:.06em;font-weight:1000}
  .fb-reply{margin-top:11px;border-radius:18px;padding:12px;background:rgba(33,207,166,.10);border:1px solid rgba(33,207,166,.16)}
  .fb-empty{text-align:center;padding:22px;border-radius:24px;background:rgba(255,255,255,.58);border:1px dashed rgba(17,34,51,.13);color:var(--muted);font-weight:850}
  @keyframes fb-float{from{transform:translate3d(0,0,0) rotate(0)}to{transform:translate3d(28px,24px,0) rotate(14deg)}}
  @keyframes fb-pulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(.72);opacity:.68}}
  @keyframes fb-spin{to{transform:rotate(360deg)}}
  @keyframes fb-core{0%,100%{transform:translate(-50%,-50%) rotate(14deg) scale(1);border-radius:44px}50%{transform:translate(-50%,-50%) rotate(24deg) scale(1.07);border-radius:70px}}
  @keyframes fb-drift-a{0%,100%{transform:translate3d(0,0,0)}50%{transform:translate3d(12px,-10px,0)}}
  @keyframes fb-drift-b{0%,100%{transform:translate3d(0,0,0)}50%{transform:translate3d(-10px,12px,0)}}
  @media(max-width:1040px){.fb-hero,.fb-layout{grid-template-columns:1fr}.fb-stats{grid-template-columns:repeat(2,minmax(0,1fr))}.fb-orbit{min-height:250px}}
  @media(max-width:640px){.fb-shell{padding:22px 12px 48px}.fb-hero,.fb-panel,.fb-side-card{border-radius:26px;padding:20px}.fb-form,.fb-stats{grid-template-columns:1fr}.fb-rating{grid-template-columns:repeat(5,1fr)}.fb-hero h1{font-size:44px}}
  @media(prefers-reduced-motion:reduce){.fb-shell::before,.fb-shell::after,.fb-dot,.fb-orbit-ring,.fb-orbit-core,.fb-orbit-word{animation:none}}
</style>

<main class="fb-shell">
  <section class="fb-hero" aria-label="Gửi phản hồi và đánh giá">
    <div class="fb-hero-main">
      <span class="fb-kicker"><span class="fb-dot"></span> <%= advisoryMode ? "UC07 · Yêu cầu tư vấn" : "UC04 · Phản hồi khách hàng" %></span>
      <h1><%= advisoryMode ? "Gửi câu hỏi và nhận <span>CSKH phản hồi rõ ràng.</span>" : "Gửi trải nghiệm <span>để resort phục vụ tốt hơn.</span>" %></h1>
      <p class="fb-lead"><%= advisoryMode ? "Dùng form này khi bạn cần hỏi thêm về chọn phòng, booking, check-in, eKYC, dịch vụ hoặc cần CSKH giải thích một tình huống cụ thể. Yêu cầu sẽ vào thẳng inbox tư vấn của bộ phận CSKH." : "Theo nghiệp vụ hệ thống cũ, phản hồi sẽ lưu kèm loại dịch vụ, mức hài lòng, nội dung, ảnh minh chứng và tự phân tích cảm xúc để CSKH ưu tiên xử lý." %></p>
      <div class="fb-actions">
        <a class="fb-button fb-button--primary" href="#feedbackForm"><%= advisoryMode ? "Tạo yêu cầu tư vấn" : "Viết phản hồi" %></a>
        <a class="fb-button" href="<%= advisoryMode ? "/customer/advisory" : "/customer/dashboard" %>"><%= advisoryMode ? "Về UC tư vấn" : "Về dashboard" %></a>
        <a class="fb-button" href="/customer/bookings">Lịch sử booking</a>
      </div>
    </div>
    <aside class="fb-orbit" aria-label="Minh họa phản hồi">
      <div class="fb-orbit-ring"></div>
      <div class="fb-orbit-core"></div>
      <span class="fb-orbit-word"><%= advisoryMode ? "Câu hỏi" : "Rating 1-5" %></span>
      <span class="fb-orbit-word"><%= advisoryMode ? "Booking context" : "Ảnh đính kèm" %></span>
      <span class="fb-orbit-word"><%= advisoryMode ? "Follow-up" : "Sentiment" %></span>
      <span class="fb-orbit-word">CSKH trả lời</span>
    </aside>
  </section>

  <% if (success) { %><div class="fb-alert fb-alert--success"><%= success %></div><% } %>
  <% if (error) { %><div class="fb-alert fb-alert--error"><%= error %></div><% } %>
  <div id="clientFeedbackError" class="fb-alert fb-alert--error" style="display:none;"></div>

  <section class="fb-stats" aria-label="Tóm tắt phản hồi">
    <article class="fb-stat"><span>Tổng phản hồi</span><strong><%= summary.total || 0 %></strong></article>
    <article class="fb-stat"><span>Đánh giá TB</span><strong><%= avgRating ? avgRating.toFixed(1) : "0.0" %>/5</strong></article>
    <article class="fb-stat"><span>Đang theo dõi</span><strong><%= summary.pending || 0 %></strong></article>
    <article class="fb-stat"><span>Đã có trả lời</span><strong><%= summary.replied || 0 %></strong></article>
  </section>

  <section class="fb-layout">
    <form class="fb-panel" id="feedbackForm" method="post" action="/feedback" enctype="multipart/form-data" novalidate>
      <input type="hidden" name="mode" value="<%= advisoryMode ? "advisory" : "feedback" %>" />
      <h2><%= advisoryMode ? "Tạo yêu cầu tư vấn" : "Gửi phản hồi mới" %></h2>
      <p class="fb-muted"><%= advisoryMode ? "Thông tin khách hàng được giữ nguyên để CSKH trả lời đúng người, đúng ngữ cảnh. Nếu đang có booking, bạn nên nêu rõ mã đặt chỗ hoặc thời gian lưu trú ngay trong nội dung." : "Thông tin khách hàng được khóa để giữ đúng snapshot khi gửi phản hồi. Nội dung tối đa 1000 ký tự, ảnh tối đa 5MB." %></p>

      <div class="fb-form">
        <div class="fb-field">
          <label>Họ tên</label>
          <input value="<%= displayName %>" disabled />
        </div>
        <div class="fb-field">
          <label>Email / SĐT</label>
          <input value="<%= customer.email || customer.sdt || "Chưa cập nhật" %>" disabled />
        </div>
        <% if (advisoryMode) { %>
          <input type="hidden" id="feedbackServiceType" name="loai_dich_vu" value="Tư vấn" />
          <input type="hidden" name="muc_do_hai_long" value="<%= form.muc_do_hai_long || "5" %>" />
          <div class="fb-field is-wide">
            <label>Loại yêu cầu</label>
            <input value="Tư vấn / hỏi đáp với CSKH" disabled />
            <div class="fb-note">Yêu cầu này sẽ đi vào inbox tư vấn của bộ phận CSKH.</div>
            <div class="fb-error-text" id="errServiceType"></div>
            <div class="fb-error-text" id="errRating"></div>
          </div>
        <% } else { %>
          <div class="fb-field">
            <label>Loại dịch vụ *</label>
            <select id="feedbackServiceType" name="loai_dich_vu" required>
              <option value="">Chọn loại dịch vụ</option>
              <% serviceTypes.forEach(function (type) { %>
                <option value="<%= type %>" <%= String(form.loai_dich_vu || "") === type ? "selected" : "" %>><%= type %></option>
              <% }) %>
            </select>
            <div class="fb-error-text" id="errServiceType"></div>
          </div>
          <div class="fb-field">
            <label>Mức độ hài lòng *</label>
            <div class="fb-rating" role="radiogroup" aria-label="Mức độ hài lòng">
              <% [1, 2, 3, 4, 5].forEach(function (rating) { %>
                <input id="rating<%= rating %>" type="radio" name="muc_do_hai_long" value="<%= rating %>" <%= String(form.muc_do_hai_long || "5") === String(rating) ? "checked" : "" %> />
                <label for="rating<%= rating %>" title="<%= rating %>/5">★<span style="font-size:12px;margin-left:3px"><%= rating %></span></label>
              <% }) %>
            </div>
            <div class="fb-error-text" id="errRating"></div>
          </div>
        <% } %>
        <div class="fb-field is-wide">
          <label><%= advisoryMode ? "Nội dung cần tư vấn *" : "Nội dung phản hồi *" %></label>
          <textarea id="feedbackContent" name="noi_dung" maxlength="1000" required placeholder="<%= advisoryMode ? "Ví dụ: tôi có booking cuối tuần tới, cần hỏi thủ tục eKYC, giờ check-in và cách thêm dịch vụ cho phòng..." : "Chia sẻ điều bạn hài lòng, điểm cần cải thiện hoặc tình huống cần CSKH hỗ trợ..." %>"><%= form.noi_dung || "" %></textarea>
          <div style="display:flex;justify-content:space-between;gap:10px;align-items:center;">
            <div class="fb-error-text" id="errContent"></div>
            <div class="fb-note"><span id="contentCount">0</span>/1000 ký tự</div>
          </div>
        </div>
        <div class="fb-field is-wide">
          <label><%= advisoryMode ? "Ảnh hoặc minh chứng đính kèm" : "Ảnh đính kèm" %></label>
          <div class="fb-upload">
            <input id="feedbackFile" name="file" type="file" accept="image/jpeg,image/png,image/webp,image/gif" />
            <div class="fb-note">Hỗ trợ JPG, PNG, WEBP, GIF. Tối đa 5MB. Có thể bỏ trống nếu không cần minh chứng.</div>
            <div class="fb-upload-preview" id="feedbackPreview"><img alt="Xem trước ảnh đính kèm" /></div>
          </div>
          <div class="fb-error-text" id="errFile"></div>
        </div>
      </div>

      <div class="fb-actions">
        <button class="fb-button fb-button--primary" type="submit"><%= advisoryMode ? "Gửi yêu cầu tư vấn" : "Gửi phản hồi" %></button>
        <button class="fb-button" type="reset">Nhập lại</button>
      </div>
    </form>

    <aside class="fb-side">
      <article class="fb-side-card">
        <h3><%= advisoryMode ? "Lịch sử yêu cầu gần đây" : "Phản hồi gần đây" %></h3>
        <p class="fb-muted"><%= advisoryMode ? "Bạn có thể theo dõi câu hỏi đã gửi, trạng thái xử lý và trả lời mới nhất từ CSKH ngay tại đây." : "Bạn có thể theo dõi trạng thái xử lý và phản hồi mới nhất từ CSKH ngay tại đây." %></p>
        <div class="fb-feedback-list">
          <% if (recentFeedbacks.length === 0) { %>
            <div class="fb-empty">Chưa có phản hồi nào. Đây là nơi ghi lại tiếng nói của bạn sau mỗi trải nghiệm.</div>
          <% } %>
          <% recentFeedbacks.forEach(function (item) { %>
            <article class="fb-feedback-item">
              <div class="fb-feedback-head">
                <div>
                  <strong><%= item.loaiDichVu || "Dịch vụ" %></strong>
                  <div class="fb-stars"><%= item.stars || "" %> <span class="fb-muted" style="font-size:12px;">· <%= item.ngayTaoLabel || "" %></span></div>
                </div>
                <span class="fb-badge is-<%= item.statusTone || "pending" %>"><%= item.statusLabel || item.trangThai %></span>
              </div>
              <p class="fb-muted" style="margin:10px 0 0;"><%= item.noiDung || "" %></p>
              <div class="fb-actions" style="margin-top:10px;">
                <span class="fb-badge fb-sentiment is-<%= item.sentimentTone || "neutral" %>"><%= item.sentimentLabel || "Trung lập" %></span>
                <% if (item.attachmentUrl) { %><a class="fb-badge" href="<%= item.attachmentUrl %>" target="_blank" rel="noopener">Xem ảnh</a><% } %>
              </div>
              <% if (item.noiDungTraLoiMoiNhat) { %>
                <div class="fb-reply">
                  <strong>CSKH phản hồi</strong>
                  <p class="fb-muted" style="margin:6px 0 0;"><%= item.noiDungTraLoiMoiNhat %></p>
                  <div class="fb-note"><%= item.nguoiTraLoiMoiNhat || "Nhân viên CSKH" %> · <%= item.ngayTraLoiMoiNhatLabel || "" %></div>
                </div>
              <% } %>
            </article>
          <% }) %>
        </div>
      </article>

      <article class="fb-side-card">
        <h3><%= advisoryMode ? "Gợi ý viết câu hỏi" : "Gợi ý viết phản hồi" %></h3>
        <p class="fb-muted"><%= advisoryMode ? "Nên nêu rõ booking, ngày ở, cơ sở, loại phòng hoặc dịch vụ đang hỏi. Câu hỏi càng cụ thể thì CSKH càng trả lời nhanh và đúng ngữ cảnh." : "Nên nêu rõ phòng, ngày lưu trú, dịch vụ sử dụng và mong muốn xử lý. Phản hồi càng cụ thể thì CSKH càng xử lý nhanh." %></p>
      </article>
    </aside>
  </section>
</main>

<script>
  (function () {
    const form = document.getElementById("feedbackForm");
    const serviceType = document.getElementById("feedbackServiceType");
    const content = document.getElementById("feedbackContent");
    const fileInput = document.getElementById("feedbackFile");
    const preview = document.getElementById("feedbackPreview");
    const previewImg = preview ? preview.querySelector("img") : null;
    const counter = document.getElementById("contentCount");
    const clientError = document.getElementById("clientFeedbackError");
    const errServiceType = document.getElementById("errServiceType");
    const errRating = document.getElementById("errRating");
    const errContent = document.getElementById("errContent");
    const errFile = document.getElementById("errFile");
    const allowedTypes = ["image/jpeg", "image/png", "image/webp", "image/gif"];
    const maxFileSize = 5 * 1024 * 1024;

    function selectedRating() {
      return form ? form.querySelector("input[name='muc_do_hai_long']:checked") : null;
    }

    function updateCounter() {
      if (!counter || !content) return;
      counter.textContent = String((content.value || "").length);
    }

    function clearErrors() {
      [errServiceType, errRating, errContent, errFile].forEach(function (el) {
        if (el) el.textContent = "";
      });
      if (clientError) {
        clientError.style.display = "none";
        clientError.textContent = "";
      }
    }

    function validate(showBanner) {
      clearErrors();
      const errors = [];
      const contentValue = (content && content.value ? content.value : "").trim();
      const file = fileInput && fileInput.files ? fileInput.files[0] : null;

      if (!serviceType || !serviceType.value) {
        errors.push("Vui lòng chọn loại dịch vụ.");
        if (errServiceType) errServiceType.textContent = "Vui lòng chọn loại dịch vụ.";
      }

      if (!selectedRating()) {
        errors.push("Vui lòng chọn mức độ hài lòng.");
        if (errRating) errRating.textContent = "Vui lòng chọn mức độ hài lòng.";
      }

      if (contentValue.length < 10) {
        errors.push("Nội dung phản hồi cần ít nhất 10 ký tự.");
        if (errContent) errContent.textContent = "Nội dung phản hồi cần ít nhất 10 ký tự.";
      }

      if (contentValue.length > 1000) {
        errors.push("Nội dung phản hồi tối đa 1000 ký tự.");
        if (errContent) errContent.textContent = "Nội dung phản hồi tối đa 1000 ký tự.";
      }

      if (file) {
        if (!allowedTypes.includes(file.type)) {
          errors.push("Tệp đính kèm chỉ hỗ trợ JPG, PNG, WEBP hoặc GIF.");
          if (errFile) errFile.textContent = "Tệp đính kèm chỉ hỗ trợ JPG, PNG, WEBP hoặc GIF.";
        }
        if (file.size > maxFileSize) {
          errors.push("Tệp đính kèm tối đa 5MB.");
          if (errFile) errFile.textContent = "Tệp đính kèm tối đa 5MB.";
        }
      }

      if (errors.length && showBanner && clientError) {
        clientError.textContent = errors[0];
        clientError.style.display = "block";
        window.scrollTo({ top: 0, behavior: "smooth" });
      }

      return errors.length === 0;
    }

    updateCounter();
    content && content.addEventListener("input", function () {
      updateCounter();
      validate(false);
    });
    serviceType && serviceType.addEventListener("change", function () { validate(false); });
    form && form.querySelectorAll("input[name='muc_do_hai_long']").forEach(function (input) {
      input.addEventListener("change", function () { validate(false); });
    });
    fileInput && fileInput.addEventListener("change", function () {
      validate(false);
      const file = fileInput.files && fileInput.files[0];
      if (!file || !preview || !previewImg || !allowedTypes.includes(file.type)) {
        if (preview) preview.style.display = "none";
        return;
      }
      previewImg.src = URL.createObjectURL(file);
      preview.style.display = "block";
    });
    form && form.addEventListener("submit", function (event) {
      if (!validate(true)) {
        event.preventDefault();
        return;
      }

      if (!window.confirm("Bạn chắc chắn muốn gửi phản hồi này?")) {
        event.preventDefault();
      }
    });
  })();
</script>
<%- include("../partials/footer") %>
