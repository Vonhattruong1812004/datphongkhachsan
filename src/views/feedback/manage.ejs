<main class="fb-ops <%= advisoryMode ? "fb-mode-advisory" : "fb-mode-feedback" %>">
  <section class="fb-hero" aria-label="Quản lý phản hồi khách hàng">
    <div class="fb-hero-main">
      <span class="fb-kicker"><span class="fb-dot"></span> <%= advisoryMode ? "Trả lời tư vấn" : "Quản lý phản hồi" %></span>
      <% if (advisoryMode) { %>
        <h1>Trả lời tư vấn <span>nhanh, đúng ngữ cảnh.</span></h1>
      <% } else { %>
        <h1>Trung tâm CSKH <span>đọc đúng, xử lý gọn.</span></h1>
      <% } %>
      <p class="fb-lead">
        <%= advisoryMode
          ? "Gom riêng câu hỏi của khách về booking, check-in, eKYC, giá, thanh toán và dịch vụ để CSKH trả lời theo từng case."
          : "Lọc phản hồi, xem đánh giá, cập nhật trạng thái, trả lời khách và lưu lịch sử xử lý trong một luồng." %>
      </p>
      <div class="fb-actions">
        <a class="fb-button fb-button--primary" href="#feedbackQueue"><%= advisoryMode ? "Xử lý tư vấn" : "Xử lý phản hồi" %></a>
        <a class="fb-button" href="/dashboard/cskh">Dashboard CSKH</a>
        <a class="fb-button" href="<%= advisoryMode ? "/feedback/manage" : "/feedback/advisory/manage" %>"><%= advisoryMode ? "Xem phản hồi thường" : "Xem inbox tư vấn" %></a>
      </div>
    </div>
    <aside class="fb-radar" aria-label="Minh họa vận hành phản hồi">
      <div class="fb-radar-ring"></div>
      <div class="fb-radar-core"></div>
      <span class="fb-radar-word"><%= advisoryMode ? "Câu hỏi" : "Cảm xúc" %></span>
      <span class="fb-radar-word"><%= advisoryMode ? "Booking" : "Rating" %></span>
      <span class="fb-radar-word">Trả lời</span>
      <span class="fb-radar-word">Đóng case</span>
    </aside>
  </section>

  <% if (success) { %><div class="fb-alert fb-alert--success"><%= success %></div><% } %>
  <% if (error) { %><div class="fb-alert fb-alert--error"><%= error %></div><% } %>

  <section class="fb-stats" aria-label="Tổng quan phản hồi">
    <article class="fb-stat is-blue"><span><%= advisoryMode ? "Tổng câu hỏi" : "Tổng phản hồi" %></span><strong><%= numberText(summary.tong) %></strong><small>Theo bộ lọc hiện tại</small></article>
    <article class="fb-stat is-red"><span><%= advisoryMode ? "Chưa trả lời" : "Chưa xử lý" %></span><strong><%= numberText(summary.chua_xu_ly) %></strong><small><%= advisoryMode ? "Cần phản hồi lần đầu" : "Cần ưu tiên tiếp nhận" %></small></article>
    <article class="fb-stat is-yellow"><span><%= advisoryMode ? "Đang follow-up" : "Đang xử lý" %></span><strong><%= numberText(summary.dang_xu_ly) %></strong><small>Đã nhận, chưa đóng</small></article>
    <article class="fb-stat is-green"><span>Đã xử lý</span><strong><%= numberText(summary.da_xu_ly) %></strong><small><%= doneRate %>% hoàn tất</small></article>
    <article class="fb-stat is-orange"><span>Khẩn cấp</span><strong><%= numberText(summary.khan_cap) %></strong><small>Tiêu cực hoặc rating thấp</small></article>
    <article class="fb-stat is-violet"><span>Quá SLA</span><strong><%= numberText(summary.qua_sla) %></strong><small><%= advisoryMode ? "Mốc tư vấn 2h/6h" : `Đánh giá TB ${avgRating ? avgRating.toFixed(1) : "0.0"}/5` %></small></article>
  </section>

  <section class="fb-filter" aria-label="Bộ lọc phản hồi">
    <div class="fb-section-head">
      <div>
        <h2>Bộ lọc nghiệp vụ</h2>
        <p><%= advisoryMode ? "Tìm theo khách, nội dung, trạng thái, nhóm câu hỏi và mức ưu tiên." : "Tìm nhanh theo khách hàng, nội dung, trạng thái, rating, dịch vụ, cảm xúc và khoảng ngày." %></p>
      </div>
      <a class="fb-button" href="<%= baseManagePath %>">Xóa lọc</a>
    </div>
    <form method="get" action="<%= baseManagePath %>">
      <div class="fb-filter-grid">
        <div class="fb-field">
          <label>Từ khóa</label>
          <input name="keyword" value="<%= filters.keyword || "" %>" placeholder="Tên, email, SĐT, nội dung..." />
        </div>
        <div class="fb-field">
          <label>Trạng thái</label>
          <select name="trang_thai">
            <% statuses.forEach(function (item) { %>
              <option value="<%= item.value %>" <%= selectedAttr(filters.trang_thai, item.value) %>><%= item.label %></option>
            <% }) %>
          </select>
        </div>
        <% if (advisoryMode) { %>
          <input type="hidden" name="danh_gia" value="all" />
          <input type="hidden" name="sentiment" value="all" />
          <div class="fb-field">
            <label>Nhóm câu hỏi</label>
            <select name="tu_van_nhom">
              <% advisoryTopics.forEach(function (item) { %>
                <option value="<%= item.value %>" <%= selectedAttr(filters.tu_van_nhom, item.value) %>><%= item.label %></option>
              <% }) %>
            </select>
          </div>
        <% } else { %>
          <div class="fb-field">
            <label>Đánh giá</label>
            <select name="danh_gia">
              <% ratings.forEach(function (item) { %>
                <option value="<%= item.value %>" <%= selectedAttr(filters.danh_gia, item.value) %>><%= item.label %></option>
              <% }) %>
            </select>
          </div>
          <div class="fb-field">
            <label>Cảm xúc</label>
            <select name="sentiment">
              <% sentiments.forEach(function (item) { %>
                <option value="<%= item.value %>" <%= selectedAttr(filters.sentiment, item.value) %>><%= item.label %></option>
              <% }) %>
            </select>
          </div>
        <% } %>
        <div class="fb-field">
          <label>Ưu tiên</label>
          <select name="uu_tien">
            <% priorities.forEach(function (item) { %>
              <option value="<%= item.value %>" <%= selectedAttr(filters.uu_tien, item.value) %>><%= item.label %></option>
            <% }) %>
          </select>
        </div>
        <% if (advisoryMode) { %>
          <input type="hidden" name="loai_dich_vu" value="Tư vấn" />
          <div class="fb-field">
            <label>Loại dịch vụ</label>
            <input value="Tư vấn / hỏi đáp" disabled />
          </div>
        <% } else { %>
          <div class="fb-field">
            <label>Loại dịch vụ</label>
            <select name="loai_dich_vu">
              <option value="all" <%= selectedAttr(filters.loai_dich_vu, "all") %>>Tất cả</option>
              <% serviceTypes.forEach(function (type) { %>
                <option value="<%= type %>" <%= selectedAttr(filters.loai_dich_vu, type) %>><%= type %></option>
              <% }) %>
            </select>
          </div>
        <% } %>
        <div class="fb-field">
          <label>Từ ngày</label>
          <input type="date" name="tu_ngay" value="<%= filters.tu_ngay || "" %>" />
        </div>
        <div class="fb-field">
          <label>Đến ngày</label>
          <input type="date" name="den_ngay" value="<%= filters.den_ngay || "" %>" />
        </div>
        <div class="fb-field">
          <label>&nbsp;</label>
          <button class="fb-button fb-button--primary" type="submit"><%= advisoryMode ? "Lọc tư vấn" : "Lọc phản hồi" %></button>
        </div>
      </div>
    </form>
  </section>

  <section class="fb-layout" id="feedbackQueue">
    <section class="fb-panel" aria-label="Danh sách phản hồi">
      <div class="fb-section-head">
        <div>
          <h2><%= advisoryMode ? "Hàng đợi tư vấn" : "Hàng đợi phản hồi" %></h2>
          <p><%= numberText(totalRows) %> <%= advisoryMode ? "câu hỏi" : "phản hồi" %> phù hợp. Chọn một mục để xem chi tiết, đổi trạng thái hoặc trả lời.</p>
        </div>
        <span class="fb-badge is-negative"><%= advisoryMode ? `${numberText(summary.qua_sla)} quá SLA` : `${numberText(pageNegativeCount)} tiêu cực trên trang` %></span>
      </div>

      <div class="fb-list">
        <% if (items.length === 0) { %>
          <div class="fb-empty">Không có <%= advisoryMode ? "yêu cầu tư vấn" : "phản hồi" %> phù hợp với bộ lọc hiện tại.</div>
        <% } %>
        <% items.forEach(function (item) { %>
          <a class="fb-card <%= selected && Number(selected.id) === Number(item.id) ? "is-active" : "" %>" href="<%= baseManagePath %><%= buildQuery({ id: item.id }) %>">
            <div class="fb-card-head">
              <div>
                <h3><%= item.tenKh || "Khách chưa xác định" %></h3>
                <div class="fb-muted"><%= item.loaiDichVu || "Dịch vụ" %> · #<%= item.id %> · <%= item.ngayTaoLabel || "" %></div>
              </div>
              <% if (advisoryMode) { %>
                <span class="fb-badge <%= toneClass(item.slaTone) %>"><%= item.slaLabel %></span>
              <% } else { %>
                <div class="fb-stars"><%= item.stars || "" %></div>
              <% } %>
            </div>
            <div class="fb-meta">
              <span class="fb-badge <%= toneClass(item.statusTone || statusTone(item.trangThai)) %>"><%= item.statusLabel || statusLabel(item.trangThai) %></span>
              <% if (advisoryMode && item.advisoryIntentLabel) { %>
                <span class="fb-badge is-blue"><%= item.advisoryIntentLabel %></span>
              <% } else { %>
                <span class="fb-badge <%= toneClass(item.sentimentTone || sentimentTone(item.sentiment)) %>"><%= item.sentimentLabel || sentimentLabel(item.sentiment) %></span>
              <% } %>
              <span class="fb-badge <%= toneClass(item.priorityTone) %>"><%= item.priorityLabel %></span>
              <% if (!advisoryMode) { %><span class="fb-badge <%= toneClass(item.slaTone) %>"><%= item.slaLabel %></span><% } %>
              <span class="fb-badge">Chờ <%= item.ageLabel %></span>
              <% if (advisoryMode) { %><span class="fb-badge"><%= Number(item.replyCount || 0) %> trả lời</span><% } %>
              <% if (item.sdt) { %><span class="fb-badge"><%= item.sdt %></span><% } %>
              <% if (item.attachmentUrl) { %><span class="fb-badge">Có ảnh</span><% } %>
            </div>
            <% if (item.topicTags && item.topicTags.length) { %>
              <div class="fb-tags">
                <% item.topicTags.forEach(function (tag) { %><span class="fb-tag"><%= tag %></span><% }) %>
              </div>
            <% } %>
            <p class="fb-content"><%= item.noiDung || "" %></p>
            <% if (item.noiDungTraLoiMoiNhat) { %>
              <div class="fb-reply-preview">
                <strong>Trả lời gần nhất</strong>
                <p class="fb-muted" style="margin:6px 0 0;"><%= item.noiDungTraLoiMoiNhat %></p>
                <div class="fb-muted" style="font-size:12px;"><%= item.nguoiTraLoiMoiNhat || "Nhân viên CSKH" %> · <%= item.ngayTraLoiMoiNhatLabel || "" %></div>
              </div>
            <% } %>
          </a>
        <% }) %>
      </div>

      <% if (totalPages > 1) { %>
        <nav class="fb-pages" aria-label="Phân trang phản hồi">
          <% for (let pageNo = 1; pageNo <= totalPages; pageNo++) { %>
            <a class="fb-page <%= pageNo === currentPage ? "is-active" : "" %>" href="<%= baseManagePath %><%= buildQuery({ page: pageNo, id: "" }) %>"><%= pageNo %></a>
          <% } %>
        </nav>
      <% } %>
    </section>

    <aside class="fb-detail" aria-label="Chi tiết phản hồi">
      <% if (!selected) { %>
        <div class="fb-empty">Chọn một <%= advisoryMode ? "yêu cầu tư vấn" : "phản hồi" %> ở hàng đợi để xem chi tiết xử lý.</div>
      <% } else { %>
        <div class="fb-detail-head">
          <div>
            <h2>#<%= selected.id %> · <%= selected.tenKh || "Khách hàng" %></h2>
            <p class="fb-muted" style="margin:7px 0 0;"><%= selected.loaiDichVu || "Dịch vụ" %> · <%= selected.ngayTaoLabel || "" %></p>
          </div>
          <% if (advisoryMode) { %>
            <span class="fb-badge is-blue"><%= selected.advisoryIntentLabel || "Tư vấn" %></span>
          <% } else { %>
            <div class="fb-stars"><%= selected.stars || "" %></div>
          <% } %>
        </div>

        <div class="fb-meta">
          <span class="fb-badge <%= toneClass(selected.statusTone || statusTone(selected.trangThai)) %>"><%= selected.statusLabel || statusLabel(selected.trangThai) %></span>
          <% if (advisoryMode && selected.advisoryIntentLabel) { %>
            <span class="fb-badge is-blue"><%= selected.advisoryIntentLabel %></span>
          <% } else { %>
            <span class="fb-badge <%= toneClass(selected.sentimentTone || sentimentTone(selected.sentiment)) %>"><%= selected.sentimentLabel || sentimentLabel(selected.sentiment) %></span>
          <% } %>
          <span class="fb-badge <%= toneClass(selected.priorityTone) %>"><%= selected.priorityLabel %></span>
          <span class="fb-badge <%= toneClass(selected.slaTone) %>"><%= selected.slaLabel %></span>
          <span class="fb-badge"><%= advisoryMode ? `${Number(selected.replyCount || 0)} trả lời` : `Điểm cảm xúc: ${selected.diemCamXuc ?? 0}` %></span>
        </div>

        <div class="fb-priority">Ưu tiên xử lý: <%= selected.actionHint || "CSKH nên phản hồi rõ hướng xử lý và cập nhật trạng thái phù hợp." %></div>

        <% if (selected.topicTags && selected.topicTags.length) { %>
          <div class="fb-tags">
            <% selected.topicTags.forEach(function (tag) { %><span class="fb-tag"><%= tag %></span><% }) %>
          </div>
        <% } %>

        <div class="fb-detail-grid">
          <div class="fb-info"><span>Email</span><strong><%= selected.email || "Chưa có" %></strong></div>
          <div class="fb-info"><span>Số điện thoại</span><strong><%= selected.sdt || "Chưa có" %></strong></div>
          <div class="fb-info"><span>CCCD</span><strong><%= selected.cccd || "Chưa có" %></strong></div>
          <div class="fb-info"><span>Nhân viên</span><strong><%= currentUserName %></strong></div>
        </div>

        <div class="fb-detail-block">
          <strong><%= advisoryMode ? "Nội dung khách đang hỏi" : "Nội dung khách gửi" %></strong>
          <p class="fb-content"><%= selected.noiDung || "" %></p>
          <% if (selected.attachmentUrl) { %>
            <a class="fb-attachment" href="<%= selected.attachmentUrl %>" target="_blank" rel="noopener">
              <img src="<%= selected.attachmentUrl %>" alt="Ảnh đính kèm phản hồi #<%= selected.id %>" />
            </a>
          <% } %>
        </div>

        <div class="fb-detail-block">
          <strong>Cập nhật trạng thái nhanh</strong>
          <form method="post" action="/feedback/<%= selected.id %>/status">
            <input type="hidden" name="return_to" value="<%= returnTo %>" />
            <div class="fb-field" style="margin-top:10px;">
              <label>Trạng thái mới</label>
              <select name="status">
                <% statusOptions.forEach(function (item) { %>
                  <option value="<%= item.value %>" <%= selectedAttr(selected.trangThai, item.value) %>><%= item.label %></option>
                <% }) %>
              </select>
            </div>
            <div class="fb-form-actions">
              <button class="fb-button" type="submit">Lưu trạng thái</button>
            </div>
          </form>
        </div>

        <div class="fb-detail-block">
          <strong><%= advisoryMode ? "Trả lời tư vấn" : "Trả lời khách hàng" %></strong>
          <p class="fb-muted" style="margin:6px 0 0;"><%= advisoryMode ? "Mỗi lần gửi trả lời sẽ lưu thành một mốc hội thoại. Bạn có thể để trạng thái Đang xử lý nếu còn cần follow-up." : "Gửi trả lời sẽ lưu vào lịch sử xử lý. Mặc định đóng trạng thái là đã xử lý." %></p>
          <form method="post" action="/feedback/<%= selected.id %>/reply">
            <input type="hidden" name="return_to" value="<%= returnTo %>" />
            <div class="fb-field" style="margin-top:10px;">
              <label>Sau khi trả lời</label>
              <select name="status">
                <% statusOptions.forEach(function (item) { %>
                  <option value="<%= item.value %>" <%= selectedAttr(item.value, advisoryMode ? "DangXuLy" : "DaXuLy") %>><%= item.label %></option>
                <% }) %>
              </select>
            </div>
            <div class="fb-field" style="margin-top:10px;">
              <label>Nội dung trả lời</label>
              <textarea id="feedbackReplyText" name="reply" required minlength="2" placeholder="<%= advisoryMode ? "Trả lời trực tiếp câu hỏi, xác nhận thông tin còn thiếu và chốt bước tiếp theo..." : "Nhập nội dung trả lời rõ hướng xử lý, xin lỗi/cảm ơn nếu cần và cam kết bước tiếp theo..." %>"></textarea>
            </div>
            <% if (selected.suggestedReplies && selected.suggestedReplies.length) { %>
              <div class="fb-ai-actions">
                <% selected.suggestedReplies.forEach(function (suggestion) { %>
                  <button class="fb-suggestion" type="button" data-reply-template="<%= suggestion %>"><%= suggestion %></button>
                <% }) %>
              </div>
            <% } %>
            <div class="fb-form-actions">
              <button class="fb-button fb-button--primary" type="submit">Gửi trả lời</button>
            </div>
          </form>
        </div>

        <div class="fb-detail-block">
          <div class="fb-reply-head">
            <strong>Lịch sử trả lời</strong>
            <span class="fb-badge"><%= replies.length %> mục</span>
          </div>
          <div class="fb-thread">
            <% if (replies.length === 0) { %>
                  <div class="fb-empty">Chưa có trả lời nào. Đây là <%= advisoryMode ? "câu hỏi" : "phản hồi" %> cần CSKH tiếp nhận đầu tiên.</div>
            <% } %>
            <% replies.forEach(function (reply) { %>
              <article class="fb-reply-item">
                <div class="fb-reply-head">
                  <strong><%= reply.tennv || "Nhân viên CSKH" %></strong>
                  <span class="fb-muted" style="font-size:12px;"><%= reply.ngayTraLoiLabel || reply.ngaytraloi || "" %></span>
                </div>
                <p class="fb-content"><%= reply.noidungtraloi || "" %></p>
              </article>
            <% }) %>
          </div>
        </div>
      <% } %>
    </aside>
  </section>
</main>

<script>
  (() => {
    const reply = document.getElementById("feedbackReplyText");
    if (!reply) return;
    document.querySelectorAll("[data-reply-template]").forEach((button) => {
      button.addEventListener("click", () => {
        reply.value = button.getAttribute("data-reply-template") || "";
        reply.focus();
      });
    });
  })();
</script>

<%- include("../partials/footer") %>
