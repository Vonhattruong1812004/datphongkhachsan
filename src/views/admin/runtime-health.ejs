<%- include("../partials/head") %>
<%- include("../partials/header") %>
<main class="container">
  <section class="panel">
    <div class="section-eyebrow">Runtime Health</div>
    <h2>Storage, uploads, build assets va runtime path</h2>
    <div class="dashboard-grid">
      <article class="dashboard-card"><strong><%= payload.summary.overall_score %>%</strong><h3>Runtime score</h3></article>
      <article class="dashboard-card"><strong><%= payload.summary.ready %></strong><h3>Ready</h3></article>
      <article class="dashboard-card"><strong><%= payload.summary.blocked %></strong><h3>Blocked</h3></article>
    </div>
    <div class="nav-links" style="margin-top:16px;">
      <a class="chip" href="/api/admin/diagnostics/runtime">Runtime JSON</a>
      <a class="chip" href="/admin/diagnostics">Tong hop</a>
    </div>
  </section>
  <section class="panel">
    <div class="section-eyebrow">Checks</div>
    <div class="room-grid room-grid--wide">
      <% payload.checks.forEach((item) => { %>
        <article class="room-card">
          <span class="badge"><%= item.status %></span>
          <h3><%= item.label %></h3>
          <p class="muted"><%= item.detail %></p>
        </article>
      <% }) %>
    </div>
  </section>
</main>
<%- include("../partials/footer") %>
