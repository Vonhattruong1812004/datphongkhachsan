<%- include("../partials/head") %>
<%- include("../partials/header") %>
<%
  const checks = payload?.checks || [];
  const summary = payload?.summary || {};
  const score = Number(summary.overall_score || 0);
  const readyCount = Number(summary.ready || 0);
  const partialCount = Number(summary.partial || 0);
  const blockedCount = Number(summary.blocked || 0);
  const generatedAt = payload?.generatedAt || new Date().toISOString();
  const shortTime = new Date(generatedAt).toLocaleString("vi-VN", { hour12: false });
  const blockedChecks = checks.filter((item) => item.status === "blocked");
  const warningChecks = checks.filter((item) => item.status === "partial");
  const healthLabel = blockedCount > 0 ? "Cần xử lý" : (partialCount > 0 ? "Cần theo dõi" : "Ổn định");
  const statusText = (status) => status === "ready" ? "Sẵn sàng" : (status === "blocked" ? "Cần xử lý" : "Theo dõi");
%>
<style>
  .runtime-health{
    --rt-ink:#102033;
    --rt-muted:#667085;
    --rt-line:rgba(16,32,51,.10);
    --rt-card:rgba(255,255,255,.84);
    --rt-blue:#0ea5e9;
    --rt-green:#14b8a6;
    --rt-amber:#f59e0b;
    --rt-red:#fb7185;
    --rt-shadow:0 24px 70px rgba(15,23,42,.14);
    min-height:calc(100vh - 84px);
    padding:34px 18px 58px;
    color:var(--rt-ink);
    background:
      radial-gradient(circle at 8% 8%, rgba(14,165,233,.26), transparent 30%),
      radial-gradient(circle at 92% 10%, rgba(20,184,166,.22), transparent 30%),
      radial-gradient(circle at 52% 106%, rgba(245,158,11,.16), transparent 35%),
      linear-gradient(135deg,#f8fcff 0%,#eef8ff 46%,#f8fff7 100%);
  }
  .rt-wrap{max-width:1220px;margin:0 auto}
  .rt-card,.rt-hero-main,.rt-score-card,.rt-check,.rt-issue{border:1px solid var(--rt-line);background:var(--rt-card);box-shadow:var(--rt-shadow);backdrop-filter:blur(24px)}
  .rt-hero{display:grid;grid-template-columns:minmax(0,1fr) 340px;gap:18px;align-items:stretch;margin-bottom:18px}
  .rt-hero-main{position:relative;overflow:hidden;border-radius:34px;padding:32px}
  .rt-hero-main::before{content:"";position:absolute;inset:-1px;background:linear-gradient(120deg,rgba(255,255,255,.70),transparent 30%),radial-gradient(circle at 88% 18%,rgba(14,165,233,.18),transparent 32%);pointer-events:none}
  .rt-chip{position:relative;z-index:1;display:inline-flex;align-items:center;gap:8px;border-radius:999px;padding:7px 12px;background:rgba(14,165,233,.12);border:1px solid rgba(14,165,233,.18);color:#0369a1;font-size:12px;font-weight:1000;text-transform:uppercase;letter-spacing:.08em}
  .rt-dot{width:8px;height:8px;border-radius:999px;background:var(--rt-blue);box-shadow:0 0 0 7px rgba(14,165,233,.14)}
  .rt-hero h1{position:relative;z-index:1;max-width:760px;margin:24px 0 12px;font-size:clamp(38px,5vw,64px);line-height:.96}
  .rt-hero h1 span{color:transparent;background:linear-gradient(135deg,#0ea5e9,#14b8a6 54%,#f59e0b);-webkit-background-clip:text;background-clip:text}
  .rt-lead{position:relative;z-index:1;max-width:760px;margin:0;color:var(--rt-muted);font-size:15.5px;line-height:1.68}
  .rt-actions{position:relative;z-index:1;display:flex;flex-wrap:wrap;gap:10px;margin-top:24px}
  .rt-button{display:inline-flex;align-items:center;justify-content:center;min-height:42px;border:1px solid rgba(16,32,51,.12);border-radius:999px;padding:10px 16px;background:rgba(255,255,255,.76);color:var(--rt-ink);font:inherit;font-size:14px;font-weight:900;text-decoration:none;cursor:pointer;transition:transform .18s ease,box-shadow .18s ease,border-color .18s ease}
  .rt-button:hover{transform:translateY(-2px);border-color:var(--rt-blue);box-shadow:0 18px 42px rgba(14,165,233,.14)}
  .rt-button--primary{border-color:transparent;color:#fff;background:linear-gradient(135deg,#0ea5e9,#14b8a6);box-shadow:0 18px 42px rgba(14,165,233,.22)}
  .rt-mini-grid{position:relative;z-index:1;display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;margin-top:28px}
  .rt-mini{border-radius:22px;padding:15px;background:rgba(255,255,255,.62);border:1px solid rgba(16,32,51,.08)}
  .rt-mini strong{display:block;font-size:28px;line-height:1}
  .rt-mini span{display:block;margin-top:8px;color:var(--rt-muted);font-size:12px;font-weight:900;text-transform:uppercase;letter-spacing:.06em}
  .rt-score-card{display:flex;flex-direction:column;justify-content:center;align-items:center;border-radius:34px;padding:24px;background:linear-gradient(160deg,rgba(255,255,255,.92),rgba(240,253,250,.76))}
  .rt-ring{--score:<%= score %>;width:200px;aspect-ratio:1;border-radius:50%;display:grid;place-items:center;background:conic-gradient(var(--rt-green) calc(var(--score)*1%),rgba(16,32,51,.09) 0);box-shadow:inset 0 0 0 16px rgba(255,255,255,.80),0 24px 70px rgba(20,184,166,.18)}
  .rt-ring-inner{width:134px;aspect-ratio:1;border-radius:50%;display:grid;place-items:center;text-align:center;background:rgba(255,255,255,.94);border:1px solid rgba(16,32,51,.08)}
  .rt-ring-inner strong{display:block;font-size:42px;line-height:1}
  .rt-ring-inner span{display:block;margin-top:6px;color:var(--rt-muted);font-size:12px;font-weight:1000;text-transform:uppercase;letter-spacing:.07em}
  .rt-score-card h2{margin:18px 0 6px;font-size:26px}
  .rt-score-card p{margin:0;color:var(--rt-muted);text-align:center;font-size:13px;line-height:1.55}
  .rt-section{margin-top:18px}
  .rt-section-head{display:flex;align-items:flex-end;justify-content:space-between;gap:12px;margin-bottom:14px}
  .rt-section-head h2{margin:0;font-size:24px}
  .rt-section-head p{margin:4px 0 0;color:var(--rt-muted);font-size:13px}
  .rt-issue-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}
  .rt-issue{position:relative;overflow:hidden;border-radius:24px;padding:16px;background:rgba(255,255,255,.76)}
  .rt-issue::before{content:"";position:absolute;inset:0 auto 0 0;width:5px;background:var(--issue-color,#f59e0b)}
  .rt-issue strong{display:block;font-size:15px}
  .rt-issue span{display:block;margin-top:6px;color:var(--rt-muted);font-size:13px;line-height:1.5}
  .rt-check-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}
  .rt-check{position:relative;overflow:hidden;border-radius:24px;padding:18px;background:rgba(255,255,255,.76)}
  .rt-check::before{content:"";position:absolute;inset:0 0 auto;height:5px;background:linear-gradient(90deg,var(--status-color,#14b8a6),transparent)}
  .rt-status{display:inline-flex;border-radius:999px;padding:6px 10px;background:color-mix(in srgb,var(--status-color,#14b8a6) 14%,white);color:var(--status-color,#14b8a6);font-size:11px;font-weight:1000;text-transform:uppercase;letter-spacing:.04em}
  .rt-check h3{margin:14px 0 6px;font-size:18px}
  .rt-check p{margin:0;color:var(--rt-muted);font-size:13px;line-height:1.55}
  .rt-empty{border:1px dashed rgba(16,32,51,.16);border-radius:22px;padding:18px;background:rgba(255,255,255,.60);color:var(--rt-muted);font-size:13px}
  @media(max-width:1080px){.rt-hero{grid-template-columns:1fr}.rt-check-grid{grid-template-columns:repeat(2,minmax(0,1fr))}}
  @media(max-width:720px){.runtime-health{padding:22px 12px 48px}.rt-hero-main,.rt-score-card{padding:20px;border-radius:26px}.rt-hero h1{font-size:42px}.rt-mini-grid,.rt-issue-grid,.rt-check-grid{grid-template-columns:1fr}.rt-section-head{display:block}.rt-ring{width:180px}.rt-ring-inner{width:122px}}
</style>

<main class="runtime-health">
  <div class="rt-wrap">
    <section class="rt-hero" aria-label="Kiểm tra runtime">
      <div class="rt-hero-main">
        <div class="rt-chip"><span class="rt-dot"></span> Runtime health workspace</div>
        <h1>Kiểm tra <span>runtime & hạ tầng</span></h1>
        <p class="rt-lead">Theo dõi database, build assets, PWA, upload, storage và backup path. Trang này chỉ kiểm tra điều kiện vận hành, không thay đổi dữ liệu nghiệp vụ.</p>
        <div class="rt-actions">
          <button class="rt-button rt-button--primary" type="button" onclick="window.location.reload()">Kiểm tra lại</button>
          <a class="rt-button" href="/admin/diagnostics">Tổng hợp sức khỏe</a>
          <a class="rt-button" href="/dashboard/admin">Về dashboard Admin</a>
          <a class="rt-button" href="/api/admin/diagnostics/runtime">Runtime JSON</a>
          <a class="rt-button" href="/admin/backups">Sao lưu dữ liệu</a>
        </div>
        <div class="rt-mini-grid">
          <div class="rt-mini"><strong><%= readyCount %></strong><span>Sẵn sàng</span></div>
          <div class="rt-mini"><strong><%= partialCount %></strong><span>Theo dõi</span></div>
          <div class="rt-mini"><strong><%= blockedCount %></strong><span>Cần xử lý</span></div>
        </div>
      </div>
      <aside class="rt-score-card">
        <div class="rt-ring" aria-label="Runtime score">
          <div class="rt-ring-inner"><div><strong><%= score %></strong><span>Runtime</span></div></div>
        </div>
        <h2><%= healthLabel %></h2>
        <p>Cập nhật: <%= shortTime %></p>
      </aside>
    </section>

    <section class="rt-section" aria-label="Điểm cần xử lý">
      <div class="rt-section-head">
        <div>
          <h2>Điểm cần xử lý</h2>
          <p>Ưu tiên xử lý các mục blocked trước, partial theo dõi sau.</p>
        </div>
      </div>
      <% if (!blockedChecks.length && !warningChecks.length) { %>
        <div class="rt-empty">Runtime đang ổn, chưa có cảnh báo cần xử lý.</div>
      <% } else { %>
        <div class="rt-issue-grid">
          <% [...blockedChecks, ...warningChecks].forEach((item) => {
            const color = item.status === "blocked" ? "#fb7185" : "#f59e0b";
          %>
            <article class="rt-issue" style="--issue-color:<%= color %>">
              <strong><%= item.label %> · <%= statusText(item.status) %></strong>
              <span><%= item.detail %></span>
              <% if (item.technical_path) { %>
                <span><%= item.technical_path %></span>
              <% } %>
            </article>
          <% }) %>
        </div>
      <% } %>
    </section>

    <section class="rt-section" aria-label="Runtime checks">
      <div class="rt-section-head">
        <div>
          <h2>Danh sách kiểm tra</h2>
          <p>Đọc trực tiếp từ service runtime diagnostics của Admin.</p>
        </div>
      </div>
      <div class="rt-check-grid">
        <% checks.forEach((item) => {
          const color = item.status === "ready" ? "#14b8a6" : (item.status === "blocked" ? "#fb7185" : "#f59e0b");
        %>
          <article class="rt-check" style="--status-color:<%= color %>">
            <span class="rt-status"><%= statusText(item.status) %></span>
            <h3><%= item.label %></h3>
            <p><%= item.detail %></p>
          </article>
        <% }) %>
      </div>
    </section>
  </div>
</main>
<%- include("../partials/footer") %>
