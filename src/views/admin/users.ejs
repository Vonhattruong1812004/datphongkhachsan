    border-radius:18px;
    border:2px solid #9bdcf4;
    background:#f9fdff;
    color:#082033;
    font-size:15px;
    font-weight:850;
    box-shadow:0 12px 26px rgba(0,0,0,.16);
  }
  .admin-filter-field input:focus,
  .admin-filter-field select:focus,
  .admin-field input:focus,
  .admin-field select:focus{
    border-color:#facc15;
