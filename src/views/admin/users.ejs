      radial-gradient(circle at 86% 16%,rgba(103,232,249,.18),transparent 26%),
      radial-gradient(circle at 16% 90%,rgba(250,204,21,.13),transparent 24%),
      linear-gradient(145deg,rgba(7,18,42,.96),rgba(12,27,58,.88));
