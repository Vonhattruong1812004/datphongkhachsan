  }
  .admin-user-meta small{
    color:#476176;
  }
  .admin-user-meta strong{
    color:#071827;
  }
  .admin-user-actions .admin-button{
    color:#061426;
    background:rgba(255,255,255,.86);
    border-color:rgba(255,255,255,.40);
  }
  .admin-user-actions .admin-button--danger{
    color:#fff;
    background:rgba(190,18,60,.82);
  }
  .admin-empty{
    color:#c7d9ec;
    background:rgba(8,18,40,.76);
    border-color:rgba(125,211,252,.30);
  }
  @keyframes admin-users-stars{
    0%{background-position:8% 12%,42% 26%,74% 8%,0 0}
    100%{background-position:8% 132%,42% 126%,74% 118%,240px 0}
  }
  @media(max-width:1080px){
    .admin-hero{
      grid-template-columns:1fr;
    }
  }
  @media(max-width:720px){
    .admin-users{
      padding:18px 12px 42px;
    }
    .admin-hero-main,
    .admin-card{
      padding:22px;
      border-radius:28px;
    }
    .admin-section-head h2{
      font-size:26px;
    }
    .admin-filter-actions{
      grid-template-columns:1fr;
    }
  }

  /* UC1 Admin final polish: clearer hierarchy and calmer account cards. */
  .admin-users{
    padding-top:28px;
  }
  .admin-users__wrap{
    max-width:1340px;
  }
  .admin-hero{
    grid-template-columns:minmax(0,1.08fr) 380px;
