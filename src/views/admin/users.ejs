    background:radial-gradient(circle at 100% 0%,rgba(255,255,255,.16),transparent 34%),linear-gradient(135deg,#10b981,#14b8a6 52%,#2563eb);
  }
  .admin-user-card:nth-child(4n+3){
    background:radial-gradient(circle at 100% 0%,rgba(255,255,255,.16),transparent 34%),linear-gradient(135deg,#f59e0b,#fb7185 58%,#7c3aed);
  }
  .admin-user-card:nth-child(4n+4){
    background:radial-gradient(circle at 100% 0%,rgba(255,255,255,.16),transparent 34%),linear-gradient(135deg,#fb7185,#a855f7 54%,#0ea5e9);
  }
  .admin-user-card::before{
    height:6px;
    background:linear-gradient(90deg,rgba(255,255,255,.92),rgba(255,255,255,.10));
  }
  .admin-user-id,
  .admin-status,
  .admin-user-meta div{
    color:#061426;
    background:rgba(255,255,255,.84);
    border-color:rgba(255,255,255,.42);
