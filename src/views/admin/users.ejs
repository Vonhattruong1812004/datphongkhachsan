  .admin-filter-actions{
    align-self:stretch;
    align-items:end;
  }
  .admin-filter-actions .admin-button{
    min-height:54px;
  }
  .admin-quick-filters{
    gap:12px;
    margin-top:20px;
  }
  .admin-quick-filter{
    min-height:42px;
    padding:9px 13px;
    border-color:rgba(186,230,253,.38);
    background:rgba(255,255,255,.08);
    color:#eaf8ff;
  }
  .admin-quick-filter.is-active{
    background:linear-gradient(135deg,#67e8f9,#a7f3d0 58%,#facc15);
    color:#061826;
  }
  .admin-grid{
    grid-template-columns:repeat(12,minmax(0,1fr));
    gap:20px;
  }
  .admin-field{
