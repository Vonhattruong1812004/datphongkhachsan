    min-height:0;
    padding:24px;
    border-radius:26px;
    border:1px solid rgba(125,211,252,.28);
    background:
      linear-gradient(90deg,var(--role-color,#38bdf8) 0 8px,transparent 8px),
      radial-gradient(circle at 96% 12%,rgba(255,255,255,.10),transparent 28%),
      linear-gradient(145deg,rgba(9,20,44,.96),rgba(13,28,61,.88));
    box-shadow:0 24px 68px rgba(0,0,0,.32),inset 0 1px 0 rgba(255,255,255,.08);
  }
  .admin-user-card::before{
    display:none;
  }
  .admin-user-top{
    align-items:center;
  }
  .admin-user-id,
  .admin-status{
    min-height:34px;
    align-items:center;
    color:#061826;
    background:#f8fdff;
    border-color:rgba(186,230,253,.78);
  }
  .admin-status{
    color:#065f46;
    background:#d1fae5;
  }
  .admin-status.is-locked{
    color:#7f1d1d;
    background:#ffe4e6;
  }
  .admin-user-card h3{
    margin:20px 0 8px;
    font-size:28px;
    line-height:1.05;
  }
  .admin-user-card p{
    color:#d7edff;
    font-size:15px;
  }
  .admin-user-meta{
    gap:12px;
    margin-top:18px;
  }
  .admin-user-meta div{
    min-height:74px;
    border:1px solid rgba(186,230,253,.70);
    background:#ffffff;
    box-shadow:0 10px 24px rgba(0,0,0,.14);
  }
  .admin-user-meta small{
    color:#526b80;
    font-size:11px;
  }
  .admin-user-meta strong{
    color:#061826;
    font-size:14px;
  }
  .admin-user-actions{
    gap:10px;
    margin-top:18px;
    padding-top:16px;
    border-top:1px solid rgba(125,211,252,.18);
  }
  .admin-user-actions .admin-button{
    min-height:40px;
    color:#061826;
    background:#f8fdff;
    border-color:rgba(186,230,253,.72);
  }
  .admin-user-actions .admin-button--danger{
    color:#fff;
    background:linear-gradient(135deg,#fb7185,#e11d48);
    border-color:rgba(255,255,255,.24);
  }
  @media(max-width:1080px){
    .admin-hero,
    .admin-filter-row{
      grid-template-columns:1fr;
    }
    .admin-users-grid{
      grid-template-columns:1fr;
    }
    .admin-field,
    .admin-field.is-wide{
      grid-column:span 6;
    }
  }
  @media(max-width:720px){
    .admin-hero-main,
    .admin-card{
      padding:22px;
    }
    .admin-section-head h2{
      font-size:27px;
    }
    .admin-field,
    .admin-field.is-wide{
      grid-column:1/-1;
    }
    .admin-filter-card{
      padding-left:24px;
    }
    .admin-filter-card::before{
      inset:22px auto 22px 12px;
    }
    .admin-user-card{
      padding:20px;
    }
  }

  /* UC1 Admin cleanup: no animated illustration on this workflow page. */
  .admin-users{
    background: transparent !important;
  }
  .admin-users::before{
    display:none !important;
    content:none !important;
    animation:none !important;
  }
  .admin-users::after{
    display:none !important;
    content:none !important;
  }
  .admin-hero{
    grid-template-columns:1fr;
  }
  .admin-hero-main{
    min-height:0;
  }
  .admin-orbit{
    display:none;
  }
</style>

<main class="admin-users">
  <div class="admin-users__wrap">
    <section class="admin-hero" aria-label="Người dùng và phân quyền">
      <div class="admin-hero-main">
        <div class="admin-chip"><span class="admin-pulse"></span> Admin access workspace</div>
        <h1>Người dùng <span>& phân quyền</span></h1>
        <p class="admin-lead">Tạo tài khoản, gán vai trò, khóa/mở truy cập và liên kết đúng hồ sơ nhân viên hoặc khách hàng mà không rời khỏi UC Admin.</p>
        <div class="admin-actions">
          <a class="admin-button admin-button--primary" href="#userForm">Tạo tài khoản</a>
          <a class="admin-button" href="/admin/diagnostics">Kiểm tra sức khỏe hệ thống</a>
          <a class="admin-button" href="/dashboard/admin">Dashboard Admin</a>
        </div>
        <div class="admin-mini-stats" aria-label="Tóm tắt tài khoản">
          <div class="admin-mini-stat"><strong><%= totalCount %></strong><span>Tài khoản</span></div>
          <div class="admin-mini-stat"><strong><%= activeCount %></strong><span>Đang hoạt động</span></div>
          <div class="admin-mini-stat"><strong><%= lockedCount %></strong><span>Bị khóa/ngưng</span></div>
        </div>
      </div>
    </section>

    <section class="admin-section" aria-label="Tìm kiếm và lọc tài khoản">
      <div class="admin-section-head">
        <div>
          <h2>Tìm kiếm tài khoản</h2>
          <p>Lọc theo username, họ tên, email, SĐT, CCCD hoặc vai trò để xử lý nhanh đúng người dùng.</p>
        </div>
        <button class="admin-button" type="button" id="exportUsersCsv">Xuất CSV</button>
      </div>
      <form class="admin-card admin-filter-card" method="get" action="/admin/users">
        <div class="admin-filter-row">
          <div class="admin-filter-field">
            <label for="keyword">Từ khóa</label>
            <div class="admin-search-box">
              <span class="admin-search-icon" aria-hidden="true"></span>
              <input id="keyword" name="keyword" value="<%= filters.keyword || "" %>" placeholder="Username, tên, email, SĐT, CCCD..." autocomplete="off" />
            </div>
          </div>
          <div class="admin-filter-field">
            <label for="filterRole">Vai trò</label>
            <select id="filterRole" name="vai_tro">
              <option value="all">Tất cả vai trò</option>
              <% roles.forEach((role) => { %>
                <option value="<%= role.id %>" <%= String(filters.vai_tro || "all") === String(role.id) ? "selected" : "" %>><%= role.tenVaiTro %></option>
              <% }) %>
            </select>
          </div>
          <div class="admin-filter-field">
            <label for="filterStatus">Trạng thái</label>
            <select id="filterStatus" name="trang_thai">
              <option value="all" <%= (filters.trang_thai || "all") === "all" ? "selected" : "" %>>Tất cả trạng thái</option>
              <option value="HoatDong" <%= filters.trang_thai === "HoatDong" ? "selected" : "" %>>Hoạt động</option>
              <option value="Khoa" <%= filters.trang_thai === "Khoa" ? "selected" : "" %>>Khóa</option>
              <option value="Ngung" <%= filters.trang_thai === "Ngung" ? "selected" : "" %>>Ngưng</option>
            </select>
          </div>
          <div class="admin-filter-field">
            <label for="filterLink">Liên kết hồ sơ</label>
            <select id="filterLink" name="lien_ket">
              <option value="all" <%= (filters.lien_ket || "all") === "all" ? "selected" : "" %>>Tất cả</option>
              <option value="staff" <%= filters.lien_ket === "staff" ? "selected" : "" %>>Nhân viên</option>
              <option value="customer" <%= filters.lien_ket === "customer" ? "selected" : "" %>>Khách hàng</option>
              <option value="orphan" <%= filters.lien_ket === "orphan" ? "selected" : "" %>>Chưa liên kết</option>
            </select>
          </div>
          <div class="admin-filter-actions">
            <button class="admin-button admin-button--primary" type="submit">Tìm kiếm</button>
            <a class="admin-button" href="/admin/users">Đặt lại</a>
          </div>
        </div>
        <div class="admin-quick-filters" aria-label="Bộ lọc nhanh">
          <a class="admin-quick-filter <%= (filters.trang_thai || "all") === "all" && (filters.lien_ket || "all") === "all" && (filters.vai_tro || "all") === "all" && !(filters.keyword || "") ? "is-active" : "" %>" href="/admin/users"><span class="admin-quick-dot"></span>Tất cả <%= totalCount %></a>
          <a class="admin-quick-filter <%= filters.trang_thai === "HoatDong" ? "is-active" : "" %>" style="--quick-color:#14b8a6" href="/admin/users?trang_thai=HoatDong"><span class="admin-quick-dot"></span>Đang hoạt động <%= activeCount %></a>
          <a class="admin-quick-filter <%= filters.trang_thai === "Khoa" ? "is-active" : "" %>" style="--quick-color:#fb7185" href="/admin/users?trang_thai=Khoa"><span class="admin-quick-dot"></span>Đang khóa</a>
          <a class="admin-quick-filter <%= filters.lien_ket === "staff" ? "is-active" : "" %>" style="--quick-color:#8b5cf6" href="/admin/users?lien_ket=staff"><span class="admin-quick-dot"></span>Nhân viên <%= staffCount %></a>
          <a class="admin-quick-filter <%= filters.lien_ket === "customer" ? "is-active" : "" %>" style="--quick-color:#f59e0b" href="/admin/users?lien_ket=customer"><span class="admin-quick-dot"></span>Khách hàng <%= customerCount %></a>
        </div>
      </form>
    </section>

    <section class="admin-section" aria-label="Form tài khoản">
      <div class="admin-section-head">
        <div>
          <h2>Tạo hoặc sửa tài khoản</h2>
          <p>Role quyết định dashboard và UC mà người dùng được phép truy cập.</p>
        </div>
      </div>
      <form method="post" action="/admin/users" class="admin-card" id="userForm" novalidate>
        <input type="hidden" name="user_id" id="user_id" />
        <div class="admin-grid">
          <div class="admin-field is-wide">
            <label for="ho_ten">Họ tên</label>
            <input id="ho_ten" name="ho_ten" required minlength="2" autocomplete="name" />
            <div class="admin-error-msg" id="err_ho_ten"></div>
          </div>
          <div class="admin-field">
            <label for="username">Username</label>
            <input id="username" name="username" required minlength="5" maxlength="30" pattern="[A-Za-z0-9_]+" autocomplete="username" />
            <div class="admin-error-msg" id="err_username"></div>
          </div>
          <div class="admin-field">
            <label for="password">Mật khẩu</label>
            <input id="password" name="password" value="Abc@123" minlength="6" autocomplete="new-password" />
            <div class="admin-error-msg" id="err_password"></div>
          </div>
          <div class="admin-field">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" required pattern="^[^\\s@]+@[^\\s@]+\\.[^\\s@]{2,}$" placeholder="user@example.com" autocomplete="email" />
            <div class="admin-error-msg" id="err_email"></div>
          </div>
          <div class="admin-field">
            <label for="sdt">Số điện thoại</label>
            <input id="sdt" name="sdt" required pattern="^(0\\d{9}|\\+84\\d{9})$" placeholder="0901234567" inputmode="tel" autocomplete="tel" />
            <div class="admin-error-msg" id="err_sdt"></div>
          </div>
          <div class="admin-field"><label for="vai_tro">Vai trò</label>
            <select id="vai_tro" name="vai_tro" required>
              <% roles.forEach((role) => { %>
                <option value="<%= role.id %>"><%= role.tenVaiTro %></option>
              <% }) %>
            </select>
            <div class="admin-error-msg" id="err_vai_tro"></div>
          </div>
          <div class="admin-field"><label for="trang_thai">Trạng thái</label>
            <select id="trang_thai" name="trang_thai">
              <option value="HoatDong">Hoạt động</option>
              <option value="Khoa">Khóa</option>
              <option value="Ngung">Ngưng</option>
            </select>
            <div class="admin-error-msg" id="err_trang_thai"></div>
          </div>
          <div class="admin-field">
            <label for="cccd">CCCD</label>
            <input id="cccd" name="cccd" placeholder="Bắt buộc khi tạo khách hàng" pattern="^\\d{9,12}$" inputmode="numeric" />
            <div class="admin-error-msg" id="err_cccd"></div>
          </div>
        </div>
        <div class="admin-form-actions">
          <span class="admin-form-note" id="formMode">Đang ở chế độ tạo mới.</span>
          <div class="admin-actions" style="margin-top:0">
            <button class="admin-button" type="reset" id="resetForm">Làm mới</button>
            <button class="admin-button admin-button--primary" type="submit">Lưu tài khoản</button>
          </div>
        </div>
      </form>
    </section>

    <section class="admin-section" aria-label="Danh sách tài khoản">
      <div class="admin-section-head">
        <div>
          <h2>Danh sách tài khoản</h2>
          <p>Đang hiển thị <%= filteredCount %>/<%= totalCount %> tài khoản. Toàn hệ thống có <%= staffCount %> nhân viên và <%= customerCount %> khách hàng.</p>
        </div>
        <a class="admin-button" href="/api/admin/users<%= filterQueryString ? `?${filterQueryString}` : "" %>">JSON</a>
      </div>
      <% if (!users.length) { %>
        <div class="admin-empty">Chưa có tài khoản nào.</div>
      <% } else { %>
        <div class="admin-users-grid">
          <% users.forEach((item) => {
            const name = item.tenKh || item.tenNv || "";
            const email = item.emailKh || item.emailNv || "";
            const sdt = item.sdtKh || item.sdtNv || "";
            const cccd = item.cccdKh || "";
            const roleColor = Number(item.maVaiTro) === 1 ? "#0ea5e9" : Number(item.maVaiTro) === 6 ? "#14b8a6" : Number(item.maVaiTro) === 7 ? "#f59e0b" : "#8b5cf6";
          %>
            <article
              class="admin-user-card"
              style="--role-color:<%= roleColor %>"
              data-user-id="<%= item.id %>"
              data-name="<%= name %>"
              data-username="<%= item.username %>"
              data-email="<%= email %>"
              data-sdt="<%= sdt %>"
              data-cccd="<%= cccd %>"
              data-role="<%= item.maVaiTro %>"
              data-status="<%= item.trangThai %>"
            >
              <div class="admin-user-top">
                <span class="admin-user-id">#<%= item.id %> · <%= roleName(item.maVaiTro) %></span>
                <span class="admin-status <%= item.trangThai === "HoatDong" ? "" : "is-locked" %>"><%= item.trangThai %></span>
              </div>
              <h3><%= item.username %></h3>
              <p><%= name || "Chưa liên kết hồ sơ" %></p>
              <div class="admin-user-meta">
                <div><small>Liên kết</small><strong><%= item.maKhachHang ? "Khách hàng" : (item.maNhanVien ? "Nhân viên" : "Chưa có") %></strong></div>
                <div><small>Role</small><strong><%= roleName(item.maVaiTro) %></strong></div>
                <div><small>Email</small><strong><%= email || "-" %></strong></div>
                <div><small>SĐT / CCCD</small><strong><%= sdt || "-" %><%= cccd ? ` · ${cccd}` : "" %></strong></div>
              </div>
              <div class="admin-user-actions">
                <button class="admin-button admin-edit-user" type="button">Sửa</button>
                <button class="admin-button admin-copy-user" type="button">Copy username</button>
                <button class="admin-button <%= item.trangThai === "HoatDong" ? "admin-button--danger" : "" %> admin-status-user" type="button" data-next-status="<%= item.trangThai === "HoatDong" ? "Khoa" : "HoatDong" %>">
                  <%= item.trangThai === "HoatDong" ? "Khóa" : "Mở" %>
                </button>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </section>
  </div>
</main>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const form = document.getElementById("userForm");
  const formMode = document.getElementById("formMode");
  const fields = {
    user_id: document.getElementById("user_id"),
    ho_ten: document.getElementById("ho_ten"),
    username: document.getElementById("username"),
    password: document.getElementById("password"),
    email: document.getElementById("email"),
    sdt: document.getElementById("sdt"),
    vai_tro: document.getElementById("vai_tro"),
    trang_thai: document.getElementById("trang_thai"),
    cccd: document.getElementById("cccd")
  };
  const errors = {
    ho_ten: document.getElementById("err_ho_ten"),
    username: document.getElementById("err_username"),
    password: document.getElementById("err_password"),
    email: document.getElementById("err_email"),
    sdt: document.getElementById("err_sdt"),
    vai_tro: document.getElementById("err_vai_tro"),
    trang_thai: document.getElementById("err_trang_thai"),
    cccd: document.getElementById("err_cccd")
  };
  const patterns = {
    username: /^[A-Za-z0-9_]{5,30}$/,
    email: /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/i,
    sdt: /^(0\d{9}|\+84\d{9})$/,
    cccd: /^\d{9,12}$/
  };

  function setError(name, message) {
    if (!fields[name]) return;
    fields[name].classList.toggle("is-invalid", Boolean(message));
    if (errors[name]) errors[name].textContent = message || "";
  }

  function validateField(name) {
    const value = String(fields[name]?.value || "").trim();
    let message = "";

    if (name === "ho_ten" && value.length < 2) message = "Họ tên phải có ít nhất 2 ký tự.";
    if (name === "username" && !patterns.username.test(value)) message = "Username 5-30 ký tự, chỉ gồm chữ, số hoặc dấu gạch dưới.";
    if (name === "password") {
      const isEditing = Boolean(fields.user_id.value);
      if (!isEditing && value.length < 6) message = "Mật khẩu tạo mới phải có ít nhất 6 ký tự.";
      if (isEditing && value && value.length < 6) message = "Mật khẩu mới phải có ít nhất 6 ký tự.";
    }
    if (name === "email" && !patterns.email.test(value)) message = "Email phải đúng định dạng, ví dụ user@example.com.";
    if (name === "sdt" && !patterns.sdt.test(value)) message = "SĐT phải gồm 10 số bắt đầu bằng 0 hoặc +84 kèm 9 số.";
    if (name === "vai_tro" && !value) message = "Vui lòng chọn vai trò.";
    if (name === "trang_thai" && !["HoatDong", "Khoa", "Ngung"].includes(value)) message = "Trạng thái không hợp lệ.";
    if (name === "cccd") {
      const isCustomer = String(fields.vai_tro.value) === "7";
      if (value && !patterns.cccd.test(value)) message = "CCCD/CMND phải gồm 9-12 chữ số.";
      if (isCustomer && !patterns.cccd.test(value)) message = "Tài khoản khách hàng bắt buộc có CCCD/CMND 9-12 chữ số.";
    }

    setError(name, message);
    return !message;
  }

  function validateForm() {
    const fieldNames = ["ho_ten", "username", "password", "email", "sdt", "vai_tro", "trang_thai", "cccd"];
    const ok = fieldNames.map(validateField).every(Boolean);
    if (!ok && formMode) formMode.textContent = "Dữ liệu chưa hợp lệ, vui lòng kiểm tra các dòng màu đỏ.";
    return ok;
  }

  Object.keys(errors).forEach((name) => {
    fields[name]?.addEventListener("input", () => validateField(name));
    fields[name]?.addEventListener("change", () => {
      validateField(name);
      if (name === "vai_tro") validateField("cccd");
    });
  });

  function fillForm(card, nextStatus) {
    fields.user_id.value = card.dataset.userId || "";
    fields.ho_ten.value = card.dataset.name || "";
    fields.username.value = card.dataset.username || "";
    fields.password.value = "";
    fields.email.value = card.dataset.email || "";
    fields.sdt.value = card.dataset.sdt || "";
    fields.vai_tro.value = card.dataset.role || "2";
    fields.trang_thai.value = nextStatus || card.dataset.status || "HoatDong";
    fields.cccd.value = card.dataset.cccd || "";
    Object.keys(errors).forEach((name) => setError(name, ""));
    if (formMode) formMode.textContent = `Đang sửa tài khoản #${card.dataset.userId}. Để trống mật khẩu nếu không đổi.`;
    form?.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  form?.addEventListener("submit", (event) => {
    if (!validateForm()) {
      event.preventDefault();
      const firstInvalid = form.querySelector(".is-invalid");
      firstInvalid?.focus();
      firstInvalid?.scrollIntoView({ behavior: "smooth", block: "center" });
    }
  });

  document.querySelectorAll(".admin-edit-user").forEach((button) => {
    button.addEventListener("click", () => fillForm(button.closest(".admin-user-card")));
  });

  document.querySelectorAll(".admin-status-user").forEach((button) => {
    button.addEventListener("click", async () => {
      const card = button.closest(".admin-user-card");
      const userId = card?.dataset.userId || "";
      const nextStatus = button.dataset.nextStatus || "Khoa";
      if (!userId) return;
      const originalText = button.textContent;
      button.textContent = "Đang lưu...";
      button.disabled = true;
      try {
        const response = await fetch(`/api/admin/users/${encodeURIComponent(userId)}/status`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ status: nextStatus })
        });
        if (!response.ok) throw new Error("Cap nhat trang thai that bai.");
        window.location.reload();
      } catch (_error) {
        button.disabled = false;
        button.textContent = originalText;
        fillForm(card, nextStatus);
        if (formMode) formMode.textContent = "Không gọi được cập nhật nhanh, đã chuyển dữ liệu lên form để bạn lưu thủ công.";
      }
    });
  });

  document.querySelectorAll(".admin-copy-user").forEach((button) => {
    button.addEventListener("click", async () => {
      const card = button.closest(".admin-user-card");
      const value = card?.dataset.username || "";
      if (!value) return;
      try {
        await navigator.clipboard.writeText(value);
        button.textContent = "Đã copy";
      } catch (_error) {
        const temp = document.createElement("input");
        temp.value = value;
        document.body.appendChild(temp);
        temp.select();
        document.execCommand("copy");
        temp.remove();
        button.textContent = "Đã copy";
      }
      setTimeout(() => { button.textContent = "Copy username"; }, 1200);
    });
  });

  document.getElementById("exportUsersCsv")?.addEventListener("click", () => {
    const cards = Array.from(document.querySelectorAll(".admin-user-card"));
    const rows = [["ID", "Username", "Ho ten", "Email", "SDT", "CCCD", "Role", "Trang thai"]];
    cards.forEach((card) => {
      rows.push([
        card.dataset.userId || "",
        card.dataset.username || "",
        card.dataset.name || "",
        card.dataset.email || "",
        card.dataset.sdt || "",
        card.dataset.cccd || "",
        card.querySelector(".admin-user-id")?.textContent?.replace(/^#\\d+\\s*·\\s*/, "").trim() || "",
        card.dataset.status || ""
      ]);
    });
    const csv = rows.map((row) => row.map((cell) => `"${String(cell).replaceAll('"', '""')}"`).join(",")).join("\\n");
    const blob = new Blob([csv], { type: "text/csv;charset=utf-8" });
    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    link.href = url;
    link.download = `admin-users-${new Date().toISOString().slice(0, 10)}.csv`;
    link.click();
    URL.revokeObjectURL(url);
  });

  document.getElementById("resetForm")?.addEventListener("click", () => {
    setTimeout(() => {
      fields.user_id.value = "";
      fields.password.value = "Abc@123";
      fields.vai_tro.value = "2";
      fields.trang_thai.value = "HoatDong";
      Object.keys(errors).forEach((name) => setError(name, ""));
      if (formMode) formMode.textContent = "Đang ở chế độ tạo mới.";
    }, 0);
  });
});
</script>
<%- include("../partials/footer") %>
