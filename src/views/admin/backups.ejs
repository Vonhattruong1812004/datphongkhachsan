<%- include("../partials/head") %>
<%- include("../partials/header") %>
<%
  const backups = payload?.backups || [];
  const autoConfig = payload?.autoBackupConfig || {};
  const hotelSummary = payload?.hotelSummary || {};
  const selectedBackup = payload?.selectedBackupInfo || null;
  const totalSize = backups.reduce((sum, item) => sum + Number(item.size || 0), 0);
  const latestBackup = backups[0] || null;
  const autoOn = Boolean(autoConfig.enabled);
  const safetyScore = Math.min(100, (backups.length ? 55 : 0) + (autoOn ? 30 : 0) + (Number(hotelSummary.count || 0) ? 15 : 0));
  const safetyLabel = safetyScore >= 80 ? "An toàn" : (safetyScore >= 50 ? "Cần theo dõi" : "Chưa an toàn");
  const formatSize = (bytes) => {
    const value = Number(bytes || 0);
    if (value >= 1024 * 1024) return `${(value / 1024 / 1024).toFixed(2)} MB`;
    return `${(value / 1024).toFixed(1)} KB`;
  };
  const typeText = (type) => type === "hom_nay" ? "Trong ngày" : (type === "chon_ngay" ? "Theo ngày chọn" : "Toàn bộ");
  const isRestorable = (item) => item && (!item.backupType || item.backupType === "toan_bo");
%>
<style>
  .backup-workspace{
    --bk-ink:#101828;
    --bk-muted:#667085;
    --bk-line:rgba(16,24,40,.10);
    --bk-card:rgba(255,255,255,.86);
    --bk-green:#10b981;
    --bk-cyan:#06b6d4;
    --bk-blue:#2563eb;
    --bk-amber:#f59e0b;
    --bk-red:#f43f5e;
    --bk-violet:#8b5cf6;
    --bk-shadow:0 24px 80px rgba(15,23,42,.12);
    min-height:calc(100vh - 84px);
    padding:34px 18px 58px;
    color:var(--bk-ink);
    background:
      linear-gradient(rgba(255,255,255,.45) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.45) 1px, transparent 1px),
      radial-gradient(circle at 8% 10%, rgba(16,185,129,.22), transparent 29%),
      radial-gradient(circle at 88% 8%, rgba(6,182,212,.20), transparent 30%),
      radial-gradient(circle at 54% 106%, rgba(139,92,246,.13), transparent 34%),
      linear-gradient(135deg,#f8fffb 0%,#eefaff 47%,#fff7fb 100%);
    background-size:auto, 42px 42px, auto, auto, auto, auto;
  }
  .bk-wrap{max-width:1180px;margin:0 auto}
  .bk-panel,.bk-score,.bk-stat,.bk-card,.bk-file,.bk-empty{border:1px solid var(--bk-line);background:var(--bk-card);box-shadow:var(--bk-shadow);backdrop-filter:blur(22px)}
  .bk-hero{display:grid;grid-template-columns:minmax(0,1fr) 330px;gap:18px;align-items:stretch}
  .bk-panel{position:relative;overflow:hidden;border-radius:30px;padding:30px}
  .bk-panel::before{content:"";position:absolute;inset:0;background:linear-gradient(120deg,rgba(255,255,255,.86),transparent 38%),radial-gradient(circle at 88% 18%,rgba(16,185,129,.18),transparent 32%);pointer-events:none}
  .bk-label{position:relative;z-index:1;display:inline-flex;align-items:center;gap:10px;border-radius:999px;padding:8px 13px;background:rgba(16,185,129,.12);border:1px solid rgba(16,185,129,.18);color:#047857;font-size:12px;font-weight:1000;text-transform:uppercase;letter-spacing:.08em}
  .bk-label::before{content:"";width:8px;height:8px;border-radius:999px;background:var(--bk-green);box-shadow:0 0 0 7px rgba(16,185,129,.14)}
  .bk-panel h1{position:relative;z-index:1;margin:22px 0 10px;max-width:760px;font-size:clamp(40px,5vw,68px);line-height:.94;letter-spacing:-.06em}
  .bk-panel h1 span{color:transparent;background:linear-gradient(135deg,#10b981,#06b6d4 52%,#8b5cf6);-webkit-background-clip:text;background-clip:text}
  .bk-lead{position:relative;z-index:1;max-width:720px;margin:0;color:var(--bk-muted);font-size:16px;line-height:1.62}
  .bk-actions{position:relative;z-index:1;display:flex;flex-wrap:wrap;gap:10px;margin-top:24px}
  .bk-button{display:inline-flex;align-items:center;justify-content:center;min-height:42px;border:1px solid rgba(16,24,40,.12);border-radius:999px;padding:10px 16px;background:rgba(255,255,255,.78);color:var(--bk-ink);font:inherit;font-size:14px;font-weight:950;text-decoration:none;cursor:pointer;transition:transform .18s ease,box-shadow .18s ease,border-color .18s ease}
  .bk-button:hover{transform:translateY(-2px);border-color:var(--bk-cyan);box-shadow:0 18px 42px rgba(6,182,212,.14)}
  .bk-button--primary{border-color:transparent;color:#fff;background:linear-gradient(135deg,#10b981,#06b6d4);box-shadow:0 18px 44px rgba(16,185,129,.22)}
  .bk-score{display:flex;flex-direction:column;align-items:center;justify-content:center;border-radius:30px;padding:24px;background:linear-gradient(160deg,rgba(255,255,255,.94),rgba(240,253,250,.78))}
  .bk-ring{--score:<%= safetyScore %>;position:relative;width:194px;aspect-ratio:1;border-radius:50%;display:grid;place-items:center;background:conic-gradient(var(--bk-green) calc(var(--score)*1%),rgba(16,24,40,.09) 0);box-shadow:inset 0 0 0 15px rgba(255,255,255,.84),0 22px 70px rgba(16,185,129,.18)}
  .bk-ring::after{content:"";position:absolute;inset:28px;border-radius:50%;border:1px solid rgba(16,24,40,.08);background:rgba(255,255,255,.95)}
  .bk-ring-value{position:relative;z-index:1;text-align:center}
  .bk-ring-value strong{display:block;font-size:46px;line-height:1;letter-spacing:-.07em}
  .bk-ring-value span{display:block;margin-top:7px;color:var(--bk-muted);font-size:12px;font-weight:1000;text-transform:uppercase;letter-spacing:.07em}
  .bk-score h2{margin:18px 0 6px;font-size:26px;letter-spacing:-.04em}
  .bk-score p{margin:0;color:var(--bk-muted);font-size:13px;text-align:center;line-height:1.5}
  .bk-flash{margin:18px 0 0;border-radius:18px;padding:13px 15px;font-weight:850;border:1px solid rgba(16,24,40,.10);background:rgba(255,255,255,.72)}
  .bk-flash--success{color:#047857;background:rgba(16,185,129,.12)}
  .bk-flash--error{color:#be123c;background:rgba(244,63,94,.12)}
  .bk-stats{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px;margin-top:18px}
  .bk-stat{position:relative;overflow:hidden;border-radius:24px;padding:18px;background:rgba(255,255,255,.74)}
  .bk-stat::before{content:"";position:absolute;inset:0 0 auto;height:5px;background:linear-gradient(90deg,var(--stat-color),transparent)}
  .bk-stat strong{display:block;font-size:32px;line-height:1;letter-spacing:-.05em}
  .bk-stat span{display:block;margin-top:8px;color:var(--bk-muted);font-size:12px;font-weight:1000;text-transform:uppercase;letter-spacing:.06em}
  .bk-section{margin-top:20px}
  .bk-section-head{display:flex;align-items:flex-end;justify-content:space-between;gap:12px;margin-bottom:14px}
  .bk-section-head h2{margin:0;font-size:25px;letter-spacing:-.04em}
  .bk-section-head p{margin:4px 0 0;color:var(--bk-muted);font-size:13px}
  .bk-grid{display:grid;grid-template-columns:380px minmax(0,1fr);gap:14px;align-items:start}
  .bk-card{border-radius:28px;padding:20px;background:rgba(255,255,255,.78)}
  .bk-card h3{margin:0 0 6px;font-size:21px;letter-spacing:-.03em}
  .bk-card p{margin:0 0 16px;color:var(--bk-muted);font-size:13px;line-height:1.55}
  .bk-form-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}
  .bk-field{display:flex;flex-direction:column;gap:7px}
  .bk-field label{font-size:12px;font-weight:1000;color:#475467;text-transform:uppercase;letter-spacing:.05em}
  .bk-field input,.bk-field select{width:100%;min-height:46px;border:1px solid rgba(16,24,40,.13);border-radius:16px;padding:10px 13px;background:rgba(255,255,255,.92);color:var(--bk-ink);font:inherit;font-weight:800;outline:none;transition:border-color .18s ease,box-shadow .18s ease}
  .bk-field input:focus,.bk-field select:focus{border-color:var(--bk-cyan);box-shadow:0 0 0 4px rgba(6,182,212,.13)}
  .bk-field input[readonly]{color:#475467;background:rgba(248,250,252,.82)}
  .bk-hint{margin-top:10px;color:var(--bk-muted);font-size:12px;line-height:1.5}
  .bk-mode{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;margin:14px 0}
  .bk-mode-item{border:1px solid rgba(16,24,40,.10);border-radius:18px;padding:12px;background:rgba(255,255,255,.62)}
  .bk-mode-item strong{display:block;font-size:14px}
  .bk-mode-item span{display:block;margin-top:5px;color:var(--bk-muted);font-size:12px;line-height:1.45}
  .bk-file-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}
  .bk-file{position:relative;overflow:hidden;border-radius:24px;padding:17px;background:rgba(255,255,255,.78)}
  .bk-file::before{content:"";position:absolute;inset:0 0 auto;height:5px;background:linear-gradient(90deg,#10b981,#06b6d4,transparent)}
  .bk-file-top{display:flex;align-items:flex-start;justify-content:space-between;gap:12px}
  .bk-badge{display:inline-flex;width:max-content;border-radius:999px;padding:6px 10px;background:rgba(16,185,129,.12);color:#047857;font-size:11px;font-weight:1000;text-transform:uppercase;letter-spacing:.04em}
  .bk-file h3{margin:12px 0 6px;font-size:17px;line-height:1.25;word-break:break-word}
  .bk-meta{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px;margin:12px 0}
  .bk-meta div{border-radius:14px;padding:9px 10px;background:rgba(248,250,252,.82);border:1px solid rgba(16,24,40,.07)}
  .bk-meta span{display:block;color:var(--bk-muted);font-size:11px;font-weight:900;text-transform:uppercase;letter-spacing:.04em}
  .bk-meta strong{display:block;margin-top:4px;font-size:13px}
  .bk-empty{border-radius:26px;padding:28px;background:rgba(255,255,255,.72);text-align:center}
  .bk-empty strong{display:block;font-size:21px;margin-bottom:8px}
  .bk-empty p{margin:0 auto 18px;max-width:520px;color:var(--bk-muted);font-size:13px;line-height:1.55}
  .bk-preview{border-radius:20px;padding:14px;background:rgba(248,250,252,.84);border:1px solid rgba(16,24,40,.08)}
  .bk-preview h4{margin:0 0 10px;font-size:15px}
  .bk-preview dl{display:grid;grid-template-columns:130px 1fr;gap:8px 10px;margin:0;font-size:13px}
  .bk-preview dt{color:var(--bk-muted);font-weight:900}
  .bk-preview dd{margin:0;font-weight:850;word-break:break-word}
  .bk-invalid{display:none;margin-top:8px;color:#be123c;font-size:12px;font-weight:850}
  .bk-field[data-invalid="true"] input,.bk-field[data-invalid="true"] select{border-color:#fb7185;box-shadow:0 0 0 4px rgba(244,63,94,.10)}
  .bk-field[data-invalid="true"] .bk-invalid{display:block}
  @media(max-width:1080px){.bk-hero,.bk-grid{grid-template-columns:1fr}.bk-stats{grid-template-columns:repeat(2,minmax(0,1fr))}}
  @media(max-width:760px){.backup-workspace{padding:22px 12px 48px}.bk-panel,.bk-score,.bk-card{padding:20px;border-radius:26px}.bk-panel h1{font-size:42px}.bk-stats,.bk-form-grid,.bk-mode,.bk-file-grid,.bk-meta{grid-template-columns:1fr}.bk-section-head{display:block}.bk-ring{width:176px}}

