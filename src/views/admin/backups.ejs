    background:rgba(255,255,255,.88);
    border-color:rgba(255,255,255,.42);
    box-shadow:0 12px 30px rgba(0,0,0,.14);
  }
  .bk-meta span{
    color:#486176;
  }
  .bk-meta strong{
    color:#071827;
  }
  .bk-file .bk-actions .bk-button{
    color:#061426;
    background:rgba(255,255,255,.88);
    border-color:rgba(255,255,255,.42);
  }
  .bk-file .bk-actions .bk-button--primary{
    background:linear-gradient(135deg,#ffffff,#dffcff);
  }
  .bk-empty{
    color:#c7d9ec;
    background:rgba(8,18,40,.76);
    border-color:rgba(125,211,252,.30);
  }
  .bk-preview{
    background:#ffffff;
    border:2px solid rgba(186,230,253,.70);
    box-shadow:0 14px 34px rgba(0,0,0,.16);
  }
  .bk-preview h4,
  .bk-preview dd{
    color:#092033;
  }
  .bk-preview dt{
    color:#486176;
  }
  @keyframes bk-stars{
    0%{background-position:8% 12%,44% 28%,76% 8%,0 0}
    100%{background-position:8% 132%,44% 128%,76% 118%,240px 0}
  }
  @media(max-width:1080px){
    .bk-hero,
    .bk-grid{
      grid-template-columns:1fr;
    }
  }
  @media(max-width:760px){
    .backup-workspace{
      padding:18px 12px 42px;
    }
    .bk-panel,
    .bk-score,
    .bk-card{
      padding:22px;
      border-radius:28px;
    }
    .bk-section-head h2{
      font-size:26px;
    }
  }

  /* Admin backup cleanup: avoid duplicate falling stars inside the page content. */
  .backup-workspace{
    width:100%;
    max-width:100%;
    overflow-x:hidden !important;
    background:
      linear-gradient(135deg,rgba(3,17,31,.86) 0%,rgba(7,22,52,.80) 48%,rgba(22,13,51,.84) 100%) !important;
  }
  .backup-workspace,
  .backup-workspace *{
    box-sizing:border-box;
  }
  .bk-wrap,
  .bk-panel,
  .bk-score,
  .bk-stat,
  .bk-card,
  .bk-file,
  .bk-empty,
  .bk-mode-item,
  .bk-preview,
  .bk-meta div,
  .bk-actions{
    min-width:0;
    max-width:100%;
  }
  .bk-field input,
  .bk-field select{
    min-width:0;
    max-width:100%;
  }
  .bk-panel h1,
  .bk-file h3,
  .bk-preview dd,
  .bk-meta strong,
  .bk-mode-item span,
  .bk-score p,
  .bk-flash,
  .bk-button{
    overflow-wrap:anywhere;
    word-break:break-word;
  }
  .backup-workspace::before,
  .backup-workspace::after{
    display:none !important;
    content:none !important;
    animation:none !important;
  }
  .bk-panel,
  .bk-score,
  .bk-stat,
  .bk-card,
  .bk-file,
  .bk-empty,
  .bk-mode-item{
    -webkit-backdrop-filter:none !important;
    backdrop-filter:none !important;
    will-change:auto !important;
    box-shadow:0 18px 52px rgba(0,0,0,.28),inset 0 1px 0 rgba(255,255,255,.08) !important;
  }
  @media(max-width:760px){
    .bk-wrap{
      width:100%;
      max-width:100%;
    }
    .bk-panel,
    .bk-score,
    .bk-stat,
    .bk-card,
    .bk-file,
    .bk-empty,
    .bk-mode-item,
    .bk-preview{
      overflow:hidden;
    }
    .bk-actions{
      display:grid;
      grid-template-columns:1fr;
      width:100%;
    }
    .bk-button{
      width:100%;
      padding-left:12px;
      padding-right:12px;
      text-align:center;
    }
  }
</style>

<main class="backup-workspace">
  <div class="bk-wrap">
    <section class="bk-hero" aria-label="Sao lưu dữ liệu">
      <div class="bk-panel">
        <div class="bk-label">Admin backup workspace</div>
        <h1>Sao lưu <span>dữ liệu hệ thống</span></h1>
        <p class="bk-lead">Tạo file SQL có metadata rõ ràng, bật/tắt sao lưu tự động và chuyển nhanh sang phục hồi khi cần. UC này chỉ tác động vào vùng backup, không tự sửa dữ liệu nghiệp vụ.</p>
        <div class="bk-actions">
          <a class="bk-button bk-button--primary" href="#manual-backup">Tạo backup</a>
          <a class="bk-button" href="/admin/restore">Phục hồi dữ liệu</a>
          <a class="bk-button" href="/admin/diagnostics">Sức khỏe hệ thống</a>
          <a class="bk-button" href="/dashboard/admin">Về dashboard Admin</a>
          <a class="bk-button" href="/api/admin/backups">Backup JSON</a>
        </div>
        <% if (success) { %>
          <div class="bk-flash bk-flash--success"><%= success %></div>
        <% } %>
        <% if (error) { %>
          <div class="bk-flash bk-flash--error"><%= error %></div>
        <% } %>
      </div>
      <aside class="bk-score">
        <div class="bk-ring" aria-label="Điểm an toàn backup">
          <div class="bk-ring-value"><strong><%= safetyScore %></strong><span>Điểm</span></div>
        </div>
        <h2><%= safetyLabel %></h2>
        <p><%= latestBackup ? `Backup mới nhất: ${latestBackup.createdAt || latestBackup.name}` : "Chưa có file backup nào." %></p>
      </aside>
    </section>

    <section class="bk-stats" aria-label="Tổng quan backup">
      <article class="bk-stat" style="--stat-color:#10b981"><strong><%= backups.length %></strong><span>File sao lưu</span></article>
      <article class="bk-stat" style="--stat-color:#06b6d4"><strong><%= hotelSummary.count || 0 %></strong><span>Cơ sở trong scope</span></article>
      <article class="bk-stat" style="--stat-color:<%= autoOn ? "#10b981" : "#f59e0b" %>"><strong><%= autoOn ? "Bật" : "Tắt" %></strong><span>Auto backup</span></article>
      <article class="bk-stat" style="--stat-color:#8b5cf6"><strong><%= formatSize(totalSize) %></strong><span>Dung lượng</span></article>
    </section>

    <section class="bk-section" aria-label="Cấu hình và tạo backup">
      <div class="bk-section-head">
        <div>
          <h2>Thiết lập sao lưu</h2>
          <p>Gom cấu hình tự động và tạo backup thủ công vào một luồng dễ kiểm soát.</p>
        </div>
      </div>
      <div class="bk-grid">
        <article class="bk-card">
          <h3>Auto backup</h3>
          <p>Bật khi muốn hệ thống tự tạo backup tại các hook vận hành đã gắn sẵn.</p>
          <form method="post" action="/admin/backups/config">
            <div class="bk-field">
              <label for="mode">Chế độ</label>
              <select id="mode" name="mode">
                <option value="auto" <%= autoOn ? "selected" : "" %>>Bật auto backup</option>
                <option value="manual" <%= !autoOn ? "selected" : "" %>>Tắt auto backup</option>
              </select>
            </div>
            <div class="bk-mode">
              <div class="bk-mode-item">
                <strong>Root lưu trữ</strong>
                <span>storage/backups</span>
              </div>
              <div class="bk-mode-item">
                <strong>Cập nhật gần nhất</strong>
                <span><%= autoConfig.updated_at || "Chưa có" %> · <%= autoConfig.updated_by || "system" %></span>
              </div>
              <div class="bk-mode-item">
                <strong>Lần auto gần nhất</strong>
                <span><%= autoConfig.last_backup || "Chưa có" %></span>
              </div>
              <div class="bk-mode-item">
                <strong>Trạng thái</strong>
                <span><%= autoOn ? "Đang theo dõi tự động." : "Đang dùng chế độ thủ công." %></span>
              </div>
            </div>
            <button class="bk-button bk-button--primary" type="submit">Lưu cấu hình</button>
          </form>
        </article>

        <article class="bk-card" id="manual-backup">
          <h3>Tạo backup thủ công</h3>
          <p>File SQL sinh ra sẽ có metadata: người tạo, thời gian, scope đa cơ sở, Node và PostgreSQL version.</p>
          <form method="post" action="/admin/backups" id="backupCreateForm" novalidate>
            <div class="bk-form-grid">
              <div class="bk-field" data-field="ten_file">
                <label for="ten_file">Tên file</label>
                <input id="ten_file" name="ten_file" value="abc_resort_backup" autocomplete="off" required />
                <span class="bk-invalid">Chỉ dùng chữ, số, dấu gạch dưới hoặc gạch ngang.</span>
              </div>
              <div class="bk-field" data-field="thu_muc">
                <label for="thu_muc">Thư mục con</label>
                <input id="thu_muc" name="thu_muc" placeholder="vd: nightly" autocomplete="off" />
                <span class="bk-invalid">Thư mục con chỉ nên dùng chữ, số, gạch dưới hoặc gạch ngang.</span>
              </div>
              <div class="bk-field">
                <label for="hinh_thuc">Hình thức</label>
                <select id="hinh_thuc" name="hinh_thuc">
                  <option value="toan_bo">Snapshot toàn bộ hệ thống</option>
                  <option value="hom_nay">Trích xuất hôm nay</option>
                  <option value="chon_ngay">Trích xuất theo ngày</option>
                </select>
              </div>
              <div class="bk-field" data-field="ngay_chon">
                <label for="ngay_chon">Ngày cần backup</label>
                <input id="ngay_chon" type="date" name="ngay_chon" />
                <span class="bk-invalid">Chọn ngày khi hình thức là “Chọn một ngày”.</span>
              </div>
            </div>
            <p class="bk-hint">Chỉ snapshot toàn bộ hệ thống được dùng để phục hồi. Trích xuất theo ngày dùng cho đối soát, báo cáo hoặc kiểm tra dữ liệu.</p>
            <div class="bk-actions">
              <button class="bk-button bk-button--primary" type="submit">Tạo backup</button>
              <a class="bk-button" href="/admin/restore">Sang phục hồi dữ liệu</a>
            </div>
          </form>
        </article>
      </div>
    </section>

    <section class="bk-section" aria-label="Danh sách backup">
      <div class="bk-section-head">
        <div>
          <h2>Kho sao lưu</h2>
          <p>Danh sách file SQL có thể preview hoặc chuyển sang UC phục hồi.</p>
        </div>
      </div>
      <% if (!backups.length) { %>
        <div class="bk-empty">
          <strong>Chưa có file backup</strong>
          <p>Hãy tạo một bản backup thủ công trước khi thử phục hồi hoặc trước các thay đổi lớn trên hệ thống.</p>
          <a class="bk-button bk-button--primary" href="#manual-backup">Tạo backup đầu tiên</a>
        </div>
      <% } else { %>
        <div class="bk-file-grid">
          <% backups.forEach((item) => { %>
            <article class="bk-file">
              <div class="bk-file-top">
                <span class="bk-badge"><%= typeText(item.backupType) %></span>
                <span class="bk-badge"><%= item.backupMode || "SQL" %></span>
              </div>
              <h3><%= item.name %></h3>
              <div class="bk-meta">
                <div><span>Tạo lúc</span><strong><%= item.createdAt || "Không rõ" %></strong></div>
                <div><span>Kích thước</span><strong><%= formatSize(item.size) %></strong></div>
                <div><span>Scope</span><strong><%= item.backupScope || "Toàn hệ thống" %></strong></div>
                <div><span>Cơ sở</span><strong><%= item.hotelCount || 0 %></strong></div>
              </div>
              <div class="bk-actions">
                <% if (isRestorable(item)) { %>
                  <a class="bk-button bk-button--primary" href="/admin/restore?file=<%= encodeURIComponent(item.name) %>">Phục hồi dữ liệu</a>
                <% } else { %>
                  <a class="bk-button" href="/admin/backups?file=<%= encodeURIComponent(item.name) %>">Chỉ đối soát</a>
                <% } %>
                <a class="bk-button" href="/admin/backups?file=<%= encodeURIComponent(item.name) %>">Preview</a>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </section>

    <% if (selectedBackup) { %>
      <section class="bk-section" aria-label="Preview backup">
        <div class="bk-card">
          <h3>Preview file đang chọn</h3>
          <div class="bk-preview">
            <dl>
              <dt>Tên file</dt><dd><%= selectedBackup.name %></dd>
              <dt>Loại backup</dt><dd><%= typeText(selectedBackup.backupType) %></dd>
              <dt>Ngày tạo</dt><dd><%= selectedBackup.createdAt || "Không rõ" %></dd>
              <dt>Dung lượng</dt><dd><%= formatSize(selectedBackup.size) %></dd>
              <dt>Scope</dt><dd><%= selectedBackup.backupScope || "Toàn hệ thống" %></dd>
            </dl>
          </div>
        </div>
      </section>
    <% } %>
  </div>
</main>

<script>
  (() => {
    const form = document.getElementById("backupCreateForm");
    const fileInput = document.getElementById("ten_file");
    const dirInput = document.getElementById("thu_muc");
    const typeInput = document.getElementById("hinh_thuc");
    const dateInput = document.getElementById("ngay_chon");
    const safeName = /^[A-Za-z0-9_-]+$/;
    const setInvalid = (name, invalid) => {
      const field = form?.querySelector(`[data-field="${name}"]`);
      if (field) field.dataset.invalid = invalid ? "true" : "false";
    };
    const syncDate = () => {
      const needsDate = typeInput.value === "chon_ngay";
      dateInput.disabled = !needsDate;
      dateInput.required = needsDate;
      if (!needsDate) {
        dateInput.value = "";
        setInvalid("ngay_chon", false);
      }
    };
    typeInput?.addEventListener("change", syncDate);
    syncDate();
    form?.addEventListener("submit", (event) => {
      let invalid = false;
      const fileOk = safeName.test(fileInput.value.trim());
      const dirValue = dirInput.value.trim();
      const dirOk = !dirValue || safeName.test(dirValue);
      const dateOk = typeInput.value !== "chon_ngay" || Boolean(dateInput.value);
      setInvalid("ten_file", !fileOk);
      setInvalid("thu_muc", !dirOk);
      setInvalid("ngay_chon", !dateOk);
      invalid = !fileOk || !dirOk || !dateOk;
      if (invalid) event.preventDefault();
    });
  })();
</script>
<%- include("../partials/footer") %>
