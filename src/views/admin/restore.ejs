    border-color:rgba(255,255,255,.42);
    box-shadow:0 12px 30px rgba(0,0,0,.14);
  }
  .rs-meta span{
    color:#486176;
  }
  .rs-meta strong{
    color:#071827;
  }
  .rs-file .rs-actions .rs-button{
    color:#061426;
    background:rgba(255,255,255,.88);
    border-color:rgba(255,255,255,.42);
  }
  .rs-file .rs-actions .rs-button--primary{
    background:linear-gradient(135deg,#ffffff,#dffcff);
  }
  .rs-empty{
    color:#c7d9ec;
    background:rgba(8,18,40,.76);
    border-color:rgba(125,211,252,.30);
  }
  @keyframes rs-stars{
    0%{background-position:8% 12%,44% 28%,76% 8%,0 0}
    100%{background-position:8% 132%,44% 128%,76% 118%,240px 0}
  }
  @media(max-width:1080px){
    .rs-hero,
    .rs-grid{
      grid-template-columns:1fr;
    }
  }
  @media(max-width:760px){
    .restore-workspace{
      padding:18px 12px 42px;
    }
    .rs-panel,
    .rs-score,
    .rs-card{
      padding:22px;
      border-radius:28px;
    }
    .rs-section-head h2{
      font-size:26px;
    }
  }

  /* Admin restore cleanup: avoid duplicate falling stars inside the page content. */
  .restore-workspace{
    width:100%;
    max-width:100%;
    overflow-x:hidden !important;
    background:
      linear-gradient(135deg,rgba(3,17,31,.86) 0%,rgba(7,22,52,.80) 48%,rgba(22,13,51,.84) 100%) !important;
  }
  .restore-workspace,
  .restore-workspace *{
    box-sizing:border-box;
  }
  .rs-wrap,
  .rs-panel,
  .rs-score,
  .rs-stat,
  .rs-card,
  .rs-file,
  .rs-empty,
  .rs-warning,
  .rs-preview,
  .rs-meta div,
  .rs-actions{
    min-width:0;
    max-width:100%;
  }
  .rs-field select{
    min-width:0;
    max-width:100%;
  }
  .rs-panel h1,
  .rs-file h3,
  .rs-preview h4,
  .rs-preview dd,
  .rs-meta strong,
  .rs-score p,
  .rs-stat strong,
  .rs-flash,
  .rs-button,
  .rs-check span{
    overflow-wrap:anywhere;
    word-break:break-word;
  }
  .restore-workspace::before,
  .restore-workspace::after{
    display:none !important;
    content:none !important;
    animation:none !important;
  }
  .rs-panel,
  .rs-score,
  .rs-stat,
  .rs-card,
  .rs-file,
  .rs-empty,
  .rs-warning{
    -webkit-backdrop-filter:none !important;
    backdrop-filter:none !important;
    will-change:auto !important;
    box-shadow:0 18px 52px rgba(0,0,0,.28),inset 0 1px 0 rgba(255,255,255,.08) !important;
  }
  @media(max-width:760px){
    .rs-wrap{
      width:100%;
      max-width:100%;
    }
    .rs-panel,
    .rs-score,
    .rs-stat,
    .rs-card,
    .rs-file,
    .rs-empty,
    .rs-warning,
    .rs-preview{
      overflow:hidden;
    }
    .rs-actions{
      display:grid;
      grid-template-columns:1fr;
      width:100%;
    }
    .rs-button{
      width:100%;
      padding-left:12px;
      padding-right:12px;
      text-align:center;
    }
  }
</style>

<main class="restore-workspace">
  <div class="rs-wrap">
    <section class="rs-hero" aria-label="Phục hồi dữ liệu">
      <div class="rs-panel">
        <div class="rs-label">Admin restore workspace</div>
        <h1>Phục hồi <span>dữ liệu từ backup</span></h1>
        <p class="rs-lead">Chọn đúng snapshot SQL, kiểm tra metadata và xác nhận trước khi phục hồi. Thao tác này sẽ ghi đè dữ liệu hiện tại, vì vậy nên tạo backup mới trước khi chạy.</p>
        <div class="rs-actions">
          <a class="rs-button rs-button--primary" href="/admin/backups">Sao lưu dữ liệu</a>
          <a class="rs-button" href="/admin/diagnostics">Sức khỏe hệ thống</a>
          <a class="rs-button" href="/dashboard/admin">Về dashboard Admin</a>
          <a class="rs-button" href="/api/admin/backups">Backup JSON</a>
        </div>
        <% if (success) { %>
          <div class="rs-flash rs-flash--success"><%= success %></div>
        <% } %>
        <% if (error) { %>
          <div class="rs-flash rs-flash--error"><%= error %></div>
        <% } %>
      </div>
      <aside class="rs-score">
        <div class="rs-ring" aria-label="Điểm sẵn sàng phục hồi">
          <div class="rs-ring-value"><strong><%= readyScore %></strong><span>Điểm</span></div>
        </div>
        <h2><%= readyLabel %></h2>
        <p><%= selectedBackup ? (selectedRestorable ? selectedBackup.name : "File theo ngày không dùng để restore toàn hệ thống.") : "Chọn một file backup để xem metadata và phục hồi." %></p>
      </aside>
    </section>

    <section class="rs-stats" aria-label="Tổng quan phục hồi">
      <article class="rs-stat" style="--stat-color:#8b5cf6"><strong><%= backups.length %></strong><span>File có sẵn</span></article>
      <article class="rs-stat" style="--stat-color:#06b6d4"><strong><%= selectedBackup ? typeText(selectedBackup.backupType) : "Chưa chọn" %></strong><span>Loại backup</span></article>
      <article class="rs-stat" style="--stat-color:#10b981"><strong><%= selectedBackup ? (selectedBackup.hotelCount || hotelSummary.count || 0) : (hotelSummary.count || 0) %></strong><span>Cơ sở trong scope</span></article>
      <article class="rs-stat" style="--stat-color:#f59e0b"><strong><%= selectedBackup ? formatSize(selectedBackup.size) : "0 KB" %></strong><span>Dung lượng chọn</span></article>
    </section>

    <section class="rs-section" aria-label="Hành động phục hồi">
      <div class="rs-section-head">
        <div>
          <h2>Phục hồi có kiểm soát</h2>
          <p>Chỉ file “Toàn bộ hệ thống” mới được phép phục hồi. File theo ngày chỉ dùng để đối soát/xuất dữ liệu.</p>
        </div>
      </div>
      <div class="rs-grid">
        <article class="rs-card">
          <h3>Chọn snapshot</h3>
          <p>Ưu tiên file mới nhất hoặc file đã được tạo ngay trước thay đổi lớn.</p>
          <form method="post" action="/admin/restore" id="restoreForm">
            <div class="rs-field">
              <label for="backup_file">File backup</label>
              <select id="backup_file" name="backup_file" required>
                <option value="">-- Chọn file backup --</option>
                <% backups.forEach((item) => { %>
                  <option value="<%= item.name %>" <%= selectedName === item.name ? "selected" : "" %>>
                    <%= item.name %> · <%= typeText(item.backupType) %> · <%= item.createdAt || "Không rõ" %>
                  </option>
                <% }) %>
              </select>
            </div>
            <div class="rs-warning" style="margin-top:14px;">
              <strong>Cảnh báo ghi đè dữ liệu</strong>
              <p>Restore sẽ import lại dữ liệu từ file SQL vào database hiện tại. Khi bấm phục hồi, hệ thống sẽ tự tạo một bản pre_restore trước rồi mới ghi đè.</p>
            </div>
            <% if (selectedBackup && !selectedRestorable) { %>
              <div class="rs-warning" style="margin-top:12px;">
                <strong>Không thể phục hồi file này</strong>
                <p>File “<%= typeText(selectedBackup.backupType) %>” là bản trích xuất theo phạm vi nhỏ. Nếu restore như snapshot toàn bộ, dữ liệu ngoài phạm vi có thể bị mất nên hệ thống đã chặn.</p>
              </div>
            <% } %>
            <label class="rs-check">
              <input id="restoreConfirm" type="checkbox" />
              <span>Tôi đã kiểm tra đúng file backup và hiểu thao tác phục hồi sẽ ghi đè dữ liệu hiện tại.</span>
            </label>
            <div class="rs-actions">
              <button class="rs-button rs-button--danger" id="restoreSubmit" type="submit" data-restorable="<%= selectedRestorable ? "true" : "false" %>" disabled>Phục hồi ngay</button>
              <a class="rs-button" href="/admin/backups#manual-backup">Tạo backup trước</a>
            </div>
          </form>
        </article>

        <article class="rs-card">
          <h3>File đang chọn</h3>
          <% if (!selectedBackup) { %>
            <div class="rs-empty">
              <strong>Chưa chọn snapshot</strong>
              <p>Chọn một file ở form bên trái hoặc từ danh sách bên dưới để xem metadata trước khi phục hồi.</p>
            </div>
          <% } else { %>
            <div class="rs-preview">
              <h4><%= selectedBackup.name %></h4>
              <dl>
                <dt>Loại backup</dt><dd><%= typeText(selectedBackup.backupType) %></dd>
                <dt>Tạo lúc</dt><dd><%= selectedBackup.createdAt || "Không rõ" %></dd>
                <dt>Scope</dt><dd><%= selectedBackup.backupScope || "Toàn hệ thống" %></dd>
                <dt>Cơ sở</dt><dd><%= selectedBackup.hotelCount || 0 %></dd>
                <dt>Dung lượng</dt><dd><%= formatSize(selectedBackup.size) %></dd>
              </dl>
            </div>
          <% } %>
        </article>
      </div>
    </section>

    <section class="rs-section" aria-label="Danh sách file backup">
      <div class="rs-section-head">
        <div>
          <h2>File có thể phục hồi</h2>
          <p>Danh sách đọc từ `storage/backups`, sắp xếp file mới nhất lên trước.</p>
        </div>
      </div>
      <% if (!backups.length) { %>
        <div class="rs-empty">
          <strong>Chưa có file backup</strong>
          <p>Hãy quay lại UC Sao lưu dữ liệu để tạo bản backup đầu tiên trước khi phục hồi.</p>
          <a class="rs-button rs-button--primary" href="/admin/backups#manual-backup">Tạo backup</a>
        </div>
      <% } else { %>
        <div class="rs-file-grid">
          <% backups.forEach((item) => { %>
            <article class="rs-file">
              <span class="rs-badge"><%= typeText(item.backupType) %></span>
              <h3><%= item.name %></h3>
              <div class="rs-meta">
                <div><span>Tạo lúc</span><strong><%= item.createdAt || "Không rõ" %></strong></div>
                <div><span>Dung lượng</span><strong><%= formatSize(item.size) %></strong></div>
                <div><span>Scope</span><strong><%= item.backupScope || "Toàn hệ thống" %></strong></div>
                <div><span>Cơ sở</span><strong><%= item.hotelCount || 0 %></strong></div>
              </div>
              <div class="rs-actions">
                <a class="rs-button <%= isRestorable(item) ? "rs-button--primary" : "" %>" href="/admin/restore?file=<%= encodeURIComponent(item.name) %>"><%= isRestorable(item) ? "Chọn file" : "Xem metadata" %></a>
                <a class="rs-button" href="/admin/backups?file=<%= encodeURIComponent(item.name) %>">Xem bên sao lưu</a>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </section>
  </div>
</main>

<script>
  (() => {
    const select = document.getElementById("backup_file");
    const confirm = document.getElementById("restoreConfirm");
    const submit = document.getElementById("restoreSubmit");
    const sync = () => {
      const restorable = submit?.dataset.restorable === "true";
      submit.disabled = !select.value || !confirm.checked || !restorable;
    };
    select?.addEventListener("change", () => {
      if (select.value) {
        window.location.href = `/admin/restore?file=${encodeURIComponent(select.value)}`;
      } else {
        sync();
      }
    });
    confirm?.addEventListener("change", sync);
    sync();
  })();
</script>
<%- include("../partials/footer") %>
