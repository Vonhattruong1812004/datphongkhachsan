<%- include("../partials/head") %>
<%- include("../partials/header") %>
<main class="container">
  <section class="panel">
    <div class="section-eyebrow">Mobile Readiness</div>
    <h2>PWA, offline shell va mobile hub</h2>
    <div class="dashboard-grid">
      <article class="dashboard-card"><strong><%= payload.summary.overall_score %>%</strong><h3>PWA score</h3></article>
      <article class="dashboard-card"><strong><%= payload.summary.ready %></strong><h3>Ready modules</h3></article>
      <article class="dashboard-card"><strong><%= payload.summary.partial %></strong><h3>Partial modules</h3></article>
    </div>
    <div class="nav-links" style="margin-top:16px;">
      <a class="chip" href="/api/admin/diagnostics/mobile">Mobile JSON</a>
      <a class="chip" href="/customer/mobile-hub">Mở Mobile Hub</a>
      <a class="chip" href="/dashboard/admin">Về dashboard Admin</a>
    </div>
  </section>
  <section class="panel">
    <div class="section-eyebrow">Tech Signals</div>
    <div class="room-grid room-grid--wide">
      <% Object.entries(payload.tech).forEach(([key, value]) => { %>
        <article class="room-card">
          <span class="badge"><%= value ? "ready" : "partial" %></span>
          <h3><%= key %></h3>
          <p class="muted"><%= value ? "Da san sang." : "Can hoan thien them." %></p>
        </article>
      <% }) %>
    </div>
  </section>
  <section class="panel">
    <div class="section-eyebrow">Modules</div>
    <div class="room-grid room-grid--wide">
      <% payload.modules.forEach((item) => { %>
        <article class="room-card">
          <span class="badge"><%= item.status %></span>
          <h3><%= item.name %></h3>
          <p class="muted"><%= item.detail %></p>
        </article>
      <% }) %>
    </div>
  </section>
</main>
<%- include("../partials/footer") %>
