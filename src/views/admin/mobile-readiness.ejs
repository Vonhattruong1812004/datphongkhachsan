<%- include("../partials/head") %>
<%- include("../partials/header") %>
<%
  const summary = payload?.summary || {};
  const tech = payload?.tech || {};
  const modules = payload?.modules || [];
  const nextActions = payload?.next_actions || [];
  const score = Number(summary.overall_score || 0);
  const readyCount = Number(summary.ready || 0);
  const partialCount = Number(summary.partial || 0);
  const blockedCount = Number(summary.blocked || 0);
  const generatedAt = payload?.generatedAt || new Date().toISOString();
  const shortTime = new Date(generatedAt).toLocaleString("vi-VN", { hour12: false });
  const statusText = (status) => status === "ready" ? "Ready" : (status === "blocked" ? "Blocked" : "Partial");
  const statusTone = (status, index) => status === "ready" ? ["cyan", "green", "blue", "violet"][index % 4] : (status === "blocked" ? "rose" : "amber");
  const techEntries = Object.entries(tech);
%>
<style>
  .mobile-readiness {
    --mr-ink: #f8fbff;
    --mr-muted: #bfd4ea;
    --mr-line: rgba(125, 211, 252, .22);
    --mr-cyan: #67e8f9;
    --mr-green: #5eead4;
    --mr-blue: #60a5fa;
    --mr-violet: #a78bfa;
    --mr-amber: #facc15;
    --mr-rose: #fb7185;
    --mr-shadow: 0 34px 100px rgba(0, 0, 0, .36);
    position: relative;
    isolation: isolate;
    min-height: calc(100vh - 84px);
    overflow: hidden;
    padding: 36px 18px 64px;
    color: var(--mr-ink);
    background:
      radial-gradient(circle at 12% 14%, rgba(94, 234, 212, .22), transparent 30%),
      radial-gradient(circle at 84% 16%, rgba(96, 165, 250, .22), transparent 34%),
      radial-gradient(circle at 54% 112%, rgba(167, 139, 250, .16), transparent 42%),
      linear-gradient(135deg, #03111f 0%, #071634 45%, #150c31 76%, #060813 100%);
  }

  .mobile-readiness::before,
  .mobile-readiness::after {
    content: "";
    position: absolute;
    pointer-events: none;
    z-index: 0;
  }

  .mobile-readiness::before {
    inset: 0;
    opacity: .72;
    background:
      radial-gradient(circle, #e0f2fe 0 1px, transparent 2px) 10% 12% / 150px 150px,
      radial-gradient(circle, #a7f3d0 0 1px, transparent 2px) 40% 30% / 210px 210px,
      radial-gradient(circle, #c4b5fd 0 1px, transparent 2px) 78% 8% / 180px 180px,
      linear-gradient(114deg, transparent 0 50%, rgba(103, 232, 249, .18) 52%, transparent 57% 100%);
  }

  .mobile-readiness::after {
    right: -15%;
    bottom: -40%;
    width: 700px;
    height: 700px;
    border-radius: 999px;
    opacity: .34;
    background: conic-gradient(from 140deg, rgba(94, 234, 212, .32), rgba(96, 165, 250, .25), rgba(167, 139, 250, .20), rgba(250, 204, 21, .14), rgba(94, 234, 212, .32));
    filter: blur(10px);
  }

  .mr-wrap {
    position: relative;
    z-index: 1;
    width: min(1280px, 100%);
    margin: 0 auto;
  }

  .mr-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) 360px;
    gap: 24px;
    align-items: stretch;
  }

  .mr-panel,
  .mr-score,
  .mr-stat,
  .mr-card,
  .mr-tech,
  .mr-action {
    border: 1px solid var(--mr-line);
    background:
      linear-gradient(145deg, rgba(8, 18, 40, .90), rgba(13, 25, 56, .76)),
      radial-gradient(circle at 88% 12%, rgba(94, 234, 212, .15), transparent 32%);
    box-shadow: var(--mr-shadow), inset 0 1px 0 rgba(255, 255, 255, .08);
    backdrop-filter: blur(22px);
  }

  .mr-panel {
    position: relative;
    overflow: hidden;
    min-height: 344px;
    border-radius: 34px;
    padding: clamp(28px, 4vw, 42px);
  }

  .mr-panel::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(120deg, rgba(255, 255, 255, .12), transparent 30%),
      radial-gradient(circle at 84% 16%, rgba(103, 232, 249, .20), transparent 28%);
  }

  .mr-label {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    width: max-content;
    border-radius: 999px;
    padding: 8px 13px;
    color: #dffcff;
    background: rgba(8, 18, 40, .76);
    border: 1px solid rgba(125, 211, 252, .30);
    box-shadow: 0 16px 42px rgba(34, 211, 238, .12);
    font-size: 12px;
    font-weight: 1000;
    text-transform: uppercase;
    letter-spacing: .08em;
  }

  .mr-label::before {
    content: "";
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--mr-green);
    box-shadow: 0 0 0 7px rgba(94, 234, 212, .16), 0 0 24px rgba(94, 234, 212, .38);
  }

  .mr-panel h1 {
    position: relative;
    z-index: 1;
    max-width: 820px;
    margin: 22px 0 12px;
    color: #fff;
    font-size: clamp(42px, 5.6vw, 72px);
    line-height: .94;
    letter-spacing: 0;
    text-shadow: 0 14px 38px rgba(0, 0, 0, .30);
  }

  .mr-panel h1 span {
    color: transparent;
    background: linear-gradient(135deg, #67e8f9 0%, #5eead4 38%, #a78bfa 70%, #facc15 100%);
    -webkit-background-clip: text;
    background-clip: text;
  }

  .mr-lead {
    position: relative;
    z-index: 1;
    max-width: 730px;
    margin: 0;
    color: var(--mr-muted);
    font-size: 15.5px;
    line-height: 1.68;
  }

  .mr-actions {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 24px;
  }

  .mr-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    border: 1px solid rgba(125, 211, 252, .28);
    border-radius: 999px;
    padding: 10px 16px;
    color: #f8fbff;
    background: rgba(10, 24, 52, .76);
    box-shadow: 0 16px 36px rgba(0, 0, 0, .20);
    font: inherit;
    font-size: 14px;
    font-weight: 950;
    text-decoration: none;
    cursor: pointer;
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
  }

  .mr-button:hover {
    transform: translateY(-2px);
    border-color: rgba(103, 232, 249, .56);
    box-shadow: 0 20px 52px rgba(34, 211, 238, .20);
  }

  .mr-button--primary {
    color: #061426;
    border-color: rgba(255, 255, 255, .22);
    background: linear-gradient(135deg, #67e8f9, #5eead4 58%, #facc15);
    box-shadow: 0 20px 54px rgba(34, 211, 238, .28);
  }

  .mr-score {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    border-radius: 34px;
    padding: 26px;
    text-align: center;
    background:
      radial-gradient(circle at 32% 20%, rgba(94, 234, 212, .20), transparent 30%),
      linear-gradient(155deg, rgba(8, 18, 40, .92), rgba(18, 12, 45, .84));
  }

  .mr-phone {
    width: 150px;
    height: 238px;
    border-radius: 34px;
    padding: 12px;
    border: 1px solid rgba(125, 211, 252, .28);
    background:
      linear-gradient(145deg, rgba(255, 255, 255, .10), rgba(255, 255, 255, .02)),
      rgba(3, 10, 24, .78);
    box-shadow: 0 26px 80px rgba(34, 211, 238, .16), inset 0 1px 0 rgba(255, 255, 255, .10);
  }

  .mr-phone-screen {
    position: relative;
    height: 100%;
    overflow: hidden;
    border-radius: 24px;
    background:
      radial-gradient(circle at 50% 22%, rgba(103, 232, 249, .34), transparent 32%),
      radial-gradient(circle at 50% 75%, rgba(167, 139, 250, .22), transparent 38%),
      linear-gradient(180deg, #061426, #0b1734);
  }

  .mr-phone-screen::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 10px;
    width: 44px;
    height: 5px;
    border-radius: 999px;
    transform: translateX(-50%);
    background: rgba(226, 232, 240, .70);
  }

  .mr-phone-score {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    text-align: center;
  }

  .mr-phone-score strong {
    display: block;
    color: #fff;
    font-size: 46px;
    line-height: 1;
  }

  .mr-phone-score span {
    display: block;
    margin-top: 7px;
    color: #a9c7df;
    font-size: 12px;
    font-weight: 1000;
    letter-spacing: .07em;
    text-transform: uppercase;
  }

  .mr-score h2 {
    margin: 20px 0 6px;
    color: #fff;
    font-size: 26px;
    letter-spacing: 0;
  }

  .mr-score p {
    margin: 0;
    color: var(--mr-muted);
    font-size: 13px;
    line-height: 1.55;
  }

  .mr-stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
    margin-top: 24px;
  }

  .mr-stat {
    position: relative;
    overflow: hidden;
    border-radius: 26px;
    padding: 20px;
  }

  .mr-stat::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 6px;
    background: linear-gradient(90deg, var(--stat-color), transparent);
  }

  .mr-stat strong {
    display: block;
    color: #fff;
    font-size: 36px;
    line-height: 1;
    letter-spacing: 0;
  }

  .mr-stat span {
    display: block;
    margin-top: 9px;
    color: var(--mr-muted);
    font-size: 12px;
    font-weight: 1000;
    text-transform: uppercase;
    letter-spacing: .06em;
  }

  .mr-section {
    margin-top: 26px;
  }

  .mr-section-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 16px;
  }

  .mr-section-head h2 {
    margin: 0;
    color: #fff;
    font-size: 28px;
    letter-spacing: 0;
  }

  .mr-section-head p {
    margin: 5px 0 0;
    color: var(--mr-muted);
    font-size: 13px;
    line-height: 1.55;
  }

  .mr-tech-grid,
  .mr-module-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .mr-tech,
  .mr-card {
    position: relative;
    overflow: hidden;
    border-radius: 26px;
    padding: 18px;
  }

  .mr-tech::before,
  .mr-card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 6px;
    background: linear-gradient(90deg, var(--tone), transparent);
  }

  .mr-tech[data-tone="green"],
  .mr-card[data-tone="green"] { --tone: var(--mr-green); }
  .mr-tech[data-tone="cyan"],
  .mr-card[data-tone="cyan"] { --tone: var(--mr-cyan); }
  .mr-tech[data-tone="blue"],
  .mr-card[data-tone="blue"] { --tone: var(--mr-blue); }
  .mr-tech[data-tone="violet"],
  .mr-card[data-tone="violet"] { --tone: var(--mr-violet); }
  .mr-tech[data-tone="amber"],
  .mr-card[data-tone="amber"] { --tone: var(--mr-amber); }
  .mr-tech[data-tone="rose"],
  .mr-card[data-tone="rose"] { --tone: var(--mr-rose); }

  .mr-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: max-content;
    border-radius: 999px;
    padding: 7px 10px;
    color: var(--tone);
    background: rgba(8, 18, 40, .78);
    border: 1px solid rgba(125, 211, 252, .20);
    font-size: 11px;
    font-weight: 1000;
    text-transform: uppercase;
    letter-spacing: .04em;
  }

  .mr-badge::before {
    content: "";
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: currentColor;
    box-shadow: 0 0 18px currentColor;
  }

  .mr-tech h3,
  .mr-card h3 {
    margin: 18px 0 8px;
    color: #fff;
    font-size: 21px;
    line-height: 1.15;
    letter-spacing: 0;
  }

  .mr-tech p,
  .mr-card p {
    margin: 0;
    color: var(--mr-muted);
    font-size: 13.5px;
    line-height: 1.58;
  }

  .mr-card {
    min-height: 188px;
  }

  .mr-card-score {
    position: absolute;
    right: 16px;
    top: 16px;
    display: grid;
    place-items: center;
    width: 54px;
    height: 54px;
    border-radius: 18px;
    color: #fff;
    background: linear-gradient(135deg, rgba(255, 255, 255, .20), rgba(255, 255, 255, .04));
    border: 1px solid rgba(255, 255, 255, .10);
    font-weight: 1000;
    transform: rotate(8deg);
  }

  .mr-action-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .mr-action {
    position: relative;
    overflow: hidden;
    min-height: 84px;
    border-radius: 24px;
    padding: 18px 18px 18px 22px;
    color: var(--mr-muted);
    font-size: 14px;
    line-height: 1.55;
  }

  .mr-action::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 6px;
    background: linear-gradient(180deg, var(--mr-green), var(--mr-violet));
  }

  .mr-empty {
    border: 1px dashed rgba(125, 211, 252, .28);
    border-radius: 24px;
    padding: 18px;
    color: var(--mr-muted);
    background: rgba(8, 18, 40, .55);
    font-weight: 850;
  }

  @media (max-width: 1100px) {
    .mr-hero {
      grid-template-columns: 1fr;
    }

    .mr-stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .mr-tech-grid,
    .mr-module-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .mobile-readiness {
      padding: 24px 12px 54px;
    }

    .mr-panel,
    .mr-score,
    .mr-tech,
    .mr-card {
      border-radius: 26px;
    }

    .mr-panel {
      min-height: auto;
      padding: 22px;
    }

    .mr-panel h1 {
      font-size: 42px;
    }

    .mr-stats,
    .mr-tech-grid,
    .mr-module-grid,
    .mr-action-list {
      grid-template-columns: 1fr;
    }

    .mr-section-head {
      display: block;
    }
  }
</style>

<main class="mobile-readiness">
  <div class="mr-wrap">
    <section class="mr-hero" aria-label="Mobile readiness">
      <div class="mr-panel">
        <div class="mr-label">Mobile readiness</div>
        <h1>PWA, offline shell và <span>mobile hub</span></h1>
        <p class="mr-lead">
          Kiểm tra các tín hiệu cần có để hệ thống chạy tốt trên thiết bị di động:
          manifest, service worker, offline page, mobile hub, API snapshot và AI concierge.
        </p>
        <div class="mr-actions">
          <button class="mr-button mr-button--primary" type="button" onclick="window.location.reload()">Kiểm tra lại</button>
          <a class="mr-button" href="/api/admin/diagnostics/mobile">Mobile JSON</a>
          <a class="mr-button" href="/customer/mobile-hub">Mở Mobile Hub</a>
          <a class="mr-button" href="/dashboard/admin">Dashboard Admin</a>
        </div>
      </div>

      <aside class="mr-score">
        <div class="mr-phone" aria-label="Mobile readiness score">
          <div class="mr-phone-screen">
            <div class="mr-phone-score">
              <div>
                <strong><%= score %></strong>
                <span>PWA score</span>
              </div>
            </div>
          </div>
        </div>
        <h2><%= partialCount || blockedCount ? "Cần theo dõi" : "Sẵn sàng" %></h2>
        <p>Cập nhật: <%= shortTime %></p>
      </aside>
    </section>

    <section class="mr-stats" aria-label="Tổng quan mobile readiness">
      <article class="mr-stat" style="--stat-color: var(--mr-green)">
        <strong><%= readyCount %></strong>
        <span>Module ready</span>
      </article>
      <article class="mr-stat" style="--stat-color: var(--mr-amber)">
        <strong><%= partialCount %></strong>
        <span>Module partial</span>
      </article>
      <article class="mr-stat" style="--stat-color: var(--mr-rose)">
        <strong><%= blockedCount %></strong>
        <span>Module blocked</span>
      </article>
      <article class="mr-stat" style="--stat-color: var(--mr-cyan)">
        <strong><%= techEntries.filter(([, value]) => value).length %>/<%= techEntries.length %></strong>
        <span>Tech signals</span>
      </article>
    </section>

    <section class="mr-section" aria-label="Tech signals">
      <div class="mr-section-head">
        <div>
          <h2>Tech signals</h2>
          <p>Các file và điểm tích hợp nền tảng di động mà service đang kiểm tra.</p>
        </div>
      </div>
      <div class="mr-tech-grid">
        <% techEntries.forEach(([key, value], index) => { const tone = value ? ["green", "cyan", "blue", "violet"][index % 4] : "amber"; %>
          <article class="mr-tech" data-tone="<%= tone %>">
            <span class="mr-badge"><%= value ? "Ready" : "Partial" %></span>
            <h3><%= key.replace(/_/g, " ") %></h3>
            <p><%= value ? "Đã sẵn sàng trong cấu hình mobile/PWA." : "Cần hoàn thiện thêm để trải nghiệm mobile đầy đủ hơn." %></p>
          </article>
        <% }) %>
      </div>
    </section>

    <section class="mr-section" aria-label="Mobile modules">
      <div class="mr-section-head">
        <div>
          <h2>Mobile modules</h2>
          <p>Tổng hợp readiness theo từng cụm trải nghiệm khách hàng trên mobile.</p>
        </div>
      </div>
      <div class="mr-module-grid">
        <% modules.forEach((item, index) => { const tone = statusTone(item.status, index); %>
          <article class="mr-card" data-tone="<%= tone %>">
            <span class="mr-card-score"><%= item.score || 0 %></span>
            <span class="mr-badge"><%= statusText(item.status) %></span>
            <h3><%= item.name %></h3>
            <p><%= item.detail %></p>
          </article>
        <% }) %>
      </div>
    </section>

    <section class="mr-section" aria-label="Gợi ý xử lý mobile">
      <div class="mr-section-head">
        <div>
          <h2>Gợi ý xử lý</h2>
          <p>Các mục chỉ hiện khi mobile/PWA còn phần cần hoàn thiện.</p>
        </div>
      </div>
      <% if (!nextActions.length) { %>
        <div class="mr-empty">Mobile/PWA đang sẵn sàng, chưa có gợi ý xử lý thêm.</div>
      <% } else { %>
        <div class="mr-action-list">
          <% nextActions.forEach((action) => { %>
            <div class="mr-action"><%= action %></div>
          <% }) %>
        </div>
      <% } %>
    </section>
  </div>
</main>
<%- include("../partials/footer") %>
