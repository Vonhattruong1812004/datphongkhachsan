      action: "Chi tiết"
    }
  ];
%>

<style>
  .guest-home {
    --guest-ink: #112233;
    --guest-muted: #667085;
    --guest-card: rgba(255, 255, 255, .74);
    --guest-card-strong: rgba(255, 255, 255, .90);
    --guest-line: rgba(17, 34, 51, .10);
    --guest-cyan: #18bff2;
    --guest-mint: #21cfa6;
    --guest-lime: #b7ef4a;
    --guest-peach: #ff9f7a;
    --guest-pink: #ff6fa3;
    --guest-violet: #8b6bff;
    --guest-yellow: #ffd166;
    --guest-shadow: 0 28px 86px rgba(18, 38, 63, .17);
    min-height: calc(100vh - 84px);
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: 34px 18px 58px;
    color: var(--guest-ink);
    background:
      radial-gradient(circle at 9% 12%, rgba(33, 207, 166, .32), transparent 27%),
      radial-gradient(circle at 82% 10%, rgba(255, 111, 163, .22), transparent 30%),
      radial-gradient(circle at 46% 104%, rgba(183, 239, 74, .24), transparent 38%),
      linear-gradient(135deg, #fbfffb 0%, #eafcff 39%, #fff7ed 100%);
  }

  .guest-home::before,
  .guest-home::after {
    content: "";
    position: absolute;
    pointer-events: none;
    z-index: -1;
  }

  .guest-home::before {
    width: 620px;
    height: 620px;
    top: -310px;
    right: -170px;
    border-radius: 48% 52% 42% 58%;
    opacity: .46;
    background: conic-gradient(from 180deg, rgba(24,191,242,.50), rgba(33,207,166,.34), rgba(183,239,74,.34), rgba(255,111,163,.28), rgba(24,191,242,.50));
    animation: guest-blob 16s ease-in-out infinite alternate;
  }

  .guest-home::after {
    width: 520px;
    height: 520px;
    left: -230px;
    bottom: -260px;
    border-radius: 999px;
    opacity: .38;
    background: conic-gradient(from 20deg, rgba(255,159,122,.36), rgba(255,209,102,.32), rgba(24,191,242,.28), rgba(139,107,255,.26), rgba(255,159,122,.36));
    animation: guest-orb-bg 14s ease-in-out infinite alternate;
  }

  .guest-wrap {
    max-width: 1240px;
    margin: 0 auto;
    position: relative;
  }

  .guest-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) 390px;
    gap: 22px;
    align-items: stretch;
    margin-bottom: 20px;
  }

  .guest-panel,
  .guest-hero-card,
  .guest-live-card,
  .guest-uc-card,
  .guest-focus-card,
  .guest-booking-card {
    border: 1px solid var(--guest-line);
    background: var(--guest-card);
    box-shadow: var(--guest-shadow);
    backdrop-filter: blur(14px);
  }

  .guest-hero,
  .guest-focus-card,
  .guest-section {
    contain: layout paint;
  }

  .guest-section {
    content-visibility: auto;
    contain-intrinsic-size: 620px;
  }

  .guest-uc-card,
  .guest-booking-card {
    backdrop-filter: none;
    contain: layout paint;
  }

  .guest-hero-card {
    min-height: 360px;
    border-radius: 38px;
    padding: 36px;
    position: relative;
    overflow: hidden;
  }

  .guest-hero-card::before {
    content: "";
    position: absolute;
    inset: -1px;
    pointer-events: none;
    background:
      linear-gradient(120deg, rgba(255, 255, 255, .70), transparent 28%),
      radial-gradient(circle at 86% 20%, rgba(24, 191, 242, .26), transparent 30%),
      radial-gradient(circle at 16% 88%, rgba(183, 239, 74, .20), transparent 28%);
  }

  .guest-chip {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-radius: 999px;
    padding: 7px 12px;
    border: 1px solid rgba(33, 207, 166, .24);
    background: rgba(33, 207, 166, .12);
    color: #087763;
    font-size: 12px;
    font-weight: 1000;
    letter-spacing: .09em;
    text-transform: uppercase;
  }

  .guest-pulse {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--guest-mint);
    box-shadow: 0 0 0 7px rgba(33, 207, 166, .14);
    animation: guest-pulse 1.8s ease-in-out infinite;
  }

  .guest-hero h1 {
    position: relative;
    z-index: 1;
    max-width: 760px;
    margin: 26px 0 14px;
    color: var(--guest-ink);
    font-size: clamp(42px, 6.4vw, 78px);
    line-height: .90;
    letter-spacing: -.075em;
  }

  .guest-hero h1 span {
    color: transparent;
    background: linear-gradient(96deg, #0891b2 0%, #10b981 43%, #f59e0b 72%, #ec4899 100%);
    -webkit-background-clip: text;
    background-clip: text;
  }

  .guest-lead {
    position: relative;
    z-index: 1;
    max-width: 690px;
    margin: 0;
    color: var(--guest-muted);
    font-size: 16px;
    line-height: 1.72;
  }

  .guest-tags,
  .guest-hero-actions {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .guest-tags {
    margin-top: 22px;
  }

  .guest-tag {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 8px 11px;
    color: var(--guest-ink);
    background: rgba(255, 255, 255, .66);
    border: 1px solid rgba(17, 34, 51, .08);
    font-size: 12px;
    font-weight: 950;
  }

  .guest-tag--ekyc {
    color: #0f766e;
    background: rgba(33, 207, 166, .11);
    border-color: rgba(33, 207, 166, .18);
  }

  .guest-hero-actions {
    margin-top: 28px;
  }

  .guest-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 45px;
    border-radius: 999px;
    padding: 10px 18px;
    border: 1px solid rgba(17, 34, 51, .12);
    background: rgba(255, 255, 255, .76);
    color: var(--guest-ink);
    text-decoration: none;
    font-size: 14px;
    font-weight: 950;
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
  }

  .guest-button:hover {
    transform: translateY(-2px);
    border-color: rgba(24, 191, 242, .34);
    box-shadow: 0 18px 44px rgba(24, 191, 242, .16);
  }

  .guest-button--primary {
    color: #fff;
    border-color: transparent;
    background: linear-gradient(135deg, #08a5c8, #21cfa6);
    box-shadow: 0 18px 42px rgba(33, 207, 166, .24);
  }

  .guest-mini-stats {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-top: 34px;
  }

  .guest-mini-stat {
    border-radius: 23px;
    padding: 16px;
    background: rgba(255, 255, 255, .58);
    border: 1px solid rgba(17, 34, 51, .08);
  }

  .guest-mini-stat strong {
    display: block;
    color: var(--guest-ink);
    font-size: 30px;
    line-height: 1;
    letter-spacing: -.055em;
  }

  .guest-mini-stat span {
    display: block;
    margin-top: 8px;
    color: var(--guest-muted);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .06em;
    text-transform: uppercase;
  }

  .guest-live-card {
    min-height: 360px;
    border-radius: 38px;
    padding: 22px;
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(160deg, rgba(255, 255, 255, .86), rgba(236, 253, 245, .58)),
      radial-gradient(circle at 30% 18%, rgba(255, 209, 102, .20), transparent 28%);
  }

  .guest-live-card::before {
    content: "";
    position: absolute;
    inset: 22px;
    border-radius: 32px;
    background:
      linear-gradient(145deg, rgba(14, 38, 58, .90), rgba(12, 86, 110, .74)),
      radial-gradient(circle at 22% 18%, rgba(183,239,74,.24), transparent 32%);
  }

  .guest-live-ring {
    position: absolute;
    inset: 48px;
    border: 1px dashed rgba(255, 255, 255, .25);
    border-radius: 999px;
    animation: guest-spin 22s linear infinite;
  }

  .guest-live-core {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 158px;
    height: 158px;
    border-radius: 46px;
    transform: translate(-50%, -50%) rotate(14deg);
    background: linear-gradient(135deg, rgba(103, 232, 249, .96), rgba(183, 239, 74, .86));
    box-shadow: 0 26px 76px rgba(33, 207, 166, .34);
    animation: guest-core 4.8s ease-in-out infinite;
  }

  .guest-live-word {
    position: absolute;
    z-index: 2;
    border-radius: 999px;
    padding: 9px 12px;
    color: #f8fbff;
    background: rgba(15, 23, 42, .48);
    border: 1px solid rgba(255, 255, 255, .18);
    backdrop-filter: none;
    font-size: 12px;
    font-weight: 1000;
  }

  .guest-home::before,
  .guest-home::after,
  .guest-live-ring,
  .guest-live-core,
  .guest-live-word {
    animation: none !important;
  }

  .guest-live-word:nth-child(4) { left: 34px; top: 42px; animation: guest-drift-a 5.5s ease-in-out infinite; }
  .guest-live-word:nth-child(5) { right: 30px; top: 98px; animation: guest-drift-b 6.2s ease-in-out infinite; }
  .guest-live-word:nth-child(6) { left: 44px; bottom: 78px; animation: guest-drift-b 5.8s ease-in-out infinite reverse; }
  .guest-live-word:nth-child(7) { right: 42px; bottom: 44px; animation: guest-drift-a 6.5s ease-in-out infinite reverse; }

  .guest-focus-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 16px;
    align-items: center;
    border-radius: 30px;
    padding: 18px 20px;
    margin-bottom: 18px;
    background: rgba(255, 255, 255, .66);
  }

  .guest-focus-card strong {
    display: block;
    color: var(--guest-ink);
    font-size: 18px;
    letter-spacing: -.02em;
  }

  .guest-focus-card span {
    display: block;
    margin-top: 4px;
    color: var(--guest-muted);
    font-size: 13px;
  }

  .guest-flow {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .guest-flow a {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 8px 11px;
    color: #0f766e;
    background: rgba(33, 207, 166, .11);
    border: 1px solid rgba(33, 207, 166, .18);
    text-decoration: none;
    font-size: 12px;
    font-weight: 950;
  }

  .guest-section {
    margin-top: 20px;
  }

  .guest-section-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 14px;
    margin: 0 0 14px;
  }

  .guest-section-head h2 {
    margin: 0;
    color: var(--guest-ink);
    font-size: 26px;
    letter-spacing: -.05em;
  }

  .guest-section-head p {
    margin: 5px 0 0;
    color: var(--guest-muted);
    font-size: 13px;
  }

  .guest-bento {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: minmax(210px, auto);
    gap: 16px;
  }

  .guest-uc-card {
    --accent: var(--guest-cyan);
    --accent-soft: rgba(24, 191, 242, .20);
    grid-column: span 4;
    position: relative;
    overflow: hidden;
    border-radius: 32px;
    padding: 22px;
    text-decoration: none;
    color: var(--guest-ink);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, .88), rgba(255, 255, 255, .62)),
      radial-gradient(circle at 100% 0%, var(--accent-soft), transparent 34%);
    transform: translateY(20px);
    opacity: 0;
    animation: guest-rise .72s cubic-bezier(.22, 1, .36, 1) forwards;
    transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
  }

  .guest-uc-card:nth-child(1) { animation-delay: .02s; }
  .guest-uc-card:nth-child(2) { animation-delay: .08s; }
  .guest-uc-card:nth-child(3) { animation-delay: .14s; }
  .guest-uc-card:nth-child(4) { animation-delay: .20s; }
  .guest-uc-card:nth-child(5) { animation-delay: .26s; }
  .guest-uc-card:nth-child(6) { animation-delay: .32s; }

  .guest-uc-card.is-wide {
    grid-column: span 5;
  }

  .guest-uc-card.is-compact {
    grid-column: span 3;
  }

  .guest-uc-card:hover {
    transform: translateY(-7px) rotate(-.24deg);
    border-color: color-mix(in srgb, var(--accent) 36%, transparent);
    box-shadow: 0 34px 92px rgba(18, 38, 63, .22);
  }

  .guest-uc-card::before {
    content: "";
    position: absolute;
    width: 190px;
    height: 190px;
    right: -64px;
    top: -64px;
    border-radius: 999px;
    background: radial-gradient(circle, var(--accent-soft), transparent 68%);
    transition: transform .25s ease;
  }

  .guest-uc-card:hover::before {
    transform: scale(1.24);
  }

  .guest-uc-card::after {
    content: "";
    position: absolute;
    left: 22px;
    right: 22px;
    bottom: 18px;
    height: 4px;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--accent), transparent);
    opacity: .62;
  }

  .guest-uc-top {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
  }

  .guest-uc-code {
    display: inline-flex;
    border-radius: 999px;
    padding: 6px 10px;
    background: rgba(255, 255, 255, .74);
    border: 1px solid rgba(17, 34, 51, .08);
    color: var(--accent);
    font-size: 12px;
    font-weight: 1000;
    letter-spacing: .06em;
  }

  .guest-uc-orb {
    width: 52px;
    height: 52px;
    border-radius: 19px;
    background: linear-gradient(135deg, var(--accent), rgba(255, 255, 255, .36));
    box-shadow: 0 16px 36px var(--accent-soft);
    transform: rotate(8deg);
  }

  .guest-uc-card h3 {
    position: relative;
    z-index: 1;
    margin: 28px 0 10px;
    max-width: 360px;
    color: var(--guest-ink);
    font-size: 26px;
    line-height: 1.05;
    letter-spacing: -.05em;
  }

  .guest-uc-card p {
    position: relative;
    z-index: 1;
    max-width: 430px;
    margin: 0;
    color: var(--guest-muted);
    font-size: 14px;
    line-height: 1.62;
  }

  .guest-open {
    position: absolute;
    z-index: 1;
    right: 22px;
    bottom: 25px;
    color: var(--accent);
    font-size: 13px;
    font-weight: 1000;
  }

  .guest-search { --accent: var(--guest-mint); --accent-soft: rgba(33,207,166,.22); }
  .guest-history { --accent: var(--guest-cyan); --accent-soft: rgba(24,191,242,.22); }
  .guest-profile { --accent: var(--guest-violet); --accent-soft: rgba(139,107,255,.20); }
  .guest-service { --accent: var(--guest-yellow); --accent-soft: rgba(255,209,102,.24); }
  .guest-edit { --accent: var(--guest-pink); --accent-soft: rgba(255,111,163,.20); }
  .guest-feedback { --accent: #74c61f; --accent-soft: rgba(116,198,31,.19); }

  .frontdesk-uc-section .guest-bento {
    grid-auto-rows: minmax(194px, auto);
    gap: 18px;
  }

  .frontdesk-uc-section .guest-uc-card {
    min-height: 194px;
    padding: 20px 20px 24px;
    border-color: rgba(17, 34, 51, .13);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, .96), rgba(255, 255, 255, .78)),
      radial-gradient(circle at 100% 0%, color-mix(in srgb, var(--accent) 28%, transparent), transparent 34%);
    box-shadow: 0 26px 74px rgba(18, 38, 63, .20);
  }

  .frontdesk-uc-section .guest-uc-card:hover {
    box-shadow: 0 36px 96px rgba(18, 38, 63, .25);
  }

  .frontdesk-uc-section .guest-uc-code {
    background: rgba(255, 255, 255, .88);
    border-color: rgba(17, 34, 51, .11);
    box-shadow: 0 10px 26px rgba(18, 38, 63, .07);
  }

  .frontdesk-uc-section .guest-uc-orb {
    width: 50px;
    height: 50px;
    border-radius: 18px;
    opacity: .92;
    box-shadow: 0 18px 42px color-mix(in srgb, var(--accent) 24%, transparent);
  }

  .frontdesk-uc-section .guest-uc-card h3 {
    margin: 48px 0 10px;
    color: #102033;
    font-size: 25px;
    line-height: 1.04;
    letter-spacing: -.055em;
  }

  .frontdesk-uc-section .guest-uc-card p {
    max-width: 510px;
    color: #5f6b7d;
    font-size: 13.5px;
    line-height: 1.55;
    font-weight: 750;
  }

  .frontdesk-uc-section .guest-open {
    right: 20px;
    bottom: 27px;
    font-size: 12.5px;
    font-weight: 1000;
  }

  .frontdesk-uc-section .guest-uc-card::after {
    left: 20px;
    right: 20px;
    bottom: 18px;
    height: 5px;
    opacity: .78;
  }

  .guest-booking-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .guest-booking-card {
    border-radius: 28px;
    padding: 20px;
    background: rgba(255, 255, 255, .70);
  }

  .guest-booking-card h3 {
    margin: 12px 0 8px;
    color: var(--guest-ink);
    font-size: 21px;
    line-height: 1.1;
    letter-spacing: -.04em;
  }

  .guest-booking-card p {
    margin: 0 0 6px;
    color: var(--guest-muted);
    font-size: 13px;
    line-height: 1.5;
  }

  .guest-booking-card strong {
    display: block;
    margin-top: 10px;
    color: var(--guest-ink);
    font-size: 21px;
  }

  .guest-booking-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
  }

  .guest-booking-actions .guest-button {
    min-height: 38px;
    padding: 8px 12px;
    font-size: 12px;
  }

  .guest-badge {
    display: inline-flex;
    border-radius: 999px;
    padding: 5px 9px;
    background: rgba(33, 207, 166, .12);
    color: #0f766e;
    font-size: 11px;
    font-weight: 1000;
    letter-spacing: .04em;
  }

  .guest-empty {
    border: 1px dashed rgba(17, 34, 51, .16);
    border-radius: 28px;
    padding: 24px;
    color: var(--guest-muted);
    background: rgba(255, 255, 255, .58);
  }

  @keyframes guest-blob {
    0% { transform: translate3d(0, 0, 0) rotate(0deg); border-radius: 48% 52% 42% 58%; }
    100% { transform: translate3d(26px, 30px, 0) rotate(18deg); border-radius: 56% 44% 60% 40%; }
  }

  @keyframes guest-orb-bg {
    from { transform: translate3d(0, 0, 0) rotate(0deg); }
    to { transform: translate3d(34px, -18px, 0) rotate(-14deg); }
  }

  @keyframes guest-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(.72); opacity: .68; }
  }

  @keyframes guest-spin {
    to { transform: rotate(360deg); }
  }

  @keyframes guest-core {
    0%, 100% { transform: translate(-50%, -50%) rotate(14deg) scale(1); border-radius: 46px; }
    50% { transform: translate(-50%, -50%) rotate(24deg) scale(1.07); border-radius: 72px; }
  }

  @keyframes guest-drift-a {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(12px, -10px, 0); }
  }

  @keyframes guest-drift-b {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(-10px, 12px, 0); }
  }

  @keyframes guest-rise {
    to { transform: translateY(0); opacity: 1; }
  }

  @media (max-width: 1080px) {
    .guest-hero { grid-template-columns: 1fr; }
    .guest-live-card { min-height: 320px; }
    .guest-uc-card,
    .guest-uc-card.is-wide,
    .guest-uc-card.is-compact { grid-column: span 6; }
    .guest-booking-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 760px) {
    .guest-home { padding: 20px 12px 42px; }
    .guest-hero-card { min-height: auto; padding: 24px; border-radius: 30px; }
    .guest-hero h1 { font-size: 44px; }
    .guest-mini-stats,
    .guest-focus-card,
    .guest-booking-grid { grid-template-columns: 1fr; }
    .guest-live-card { min-height: 280px; }
    .guest-uc-card,
    .guest-uc-card.is-wide,
    .guest-uc-card.is-compact {
      grid-column: 1 / -1;
      min-height: 220px;
    }
    .guest-section-head { display: block; }
  }

  @media (prefers-reduced-motion: reduce) {
    .guest-home::before,
    .guest-home::after,
    .guest-pulse,
    .guest-live-ring,
    .guest-live-core,
    .guest-live-word,
    .guest-uc-card {
      animation: none;
    }
    .guest-uc-card {
      transform: none;
      opacity: 1;
    }
  }
</style>

<main class="guest-home">
  <div class="guest-wrap">
    <%- include("./_notice", { notice }) %>

    <section class="guest-hero" aria-label="Dashboard lễ tân">
      <div class="guest-hero-card">
        <div class="guest-chip"><span class="guest-pulse"></span> Frontdesk command center</div>
        <h1>Xin chào <span><%= staffName %></span></h1>
        <p class="guest-lead">
          Một dashboard sạch cho ca trực: tạo booking tại quầy, nhận phòng,
          đặt dịch vụ, chỉnh/hủy booking và checkout trong cùng một luồng.
        </p>

        <div class="guest-tags" aria-label="Thông tin nhanh">
          <span class="guest-tag guest-tag--ekyc">Ca trực: sẵn sàng</span>
          <span class="guest-tag"><%= todayLabel %></span>
          <span class="guest-tag">6 nghiệp vụ chính</span>
        </div>

        <div class="guest-hero-actions">
          <a class="guest-button guest-button--primary" href="/frontdesk/direct-booking">Đặt phòng tại quầy</a>
          <a class="guest-button" href="/frontdesk/checkin">Check-in</a>
          <a class="guest-button" href="/frontdesk/checkout-v2">Check-out</a>
        </div>

        <div class="guest-mini-stats" aria-label="Tóm tắt ca trực">
          <div class="guest-mini-stat"><strong>06</strong><span>Nghiệp vụ chính</span></div>
          <div class="guest-mini-stat"><strong>04</strong><span>Bước ưu tiên</span></div>
          <div class="guest-mini-stat"><strong>Live</strong><span>Vận hành quầy</span></div>
        </div>
      </div>

      <aside class="guest-live-card" aria-label="Minh họa vận hành lễ tân">
        <div class="guest-live-ring"></div>
        <div class="guest-live-core"></div>
        <span class="guest-live-word">Booking</span>
        <span class="guest-live-word">Check-in</span>
        <span class="guest-live-word">Service</span>
        <span class="guest-live-word">Check-out</span>
      </aside>
    </section>

    <section class="guest-focus-card">
      <div>
        <strong>Luồng ưu tiên trong một ca trực</strong>
        <span>Tạo booking, nhận khách, bổ sung dịch vụ, chỉnh booking khi cần và kết ca bằng checkout sạch.</span>
      </div>
      <div class="guest-flow" aria-label="Luồng nghiệp vụ lễ tân">
        <a href="/frontdesk/direct-booking">Đặt phòng</a>
        <a href="/frontdesk/checkin">Nhận phòng</a>
        <a href="/service?from=frontdesk">Dịch vụ</a>
        <a href="/frontdesk/checkout-v2">Trả phòng</a>
      </div>
    </section>

    <section class="guest-section frontdesk-uc-section" aria-label="Nghiệp vụ lễ tân">
      <div class="guest-section-head">
        <div>
          <h2>Tác vụ chính</h2>
          <p>Các thao tác lễ tân dùng nhiều nhất.</p>
        </div>
      </div>

      <div class="guest-bento">
        <a class="guest-uc-card guest-search is-wide" href="/frontdesk/direct-booking">
          <div class="guest-uc-top">
            <span class="guest-uc-code">01</span>
            <span class="guest-uc-orb"></span>
          </div>
          <h3>Đặt phòng tại quầy</h3>
          <p>Tạo booking trực tiếp, chọn phòng, gắn khách, dịch vụ, khuyến mãi và tổng tiền.</p>
          <span class="guest-open">Mở</span>
        </a>

        <a class="guest-uc-card guest-history is-compact" href="/frontdesk/checkin">
          <div class="guest-uc-top">
            <span class="guest-uc-code">02</span>
            <span class="guest-uc-orb"></span>
          </div>
          <h3>Check-in</h3>
          <p>Tra cứu giao dịch, kiểm tra eKYC/giấy tờ và xác nhận nhận phòng.</p>
          <span class="guest-open">Mở</span>
        </a>

        <a class="guest-uc-card guest-profile" href="/frontdesk/checkout-v2">
          <div class="guest-uc-top">
            <span class="guest-uc-code">03</span>
            <span class="guest-uc-orb"></span>
          </div>
          <h3>Check-out</h3>
          <p>Kiểm tiền phòng, dịch vụ, bồi thường, VietQR và hoàn tất trả phòng.</p>
          <span class="guest-open">Mở</span>
        </a>

        <a class="guest-uc-card guest-service" href="/frontdesk/edit-booking">
          <div class="guest-uc-top">
            <span class="guest-uc-code">04</span>
            <span class="guest-uc-orb"></span>
          </div>
          <h3>Sửa thông tin đặt phòng</h3>
          <p>Cập nhật trưởng đoàn, ngày ở, phòng, số người và tổng tiền realtime.</p>
          <span class="guest-open">Mở</span>
        </a>

        <a class="guest-uc-card guest-edit is-compact" href="/frontdesk/cancel-booking">
          <div class="guest-uc-top">
            <span class="guest-uc-code">05</span>
            <span class="guest-uc-orb"></span>
          </div>
          <h3>Hủy đặt phòng</h3>
          <p>Hủy booking hợp lệ, bắt buộc lý do và đồng bộ trạng thái phòng.</p>
          <span class="guest-open">Mở</span>
        </a>

        <a class="guest-uc-card guest-feedback is-wide" href="/service?from=frontdesk">
          <div class="guest-uc-top">
            <span class="guest-uc-code">06</span>
            <span class="guest-uc-orb"></span>
          </div>
          <h3>Đặt dịch vụ</h3>
          <p>Bổ sung dịch vụ cho khách đang ở, cộng tiền vào giao dịch đang mở.</p>
          <span class="guest-open">Mở</span>
        </a>
      </div>
    </section>

    <section class="guest-section" aria-label="Ca trực hôm nay">
      <div class="guest-section-head">
        <div>
          <h2>Ca trực hôm nay</h2>
          <p>Các điểm vận hành quan trọng, cùng nhịp card giống khu Booking gần đây của khách hàng.</p>
        </div>
        <a class="guest-button" href="/frontdesk/direct-booking">Bắt đầu ca trực</a>
      </div>

      <div class="guest-booking-grid">
        <% shiftCards.forEach((card) => { %>
          <article class="guest-booking-card">
            <span class="guest-badge"><%= card.badge %></span>
            <h3><%= card.title %></h3>
            <p><%= card.line1 %></p>
            <p><%= card.line2 %></p>
            <strong><%= card.strong %></strong>
            <div class="guest-booking-actions">
              <a class="guest-button" href="<%= card.href %>"><%= card.action %></a>
            </div>
          </article>
        <% }) %>
      </div>
    </section>
  </div>
</main>

<%- include("../partials/footer") %>
