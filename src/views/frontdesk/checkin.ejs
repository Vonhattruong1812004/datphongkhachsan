  }
  @keyframes checkin-float{from{transform:translate3d(0,0,0) rotate(0)}to{transform:translate3d(24px,20px,0) rotate(14deg)}}
  @media (max-width:900px){.checkin-search-grid{grid-template-columns:1fr}.checkin-search-actions{justify-content:flex-start;padding-bottom:0;white-space:normal}}
</style>

<main class="checkin-shell">
  <section class="checkin-title">
    <div>
      <div class="checkin-chip">Quy trình Check-in · Lễ tân</div>
      <h1>Xác nhận check-in khách hàng</h1>
      <div class="checkin-muted">Tìm giao dịch, đối chiếu CCCD/hộ chiếu gốc, kiểm tra phòng Booked và hoàn tất nhận phòng.</div>
    </div>
    <a class="button" href="/frontdesk">Quay lại trang lễ tân</a>
  </section>

  <% if (notice?.error) { %>
    <div class="checkin-alert checkin-alert--error"><%= notice.error %></div>
  <% } %>
  <% if (notice?.success) { %>
    <div class="checkin-alert checkin-alert--success"><%= notice.success %></div>
  <% } %>
  <div id="clientErrors" class="checkin-alert checkin-alert--error" style="display:none">
    <strong>Có lỗi xảy ra:</strong>
    <ul id="clientErrorsList" style="margin:8px 0 0 18px;padding:0"></ul>
  </div>

  <form method="post" action="/frontdesk/checkin" id="formSearch" class="checkin-card">
    <h2>Tìm kiếm giao dịch để check-in <span class="checkin-tag">Bước 1</span></h2>
    <p class="checkin-muted">Nhập mã giao dịch, CMND/CCCD hoặc số điện thoại của trưởng đoàn/khách trong phòng.</p>
    <div class="checkin-search-grid">
      <div class="checkin-field">
        <label for="search_ma_gd">Mã giao dịch / CMND/CCCD / SĐT</label>
        <input id="search_ma_gd" name="search_ma_gd" value="<%= keyword || "" %>" placeholder="VD: 338, 080909080701 hoặc 0901234567" />
        <div class="checkin-error-msg" id="err_search"></div>
      </div>
      <div class="checkin-search-actions">
        <button class="button button--primary" type="submit" name="btn_action" value="search">Tìm giao dịch</button>
        <button class="button" type="submit" name="btn_action" value="back">Quay lại</button>
      </div>
    </div>
  </form>

  <form method="post" action="/frontdesk/checkin" id="formCheckin" class="checkin-card">
    <h2>Thông tin giao dịch <span class="checkin-tag">Bước 2-3</span></h2>

    <% if (transaction && checkin) { %>
      <input type="hidden" name="ma_giao_dich" value="<%= transaction.maGiaoDich %>" />
      <input type="hidden" name="search_ma_gd" value="<%= keyword || transaction.maGiaoDich %>" />

      <p class="checkin-muted">Chỉ các phòng ở trạng thái <strong>Booked</strong> mới được phép check-in.</p>

      <div class="checkin-row">
        <div class="checkin-field">
          <label>Mã giao dịch</label>
          <input type="text" value="<%= transaction.maGiaoDich %>" disabled />
        </div>
        <div class="checkin-field">
          <label>Trạng thái giao dịch</label>
          <input type="text" value="<%= transaction.trangThai %>" disabled />
        </div>
        <div class="checkin-field">
          <label>Khách sạn / cơ sở</label>
          <input type="text" value="<%= checkin.hotelLabel %>" disabled />
        </div>
      </div>

      <div class="checkin-row">
        <div class="checkin-field">
          <label>Tên trưởng đoàn</label>
          <input type="text" value="<%= checkin.leaderName || "Khách vãng lai" %>" disabled />
        </div>
        <div class="checkin-field">
          <label>CMND/CCCD trưởng đoàn</label>
          <input type="text" value="<%= checkin.leaderCccd || "" %>" disabled />
        </div>
        <div class="checkin-field">
          <label>Số lượng thành viên</label>
          <input type="number" value="<%= checkin.totalGuests || 0 %>" disabled />
        </div>
      </div>

      <div class="checkin-table-wrap">
        <table class="checkin-table">
          <thead>
            <tr>
              <th>Họ tên khách</th>
              <th>CMND/CCCD</th>
              <th>Mã phòng</th>
              <th>Số phòng</th>
              <th>Khách sạn / cơ sở</th>
              <th>Ngày bắt đầu</th>
              <th>Ngày kết thúc</th>
              <th>Trạng thái</th>
              <th style="text-align:center">Check-in</th>
            </tr>
          </thead>
          <tbody>
            <% rooms.forEach((room) => {
              const statusClass = ["Cancelled", "DaHuy"].includes(room.trangThai) ? "checkin-badge--red" : (["CheckedIn", "Stayed"].includes(room.trangThai) ? "checkin-badge--green" : "checkin-badge--blue");
            %>
              <tr>
                <td><%= room.tenKhach || checkin.leaderName || "" %></td>
                <td><%= room.cccd || checkin.leaderCccd || "" %></td>
                <td><%= room.maPhong %></td>
                <td><%= room.soPhong %></td>
                <td><%= [room.hotelName, room.hotelCity].filter(Boolean).join(" · ") || "Chưa phân cơ sở" %></td>
                <td><%= room.ngayNhanLabel %></td>
                <td><%= room.ngayTraLabel %></td>
                <td><span class="checkin-badge <%= statusClass %>"><%= room.trangThai %></span></td>
                <td style="text-align:center">
                  <% if (room.trangThai === "Booked") { %>
                    <input type="checkbox" name="phong_checkin" value="<%= room.maPhong %>" data-booked-room="1" />
                  <% } else { %>
                    -
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="checkin-scope">
        <label>
          <input type="radio" id="check_scope_all" name="check_scope" value="all" checked />
          <span>Check-in toàn bộ phòng đang Booked (<%= checkin.counts?.booked || 0 %> phòng)</span>
        </label>
        <label>
          <input type="radio" id="check_scope_partial" name="check_scope" value="partial" />
          <span>Chỉ check-in các phòng được chọn ở bảng trên</span>
        </label>
      </div>

      <div class="checkin-confirm">
        <label>
          <input type="checkbox" id="xac_nhan_giay_to" name="xac_nhan_giay_to" value="1" />
          <span>Tôi xác nhận đã kiểm tra CCCD/hộ chiếu gốc, thông tin khớp booking và khách đủ điều kiện nhận phòng.</span>
        </label>
      </div>

      <div class="checkin-actions">
        <button type="submit" class="button" name="btn_action" value="abort">Hủy check-in</button>
        <div class="checkin-actions__right">
          <button type="reset" class="button">Làm lại chọn phòng</button>
          <button type="submit" class="button button--primary" name="btn_action" value="confirm">Hoàn tất Check-in</button>
        </div>
      </div>
    <% } else { %>
      <p class="checkin-muted">Chưa có giao dịch nào được chọn. Vui lòng tra cứu giao dịch ở phần trên để hiển thị danh sách phòng và tiến hành check-in.</p>
    <% } %>
  </form>
</main>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const formSearch = document.getElementById("formSearch");
  const searchField = document.getElementById("search_ma_gd");
  const searchError = document.getElementById("err_search");
  const formCheckin = document.getElementById("formCheckin");
  const clientErrors = document.getElementById("clientErrors");
  const clientErrorsList = document.getElementById("clientErrorsList");
  const scopeAll = document.getElementById("check_scope_all");
  const scopePartial = document.getElementById("check_scope_partial");
  const roomChecks = Array.from(document.querySelectorAll('input[name="phong_checkin"][data-booked-room="1"]'));

  function setSearchError(message) {
    if (!searchField || !searchError) return;
    searchField.classList.add("input-error");
    searchError.textContent = message;
  }
  function clearSearchError() {
    if (!searchField || !searchError) return;
    searchField.classList.remove("input-error");
    searchError.textContent = "";
  }
  function validateSearch(fromSubmit) {
    const value = (searchField?.value || "").trim();
    clearSearchError();
    if (!value && fromSubmit) return setSearchError("Vui lòng nhập mã giao dịch, CMND/CCCD hoặc SĐT."), false;
    if (value && !/^\d+$/.test(value)) return setSearchError("Chỉ được nhập số."), false;
    if (value.length > 18) return setSearchError("Tối đa 18 số."), false;
    return true;
  }

  searchField?.addEventListener("input", () => validateSearch(false));
  formSearch?.addEventListener("submit", (event) => {
    if ((event.submitter?.value || "") !== "search") return;
    if (!validateSearch(true)) event.preventDefault();
  });

  function syncRoomSelectionMode() {
    const checkAll = Boolean(scopeAll?.checked);
    roomChecks.forEach((checkbox) => {
      checkbox.checked = checkAll;
      checkbox.disabled = checkAll;
    });
  }

  scopeAll?.addEventListener("change", syncRoomSelectionMode);
  scopePartial?.addEventListener("change", syncRoomSelectionMode);
  formCheckin?.addEventListener("reset", () => window.setTimeout(syncRoomSelectionMode, 0));
  syncRoomSelectionMode();

  function showClientErrors(messages) {
    if (!clientErrors || !clientErrorsList) return;
    clientErrorsList.innerHTML = "";
    messages.forEach((message) => {
      const li = document.createElement("li");
      li.textContent = message;
      clientErrorsList.appendChild(li);
    });
    clientErrors.style.display = "block";
    window.scrollTo({ top: 0, behavior: "smooth" });
  }

  formCheckin?.addEventListener("submit", (event) => {
    if ((event.submitter?.value || "") !== "confirm") return;
    if (clientErrors) clientErrors.style.display = "none";

    const messages = [];
    const identity = document.getElementById("xac_nhan_giay_to");
    const checkedRooms = roomChecks.filter((checkbox) => checkbox.checked);

    if (identity && !identity.checked) {
      messages.push("Vui lòng xác nhận đã kiểm tra giấy tờ.");
    }

    if (scopePartial?.checked && checkedRooms.length === 0) {
      messages.push("Vui lòng chọn ít nhất một phòng để check-in.");
    }

    if (messages.length) {
      event.preventDefault();
      showClientErrors(messages);
    }
  });
});
</script>
<%- include("../partials/footer") %>
