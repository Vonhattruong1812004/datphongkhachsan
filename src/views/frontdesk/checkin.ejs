    overflow:hidden;
    max-width:1220px;
    padding:30px 18px 56px;
    background:
      radial-gradient(circle at 8% 10%, rgba(20,184,166,.26), transparent 26%),
      radial-gradient(circle at 88% 12%, rgba(251,113,133,.18), transparent 28%),
      radial-gradient(circle at 54% 100%, rgba(250,204,21,.14), transparent 30%),
      linear-gradient(135deg,#fbfffb 0%,#ecfff8 36%,#eef8ff 68%,#fff6eb 100%);
    border-radius:34px;
  }
