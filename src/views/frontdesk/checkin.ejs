<%- include("../partials/head") %>
<%- include("../partials/header") %>
<%
  const transaction = payload?.transaction || null;
  const rooms = payload?.rooms || [];
  const checkin = payload?.checkin || null;
%>
<style>
  .checkin-shell{
    --ux-card:rgba(15,23,42,.94);
    --ux-card-soft:rgba(30,41,59,.68);
    --ux-card-strong:rgba(2,6,23,.82);
    --ux-border:rgba(148,163,184,.24);
    --ux-border-strong:rgba(103,200,255,.42);
    --ux-text:#e5e7eb;
    --ux-heading:#f8fafc;
    --ux-muted:#9fb0c8;
    --ux-cyan:#67c8ff;
    --ux-cyan-strong:#0ea5e9;
    --ux-green:#51d0b1;
    --ux-red:#fb7185;
    --ux-amber:#f4c46c;
    --ux-shadow:0 22px 60px rgba(0,0,0,.32);
    max-width:1180px;margin:0 auto;padding:24px 18px 48px
  }
  .checkin-title{display:flex;align-items:flex-start;justify-content:space-between;gap:14px;margin-bottom:18px}
  .checkin-title h1{margin:4px 0 6px;font-size:28px;color:var(--ux-heading)}
  .checkin-shell .button{background:rgba(15,23,42,.88);border-color:var(--ux-border);color:var(--ux-text)}
  .checkin-shell .button:hover{border-color:var(--ux-border-strong);transform:translateY(-1px)}
  .checkin-shell .button--primary{background:linear-gradient(135deg,rgba(14,165,233,.92),rgba(37,99,235,.78));border-color:rgba(103,200,255,.55);color:#f8fafc;box-shadow:0 14px 34px rgba(14,165,233,.22)}
  .checkin-chip{display:inline-flex;align-items:center;gap:6px;padding:5px 11px;border-radius:999px;background:rgba(103,200,255,.12);border:1px solid rgba(103,200,255,.28);color:#bae6fd;font-size:12px;font-weight:800;letter-spacing:.08em;text-transform:uppercase}
  .checkin-muted{color:var(--ux-muted);font-size:13px}
  .checkin-card{background:linear-gradient(180deg,rgba(15,23,42,.96),rgba(8,21,37,.94));border:1px solid var(--ux-border);border-radius:24px;padding:20px;margin-bottom:18px;box-shadow:var(--ux-shadow)}
  .checkin-card h2{margin:0 0 8px;font-size:20px;color:var(--ux-heading)}
  .checkin-tag{display:inline-flex;margin-left:8px;padding:3px 9px;border-radius:999px;background:rgba(103,200,255,.12);border:1px solid rgba(103,200,255,.24);color:#bae6fd;font-size:12px;font-weight:800}
  .checkin-row{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}
  .checkin-field{display:flex;flex-direction:column;gap:6px}
  .checkin-field label{font-size:13px;font-weight:800;color:#cbd5e1}
  .checkin-field input{width:100%;border:1px solid rgba(148,163,184,.28);border-radius:16px;padding:12px 14px;background:rgba(2,6,23,.72);color:var(--ux-heading);font:inherit;outline:none;transition:border-color .16s ease,box-shadow .16s ease,background .16s ease}
  .checkin-field input:focus{border-color:rgba(103,200,255,.62);box-shadow:0 0 0 3px rgba(103,200,255,.12);background:rgba(2,6,23,.9)}
  .checkin-field input[disabled]{background:rgba(15,23,42,.72);color:#cbd5e1}
  .checkin-actions{display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap;margin-top:16px}
  .checkin-actions__right{display:flex;gap:10px;flex-wrap:wrap}
  .checkin-alert{border-radius:18px;padding:12px 14px;margin-bottom:14px}
  .checkin-alert--error{background:rgba(251,113,133,.14);color:#fecdd3;border:1px solid rgba(251,113,133,.36)}
  .checkin-alert--success{background:rgba(81,208,177,.14);color:#bbf7d0;border:1px solid rgba(81,208,177,.36)}
  .checkin-error-msg{font-size:12px;color:#fda4af;min-height:16px}
  .input-error{border-color:rgba(251,113,133,.78)!important;background:rgba(127,29,29,.22)!important}
  .checkin-table-wrap{overflow:auto;border:1px solid var(--ux-border);border-radius:18px;margin-top:12px;background:rgba(2,6,23,.42)}
  .checkin-table{width:100%;border-collapse:collapse;font-size:14px;min-width:980px;background:transparent;color:var(--ux-text)}
  .checkin-table th,.checkin-table td{padding:12px;border-bottom:1px solid rgba(148,163,184,.16);text-align:left;white-space:nowrap}
  .checkin-table th{background:rgba(15,23,42,.92);color:#cbd5e1;font-size:12px;text-transform:uppercase;letter-spacing:.08em}
  .checkin-table tr:last-child td{border-bottom:0}
  .checkin-table tbody tr:hover{background:rgba(103,200,255,.06)}
  .checkin-badge{display:inline-flex;border-radius:999px;padding:4px 9px;background:rgba(103,200,255,.14);color:#bae6fd;border:1px solid rgba(103,200,255,.26);font-size:12px;font-weight:800}
  .badge-green,.checkin-badge--green{background:rgba(81,208,177,.16);color:#bbf7d0;border-color:rgba(81,208,177,.34)}
  .badge-red,.checkin-badge--red{background:rgba(251,113,133,.16);color:#fecdd3;border-color:rgba(251,113,133,.34)}
  .badge-blue,.checkin-badge--blue{background:rgba(103,200,255,.14);color:#bae6fd;border-color:rgba(103,200,255,.26)}
  .badge-slate,.checkin-badge--slate{background:rgba(148,163,184,.16);color:#e2e8f0;border-color:rgba(148,163,184,.26)}
  .checkin-scope{display:grid;gap:10px;margin-top:16px}
  .checkin-scope label,.checkin-confirm label{display:flex;align-items:flex-start;gap:10px;border:1px solid var(--ux-border);border-radius:16px;padding:12px;background:rgba(2,6,23,.46);color:var(--ux-text);cursor:pointer}
  .checkin-scope label:has(input:checked),.checkin-confirm label:has(input:checked){border-color:rgba(103,200,255,.45);background:rgba(14,165,233,.12)}
  .checkin-confirm{display:grid;gap:10px;margin-top:12px}
  .ekyc-panel{border-radius:20px;padding:16px;margin:16px 0;border:1px solid var(--ux-border);background:rgba(2,6,23,.46);color:var(--ux-text)}
  .ekyc-success{background:rgba(81,208,177,.12);border-color:rgba(81,208,177,.34)}
  .ekyc-warning{background:rgba(244,196,108,.12);border-color:rgba(244,196,108,.34)}
  .ekyc-danger{background:rgba(251,113,133,.12);border-color:rgba(251,113,133,.34)}
  .ekyc-pending{background:rgba(148,163,184,.10);border-color:rgba(148,163,184,.24)}
  .ekyc-head{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:8px}
  .ekyc-title{font-weight:900;color:var(--ux-heading)}
  .ekyc-meta{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:8px;margin-top:12px;font-size:12px;color:#cbd5e1}
  .ekyc-note{margin-top:10px;color:var(--ux-muted);font-size:13px;line-height:1.55}
  @media (max-width:900px){.checkin-title,.checkin-actions{flex-direction:column}.checkin-row,.ekyc-meta{grid-template-columns:1fr}.checkin-card{padding:16px}}
</style>
<style>
  body{
    background:
      radial-gradient(circle at 10% 12%, rgba(45,212,191,.24), transparent 24%),
      radial-gradient(circle at 88% 10%, rgba(251,113,133,.16), transparent 26%),
      radial-gradient(circle at 52% 100%, rgba(250,204,21,.16), transparent 28%),
      linear-gradient(160deg,#fffef5 0%,#effffd 32%,#eef8ff 66%,#fff4f8 100%);
    color:#14314b;
  }
  .checkin-shell{
    --ux-card:rgba(255,255,255,.84);
    --ux-card-soft:rgba(255,255,255,.72);
    --ux-card-strong:rgba(255,255,255,.9);
    --ux-border:rgba(19,48,74,.12);
    --ux-border-strong:rgba(14,165,233,.34);
    --ux-text:#14314b;
    --ux-heading:#102033;
    --ux-muted:#5f778f;
    --ux-cyan:#0ea5e9;
    --ux-cyan-strong:#0284c7;
    --ux-green:#10b981;
    --ux-red:#ef476f;
    --ux-amber:#f59e0b;
