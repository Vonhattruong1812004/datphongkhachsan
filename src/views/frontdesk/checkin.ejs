  .checkin-shell::before{top:-210px;right:-120px;background:conic-gradient(from 130deg,rgba(14,165,233,.42),rgba(20,184,166,.32),rgba(250,204,21,.26),rgba(251,113,133,.26),rgba(14,165,233,.42))}
  .checkin-shell::after{left:-180px;bottom:-220px;background:conic-gradient(from 20deg,rgba(251,113,133,.28),rgba(245,158,11,.22),rgba(45,212,191,.24),rgba(59,130,246,.22),rgba(251,113,133,.28));animation-delay:-4s}
  .checkin-title,.checkin-card,.checkin-alert{position:relative;z-index:1}
  .checkin-title h1{color:var(--ux-heading);font-size:34px;letter-spacing:-.05em}
  .checkin-shell .button{background:rgba(255,255,255,.76);border-color:var(--ux-border);color:var(--ux-text);box-shadow:0 14px 32px rgba(12,39,64,.08)}
  .checkin-shell .button--primary{background:linear-gradient(135deg,#0ea5e9,#14b8a6 50%,#22c55e);border-color:transparent;color:#fff;box-shadow:0 18px 38px rgba(20,184,166,.18)}
  .checkin-shell .button:not(.button--primary){background:linear-gradient(135deg,rgba(255,255,255,.94),rgba(242,251,255,.86))}
  .checkin-chip{background:rgba(20,184,166,.12);border-color:rgba(20,184,166,.18);color:#0f766e}
  .checkin-card{background:
      linear-gradient(180deg,rgba(255,255,255,.92),rgba(255,255,255,.76)),
      radial-gradient(circle at 100% 0%, rgba(14,165,233,.1), transparent 34%);
    border-color:var(--ux-border);
    box-shadow:var(--ux-shadow)}
  .checkin-card h2{color:var(--ux-heading);font-size:24px;letter-spacing:-.04em}
  .checkin-tag{background:rgba(14,165,233,.1);border-color:rgba(14,165,233,.16);color:#0c6e90}
  .checkin-field label{color:#173651}
  .checkin-field input{background:rgba(255,255,255,.92);border-color:rgba(19,48,74,.12);color:var(--ux-heading)}
  .checkin-field input[disabled]{background:rgba(255,255,255,.74);color:var(--ux-muted)}
  .checkin-table-wrap,.ekyc-panel{background:rgba(255,255,255,.66);border-color:var(--ux-border)}
  .checkin-table{color:var(--ux-text)}
  .checkin-table th{background:rgba(255,255,255,.84);color:#36506a}
  .checkin-table tbody tr:hover{background:rgba(14,165,233,.06)}
  .checkin-scope label,.checkin-confirm label{background:linear-gradient(180deg,rgba(255,255,255,.82),rgba(246,253,255,.74));border-color:var(--ux-border);color:var(--ux-text)}
  .checkin-scope label:has(input:checked),.checkin-confirm label:has(input:checked){background:rgba(14,165,233,.08);border-color:rgba(14,165,233,.28)}
  .checkin-badge{background:rgba(14,165,233,.1);border-color:rgba(14,165,233,.16);color:#0c6e90}
  .badge-green,.checkin-badge--green{background:rgba(16,185,129,.1);border-color:rgba(16,185,129,.18);color:#047857}
  .badge-red,.checkin-badge--red{background:rgba(239,71,111,.1);border-color:rgba(239,71,111,.18);color:#be123c}
  .badge-slate,.checkin-badge--slate{background:rgba(148,163,184,.12);border-color:rgba(148,163,184,.18);color:#475569}
  .ekyc-success{background:rgba(16,185,129,.08)}
  .ekyc-warning{background:rgba(245,158,11,.08)}
  .ekyc-danger{background:rgba(239,71,111,.08)}
  .ekyc-pending{background:rgba(148,163,184,.08)}
  .checkin-shell{
    background:transparent;
    overflow:visible;
    border-radius:0;
  }
  .checkin-shell::before,.checkin-shell::after{display:none}
  .checkin-card{
    background:rgba(255,255,255,.92);
    border:1px solid rgba(15,23,42,.10);
