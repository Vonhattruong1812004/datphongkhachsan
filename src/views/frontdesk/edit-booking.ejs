<%- include("../partials/head") %>
<%- include("../partials/header") %>
<%
  const transaction = payload?.transaction || null;
  const rooms = payload?.rooms || [];
  const edit = payload?.edit || null;
  const form = edit?.form || {};
  const services = edit?.services || [];
  const availableRooms = edit?.availableRooms || [];
  const promotion = edit?.promotion || { label: "Khong ap dung", value: 0, type: "PERCENT" };
  const money = edit?.money || {};
%>
<style>
  .edit-booking-shell{
    --ux-card:rgba(15,23,42,.94);
    --ux-card-soft:rgba(30,41,59,.68);
    --ux-border:rgba(148,163,184,.24);
    --ux-border-strong:rgba(103,200,255,.42);
    --ux-text:#e5e7eb;
    --ux-heading:#f8fafc;
    --ux-muted:#9fb0c8;
    --ux-cyan:#67c8ff;
    --ux-green:#51d0b1;
    --ux-red:#fb7185;
    --ux-amber:#f4c46c;
    --ux-shadow:0 22px 60px rgba(0,0,0,.32);
    max-width:1180px;margin:0 auto;padding:24px 18px 48px
  }
  .edit-booking-title{display:flex;align-items:flex-start;justify-content:space-between;gap:14px;margin-bottom:18px}
  .edit-booking-title h1{margin:4px 0 6px;font-size:28px;color:var(--ux-heading)}
  .edit-booking-shell .button{background:rgba(15,23,42,.88);border-color:var(--ux-border);color:var(--ux-text)}
  .edit-booking-shell .button:hover{border-color:var(--ux-border-strong);transform:translateY(-1px)}
  .edit-booking-shell .button--primary{background:linear-gradient(135deg,rgba(14,165,233,.92),rgba(37,99,235,.78));border-color:rgba(103,200,255,.55);color:#f8fafc;box-shadow:0 14px 34px rgba(14,165,233,.22)}
  .edit-chip{display:inline-flex;align-items:center;gap:6px;padding:5px 11px;border-radius:999px;background:rgba(103,200,255,.12);border:1px solid rgba(103,200,255,.28);color:#bae6fd;font-size:12px;font-weight:800;letter-spacing:.08em;text-transform:uppercase}
  .edit-muted{color:var(--ux-muted);font-size:13px}
  .edit-card{background:linear-gradient(180deg,rgba(15,23,42,.96),rgba(8,21,37,.94));border:1px solid var(--ux-border);border-radius:24px;padding:20px;margin-bottom:18px;box-shadow:var(--ux-shadow)}
  .edit-card h2{margin:0 0 8px;font-size:20px;color:var(--ux-heading)}
  .edit-card .tag{display:inline-flex;margin-left:8px;padding:3px 9px;border-radius:999px;background:rgba(103,200,255,.12);border:1px solid rgba(103,200,255,.24);color:#bae6fd;font-size:12px;font-weight:800}
  .edit-row{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}
  .edit-row--4{grid-template-columns:repeat(4,minmax(0,1fr))}
  .edit-field{display:flex;flex-direction:column;gap:6px}
  .edit-field label{font-size:13px;font-weight:800;color:#cbd5e1}
  .edit-field input,.edit-field select{width:100%;border:1px solid rgba(148,163,184,.28);border-radius:16px;padding:12px 14px;background:rgba(2,6,23,.72);color:var(--ux-heading);font:inherit;outline:none;transition:border-color .16s ease,box-shadow .16s ease,background .16s ease}
  .edit-field input:focus,.edit-field select:focus{border-color:rgba(103,200,255,.62);box-shadow:0 0 0 3px rgba(103,200,255,.12);background:rgba(2,6,23,.9)}
  .edit-field input[readonly],.edit-field input:disabled{background:rgba(15,23,42,.72);color:#cbd5e1}
  .edit-field select option{background:#0f172a;color:#e5e7eb}
  .edit-actions{display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap;margin-top:16px}
  .edit-actions__right{display:flex;gap:10px;flex-wrap:wrap}
  .edit-alert{border-radius:18px;padding:12px 14px;margin-bottom:14px}
  .edit-alert--error{background:rgba(251,113,133,.14);color:#fecdd3;border:1px solid rgba(251,113,133,.36)}
  .edit-alert--success{background:rgba(81,208,177,.14);color:#bbf7d0;border:1px solid rgba(81,208,177,.36)}
  .edit-error-msg{font-size:12px;color:#fda4af;min-height:16px}
  .input-error{border-color:rgba(251,113,133,.78)!important;background:rgba(127,29,29,.22)!important}
  .edit-table-wrap{overflow:auto;border:1px solid var(--ux-border);border-radius:18px;margin-top:12px;background:rgba(2,6,23,.42)}
  .edit-table{width:100%;border-collapse:collapse;font-size:14px;min-width:760px;background:transparent;color:var(--ux-text)}
  .edit-table th,.edit-table td{padding:12px;border-bottom:1px solid rgba(148,163,184,.16);text-align:left;white-space:nowrap}
  .edit-table th{background:rgba(15,23,42,.92);color:#cbd5e1;font-size:12px;text-transform:uppercase;letter-spacing:.08em}
  .edit-table tr:last-child td{border-bottom:0}
  .edit-table tbody tr:hover{background:rgba(103,200,255,.06)}
  .edit-badge{display:inline-flex;border-radius:999px;padding:4px 9px;background:rgba(103,200,255,.14);color:#bae6fd;border:1px solid rgba(103,200,255,.26);font-size:12px;font-weight:800}
  .edit-badge--red{background:rgba(251,113,133,.16);color:#fecdd3;border-color:rgba(251,113,133,.34)}
  .edit-badge--green{background:rgba(81,208,177,.16);color:#bbf7d0;border-color:rgba(81,208,177,.34)}
  .service-qty{max-width:110px}
  .payment-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}
  @media (max-width:800px){.edit-booking-title,.edit-actions{flex-direction:column}.edit-row,.edit-row--4,.payment-grid{grid-template-columns:1fr}.edit-card{padding:16px}}
</style>
<style>
  body{
    background:
      radial-gradient(circle at 10% 12%, rgba(45,212,191,.24), transparent 24%),
      radial-gradient(circle at 88% 10%, rgba(251,113,133,.16), transparent 26%),
      radial-gradient(circle at 52% 100%, rgba(250,204,21,.16), transparent 28%),
      linear-gradient(160deg,#fffef5 0%,#effffd 32%,#eef8ff 66%,#fff4f8 100%);
    color:#14314b;
  }
  .edit-booking-shell{
    --ux-card:rgba(255,255,255,.84);
    --ux-card-soft:rgba(255,255,255,.72);
    --ux-border:rgba(19,48,74,.12);
    --ux-border-strong:rgba(14,165,233,.34);
    --ux-text:#14314b;
    --ux-heading:#102033;
    --ux-muted:#5f778f;
    --ux-cyan:#0ea5e9;
    --ux-green:#10b981;
    --ux-red:#ef476f;
    --ux-amber:#f59e0b;
    --ux-shadow:0 26px 72px rgba(12,39,64,.14);
    position:relative;
    overflow:hidden;
    max-width:1220px;
    padding:30px 18px 56px;
    background:
      radial-gradient(circle at 8% 10%, rgba(20,184,166,.26), transparent 26%),
      radial-gradient(circle at 88% 12%, rgba(251,113,133,.18), transparent 28%),
      radial-gradient(circle at 54% 100%, rgba(250,204,21,.14), transparent 30%),
      linear-gradient(135deg,#fbfffb 0%,#ecfff8 36%,#eef8ff 68%,#fff6eb 100%);
    border-radius:34px;
  }
  .edit-booking-shell::before,.edit-booking-shell::after{content:"";position:absolute;width:420px;height:420px;border-radius:999px;pointer-events:none;opacity:.44;z-index:0;animation:edit-float 12s ease-in-out infinite alternate}
  .edit-booking-shell::before{top:-210px;right:-120px;background:conic-gradient(from 130deg,rgba(14,165,233,.42),rgba(20,184,166,.32),rgba(250,204,21,.26),rgba(251,113,133,.26),rgba(14,165,233,.42))}
  .edit-booking-shell::after{left:-180px;bottom:-220px;background:conic-gradient(from 20deg,rgba(251,113,133,.28),rgba(245,158,11,.22),rgba(45,212,191,.24),rgba(59,130,246,.22),rgba(251,113,133,.28));animation-delay:-4s}
  .edit-booking-title,.edit-card,.edit-alert{position:relative;z-index:1}
  .edit-booking-title h1{color:var(--ux-heading);font-size:34px;letter-spacing:-.05em}
  .edit-booking-shell .button{background:rgba(255,255,255,.76);border-color:var(--ux-border);color:var(--ux-text);box-shadow:0 14px 32px rgba(12,39,64,.08)}
  .edit-booking-shell .button--primary{background:linear-gradient(135deg,#0ea5e9,#14b8a6 50%,#22c55e);border-color:transparent;color:#fff;box-shadow:0 18px 38px rgba(20,184,166,.18)}
  .edit-booking-shell .button:not(.button--primary){background:linear-gradient(135deg,rgba(255,255,255,.94),rgba(242,251,255,.86))}
  .edit-chip{background:rgba(20,184,166,.12);border-color:rgba(20,184,166,.18);color:#0f766e}
  .edit-card{background:
      linear-gradient(180deg,rgba(255,255,255,.92),rgba(255,255,255,.76)),
      radial-gradient(circle at 100% 0%, rgba(14,165,233,.1), transparent 34%);
    border-color:var(--ux-border);
    box-shadow:var(--ux-shadow)}
  .edit-card h2{color:var(--ux-heading);font-size:24px;letter-spacing:-.04em}
  .edit-card .tag{background:rgba(14,165,233,.1);border-color:rgba(14,165,233,.16);color:#0c6e90}
  .edit-field label{color:#173651}
  .edit-field input,.edit-field select{background:rgba(255,255,255,.92);border-color:rgba(19,48,74,.12);color:var(--ux-heading)}
  .edit-field input[readonly],.edit-field input:disabled{background:rgba(255,255,255,.74);color:var(--ux-muted)}
  .edit-field select option{background:#fff;color:#173651}
  .edit-table-wrap{background:rgba(255,255,255,.66);border-color:var(--ux-border)}
  .edit-table{color:var(--ux-text)}
  .edit-table th{background:rgba(255,255,255,.84);color:#36506a}
  .edit-table tbody tr:hover{background:rgba(14,165,233,.06)}
  .edit-badge{background:rgba(14,165,233,.1);border-color:rgba(14,165,233,.16);color:#0c6e90}
  .edit-badge--green{background:rgba(16,185,129,.1);border-color:rgba(16,185,129,.18);color:#047857}
  .edit-badge--red{background:rgba(239,71,111,.1);border-color:rgba(239,71,111,.18);color:#be123c}
  .edit-card--payment{margin:18px 0 0;padding:18px;background:
      linear-gradient(180deg,rgba(255,255,255,.88),rgba(255,255,255,.72)),
      radial-gradient(circle at 100% 0, rgba(250,204,21,.12), transparent 36%)}
  @keyframes edit-float{from{transform:translate3d(0,0,0) rotate(0)}to{transform:translate3d(24px,20px,0) rotate(14deg)}}
</style>

<main class="edit-booking-shell">
  <section class="edit-booking-title">
    <div>
      <div class="edit-chip">Sửa thông tin đặt phòng · Lễ tân</div>
      <h1>Sửa thông tin đặt phòng</h1>
      <div class="edit-muted">Tìm giao dịch, chọn đúng phòng, chỉnh thông tin trưởng đoàn/phòng/dịch vụ và lưu lại.</div>
    </div>
    <a class="button" href="/frontdesk">Quay lại trang lễ tân</a>
  </section>

  <% if (notice?.error) { %>
    <div class="edit-alert edit-alert--error"><%= notice.error %></div>
  <% } %>
  <% if (notice?.success) { %>
    <div class="edit-alert edit-alert--success"><%= notice.success %></div>
  <% } %>
  <div id="clientErrors" class="edit-alert edit-alert--error" style="display:none">
    <strong>Có lỗi xảy ra:</strong>
    <ul id="clientErrorsList" style="margin:8px 0 0 18px;padding:0"></ul>
  </div>

  <form method="post" action="/frontdesk/edit-booking" id="formSearch" class="edit-card">
    <h2>Tìm kiếm giao dịch <span class="tag">Bước 1</span></h2>
    <p class="edit-muted">Nhập mã giao dịch hoặc CMND/CCCD trưởng đoàn.</p>
    <div class="edit-row">
      <div class="edit-field">
        <label for="search_keyword">Mã giao dịch / CMND/CCCD</label>
        <input id="search_keyword" name="search_keyword" value="<%= keyword || "" %>" placeholder="VD: 1 hoặc 012345678901" />
        <div class="edit-error-msg" id="err_search_keyword"></div>
      </div>
      <div class="edit-field" style="justify-content:flex-end">
        <div class="edit-actions" style="margin-top:0;justify-content:flex-start">
          <button class="button button--primary" type="submit" name="btn_action" value="search">Tìm kiếm</button>
          <button class="button" type="submit" name="btn_action" value="cancel">Hủy thao tác</button>
        </div>
      </div>
    </div>
  </form>

  <form method="post" action="/frontdesk/edit-booking" id="formEditBooking" class="edit-card">
    <h2>Thông tin đặt phòng hiện tại <span class="tag">Bước 2</span></h2>

    <% if (transaction && edit) { %>
      <input type="hidden" name="ma_giao_dich" value="<%= transaction.maGiaoDich %>" />
      <input type="hidden" name="ma_phong_cu" value="<%= form.maPhongCu %>" />
      <input type="hidden" name="search_keyword" value="<%= keyword || transaction.maGiaoDich %>" />
      <input type="hidden" id="km_giatri" value="<%= promotion.value || 0 %>" />
      <input type="hidden" id="km_type" value="<%= promotion.type || "PERCENT" %>" />

      <div class="edit-row">
        <div class="edit-field">
          <label>Tổng tiền hiện tại</label>
          <input type="text" value="<%= transaction.tongTienFormatted %>" readonly />
        </div>
        <div class="edit-field">
          <label>Khuyến mãi áp dụng</label>
          <input type="text" value="<%= promotion.label %>" readonly />
          <span class="edit-muted">Tiền giảm realtime tính theo khuyến mãi đang gắn với giao dịch.</span>
        </div>
      </div>

      <div class="edit-row">
        <div class="edit-field">
          <label>Mã giao dịch</label>
          <input type="text" value="<%= transaction.maGiaoDich %>" disabled />
        </div>
        <div class="edit-field">
          <label>Trạng thái giao dịch</label>
          <input type="text" value="<%= transaction.trangThai %>" disabled />
        </div>
      </div>

      <div class="edit-row">
        <div class="edit-field">
          <label for="ten_kh">Họ tên trưởng đoàn *</label>
          <input id="ten_kh" name="ten_kh" value="<%= form.tenKhach || "" %>" />
          <div class="edit-error-msg" id="err_ten_kh"></div>
        </div>
        <div class="edit-field">
          <label for="cccd">CMND/CCCD *</label>
          <input id="cccd" name="cccd" value="<%= form.cccd || "" %>" />
          <div class="edit-error-msg" id="err_cccd"></div>
        </div>
      </div>

      <div class="edit-row">
        <div class="edit-field">
          <label for="sdt">Số điện thoại *</label>
          <input id="sdt" name="sdt" value="<%= form.sdt || "" %>" />
          <div class="edit-error-msg" id="err_sdt"></div>
        </div>
        <div class="edit-field">
          <label for="email">Email *</label>
          <input id="email" name="email" value="<%= form.email || "" %>" />
          <div class="edit-error-msg" id="err_email"></div>
        </div>
      </div>

      <div class="edit-row edit-row--4">
        <div class="edit-field">
          <label for="ngay_den">Ngày đến *</label>
          <input type="date" id="ngay_den" name="ngay_den" value="<%= form.ngayDen || "" %>" />
          <div class="edit-error-msg" id="err_ngay_den"></div>
        </div>
        <div class="edit-field">
          <label for="ngay_di">Ngày đi *</label>
          <input type="date" id="ngay_di" name="ngay_di" value="<%= form.ngayDi || "" %>" />
          <div class="edit-error-msg" id="err_ngay_di"></div>
        </div>
        <div class="edit-field">
          <label>Số đêm</label>
          <input type="text" id="so_dem" value="0" readonly />
        </div>
        <div class="edit-field">
          <label for="so_nguoi">Số người *</label>
          <input type="number" min="1" id="so_nguoi" name="so_nguoi" value="<%= form.soNguoi || 1 %>" />
          <div class="edit-error-msg" id="err_so_nguoi"></div>
        </div>
      </div>

      <div class="edit-row">
        <div class="edit-field">
          <label for="ma_phong">Phòng *</label>
          <select id="ma_phong" name="ma_phong">
            <option value="">-- Chọn phòng --</option>
            <% availableRooms.forEach((room) => { %>
              <option value="<%= room.maPhong %>" data-dongia="<%= room.gia %>" <%= room.maPhong === form.maPhong ? "selected" : "" %>>
                <%= room.soPhong %> - <%= room.loaiPhong %> - <%= room.giaFormatted %>
              </option>
            <% }) %>
          </select>
          <div class="edit-error-msg" id="err_ma_phong"></div>
        </div>
      </div>

      <% if (services.length) { %>
        <h2 style="margin-top:18px">Dịch vụ đã đặt</h2>
        <p class="edit-muted">Đổi số lượng sẽ tự tính tiền ngay. Đặt 0 để xóa dịch vụ khỏi giao dịch.</p>
        <div class="edit-table-wrap">
          <table class="edit-table">
            <thead>
              <tr>
                <th>Dịch vụ</th>
                <th>Đơn giá</th>
                <th>Số lượng</th>
                <th>Thành tiền</th>
              </tr>
            </thead>
            <tbody>
              <% services.forEach((service) => { %>
                <tr>
                  <td><%= service.tenDichVu %></td>
                  <td><%= service.giaBanFormatted %></td>
                  <td>
                    <input
                      type="number"
                      min="0"
                      class="service-qty serviceQty"
                      name="services[<%= service.maDichVu %>]"
                      value="<%= service.soLuong %>"
                      data-madv="<%= service.maDichVu %>"
                      data-dongia="<%= service.giaBan %>"
                    />
                    <input type="checkbox" class="serviceRemove" name="remove_services[]" value="<%= service.maDichVu %>" style="display:none" />
                  </td>
                  <td class="serviceLineTotal" data-madv="<%= service.maDichVu %>"><%= service.thanhTienFormatted %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>

      <section class="edit-card edit-card--payment">
        <h2>Thông tin thanh toán <span class="tag">Tự động tính</span></h2>
        <div class="payment-grid">
          <div class="edit-field"><label>Đơn giá phòng</label><input type="text" id="view_dongia_phong" value="<%= money.donGiaHienTaiFormatted || "0 đ" %>" readonly /></div>
          <div class="edit-field"><label>Tổng tiền phòng</label><input type="text" id="view_tong_phong" value="<%= money.tongPhongFormatted || "0 đ" %>" readonly /></div>
          <div class="edit-field"><label>Tổng tiền dịch vụ</label><input type="text" id="view_tong_dv" value="<%= money.tongDVFormatted || "0 đ" %>" readonly /></div>
          <div class="edit-field"><label>Tổng trước giảm</label><input type="text" id="view_tong_truoc_giam" value="<%= money.tongTruocGiamFormatted || "0 đ" %>" readonly /></div>
          <div class="edit-field"><label>Tiền giảm</label><input type="text" id="view_tien_giam" value="<%= money.tienGiamFormatted || "0 đ" %>" readonly /></div>
          <div class="edit-field"><label>THÀNH TIỀN</label><input type="text" id="view_thanh_tien" value="<%= money.thanhTienFormatted || "0 đ" %>" readonly style="font-weight:900" /></div>
        </div>
      </section>

      <div class="edit-actions">
        <button type="reset" class="button">Làm lại</button>
        <div class="edit-actions__right">
          <button type="submit" class="button" name="btn_action" value="cancel">Hủy thao tác</button>
          <button type="submit" class="button button--primary" name="btn_action" value="save">Lưu thông tin</button>
        </div>
      </div>
    <% } else { %>
      <p class="edit-muted">Chưa có giao dịch nào được chọn. Vui lòng tìm kiếm ở phần trên.</p>
    <% } %>
  </form>

  <% if (transaction && rooms.length) { %>
    <section class="edit-card">
      <h2>Danh sách chi tiết giao dịch</h2>
      <p class="edit-muted">Chọn đúng phòng cần sửa rồi bấm “Sửa phòng này” để load form theo phòng đó.</p>
      <div class="edit-table-wrap">
        <table class="edit-table">
          <thead>
            <tr>
              <th>Mã phòng</th>
              <th>Số phòng</th>
              <th>Loại phòng</th>
              <th>Ngày bắt đầu</th>
              <th>Ngày kết thúc</th>
              <th>Số người</th>
              <th>Trạng thái</th>
              <th>Thao tác</th>
            </tr>
          </thead>
          <tbody>
            <% rooms.forEach((room) => {
              const badgeClass = room.trangThai === "Cancelled" || room.trangThai === "DaHuy" ? "edit-badge--red" : (["CheckedIn", "Stayed"].includes(room.trangThai) ? "edit-badge--green" : "");
            %>
              <tr>
                <td><%= room.maPhong %></td>
                <td><%= room.soPhong %></td>
                <td><%= room.loaiPhong %></td>
                <td><%= room.ngayNhanLabel %></td>
                <td><%= room.ngayTraLabel %></td>
                <td><%= room.soNguoi || 0 %></td>
                <td><span class="edit-badge <%= badgeClass %>"><%= room.trangThai %></span></td>
                <td>
                  <form method="post" action="/frontdesk/edit-booking" style="display:inline">
                    <input type="hidden" name="search_keyword" value="<%= keyword || transaction.maGiaoDich %>" />
                    <input type="hidden" name="ma_giao_dich" value="<%= transaction.maGiaoDich %>" />
                    <input type="hidden" name="ma_phong_cu" value="<%= room.maPhong %>" />
                    <button class="button" type="submit" name="btn_action" value="pick_room">Sửa phòng này</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  <% } %>
</main>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const formSearch = document.getElementById("formSearch");
  const searchField = document.getElementById("search_keyword");
  const searchErr = document.getElementById("err_search_keyword");

  function setSearchError(msg) {
    if (!searchField || !searchErr) return;
    searchField.classList.add("input-error");
    searchErr.textContent = msg;
  }
  function clearSearchError() {
    if (!searchField || !searchErr) return;
    searchField.classList.remove("input-error");
    searchErr.textContent = "";
  }
  function validateSearch(fromSubmit) {
    const value = (searchField?.value || "").trim();
    clearSearchError();
    if (!value && fromSubmit) return setSearchError("Vui lòng nhập mã giao dịch hoặc CMND/CCCD."), false;
    if (value && !/^\d+$/.test(value)) return setSearchError("Chỉ được nhập số."), false;
    if (value.length > 12) return setSearchError("Tối đa 12 số."), false;
    return true;
  }

  searchField?.addEventListener("input", () => validateSearch(false));
  formSearch?.addEventListener("submit", (event) => {
    if ((event.submitter?.value || "") !== "search") return;
    if (!validateSearch(true)) event.preventDefault();
  });

  const formEdit = document.getElementById("formEditBooking");
  const clientErrors = document.getElementById("clientErrors");
  const clientErrorsList = document.getElementById("clientErrorsList");
  const fields = {
    ten_kh: document.getElementById("ten_kh"),
    cccd: document.getElementById("cccd"),
    sdt: document.getElementById("sdt"),
    email: document.getElementById("email"),
    ngay_den: document.getElementById("ngay_den"),
    ngay_di: document.getElementById("ngay_di"),
    so_nguoi: document.getElementById("so_nguoi"),
    ma_phong: document.getElementById("ma_phong")
  };
  const errors = {
    ten_kh: document.getElementById("err_ten_kh"),
    cccd: document.getElementById("err_cccd"),
    sdt: document.getElementById("err_sdt"),
    email: document.getElementById("err_email"),
    ngay_den: document.getElementById("err_ngay_den"),
    ngay_di: document.getElementById("err_ngay_di"),
    so_nguoi: document.getElementById("err_so_nguoi"),
    ma_phong: document.getElementById("err_ma_phong")
  };

  function setError(name, msg) {
    fields[name]?.classList.add("input-error");
    if (errors[name]) errors[name].textContent = msg;
  }
  function clearError(name) {
    fields[name]?.classList.remove("input-error");
    if (errors[name]) errors[name].textContent = "";
  }
  function validateDates() {
    clearError("ngay_den");
    clearError("ngay_di");
    const d1 = fields.ngay_den?.value || "";
    const d2 = fields.ngay_di?.value || "";
    if (!d1) setError("ngay_den", "Chọn ngày đến.");
    if (!d2) setError("ngay_di", "Chọn ngày đi.");
    if (d1 && d2 && new Date(d2) <= new Date(d1)) {
      setError("ngay_di", "Ngày đi phải lớn hơn ngày đến.");
    }
  }
  function validateField(name) {
    clearError(name);
    const value = (fields[name]?.value || "").trim();
    if (name === "ten_kh" && (!value || value.length < 2 || /\d/.test(value))) setError(name, "Họ tên không hợp lệ.");
    if (name === "cccd" && !/^\d{9,12}$/.test(value)) setError(name, "Chỉ 9-12 số.");
    if (name === "sdt" && !/^0\d{8,10}$/.test(value)) setError(name, "Số điện thoại không hợp lệ.");
    if (name === "email" && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value)) setError(name, "Email không hợp lệ.");
    if (name === "ngay_den" || name === "ngay_di") validateDates();
    if (name === "so_nguoi" && (!value || Number(value) <= 0)) setError(name, "Số người > 0.");
    if (name === "ma_phong" && !value) setError(name, "Hãy chọn phòng.");
  }
  Object.keys(fields).forEach((name) => {
    fields[name]?.addEventListener("input", () => validateField(name));
    fields[name]?.addEventListener("change", () => validateField(name));
  });

  function money(value) {
    return Math.round(Number(value || 0)).toLocaleString("vi-VN") + " đ";
  }
  function calcNights() {
    const d1 = fields.ngay_den?.value || "";
    const d2 = fields.ngay_di?.value || "";
    if (!d1 || !d2) return 0;
    return Math.max(0, Math.floor((new Date(d2) - new Date(d1)) / 86400000));
  }
  function updateServices() {
    let total = 0;
    document.querySelectorAll(".serviceQty").forEach((input) => {
      const qty = Number(input.value || 0);
      const price = Number(input.dataset.dongia || 0);
      const id = input.dataset.madv;
      total += qty * price;
      const line = document.querySelector('.serviceLineTotal[data-madv="' + id + '"]');
      if (line) line.textContent = money(qty * price);
      const remove = document.querySelector('.serviceRemove[value="' + id + '"]');
      if (remove) remove.checked = qty === 0;
    });
    return total;
  }
  function updateMoney() {
    validateDates();
    const nights = calcNights();
    const soDem = document.getElementById("so_dem");
    if (soDem) soDem.value = String(nights);
    const selected = fields.ma_phong?.selectedOptions?.[0];
    const roomPrice = Number(selected?.dataset?.dongia || 0);
    const roomTotal = nights * roomPrice;
    const serviceTotal = updateServices();
    const beforeDiscount = roomTotal + serviceTotal;
    const kmValue = Number(document.getElementById("km_giatri")?.value || 0);
    const kmType = String(document.getElementById("km_type")?.value || "PERCENT").toUpperCase();
    const discount = kmValue > 0
      ? (kmType === "FIXED" || kmValue >= 100 ? Math.min(kmValue, beforeDiscount) : beforeDiscount * kmValue / 100)
      : 0;
    const finalTotal = Math.max(0, beforeDiscount - discount);
    const view = {
      dgPhong: document.getElementById("view_dongia_phong"),
      tongPhong: document.getElementById("view_tong_phong"),
      tongDV: document.getElementById("view_tong_dv"),
      tongTruocGiam: document.getElementById("view_tong_truoc_giam"),
      tienGiam: document.getElementById("view_tien_giam"),
      thanhTien: document.getElementById("view_thanh_tien")
    };
    if (view.dgPhong) view.dgPhong.value = money(roomPrice);
    if (view.tongPhong) view.tongPhong.value = money(roomTotal);
    if (view.tongDV) view.tongDV.value = money(serviceTotal);
    if (view.tongTruocGiam) view.tongTruocGiam.value = money(beforeDiscount);
    if (view.tienGiam) view.tienGiam.value = money(discount);
    if (view.thanhTien) view.thanhTien.value = money(finalTotal);
  }
  document.addEventListener("input", (event) => {
    if (event.target?.classList?.contains("serviceQty") || event.target === fields.ngay_den || event.target === fields.ngay_di) updateMoney();
  });
  fields.ma_phong?.addEventListener("change", updateMoney);
  updateMoney();

  formEdit?.addEventListener("submit", (event) => {
    if ((event.submitter?.value || "") !== "save") return;
    if (clientErrors) clientErrors.style.display = "none";
    if (clientErrorsList) clientErrorsList.innerHTML = "";
    Object.keys(fields).forEach(validateField);
    const list = Object.values(errors).map((item) => item?.textContent || "").filter(Boolean);
    if (list.length) {
      event.preventDefault();
      list.forEach((msg) => {
        const li = document.createElement("li");
        li.textContent = msg;
        clientErrorsList?.appendChild(li);
      });
      if (clientErrors) clientErrors.style.display = "block";
      window.scrollTo({ top: 0, behavior: "smooth" });
    }
  });
});
</script>
<%- include("../partials/footer") %>
