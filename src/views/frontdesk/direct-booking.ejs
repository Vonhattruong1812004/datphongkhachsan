    }

    .customer-mode-tabs {
      border-color: rgba(255, 255, 255, 0.30);
      background: rgba(15, 23, 42, 0.20);
    }

    .customer-mode-tab {
      color: rgba(255, 255, 255, 0.86);
    }

    .customer-mode-tab.is-active {
      color: #0f2f44;
      background: #ffffff;
      box-shadow: 0 14px 30px rgba(15, 23, 42, 0.16);
    }

    input,
    select,
    td input,
    td select {
      color: #0f2f44;
      background: #ffffff !important;
      border-color: rgba(15, 23, 42, 0.36);
      box-shadow:
        0 0 0 4px rgba(255, 255, 255, 0.78),
        0 8px 0 rgba(15, 23, 42, 0.12),
        0 16px 30px rgba(15, 23, 42, 0.16);
    }

    input[readonly] {
      color: #40586b;
      background: #f8fafc !important;
    }

    .room-list {
      border-color: rgba(255, 255, 255, 0.38);
      background: #ffffff;
      box-shadow: 0 18px 44px rgba(15, 23, 42, 0.18);
    }

    .service-room-list {
      overflow: hidden;
    }

    .service-table {
      table-layout: fixed;
      width: 100%;
    }

    .service-table th,
    .service-table td {
      padding: 14px 12px;
      line-height: 1.2;
      overflow-wrap: anywhere;
    }

    .service-table th:nth-child(1),
    .service-table td:nth-child(1) {
      width: 22%;
    }

    .service-table th:nth-child(2),
    .service-table td:nth-child(2) {
      width: 24%;
    }

    .service-table th:nth-child(3),
    .service-table td:nth-child(3) {
      width: 23%;
    }

    .service-table th:nth-child(4),
    .service-table td:nth-child(4) {
      width: 31%;
    }

    .service-table .js-service-qty,
    .service-table .js-service-room {
      width: 100% !important;
      min-width: 0;
      max-width: 100%;
      margin: 0;
    }

    .service-table .js-service-qty {
      text-align: left;
    }

    .service-table .js-service-room {
      padding-left: 10px;
      padding-right: 28px;
      white-space: nowrap;
    }

    .room-list table {
      color: #14354b;
    }

    .room-list th {
      color: #173651;
      background: #eaf6ff;
    }

    .room-list td {
      background: #ffffff;
    }

    .totals {
      color: #064e3b;
      border-color: rgba(255, 255, 255, 0.48);
      background:
        linear-gradient(135deg, #bef264 0%, #34d399 52%, #14b8a6 100%) !important;
      box-shadow:
        inset 0 0 0 1px rgba(255, 255, 255, 0.24),
        0 22px 48px rgba(16, 185, 129, 0.28);
    }

    .totals .grand-total,
    .totals .grand-total strong {
      color: #052e24 !important;
      text-shadow: none;
    }

    @media (max-width: 720px) {
      label {
        display: block;
      }
      label .note {
        display: block;
        max-width: none;
        margin-top: 4px;
        text-align: left;
      }
      .section-title span {
        max-width: none;
        margin: 8px 0 0;
      }
    }

    @media (max-width: 980px) {
      .grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 720px) {
      .topbar-inner, .container { padding-left: 12px; padding-right: 12px; }
      .page-header { flex-direction: column; }
      .card { padding: 20px; border-radius: 24px; }
      .card-title { font-size: 20px; }
      .section-title { display: block; }
      .section-title::before { display: inline-block; margin-right: 8px; vertical-align: middle; }
      .row { grid-template-columns: 1fr; }
      .button-row { align-items: stretch; }
      .button-group { width: 100%; }
      .button, .button-secondary, .button-link { width: 100%; }
      table { display: block; overflow-x: auto; white-space: nowrap; }
      .service-room-list { overflow-x: auto; }
      .service-table { min-width: 560px; }
    }
  </style>
</head>
<body>
  <div class="system-galaxy-background" aria-hidden="true">
    <span class="system-galaxy-comet system-galaxy-comet--one"></span>
    <span class="system-galaxy-comet system-galaxy-comet--two"></span>
    <span class="system-galaxy-comet system-galaxy-comet--three"></span>
    <span class="system-galaxy-comet system-galaxy-comet--four"></span>
  </div>
  <header class="topbar">
    <div class="topbar-inner">
      <div class="brand">
        <div class="brand-logo">BB</div>
        <div>
          <div class="brand-title">Bento Booking</div>
          <div class="brand-subtitle">Bảng điều khiển · Lễ tân</div>
        </div>
      </div>
      <div class="topbar-right">
        <div class="topbar-clock" aria-label="Đồng hồ và lịch">
          <span id="directBookingDate">--/--/----</span>
          <strong id="directBookingTime">--:--:--</strong>
        </div>
        <div class="user-pill">Đang đăng nhập · <strong><%= userName %></strong></div>
        <a class="nav-link" href="/frontdesk">Trang lễ tân</a>
        <a class="nav-link logout" href="/auth/logout">Đăng xuất</a>
      </div>
    </div>
  </header>

  <main class="container">
    <section class="page-header">
      <div>
        <div class="page-chip">Đặt phòng trực tiếp V2 · Lễ tân</div>
        <h1>Đặt phòng tại quầy</h1>
      </div>
    </section>

    <% if (error) { %>
      <section class="alert alert-error"><strong>Có lỗi xảy ra:</strong><div><%= error %></div></section>
    <% } %>

    <% if (success) { %>
      <section
        id="paymentHoldAlert"
        class="alert <%= paymentPending ? 'alert-warning' : 'alert-success' %>"
        data-payment-expires-at="<%= result?.expiresAt || '' %>"
        data-payment-hold-id="<%= result?.holdId || '' %>"
      >
        <strong><%= success %></strong>
        <% if (result) { %>
          <div><%= paymentPending ? `Mã giữ chỗ #${result.holdId}` : `Mã giao dịch #${result.transactionId}` %> · Tổng tiền <%= result.totalFormatted %></div>
          <% if (result.paymentTransfer) { %>
            <div id="paymentQrBlock" style="margin-top:12px;display:grid;grid-template-columns:112px minmax(0,1fr);gap:14px;align-items:center;">
              <img src="<%= result.paymentTransfer.qrImageUrl %>" alt="QR cọc SePay" style="width:112px;height:112px;border-radius:16px;background:#fff;border:1px solid rgba(15,23,42,.12);padding:6px;" />
              <div>
                <div><strong>Tiền phòng:</strong> <%= result.roomAmountFormatted %> · <strong>Dịch vụ:</strong> <%= result.serviceAmountFormatted %></div>
                <div><strong>Khuyến mãi:</strong> - <%= result.discountAmountFormatted %> · <strong>Tổng hóa đơn:</strong> <%= result.totalFormatted %></div>
                <div><strong>Cọc 50%:</strong> <%= result.depositAmountFormatted %></div>
                <div><strong>Nội dung:</strong> <code><%= result.paymentTransfer.content %></code></div>
                <div><strong>Hạn giữ phòng:</strong> <span id="paymentCountdown"><%= result.paymentTransfer.expiresInMinutes %>:00</span></div>
                <div><%= result.paymentTransfer.bankName %> · <%= result.paymentTransfer.accountNo %> · <%= result.paymentTransfer.accountName %></div>
                <div><strong>Trạng thái:</strong> <span id="paymentStatusLine">Đang chờ SePay xác nhận cọc.</span></div>
              </div>
            </div>
            <div id="paymentSuccessDetails" style="display:none;margin-top:12px;"></div>
          <% } %>
        <% } %>
      </section>
    <% } %>

    <% if (createdAccounts.length) { %>
      <section class="card" style="margin-bottom:16px;">
        <div class="card-header">
          <h2 class="card-title">Tài khoản vừa tạo</h2>
          <div class="card-tag">Hoàn tất</div>
        </div>
        <p class="caption">Hệ thống đã tạo tài khoản cho trưởng đoàn và các thành viên đi cùng trong booking này.</p>
        <div class="room-list">
          <table>
            <thead>
              <tr>
                <th>Họ tên</th>
                <th>Username</th>
                <th>Password</th>
                <th>Vai trò</th>
              </tr>
            </thead>
            <tbody>
              <% createdAccounts.forEach((account) => { %>
                <tr>
                  <td><%= account.hoTen %></td>
                  <td><strong><%= account.username %></strong></td>
                  <td><%= account.password %></td>
                  <td><%= account.vaiTro %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    <% } %>

    <div id="clientErrors" class="alert alert-error" style="display:none;">
      <strong>Có lỗi phía trình duyệt:</strong>
      <ul id="clientErrorsList"></ul>
    </div>

    <form method="post" action="/frontdesk/direct-booking" id="formDatPhongV2">
      <input type="hidden" id="services_json" name="services_json" value="" />
      <input type="hidden" id="customer_mode" name="customer_mode" value="<%= form.customer_mode || 'new' %>" />
      <input type="hidden" id="existing_customer_id" name="existing_customer_id" value="<%= form.existing_customer_id || '' %>" />
      <div class="grid">
        <section class="card">
          <div class="card-header">
            <h2 class="card-title">Trưởng đoàn & thông tin booking</h2>
            <div class="card-tag">Bước 1</div>
          </div>
          <p class="caption">Thông tin trưởng đoàn dùng để liên hệ, tạo tài khoản và gắn vào booking.</p>
          <div class="divider"></div>

          <div class="customer-mode-tabs" role="tablist" aria-label="Chọn loại khách hàng">
            <button class="customer-mode-tab <%= form.customer_mode === 'existing' ? 'is-active' : '' %>" type="button" data-customer-mode-tab="existing">Khách hàng cũ</button>
            <button class="customer-mode-tab <%= form.customer_mode !== 'existing' ? 'is-active' : '' %>" type="button" data-customer-mode-tab="new">Khách hàng mới</button>
          </div>

          <div class="customer-mode-panel <%= form.customer_mode === 'existing' ? 'is-active' : '' %>" id="existingCustomerPanel">
            <div class="section-title">Tra cứu khách cũ <span>Chọn hồ sơ để không tạo trùng khách hàng/tài khoản</span></div>
            <div class="customer-lookup-row">
              <div class="field" style="margin-bottom:0;">
                <label for="existingCustomerKeyword">SĐT / CCCD / email / tên</label>
                <input id="existingCustomerKeyword" type="search" placeholder="Nhập ít nhất 2 ký tự..." autocomplete="off" />
              </div>
              <button class="button-secondary" type="button" id="btnLookupExistingCustomer">Tìm khách</button>
            </div>
            <div class="customer-results" id="existingCustomerResults"></div>
            <div class="customer-selected-card <%= form.customer_mode === 'existing' && form.existing_customer_id ? 'is-visible' : '' %>" id="selectedCustomerCard">
              <strong>Đã chọn khách hàng cũ</strong>
              <span id="selectedCustomerText">Hồ sơ #<%= form.existing_customer_id || '' %> sẽ được dùng làm trưởng đoàn.</span>
            </div>
          </div>

          <div class="customer-mode-panel <%= form.customer_mode !== 'existing' ? 'is-active' : '' %>" id="newCustomerPanel">
            <div class="section-title">Khách hàng mới <span>Nhập hồ sơ mới, hệ thống sẽ tạo khách/tài khoản sau khi thanh toán cọc</span></div>
            <p class="caption">Nếu khách đã từng lưu trú, hãy chuyển sang tab khách hàng cũ để tránh trùng CCCD, email hoặc tài khoản.</p>
          </div>

          <div class="field">
            <label>Họ tên trưởng đoàn <span class="note">Bắt buộc</span></label>
            <input id="leader_ten_kh" name="leader_ten_kh" value="<%= form.leader_ten_kh %>" placeholder="Nguyen Van A" />
            <div class="error-msg" id="err_leader_ten_kh"></div>
          </div>

          <div class="row">
            <div class="field">
              <label>CCCD trưởng đoàn <span class="note">9-12 chữ số</span></label>
              <input id="leader_cccd" name="leader_cccd" value="<%= form.leader_cccd %>" placeholder="012345678901" />
              <div class="error-msg" id="err_leader_cccd"></div>
            </div>
            <div class="field">
              <label>Số điện thoại <span class="note">Bắt đầu bằng 0</span></label>
              <input id="leader_sdt" name="leader_sdt" value="<%= form.leader_sdt %>" placeholder="0900000000" />
              <div class="error-msg" id="err_leader_sdt"></div>
            </div>
          </div>

          <div class="row">
            <div class="field">
              <label>Email <span class="note">Bắt buộc</span></label>
              <input id="leader_email" type="email" name="leader_email" value="<%= form.leader_email %>" placeholder="leader@example.com" />
              <div class="error-msg" id="err_leader_email"></div>
            </div>
            <div class="field">
              <label>Địa chỉ <span class="note">Không bắt buộc</span></label>
              <input name="leader_diachi" value="<%= form.leader_diachi %>" placeholder="Dia chi lien he" />
            </div>
          </div>

          <div class="section-title">Thông tin đặt phòng <span>Tìm phòng trước, sau đó mới chốt booking</span></div>

          <div class="row">
            <div class="field">
              <label>Ngày đến</label>
              <input id="ngay_den" type="date" name="ngay_den" value="<%= form.ngay_den %>" />
              <div class="error-msg" id="err_ngay_den"></div>
            </div>
            <div class="field">
              <label>Ngày đi</label>
              <input id="ngay_di" type="date" name="ngay_di" value="<%= form.ngay_di %>" />
              <div class="error-msg" id="err_ngay_di"></div>
            </div>
          </div>

          <div class="row">
            <div class="field">
              <label>Số đêm</label>
              <input id="so_dem_display" value="<%= form.so_dem || '' %>" readonly />
              <input id="so_dem" type="hidden" name="so_dem" value="<%= form.so_dem || '' %>" />
            </div>
            <div class="field">
              <label>Số khách ước tính</label>
              <input id="so_nguoi" type="number" min="1" name="so_nguoi" value="<%= form.so_nguoi %>" />
              <div class="error-msg" id="err_so_nguoi"></div>
            </div>
          </div>

          <div class="row">
            <div class="field">
              <label>Khuyến mãi</label>
              <select name="ma_khuyen_mai" id="ma_khuyen_mai">
                <option value="">-- Không áp dụng --</option>
                <% payload.promotions.forEach((promotion) => { %>
                  <option
                    value="<%= promotion.id %>"
                    data-discount-type="<%= promotion.loaiUuDai %>"
                    data-discount-value="<%= promotion.mucUuDai %>"
                    <%= String(form.ma_khuyen_mai) === String(promotion.id) ? "selected" : "" %>
                  >
                    <%= promotion.tenChuongTrinh %> · <%= promotion.loaiUuDai %> · <%= promotion.mucUuDai %>
                  </option>
                <% }) %>
              </select>
            </div>
            <div class="field">
              <label>Ghi chú chung</label>
              <input name="ghichu" value="<%= form.ghichu %>" placeholder="Yeu cau dac biet, luu y booking..." />
            </div>
          </div>

          <div class="button-row">
            <span></span>
            <div class="button-group">
              <a class="button-link" href="/frontdesk/direct-booking">Làm mới</a>
              <button class="button-secondary" type="submit" name="btn_action" value="search">Tìm phòng phù hợp</button>
            </div>
          </div>
        </section>

        <section class="card">
          <div class="card-header">
            <h2 class="card-title">Phòng, khách theo phòng và dịch vụ</h2>
            <div class="card-tag">Bước 2-3</div>
          </div>
          <p class="caption">
            Chọn ít nhất một phòng sau khi tìm kiếm. Nếu khách ở từng phòng khác trưởng đoàn thì nhập riêng thông tin theo phòng.
          </p>
          <div class="divider"></div>

          <div class="section-title">Danh sách phòng phù hợp</div>
          <div class="room-list">
            <table>
              <thead>
                <tr>
                  <th></th>
                  <th>Phòng</th>
                  <th>Loại</th>
                  <th>Sức chứa</th>
                  <th>Giá / đêm</th>
                  <th>View</th>
                </tr>
              </thead>
              <tbody>
                <% if (!hasSearch) { %>
                  <tr><td class="table-empty" colspan="6">Chưa tìm kiếm. Nhập ngày đến, ngày đi và số khách rồi bấm “Tìm phòng phù hợp”.</td></tr>
                <% } else if (!searchRooms.length) { %>
                  <tr><td class="table-empty" colspan="6">Không còn phòng phù hợp cho bộ lọc hiện tại.</td></tr>
                <% } else { %>
                  <% searchRooms.forEach((room) => { %>
                    <tr data-room-id="<%= room.id %>" data-room-name="<%= room.soPhong %>" data-room-price="<%= room.gia %>">
                      <td>
                        <input
                          type="checkbox"
                          class="room-checkbox"
                          name="rooms[]"
                          value="<%= room.id %>"
                          <%= selectedRooms.includes(Number(room.id)) ? "checked" : "" %>
                        />
                      </td>
                      <td><strong>P<%= room.soPhong %></strong></td>
                      <td><%= room.loaiPhong %></td>
                      <td><%= room.soKhachToiDa %> khách</td>
                      <td><%= room.giaFormatted %></td>
                      <td><%= room.viewPhong || "-" %></td>
                    </tr>
                  <% }) %>
                <% } %>
              </tbody>
            </table>
          </div>

          <div class="room-guests-wrapper" id="roomGuestsWrapper">
            <div class="room-guests-header">
              <strong>Khách theo từng phòng</strong>
              <span>Để trống nghĩa là dùng thông tin trưởng đoàn cho phòng đó.</span>
            </div>
            <div id="roomGuestsContainer">
              <% selectedRooms.forEach((roomId) => {
                const guest = roomGuests[String(roomId)] || {};
                const roomMeta = roomLookup.get(Number(roomId));
                const roomLabel = roomMeta?.soPhong ? `Phòng ${roomMeta.soPhong}` : `Phòng #${roomId}`;
              %>
                <div class="room-guest-card" data-room-id="<%= roomId %>">
                  <div class="room-guest-title">
                    <span><%= roomLabel %></span>
                    <small>Để trống = dùng trưởng đoàn</small>
                  </div>
                  <div class="field">
                    <label>Tên khách phòng</label>
                    <input name="room_guests[<%= roomId %>][TenKhach]" value="<%= guest.TenKhach || '' %>" placeholder="Nếu khác trưởng đoàn" />
                  </div>
                  <div class="row">
                    <div class="field">
                      <label>CCCD khách</label>
                      <input name="room_guests[<%= roomId %>][CCCD]" value="<%= guest.CCCD || '' %>" placeholder="9-12 chữ số" />
                    </div>
                    <div class="field">
                      <label>SĐT khách</label>
                      <input name="room_guests[<%= roomId %>][SDT]" value="<%= guest.SDT || '' %>" placeholder="Nếu khác trưởng đoàn" />
                    </div>
                  </div>
                  <div class="row">
                    <div class="field">
                      <label>Email khách</label>
                      <input type="email" name="room_guests[<%= roomId %>][Email]" value="<%= guest.Email || '' %>" placeholder="Nếu khác trưởng đoàn" />
                    </div>
                    <div class="field">
                      <label>Địa chỉ khách</label>
                      <input name="room_guests[<%= roomId %>][DiaChi]" value="<%= guest.DiaChi || '' %>" placeholder="Nếu khác trưởng đoàn" />
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>

          <div class="divider"></div>
          <div class="section-title">Dịch vụ kèm theo <span>Số lượng > 0 bắt buộc phải gán vào một phòng đã chọn</span></div>

          <% if (!payload.services.length) { %>
            <div class="caption">Hiện chưa có dịch vụ hoạt động.</div>
          <% } else { %>
            <div class="room-list service-room-list">
              <table class="service-table">
                <thead>
                  <tr>
                    <th>Dịch vụ</th>
                    <th>Giá</th>
                    <th>Số lượng</th>
                    <th>Phòng sử dụng</th>
                  </tr>
                </thead>
                <tbody>
                  <% payload.services.forEach((service) => { %>
                    <tr>
                      <td><%= service.tenDichVu %></td>
                      <td><%= service.giaDichVuFormatted %></td>
                      <td>
                        <input
                          type="number"
                          min="0"
                          style="width:90px;"
                          class="js-service-qty"
                          name="services[<%= service.id %>]"
                          data-price="<%= service.giaDichVu %>"
                          value="<%= serviceQuantities[String(service.id)] || 0 %>"
                        />
                      </td>
                      <td>
                        <select
                          class="js-service-room"
                          name="services_room[<%= service.id %>]"
                          data-selected-room="<%= serviceRooms[String(service.id)] || '' %>"
                        >
                          <option value="">-- Chọn phòng --</option>
                          <% selectedRooms.forEach((roomId) => {
                            const roomMeta = roomLookup.get(Number(roomId));
                            const roomLabel = roomMeta?.soPhong ? `Phòng ${roomMeta.soPhong}` : `Phòng #${roomId}`;
                          %>
                            <option value="<%= roomId %>" <%= String(serviceRooms[String(service.id)] || '') === String(roomId) ? "selected" : "" %>><%= roomLabel %></option>
                          <% }) %>
                        </select>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>

          <div class="totals">
            <div>Tiền phòng: <strong id="sumRoom">0 đ</strong></div>
            <div>Tiền dịch vụ: <strong id="sumService">0 đ</strong></div>
            <div>Khuyến mãi: <strong id="sumDiscount">- 0 đ</strong></div>
            <div class="grand-total">Tổng thanh toán: <strong id="sumTotal">0 đ</strong></div>
          </div>

          <div class="button-row" style="margin-top:16px;">
            <div class="danger-banner" id="btnDanger">Thiếu hoặc sai thông tin. Vui lòng kiểm tra lại các ô màu đỏ.</div>
            <div class="button-group">
              <button class="button" type="submit" name="btn_action" value="book">Giữ phòng & tạo QR cọc</button>
            </div>
          </div>
        </section>
      </div>
    </form>
  </main>

  <script>
    (() => {
      const dateEl = document.getElementById("directBookingDate");
      const timeEl = document.getElementById("directBookingTime");
      if (!dateEl || !timeEl) return;
      const updateClock = () => {
        const now = new Date();
        dateEl.textContent = now.toLocaleDateString("vi-VN", {
          weekday: "short",
          day: "2-digit",
          month: "2-digit",
          year: "numeric"
        });
        timeEl.textContent = now.toLocaleTimeString("vi-VN", {
          hour: "2-digit",
          minute: "2-digit",
          second: "2-digit"
        });
      };
      updateClock();
      window.setInterval(updateClock, 1000);
    })();

    document.addEventListener("DOMContentLoaded", () => {
      const form = document.getElementById("formDatPhongV2");
      const clientErrors = document.getElementById("clientErrors");
      const clientErrorsList = document.getElementById("clientErrorsList");
      const btnDanger = document.getElementById("btnDanger");
      const roomGuestsContainer = document.getElementById("roomGuestsContainer");
      const customerModeInput = document.getElementById("customer_mode");
      const existingCustomerIdInput = document.getElementById("existing_customer_id");
      const modeTabs = document.querySelectorAll("[data-customer-mode-tab]");
      const existingPanel = document.getElementById("existingCustomerPanel");
      const newPanel = document.getElementById("newCustomerPanel");
      const existingKeyword = document.getElementById("existingCustomerKeyword");
      const lookupExistingButton = document.getElementById("btnLookupExistingCustomer");
      const existingResults = document.getElementById("existingCustomerResults");
      const selectedCustomerCard = document.getElementById("selectedCustomerCard");
      const selectedCustomerText = document.getElementById("selectedCustomerText");

      const fields = {
        leader_ten_kh: document.getElementById("leader_ten_kh"),
        leader_cccd: document.getElementById("leader_cccd"),
        leader_sdt: document.getElementById("leader_sdt"),
        leader_email: document.getElementById("leader_email"),
        ngay_den: document.getElementById("ngay_den"),
        ngay_di: document.getElementById("ngay_di"),
        so_nguoi: document.getElementById("so_nguoi")
      };

      const errsDom = {
        leader_ten_kh: document.getElementById("err_leader_ten_kh"),
        leader_cccd: document.getElementById("err_leader_cccd"),
        leader_sdt: document.getElementById("err_leader_sdt"),
        leader_email: document.getElementById("err_leader_email"),
        ngay_den: document.getElementById("err_ngay_den"),
        ngay_di: document.getElementById("err_ngay_di"),
        so_nguoi: document.getElementById("err_so_nguoi")
      };

      const touched = {
        leader_ten_kh: false,
        leader_cccd: false,
        leader_sdt: false,
        leader_email: false,
        ngay_den: false,
        ngay_di: false,
        so_nguoi: false
      };

      function setError(name, message) {
        if (!fields[name]) return;
        fields[name].classList.add("input-error");
        if (errsDom[name]) errsDom[name].textContent = message;
      }

      function clearError(name) {
        if (!fields[name]) return;
        fields[name].classList.remove("input-error");
        if (errsDom[name]) errsDom[name].textContent = "";
      }

      function formatVnd(value) {
        return new Intl.NumberFormat("vi-VN").format(Number(value || 0)) + " đ";
      }

      function escapeHtml(value) {
        return String(value || "")
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#039;");
      }

      function setCustomerMode(mode) {
        const nextMode = mode === "existing" ? "existing" : "new";
        if (customerModeInput) customerModeInput.value = nextMode;
        modeTabs.forEach((button) => {
          button.classList.toggle("is-active", button.getAttribute("data-customer-mode-tab") === nextMode);
        });
        existingPanel?.classList.toggle("is-active", nextMode === "existing");
        newPanel?.classList.toggle("is-active", nextMode === "new");
        if (nextMode === "new") {
          if (existingCustomerIdInput) existingCustomerIdInput.value = "";
          selectedCustomerCard?.classList.remove("is-visible");
        }
      }

      function applyExistingCustomer(customer) {
        if (!customer) return;
        setCustomerMode("existing");
        if (existingCustomerIdInput) existingCustomerIdInput.value = customer.id || "";
        if (fields.leader_ten_kh) fields.leader_ten_kh.value = customer.tenKhach || "";
        if (fields.leader_cccd) fields.leader_cccd.value = customer.cccd || "";
        if (fields.leader_sdt) fields.leader_sdt.value = customer.sdt || "";
        if (fields.leader_email) fields.leader_email.value = customer.email || "";
        const addressInput = form?.querySelector('[name="leader_diachi"]');
        if (addressInput) addressInput.value = customer.diaChi || "";
        selectedCustomerCard?.classList.add("is-visible");
        if (selectedCustomerText) {
          selectedCustomerText.textContent = `${customer.tenKhach || "Khách hàng"} · CCCD ${customer.cccd || "chưa có"} · ${customer.bookingCount || 0} booking trước đó${customer.hasAccount ? " · đã có tài khoản" : " · chưa có tài khoản"}`;
        }
        ["leader_ten_kh", "leader_cccd", "leader_sdt", "leader_email"].forEach((name) => {
          touched[name] = true;
          validateField(name, true);
        });
      }

      async function lookupExistingCustomers() {
        if (!existingResults || !existingKeyword) return;
        const keyword = existingKeyword.value.trim();
        existingResults.innerHTML = "";
        if (keyword.length < 2) {
          existingResults.innerHTML = '<div class="caption">Nhập ít nhất 2 ký tự để tìm khách hàng cũ.</div>';
          return;
        }

        lookupExistingButton.disabled = true;
        lookupExistingButton.textContent = "Đang tìm...";
        try {
          const response = await fetch(`/api/frontdesk/direct-booking/customers?keyword=${encodeURIComponent(keyword)}`, {
            headers: { Accept: "application/json" }
          });
          const payload = await response.json();
          const customers = Array.isArray(payload?.data) ? payload.data : [];
          if (!customers.length) {
            existingResults.innerHTML = '<div class="caption">Không tìm thấy khách phù hợp. Có thể chuyển sang tab khách hàng mới.</div>';
            return;
          }

          existingResults.innerHTML = customers.map((customer, index) => `
            <button class="customer-result-card" type="button" data-customer-index="${index}">
              <strong>${escapeHtml(customer.tenKhach)} · #${escapeHtml(customer.id)}</strong>
              <span>CCCD ${escapeHtml(customer.cccd || "chưa có")} · ${escapeHtml(customer.sdt || "chưa có SĐT")} · ${escapeHtml(customer.email || "chưa có email")}</span>
              <span>${escapeHtml(customer.trangThaiEkyc || "ChuaXacThuc")} · ${Number(customer.bookingCount || 0)} booking · ${customer.hasAccount ? "Đã có tài khoản" : "Chưa có tài khoản"}</span>
            </button>
          `).join("");

          existingResults.querySelectorAll("[data-customer-index]").forEach((button) => {
            button.addEventListener("click", () => {
              applyExistingCustomer(customers[Number(button.getAttribute("data-customer-index") || 0)]);
            });
          });
        } catch (_error) {
          existingResults.innerHTML = '<div class="caption">Không thể tra cứu khách hàng lúc này.</div>';
        } finally {
          lookupExistingButton.disabled = false;
          lookupExistingButton.textContent = "Tìm khách";
        }
      }

      modeTabs.forEach((button) => {
        button.addEventListener("click", () => setCustomerMode(button.getAttribute("data-customer-mode-tab")));
      });
      lookupExistingButton?.addEventListener("click", lookupExistingCustomers);
      existingKeyword?.addEventListener("keydown", (event) => {
        if (event.key === "Enter") {
          event.preventDefault();
          lookupExistingCustomers();
        }
      });

      function calcSoDem() {
        const ngayDen = fields.ngay_den.value;
        const ngayDi = fields.ngay_di.value;
        const soDemHidden = document.getElementById("so_dem");
        const soDemDisplay = document.getElementById("so_dem_display");

        if (!ngayDen || !ngayDi) {
          soDemHidden.value = "";
          soDemDisplay.value = "";
          return 0;
        }

        const diffMs = new Date(ngayDi).getTime() - new Date(ngayDen).getTime();
        const nights = diffMs > 0 ? Math.round(diffMs / (1000 * 60 * 60 * 24)) : 0;

        soDemHidden.value = nights || "";
        soDemDisplay.value = nights || "";
        return nights;
      }

      const countdownEl = document.getElementById("paymentCountdown");
      const countdownSource = document.querySelector("[data-payment-expires-at]");
      const expiresAt = countdownSource?.getAttribute("data-payment-expires-at") || "";
      const paymentHoldId = countdownSource?.getAttribute("data-payment-hold-id") || "";
      const paymentStatusLine = document.getElementById("paymentStatusLine");
      const paymentHoldAlert = document.getElementById("paymentHoldAlert");
      const paymentQrBlock = document.getElementById("paymentQrBlock");
      const paymentSuccessDetails = document.getElementById("paymentSuccessDetails");
      let countdownTimer = null;
      let paymentPollTimer = null;
      let paymentHandled = false;
      if (countdownEl && expiresAt) {
        const deadline = new Date(expiresAt).getTime();
        const renderCountdown = () => {
          const remaining = Math.max(0, deadline - Date.now());
          const seconds = Math.ceil(remaining / 1000);
          const minutesText = String(Math.floor(seconds / 60)).padStart(2, "0");
          const secondsText = String(seconds % 60).padStart(2, "0");
          countdownEl.textContent = `${minutesText}:${secondsText}`;
          if (seconds <= 0) {
            countdownEl.textContent = "Đã hết hạn";
            clearInterval(countdownTimer);
          }
        };
        countdownTimer = setInterval(renderCountdown, 1000);
        renderCountdown();
      }

      if (paymentHoldId && paymentStatusLine) {
        const escapeHtml = (value) => String(value || "")
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#039;");

        const renderSuccessDetails = (data) => {
          if (!paymentSuccessDetails) return;
          const accounts = Array.isArray(data.createdAccounts) ? data.createdAccounts : [];
          const accountRows = accounts.length
            ? `<div class="room-list" style="margin-top:10px;"><table><thead><tr><th>Họ tên</th><th>Username</th><th>Password</th><th>Vai trò</th></tr></thead><tbody>${accounts.map((account) => `
                <tr>
                  <td>${escapeHtml(account.hoTen)}</td>
                  <td><strong>${escapeHtml(account.username)}</strong></td>
                  <td>${escapeHtml(account.password)}</td>
                  <td>${escapeHtml(account.vaiTro)}</td>
                </tr>
              `).join("")}</tbody></table></div>`
            : "";

          paymentSuccessDetails.innerHTML = `
            <div style="display:grid;gap:8px;">
              <div><strong>Mã giao dịch:</strong> #${escapeHtml(data.transactionId)}</div>
              <div><strong>Mã đặt chỗ:</strong> ${escapeHtml(data.bookingCode || "Đã tạo")}</div>
              <div><strong>Tổng hóa đơn:</strong> ${escapeHtml(data.totalFormatted || "")}</div>
              <div><strong>Cọc đã thanh toán:</strong> ${escapeHtml(data.depositAmountFormatted || "")}</div>
              <div><strong>Trạng thái:</strong> Đã tạo đoàn, tài khoản khách hàng và giao dịch thật.</div>
            </div>
            ${accountRows}
          `;
          paymentSuccessDetails.style.display = "block";
        };

        const renderPaidState = (data) => {
          if (paymentHandled) return;
          paymentHandled = true;
          paymentStatusLine.innerHTML = `Thanh toán cọc thành công. Đã tạo giao dịch #${data.transactionId}${data.bookingCode ? ` · Mã đặt chỗ ${data.bookingCode}` : ""}.`;
          if (paymentHoldAlert) {
            paymentHoldAlert.classList.remove("alert-warning");
            paymentHoldAlert.classList.add("alert-success");
          }
          if (paymentQrBlock) {
            paymentQrBlock.style.display = "none";
          }
          renderSuccessDetails(data);
          if (countdownEl) {
            countdownEl.textContent = "Đã thanh toán";
          }
          if (countdownTimer) {
            clearInterval(countdownTimer);
          }
          if (paymentPollTimer) {
            clearInterval(paymentPollTimer);
          }
        };

        const renderExpiredState = () => {
          if (paymentHandled) return;
          paymentHandled = true;
          paymentStatusLine.textContent = "Mã giữ phòng đã hết hạn thanh toán. Vui lòng tạo QR giữ phòng mới.";
          if (countdownEl) {
            countdownEl.textContent = "Đã hết hạn";
          }
          if (countdownTimer) {
            clearInterval(countdownTimer);
          }
          if (paymentPollTimer) {
            clearInterval(paymentPollTimer);
          }
        };

        const pollPaymentStatus = async () => {
          if (paymentHandled) return;
          try {
            const response = await fetch(`/api/frontdesk/direct-booking/holds/${paymentHoldId}`, {
              headers: { Accept: "application/json" }
            });
            const payload = await response.json();
            const data = payload?.data || {};
            if (data.status === "PAID") {
              renderPaidState(data);
            } else if (data.status === "EXPIRED") {
              renderExpiredState();
            }
          } catch (_error) {
            // Giữ polling im lặng để lễ tân không bị nhiễu nếu mạng chập chờn.
          }
        };

        if (window.EventSource) {
          const stream = new EventSource("/api/realtime/stream?scope=letan");
          stream.addEventListener("booking_created_after_deposit", (event) => {
            try {
              const data = JSON.parse(event.data || "{}");
              if (String(data.holdId || "") === String(paymentHoldId)) {
                renderPaidState(data);
                stream.close();
              }
            } catch (_error) {
              // Realtime event lỗi định dạng thì polling bên dưới vẫn xử lý.
            }
          });
        }

        paymentPollTimer = setInterval(pollPaymentStatus, 1000);
        pollPaymentStatus();
      }

      function validateField(name, fromSubmit = false) {
        if (!fromSubmit && !touched[name]) {
          clearError(name);
          return;
        }

        const value = (fields[name]?.value || "").trim();
        clearError(name);

        switch (name) {
          case "leader_ten_kh":
            if (!value) {
              setError(name, "Vui lòng nhập họ tên trưởng đoàn.");
            }
            break;
          case "leader_cccd":
            if (!/^\d{9,12}$/.test(value)) {
              setError(name, "CCCD trưởng đoàn phải gồm 9-12 chữ số.");
            }
            break;
          case "leader_sdt":
            if (!/^(0|\+84)\d{8,10}$/.test(value)) {
              setError(name, "Số điện thoại trưởng đoàn không hợp lệ.");
            }
            break;
          case "leader_email":
            if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value)) {
              setError(name, "Email trưởng đoàn không hợp lệ.");
            }
            break;
          case "ngay_den":
          case "ngay_di": {
            const ngayDen = fields.ngay_den.value;
            const ngayDi = fields.ngay_di.value;
            clearError("ngay_den");
            clearError("ngay_di");
            if (!ngayDen) setError("ngay_den", "Vui lòng chọn ngày đến.");
            if (!ngayDi) setError("ngay_di", "Vui lòng chọn ngày đi.");
            if (ngayDen && ngayDi && new Date(ngayDi).getTime() <= new Date(ngayDen).getTime()) {
              setError("ngay_di", "Ngày đi phải lớn hơn ngày đến.");
            }
            calcSoDem();
            break;
          }
          case "so_nguoi":
            if (Number(value || 0) <= 0) {
              setError(name, "Số khách phải lớn hơn 0.");
            }
            break;
        }
      }

      Object.keys(fields).forEach((name) => {
        fields[name].addEventListener("blur", () => {
          touched[name] = true;
          validateField(name, false);
        });
        fields[name].addEventListener("input", () => {
          if (touched[name]) validateField(name, false);
          if (name === "ngay_den" || name === "ngay_di") {
            calcTotalMoney();
          }
        });
      });

      function getSelectedRooms() {
        return Array.from(document.querySelectorAll(".room-checkbox:checked")).map((checkbox) => {
          const row = checkbox.closest("tr");
          return {
            id: checkbox.value,
            name: row?.getAttribute("data-room-name") || checkbox.value
          };
        });
      }

      function buildRoomGuestCard(roomId, roomName) {
        const wrapper = document.createElement("div");
        wrapper.className = "room-guest-card";
        wrapper.dataset.roomId = roomId;
        wrapper.innerHTML = `
          <div class="room-guest-title">
            <span>Phòng ${roomName}</span>
            <small>Để trống = dùng trưởng đoàn</small>
          </div>
          <div class="field">
            <label>Tên khách phòng</label>
            <input name="room_guests[${roomId}][TenKhach]" placeholder="Nếu khác trưởng đoàn" />
          </div>
          <div class="row">
            <div class="field">
              <label>CCCD khách</label>
              <input name="room_guests[${roomId}][CCCD]" placeholder="9-12 chữ số" />
            </div>
            <div class="field">
              <label>SĐT khách</label>
              <input name="room_guests[${roomId}][SDT]" placeholder="Nếu khác trưởng đoàn" />
            </div>
          </div>
          <div class="row">
            <div class="field">
              <label>Email khách</label>
              <input type="email" name="room_guests[${roomId}][Email]" placeholder="Nếu khác trưởng đoàn" />
            </div>
            <div class="field">
              <label>Địa chỉ khách</label>
              <input name="room_guests[${roomId}][DiaChi]" placeholder="Nếu khác trưởng đoàn" />
            </div>
          </div>
        `;
        return wrapper;
      }

      function syncRoomGuestCards() {
        const selectedRooms = getSelectedRooms();
        const selectedIds = selectedRooms.map((room) => String(room.id));

        Array.from(roomGuestsContainer.querySelectorAll(".room-guest-card")).forEach((card) => {
          if (!selectedIds.includes(card.dataset.roomId || "")) {
            card.remove();
          }
        });

        selectedRooms.forEach((room) => {
          if (!roomGuestsContainer.querySelector(`.room-guest-card[data-room-id="${room.id}"]`)) {
            roomGuestsContainer.appendChild(buildRoomGuestCard(room.id, room.name));
          }
        });
      }

      function updateServiceRoomOptions() {
        const selectedRooms = getSelectedRooms();
        document.querySelectorAll(".js-service-room").forEach((select) => {
          const current = select.getAttribute("data-selected-room") || select.value || "";
          select.innerHTML = '<option value="">-- Chọn phòng --</option>';
          selectedRooms.forEach((room) => {
            const option = document.createElement("option");
            option.value = room.id;
            option.textContent = `Phòng ${room.name}`;
            if (String(current) === String(room.id)) {
              option.selected = true;
            }
            select.appendChild(option);
          });
          if (!selectedRooms.some((room) => String(room.id) === String(current))) {
            select.value = "";
          }
        });
      }

      function calcTotalMoney() {
        const soDem = calcSoDem();
        let sumRoom = 0;
        let sumService = 0;
        let discount = 0;

        document.querySelectorAll(".room-checkbox:checked").forEach((checkbox) => {
          const row = checkbox.closest("tr");
          const price = Number(row?.getAttribute("data-room-price") || 0);
          sumRoom += price * soDem;
        });

        document.querySelectorAll('input[name^="services["]').forEach((input) => {
          const quantity = Number(input.value || 0);
          const price = Number(input.getAttribute("data-price") || 0);
          if (quantity > 0) {
            sumService += quantity * price;
          }
        });

        const promotion = document.getElementById("ma_khuyen_mai");
        const selectedOption = promotion?.options[promotion.selectedIndex];
        if (selectedOption && selectedOption.value) {
          const type = selectedOption.getAttribute("data-discount-type") || "";
          const value = Number(selectedOption.getAttribute("data-discount-value") || 0);
          const subtotal = sumRoom + sumService;
          discount = type === "FIXED" ? value : subtotal * (value / 100);
          discount = Math.min(discount, subtotal);
        }

        const total = Math.max(0, sumRoom + sumService - discount);
        document.getElementById("sumRoom").textContent = formatVnd(sumRoom);
        document.getElementById("sumService").textContent = formatVnd(sumService);
        document.getElementById("sumDiscount").textContent = "- " + formatVnd(discount);
        document.getElementById("sumTotal").textContent = formatVnd(total);
      }

      function collectServiceSelections() {
        const selections = [];
        document.querySelectorAll('input[name^="services["]').forEach((input) => {
          const quantity = Number(input.value || 0);
          const match = (input.getAttribute("name") || "").match(/services\[(\d+)\]/);
          if (!match || quantity <= 0) return;

          const select = document.querySelector(`select[name="services_room[${match[1]}]"]`);
          selections.push({
            service_id: Number(match[1]),
            room_id: Number(select?.value || 0),
            quantity,
            note: ""
          });
        });
        return selections;
      }

      document.querySelectorAll(".room-checkbox").forEach((checkbox) => {
        checkbox.addEventListener("change", () => {
          syncRoomGuestCards();
          updateServiceRoomOptions();
          calcTotalMoney();
        });
      });

      document.addEventListener("change", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        const targetName = target.getAttribute("name") || "";

        if (target.classList.contains("js-service-room")) {
          const match = targetName.match(/services_room\[(\d+)\]/);
          const qtyInput = match ? document.querySelector(`input[name="services[${match[1]}]"]`) : null;
          if (target.value && qtyInput && Number(qtyInput.value || 0) <= 0) {
            qtyInput.value = "1";
          }
          calcTotalMoney();
          return;
        }

        if (
          target.id === "ma_khuyen_mai" ||
          target.id === "ngay_den" ||
          target.id === "ngay_di" ||
          targetName.startsWith("services[")
        ) {
          calcTotalMoney();
        }
      });

      document.addEventListener("input", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        if ((target.getAttribute("name") || "").startsWith("services[")) {
          const match = (target.getAttribute("name") || "").match(/services\[(\d+)\]/);
          const select = match ? document.querySelector(`select[name="services_room[${match[1]}]"]`) : null;
          const selectedRooms = getSelectedRooms();
          if (Number(target.value || 0) > 0 && select && !select.value && selectedRooms.length === 1) {
            select.value = selectedRooms[0].id;
          }
          calcTotalMoney();
        }
      });

      form.addEventListener("submit", (event) => {
        const submitter = event.submitter;
        const action = submitter?.value || "search";
        const servicesJsonInput = document.getElementById("services_json");
        if (servicesJsonInput) {
          servicesJsonInput.value = JSON.stringify(collectServiceSelections());
        }

        clientErrors.style.display = "none";
        clientErrorsList.innerHTML = "";
        btnDanger.style.display = "none";

        Object.keys(fields).forEach((name) => validateField(name, true));

        const errors = Object.keys(errsDom)
          .map((name) => errsDom[name]?.textContent || "")
          .filter(Boolean);

        if (action === "book") {
          if (customerModeInput?.value === "existing" && !existingCustomerIdInput?.value) {
            errors.push("Vui lòng chọn một hồ sơ khách hàng cũ trước khi giữ phòng.");
          }

          if (!document.querySelector(".room-checkbox:checked")) {
            errors.push("Vui lòng chọn ít nhất một phòng trước khi đặt.");
          }

          document.querySelectorAll('input[name^="services["]').forEach((input) => {
            const quantity = Number(input.value || 0);
            if (quantity > 0) {
              const match = (input.getAttribute("name") || "").match(/services\[(\d+)\]/);
              if (!match) return;
              const select = document.querySelector(`select[name="services_room[${match[1]}]"]`);
              if (select && !select.value) {
                errors.push(`Dịch vụ ${match[1]} có số lượng > 0 nhưng chưa chọn phòng sử dụng.`);
              }
            }
          });
        }

        if (errors.length) {
          event.preventDefault();
          errors.forEach((message) => {
            const li = document.createElement("li");
            li.textContent = message;
            clientErrorsList.appendChild(li);
          });
          clientErrors.style.display = "block";
          btnDanger.style.display = "inline-flex";
          window.scrollTo({ top: 0, behavior: "smooth" });
        }
      });

      syncRoomGuestCards();
      updateServiceRoomOptions();
      calcTotalMoney();
    });
  </script>
</body>
</html>
