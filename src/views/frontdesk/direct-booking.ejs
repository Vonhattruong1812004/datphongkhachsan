    .system-galaxy-comet--three { left: 22%; top: 0; width: 92px; animation: system-comet-fall 7.8s linear infinite .6s; }
    .system-galaxy-comet--four { left: 62%; bottom: 0; width: 96px; animation: system-comet-rise 9s linear infinite 2s; }

    @keyframes system-galaxy-star-drift { from { transform: translate3d(0,0,0); } to { transform: translate3d(-120px,90px,0); } }
