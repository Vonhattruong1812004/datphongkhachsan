<%
  const catalog = payload.catalog || [];
  const serviceHotelScopeSupported = Boolean(payload.serviceHotelScopeSupported);
  const hotelOptions = payload.hotelOptions || [];
  const filters = payload.filters || {};
  const activeHotelId = Number(payload.activeHotelId || filters.hotelId || query?.hotel_id || 0);
  const catalogStats = payload.catalogStats || {
    total: catalog.length,
    active: catalog.filter((item) => item.trangThai === "HoatDong").length,
    maintenance: catalog.filter((item) => item.trangThai === "BaoTri").length,
    stopped: catalog.filter((item) => item.trangThai === "NgungBan").length,
    linked: catalog.filter((item) => Number(item.orderCount || 0) > 0).length,
    missingImage: catalog.filter((item) => !item.imageUrl).length,
    openOrders: catalog.reduce((sum, item) => sum + Number(item.openOrderCount || 0), 0),
    orders30Days: catalog.reduce((sum, item) => sum + Number(item.orderCount30Days || 0), 0),
    revenue30DaysFormatted: "0 đ"
  };
  const categoryOptions = payload.categoryOptions || [
    { key: "all", label: "Tất cả nhóm" },
    { key: "wellness", label: "Wellness" },
    { key: "transport", label: "Di chuyển" },
    { key: "room", label: "Tiện nghi phòng" },
    { key: "dining", label: "Ẩm thực" },
    { key: "other", label: "Trải nghiệm khác" }
  ];
  const categorySummary = payload.categorySummary || [];
  const catalogDraftData = (typeof catalogDraft !== "undefined" && catalogDraft) ? catalogDraft : {};
  const editServiceId = Number(catalogDraftData.service_id || query?.edit_service || 0);
  const editingService = editServiceId ? catalog.find((item) => Number(item.id) === editServiceId) : null;
  const catalogForm = {
    service_id: catalogDraftData.service_id || editingService?.id || "",
    hotel_id: Number(catalogDraftData.hotel_id || editingService?.hotelId || activeHotelId || 0),
    ten_dich_vu: catalogDraftData.ten_dich_vu || editingService?.tenDichVu || "",
    gia_dich_vu: catalogDraftData.gia_dich_vu || editingService?.giaDichVu || "",
    trang_thai: catalogDraftData.trang_thai || editingService?.trangThai || "HoatDong",
    mo_ta: catalogDraftData.mo_ta || editingService?.moTa || "",
    hinh_anh: catalogDraftData.hinh_anh || editingService?.hinhAnh || ""
  };
  const selectedAttr = (value, expected) => String(value || "all") === String(expected) ? "selected" : "";
  const checkedFilter = (key) => String(filters.attention || "all") === key ? "selected" : "";
  const statusClass = (status) => status === "HoatDong" ? "is-active" : (status === "BaoTri" ? "is-maintenance" : "is-stopped");
  const baseQuery = new URLSearchParams();
  if (filters.keyword) baseQuery.set("keyword", filters.keyword);
  if (filters.status && filters.status !== "all") baseQuery.set("status", filters.status);
  if (filters.category && filters.category !== "all") baseQuery.set("category", filters.category);
  if (filters.attention && filters.attention !== "all") baseQuery.set("attention", filters.attention);
  if (activeHotelId) baseQuery.set("hotel_id", String(activeHotelId));
  const withEditQuery = (id) => {
    const params = new URLSearchParams(baseQuery.toString());
    params.set("edit_service", String(id));
    const qs = params.toString();
    return qs ? `?${qs}` : "";
  };
  const resetUrl = activeHotelId ? `/service/catalog/manage?hotel_id=${activeHotelId}` : "/service/catalog/manage";
%>

