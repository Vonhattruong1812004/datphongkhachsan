<%- include("../partials/head") %>
<%- include("../partials/header") %>
<%
  const catalog = payload.catalog || [];
  const serviceHotelScopeSupported = Boolean(payload.serviceHotelScopeSupported);
  const hotelOptions = payload.hotelOptions || [];
  const activeHotelId = Number(payload.activeHotelId || query?.hotel_id || 0);
  const catalogStats = payload.catalogStats || {
    total: catalog.length,
    active: catalog.filter((item) => item.trangThai === "HoatDong").length,
    maintenance: catalog.filter((item) => item.trangThai === "BaoTri").length,
    stopped: catalog.filter((item) => item.trangThai === "NgungBan").length,
    linked: catalog.filter((item) => Number(item.orderCount || 0) > 0).length
  };
  const catalogDraftData = (typeof catalogDraft !== "undefined" && catalogDraft) ? catalogDraft : {};
  const editServiceId = Number(catalogDraftData.service_id || query?.edit_service || 0);
  const editingService = editServiceId ? catalog.find((item) => Number(item.id) === editServiceId) : null;
  const catalogForm = {
    service_id: catalogDraftData.service_id || editingService?.id || "",
    hotel_id: Number(catalogDraftData.hotel_id || editingService?.hotelId || activeHotelId || 0),
    ten_dich_vu: catalogDraftData.ten_dich_vu || editingService?.tenDichVu || "",
    gia_dich_vu: catalogDraftData.gia_dich_vu || editingService?.giaDichVu || "",
    trang_thai: catalogDraftData.trang_thai || editingService?.trangThai || "HoatDong",
    mo_ta: catalogDraftData.mo_ta || editingService?.moTa || "",
    hinh_anh: catalogDraftData.hinh_anh || editingService?.hinhAnh || ""
  };
  const serviceStatusLabel = (status) => ({
    HoatDong: "Hoạt động",
    NgungBan: "Ngưng bán",
    BaoTri: "Bảo trì"
  }[status] || status || "Không rõ");
  const serviceStatusClass = (status) => status === "HoatDong" ? "" : (status === "BaoTri" ? "catalog-badge--amber" : "catalog-badge--danger");
%>

<style>
  .catalog-shell{
    --ink:#102033;
    --muted:#667085;
    --line:rgba(16,32,51,.10);
    --card:rgba(255,255,255,.82);
    --teal:#14b8a6;
    --blue:#0ea5e9;
    --rose:#fb7185;
    --amber:#f59e0b;
    --shadow:0 26px 76px rgba(15,23,42,.16);
    min-height:calc(100vh - 84px);
    padding:34px 18px 56px;
    color:var(--ink);
    background:
      radial-gradient(circle at 6% 8%,rgba(20,184,166,.28),transparent 31%),
      radial-gradient(circle at 86% 12%,rgba(14,165,233,.24),transparent 34%),
      linear-gradient(135deg,#fbfffb 0%,#e9fbf6 42%,#f7fbff 100%);
  }
  .catalog-wrap{max-width:1220px;margin:0 auto}
  .catalog-hero,.catalog-card{border:1px solid var(--line);background:var(--card);box-shadow:var(--shadow);backdrop-filter:blur(22px)}
  .catalog-hero{position:relative;overflow:hidden;border-radius:34px;padding:34px;margin-bottom:18px}
  .catalog-chip{display:inline-flex;align-items:center;border-radius:999px;padding:7px 12px;background:rgba(20,184,166,.12);border:1px solid rgba(20,184,166,.22);color:#0f766e;font-size:12px;font-weight:1000;letter-spacing:.08em;text-transform:uppercase}
  .catalog-hero h1{max-width:760px;margin:22px 0 12px;font-size:clamp(38px,5.8vw,68px);line-height:.92;letter-spacing:-.07em}
  .catalog-hero h1 span{color:transparent;background:linear-gradient(100deg,#0284c7,#0f766e 48%,#65a30d);-webkit-background-clip:text;background-clip:text}
  .catalog-lead{max-width:760px;margin:0;color:var(--muted);font-size:16px;line-height:1.7}
  .catalog-actions{display:flex;flex-wrap:wrap;gap:10px;margin-top:24px}
  .catalog-button,.catalog-mini-button{display:inline-flex;align-items:center;justify-content:center;border-radius:999px;text-decoration:none;font-weight:950;cursor:pointer}
  .catalog-button{min-height:44px;padding:10px 17px;border:1px solid rgba(16,32,51,.12);background:rgba(255,255,255,.76);color:var(--ink)}
  .catalog-button--primary{color:#fff;border-color:transparent;background:linear-gradient(135deg,#0891b2,#14b8a6);box-shadow:0 18px 38px rgba(20,184,166,.22)}
  .catalog-card{border-radius:30px;padding:22px;margin-bottom:18px}
  .catalog-card h2{margin:0 0 8px;font-size:24px;letter-spacing:-.04em}
  .catalog-muted{color:var(--muted);font-size:13px;line-height:1.55}
  .catalog-alert{border-radius:18px;padding:12px 14px;margin-bottom:14px;border:1px solid transparent}
  .catalog-alert--error{background:rgba(251,113,133,.14);color:#be123c;border-color:rgba(251,113,133,.30)}
  .catalog-alert--success{background:rgba(20,184,166,.14);color:#0f766e;border-color:rgba(20,184,166,.30)}
  .catalog-summary{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px;margin:16px 0}
  .catalog-stat{border-radius:22px;padding:16px;background:rgba(255,255,255,.58);border:1px solid rgba(16,32,51,.08)}
  .catalog-stat strong{display:block;font-size:28px;line-height:1;letter-spacing:-.05em}
  .catalog-stat span{display:block;margin-top:8px;color:var(--muted);font-size:12px;font-weight:900;text-transform:uppercase;letter-spacing:.06em}
  .catalog-row{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}
  .catalog-field{display:flex;flex-direction:column;gap:6px;margin-top:10px}
  .catalog-field label{font-size:13px;font-weight:900;color:#344054}
  .catalog-field input,.catalog-field select,.catalog-field textarea{width:100%;border:1px solid rgba(16,32,51,.14);border-radius:16px;padding:12px 14px;background:rgba(255,255,255,.76);color:var(--ink);font:inherit;outline:none}
  .catalog-field textarea{min-height:78px;resize:vertical}
  .catalog-field input:focus,.catalog-field select:focus,.catalog-field textarea:focus{border-color:rgba(14,165,233,.50);box-shadow:0 0 0 3px rgba(14,165,233,.10)}
  .catalog-table-wrap{overflow:auto;border:1px solid var(--line);border-radius:22px;background:rgba(255,255,255,.58);margin-top:16px}
  .catalog-table{width:100%;border-collapse:collapse;min-width:980px;font-size:14px}
  .catalog-table th,.catalog-table td{padding:13px;border-bottom:1px solid rgba(16,32,51,.08);text-align:left;vertical-align:top}
  .catalog-table th{background:rgba(255,255,255,.68);color:#344054;font-size:12px;text-transform:uppercase;letter-spacing:.08em}
  .catalog-badge{display:inline-flex;border-radius:999px;padding:5px 9px;background:rgba(20,184,166,.12);color:#0f766e;font-size:11px;font-weight:1000;letter-spacing:.04em}
  .catalog-badge--blue{background:rgba(14,165,233,.12);color:#0369a1}
  .catalog-badge--amber{background:rgba(245,158,11,.13);color:#b45309}
  .catalog-badge--danger{background:rgba(251,113,133,.14);color:#be123c}
  .catalog-img{width:72px;height:72px;border-radius:20px;object-fit:cover;border:1px solid rgba(16,32,51,.10);background:rgba(255,255,255,.72)}
  .catalog-img--lg{width:100%;max-width:240px;height:150px}
  .catalog-inline-actions{display:flex;flex-wrap:wrap;gap:8px;align-items:center}
  .catalog-mini-button{min-height:36px;padding:8px 12px;border:1px solid rgba(16,32,51,.12);background:rgba(255,255,255,.75);color:var(--ink)}
  .catalog-mini-button--danger{color:#be123c;border-color:rgba(251,113,133,.28);background:rgba(255,241,242,.72)}
  .catalog-empty{border:1px dashed rgba(16,32,51,.14);border-radius:22px;padding:22px;background:rgba(255,255,255,.58);color:var(--muted)}
  @media(max-width:760px){.catalog-shell{padding:20px 12px 42px}.catalog-hero{padding:24px}.catalog-row,.catalog-summary{grid-template-columns:1fr}}
</style>

<main class="catalog-shell">
  <div class="catalog-wrap">
    <% if (notice?.error) { %><div class="catalog-alert catalog-alert--error"><%= notice.error %></div><% } %>
    <% if (notice?.success) { %><div class="catalog-alert catalog-alert--success"><%= notice.success %></div><% } %>

    <section class="catalog-hero" aria-label="Quản lý dịch vụ">
      <span class="catalog-chip">Quản lý dịch vụ</span>
      <h1>Quản lý dịch vụ <span>riêng biệt.</span></h1>
      <p class="catalog-lead">
        Trang này chỉ xử lý danh mục dịch vụ: thêm mới, chỉnh sửa, cập nhật giá, mô tả, hình ảnh,
        trạng thái và xóa an toàn khi chưa phát sinh giao dịch.
      </p>
      <div class="catalog-actions">
        <a class="catalog-button catalog-button--primary" href="/dashboard/dichvu">Quay lại dashboard</a>
        <a class="catalog-button" href="/api/service/catalog">Catalog API</a>
      </div>
    </section>

    <section class="catalog-card">
      <h2><%= catalogForm.service_id ? "Chỉnh sửa dịch vụ" : "Tạo dịch vụ mới" %></h2>
      <p class="catalog-muted">Dịch vụ đã phát sinh trong giao dịch sẽ bị khóa xóa để bảo toàn lịch sử checkout; khi không phục vụ nữa hãy chuyển sang Ngưng bán hoặc Bảo trì.</p>

      <% if (serviceHotelScopeSupported) { %>
        <form method="get" action="/service/catalog/manage" class="catalog-card" style="box-shadow:none;background:rgba(255,255,255,.50);margin:16px 0">
          <h2 style="font-size:18px">Lọc theo cơ sở</h2>
          <div class="catalog-row" style="grid-template-columns:2fr 1fr">
            <div class="catalog-field">
              <label for="hotel_id_filter">Khách sạn / cơ sở</label>
              <select id="hotel_id_filter" name="hotel_id">
                <option value="0">Toàn hệ thống</option>
                <% hotelOptions.forEach((hotel) => { %>
                  <option value="<%= hotel.id %>" <%= Number(activeHotelId) === Number(hotel.id) ? "selected" : "" %>>
                    <%= hotel.tenKhachSan %><%= hotel.tinhThanh ? ` · ${hotel.tinhThanh}` : "" %>
                  </option>
                <% }) %>
              </select>
            </div>
            <div class="catalog-field" style="justify-content:flex-end">
              <button class="catalog-button catalog-button--primary" type="submit">Áp dụng lọc</button>
            </div>
          </div>
        </form>
      <% } else { %>
        <div class="catalog-alert catalog-alert--success">
          Bảng <strong>dichvu</strong> chưa có cột <strong>makhachsan</strong>, nên danh mục dịch vụ đang dùng chung toàn hệ thống.
        </div>
      <% } %>

      <div class="catalog-summary">
        <div class="catalog-stat"><strong><%= catalogStats.total %></strong><span>Tổng dịch vụ</span></div>
        <div class="catalog-stat"><strong><%= catalogStats.active %></strong><span>Đang hoạt động</span></div>
        <div class="catalog-stat"><strong><%= catalogStats.maintenance + catalogStats.stopped %></strong><span>Bảo trì / ngưng</span></div>
        <div class="catalog-stat"><strong><%= catalogStats.linked %></strong><span>Đã phát sinh</span></div>
      </div>

      <form method="post" action="/service/catalog" enctype="multipart/form-data" id="catalogForm">
        <input type="hidden" name="service_id" value="<%= catalogForm.service_id %>" />
        <input type="hidden" name="hinh_anh" value="<%= catalogForm.hinh_anh %>" />
        <div class="catalog-row">
          <% if (serviceHotelScopeSupported) { %>
            <div class="catalog-field">
              <label for="catalog_hotel">Cơ sở <span style="color:#be123c">*</span></label>
              <select id="catalog_hotel" name="hotel_id" required>
                <option value="">-- Chọn cơ sở --</option>
                <% hotelOptions.forEach((hotel) => { %>
                  <option value="<%= hotel.id %>" <%= Number(catalogForm.hotel_id) === Number(hotel.id) ? "selected" : "" %>>
                    <%= hotel.tenKhachSan %><%= hotel.tinhThanh ? ` · ${hotel.tinhThanh}` : "" %>
                  </option>
                <% }) %>
              </select>
            </div>
          <% } else { %>
            <input type="hidden" name="hotel_id" value="0" />
          <% } %>
          <div class="catalog-field">
            <label for="catalog_name">Tên dịch vụ <span style="color:#be123c">*</span></label>
            <input id="catalog_name" name="ten_dich_vu" value="<%= catalogForm.ten_dich_vu %>" required maxlength="160" />
          </div>
          <div class="catalog-field">
            <label for="catalog_price">Giá dịch vụ <span style="color:#be123c">*</span></label>
            <input id="catalog_price" name="gia_dich_vu" type="number" min="0" step="1000" value="<%= catalogForm.gia_dich_vu %>" required />
          </div>
          <div class="catalog-field">
            <label for="catalog_status">Trạng thái <span style="color:#be123c">*</span></label>
            <select id="catalog_status" name="trang_thai" required>
              <option value="HoatDong" <%= catalogForm.trang_thai === "HoatDong" ? "selected" : "" %>>Hoạt động</option>
              <option value="NgungBan" <%= catalogForm.trang_thai === "NgungBan" ? "selected" : "" %>>Ngưng bán</option>
              <option value="BaoTri" <%= catalogForm.trang_thai === "BaoTri" ? "selected" : "" %>>Bảo trì</option>
            </select>
          </div>
          <div class="catalog-field" style="grid-column:span 2">
            <label for="catalog_desc">Mô tả</label>
            <textarea id="catalog_desc" name="mo_ta" placeholder="Mô tả ngắn về dịch vụ, điều kiện phục vụ hoặc lưu ý nội bộ..."><%= catalogForm.mo_ta %></textarea>
          </div>
          <div class="catalog-field">
            <label for="catalog_image">Hình ảnh dịch vụ</label>
            <% if (editingService?.imageUrl) { %>
              <img class="catalog-img catalog-img--lg" src="<%= editingService.imageUrl %>" alt="Ảnh dịch vụ đang chỉnh sửa" onerror="this.style.display='none'" />
            <% } %>
            <input id="catalog_image" name="hinh_anh_file" type="file" accept="image/jpeg,image/png,image/webp" />
            <div class="catalog-muted">Chấp nhận JPG, PNG, WEBP. Nếu bỏ trống khi sửa, hệ thống giữ ảnh hiện tại.</div>
          </div>
        </div>
        <div class="catalog-actions">
          <button class="catalog-button catalog-button--primary" type="submit"><%= catalogForm.service_id ? "Lưu thay đổi" : "Tạo dịch vụ" %></button>
          <% if (catalogForm.service_id) { %>
            <a class="catalog-button" href="/service/catalog/manage<%= activeHotelId ? `?hotel_id=${activeHotelId}` : "" %>">Tạo mới</a>
          <% } %>
        </div>
      </form>

      <div class="catalog-table-wrap">
        <table class="catalog-table">
          <thead>
            <tr>
              <th>Ảnh</th>
              <th>Dịch vụ</th>
              <% if (serviceHotelScopeSupported) { %><th>Cơ sở</th><% } %>
              <th>Giá</th>
              <th>Trạng thái</th>
              <th>Mô tả</th>
              <th>Đã phát sinh</th>
              <th>Thao tác</th>
            </tr>
          </thead>
          <tbody>
            <% if (!catalog.length) { %>
              <tr><td colspan="<%= serviceHotelScopeSupported ? 8 : 7 %>"><div class="catalog-empty">Hiện chưa có dịch vụ nào trong hệ thống.</div></td></tr>
            <% } %>
            <% catalog.forEach((item) => { %>
              <tr>
                <td><img class="catalog-img" src="<%= item.imageUrl %>" alt="Ảnh <%= item.tenDichVu %>" onerror="this.src='/uploads/dichvu/default.jpg'" /></td>
                <td>
                  <strong><%= item.tenDichVu %></strong>
                  <div class="catalog-muted">Mã DV: #<%= item.id %></div>
                </td>
                <% if (serviceHotelScopeSupported) { %><td><%= item.hotelLabel %></td><% } %>
                <td><strong><%= item.giaDichVuFormatted %></strong></td>
                <td><span class="catalog-badge <%= serviceStatusClass(item.trangThai) %>"><%= serviceStatusLabel(item.trangThai) %></span></td>
                <td style="max-width:280px"><%= item.moTa || "Chưa có mô tả." %></td>
                <td><span class="catalog-badge <%= Number(item.orderCount || 0) > 0 ? "catalog-badge--blue" : "" %>"><%= item.orderCount || 0 %> dòng</span></td>
                <td>
                  <div class="catalog-inline-actions">
                    <a class="catalog-mini-button" href="/service/catalog/manage?edit_service=<%= item.id %><%= activeHotelId ? `&hotel_id=${activeHotelId}` : "" %>">Sửa</a>
                    <% if (Number(item.orderCount || 0) > 0 && item.trangThai !== "NgungBan") { %>
                      <form method="post" action="/service/catalog">
                        <input type="hidden" name="service_id" value="<%= item.id %>" />
                        <input type="hidden" name="hotel_id" value="<%= item.hotelId || 0 %>" />
                        <input type="hidden" name="ten_dich_vu" value="<%= item.tenDichVu %>" />
                        <input type="hidden" name="gia_dich_vu" value="<%= item.giaDichVu %>" />
                        <input type="hidden" name="mo_ta" value="<%= item.moTa || "" %>" />
                        <input type="hidden" name="hinh_anh" value="<%= item.hinhAnh || "" %>" />
                        <input type="hidden" name="trang_thai" value="NgungBan" />
                        <button class="catalog-mini-button" type="submit">Ngưng bán</button>
                      </form>
                    <% } %>
                    <form method="post" action="/service/catalog/<%= item.id %>/delete" onsubmit="return confirm('Xóa dịch vụ này? Chỉ dịch vụ chưa phát sinh giao dịch mới được xóa.');">
                      <input type="hidden" name="hotel_id" value="<%= activeHotelId || item.hotelId || 0 %>" />
                      <button class="catalog-mini-button catalog-mini-button--danger" type="submit" <%= Number(item.orderCount || 0) > 0 ? "disabled title='Dịch vụ đã phát sinh, hãy ngưng bán thay vì xóa.'" : "" %>>Xóa</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  </div>
</main>

<%- include("../partials/footer") %>
