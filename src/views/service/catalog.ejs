    .catalog-shell{padding:22px 12px 44px}
    .catalog-hero{padding:24px;border-radius:28px}
    .catalog-hero::before{width:250px;height:170px;right:-100px;bottom:-78px}
    .catalog-hero::after{display:none}
    .catalog-hero h1{font-size:42px}
    .catalog-summary,
    .catalog-form-grid,
    .catalog-filter,
    .catalog-metrics{grid-template-columns:1fr}
    .catalog-filter-actions{flex-direction:column}
    .catalog-service-head{grid-template-columns:64px 1fr}
    .catalog-img,
    .catalog-img-fallback{width:64px;height:64px}
    .catalog-img--lg,
    .catalog-img-fallback--lg{width:100%;height:160px}
    .catalog-button{width:100%}
  }

  /* Keep the galaxy background continuous while scrolling or entering the page. */
  html,
  body{
    min-height:100%;
    background:#061321;
    overscroll-behavior-y:none;
  }
  body{
    background:
      radial-gradient(circle at 10% 8%,rgba(34,211,238,.18),transparent 27%),
      radial-gradient(circle at 84% 12%,rgba(167,139,250,.15),transparent 30%),
      radial-gradient(circle at 72% 92%,rgba(251,113,133,.12),transparent 30%),
      linear-gradient(145deg,#061321 0%,#0a1731 48%,#190e37 100%);
  }
  .catalog-shell{
    min-height:100vh;
    min-height:100dvh;
    overflow-x:hidden;
    overflow-y:visible;
    background-color:#061321;
    background-attachment:fixed;
  }
</style>

<main class="catalog-shell">
  <div class="catalog-wrap">
    <% if (notice?.error) { %><div class="catalog-alert catalog-alert--error"><%= notice.error %></div><% } %>
    <% if (notice?.success) { %><div class="catalog-alert catalog-alert--success"><%= notice.success %></div><% } %>

    <section class="catalog-hero" aria-label="Quản lý dịch vụ">
      <span class="catalog-chip">Service catalog</span>
      <h1>Quản lý <span>dịch vụ resort.</span></h1>
      <p class="catalog-lead">Quản lý dịch vụ bán thêm: cơ sở, giá, ảnh, trạng thái và lượt dùng.</p>
      <div class="catalog-actions">
        <a class="catalog-button catalog-button--primary" href="/dashboard/dichvu">Quay lại dashboard</a>
        <a class="catalog-button" href="/service">Dịch vụ</a>
      </div>
    </section>

    <section class="catalog-summary" aria-label="Tổng quan danh mục dịch vụ">
      <div class="catalog-stat"><strong><%= catalogStats.total %></strong><span>Dịch vụ theo lọc</span></div>
      <div class="catalog-stat"><strong><%= catalogStats.active %></strong><span>Đang phục vụ</span></div>
      <div class="catalog-stat"><strong><%= catalogStats.orders30Days %></strong><span>Lượt dùng 30 ngày</span></div>
      <div class="catalog-stat"><strong><%= catalogStats.revenue30DaysFormatted %></strong><span>Doanh thu dịch vụ 30 ngày</span></div>
    </section>

    <section class="catalog-card">
      <h2>Lọc danh mục</h2>
      <p class="catalog-muted">Lọc danh sách và thống kê.</p>
      <form method="get" action="/service/catalog/manage" class="catalog-filter">
        <div class="catalog-field">
          <label for="filter_keyword">Tìm kiếm</label>
          <input id="filter_keyword" name="keyword" value="<%= filters.keyword || "" %>" placeholder="Tên dịch vụ, mô tả..." />
        </div>
        <% if (serviceHotelScopeSupported) { %>
          <div class="catalog-field">
            <label for="filter_hotel">Cơ sở</label>
            <select id="filter_hotel" name="hotel_id">
              <option value="0">Toàn hệ thống</option>
              <% hotelOptions.forEach((hotel) => { %>
                <option value="<%= hotel.id %>" <%= Number(activeHotelId) === Number(hotel.id) ? "selected" : "" %>>
                  <%= hotel.tenKhachSan %><%= hotel.tinhThanh ? ` · ${hotel.tinhThanh}` : "" %>
                </option>
              <% }) %>
            </select>
          </div>
        <% } %>
        <div class="catalog-field">
          <label for="filter_status">Trạng thái</label>
          <select id="filter_status" name="status">
            <option value="all" <%= selectedAttr(filters.status, "all") %>>Tất cả</option>
            <option value="HoatDong" <%= selectedAttr(filters.status, "HoatDong") %>>Đang phục vụ</option>
            <option value="BaoTri" <%= selectedAttr(filters.status, "BaoTri") %>>Bảo trì</option>
            <option value="NgungBan" <%= selectedAttr(filters.status, "NgungBan") %>>Ngưng bán</option>
          </select>
        </div>
        <div class="catalog-field">
          <label for="filter_category">Nhóm dịch vụ</label>
          <select id="filter_category" name="category">
            <% categoryOptions.forEach((item) => { %>
              <option value="<%= item.key %>" <%= selectedAttr(filters.category, item.key) %>><%= item.label %></option>
            <% }) %>
          </select>
        </div>
        <div class="catalog-field">
          <label for="filter_attention">Cần chú ý</label>
          <select id="filter_attention" name="attention">
            <option value="all" <%= checkedFilter("all") %>>Tất cả</option>
            <option value="missing_image" <%= checkedFilter("missing_image") %>>Thiếu ảnh</option>
            <option value="inactive" <%= checkedFilter("inactive") %>>Bảo trì / ngưng</option>
            <option value="open_orders" <%= checkedFilter("open_orders") %>>Còn order mở</option>
            <option value="ordered" <%= checkedFilter("ordered") %>>Đã phát sinh</option>
            <option value="no_usage" <%= checkedFilter("no_usage") %>>Chưa có lượt dùng</option>
          </select>
        </div>
        <div class="catalog-filter-actions">
          <button class="catalog-button catalog-button--primary" type="submit">Áp dụng</button>
          <a class="catalog-button" href="<%= resetUrl %>">Đặt lại</a>
        </div>
      </form>
      <% if (categorySummary.length) { %>
        <div class="catalog-category-row">
          <% categorySummary.forEach((item) => { %>
            <span class="catalog-badge catalog-badge--blue"><%= item.label %>: <%= item.total %></span>
          <% }) %>
          <% if (catalogStats.missingImage) { %><span class="catalog-badge catalog-badge--amber">Thiếu ảnh: <%= catalogStats.missingImage %></span><% } %>
          <% if (catalogStats.openOrders) { %><span class="catalog-badge catalog-badge--violet">Order mở: <%= catalogStats.openOrders %></span><% } %>
        </div>
      <% } %>
    </section>

    <% if (!serviceHotelScopeSupported) { %>
      <div class="catalog-alert catalog-alert--success">
        Bảng <strong>dichvu</strong> chưa có cột <strong>makhachsan</strong>, nên danh mục dịch vụ đang dùng chung toàn hệ thống.
      </div>
    <% } %>

    <div class="catalog-grid">
      <aside class="catalog-card">
        <h2><%= catalogForm.service_id ? "Chỉnh sửa dịch vụ" : "Tạo dịch vụ mới" %></h2>
        <p class="catalog-muted">Dịch vụ đã phát sinh giao dịch không thể xóa.</p>

        <form method="post" action="/service/catalog" enctype="multipart/form-data" id="catalogForm">
          <input type="hidden" name="service_id" value="<%= catalogForm.service_id %>" />
          <input type="hidden" name="hinh_anh" value="<%= catalogForm.hinh_anh %>" />
          <input type="hidden" name="keyword" value="<%= filters.keyword || "" %>" />
          <input type="hidden" name="status" value="<%= filters.status || "all" %>" />
          <input type="hidden" name="category" value="<%= filters.category || "all" %>" />
          <input type="hidden" name="attention" value="<%= filters.attention || "all" %>" />

          <div class="catalog-form-grid">
            <% if (serviceHotelScopeSupported) { %>
              <div class="catalog-field catalog-field--full">
                <label for="catalog_hotel">Cơ sở <span style="color:#be123c">*</span></label>
                <select id="catalog_hotel" name="hotel_id" required>
                  <option value="">-- Chọn cơ sở --</option>
                  <% hotelOptions.forEach((hotel) => { %>
                    <option value="<%= hotel.id %>" <%= Number(catalogForm.hotel_id) === Number(hotel.id) ? "selected" : "" %>>
                      <%= hotel.tenKhachSan %><%= hotel.tinhThanh ? ` · ${hotel.tinhThanh}` : "" %>
                    </option>
                  <% }) %>
                </select>
              </div>
            <% } else { %>
              <input type="hidden" name="hotel_id" value="0" />
            <% } %>
            <div class="catalog-field catalog-field--full">
              <label for="catalog_name">Tên dịch vụ <span style="color:#be123c">*</span></label>
              <input id="catalog_name" name="ten_dich_vu" value="<%= catalogForm.ten_dich_vu %>" required maxlength="160" placeholder="VD: Massage đá nóng, đưa đón sân bay..." />
            </div>
            <div class="catalog-field">
              <label for="catalog_price">Giá dịch vụ <span style="color:#be123c">*</span></label>
              <input id="catalog_price" name="gia_dich_vu" type="number" min="0" step="1000" value="<%= catalogForm.gia_dich_vu %>" required />
            </div>
            <div class="catalog-field">
              <label for="catalog_status">Trạng thái</label>
              <select id="catalog_status" name="trang_thai" required>
                <option value="HoatDong" <%= catalogForm.trang_thai === "HoatDong" ? "selected" : "" %>>Đang phục vụ</option>
                <option value="NgungBan" <%= catalogForm.trang_thai === "NgungBan" ? "selected" : "" %>>Ngưng bán</option>
                <option value="BaoTri" <%= catalogForm.trang_thai === "BaoTri" ? "selected" : "" %>>Bảo trì</option>
              </select>
            </div>
            <div class="catalog-field catalog-field--full">
              <label for="catalog_desc">Mô tả / điều kiện phục vụ</label>
              <textarea id="catalog_desc" name="mo_ta" placeholder="Mô tả ngắn, thời gian chuẩn bị, điều kiện áp dụng hoặc lưu ý nội bộ..."><%= catalogForm.mo_ta %></textarea>
            </div>
            <div class="catalog-field catalog-field--full">
              <label for="catalog_image">Hình ảnh dịch vụ</label>
              <% if (editingService?.imageUrl) { %>
                <img class="catalog-img catalog-img--lg" src="<%= editingService.imageUrl %>" alt="Ảnh dịch vụ đang chỉnh sửa" onerror="this.replaceWith(Object.assign(document.createElement('div'), { className: 'catalog-img-fallback catalog-img-fallback--lg', textContent: 'DV' }))" />
              <% } else { %>
                <div class="catalog-img-fallback catalog-img-fallback--lg" aria-hidden="true">DV</div>
              <% } %>
              <input id="catalog_image" name="hinh_anh_file" type="file" accept="image/jpeg,image/png,image/webp" />
              <div class="catalog-muted">JPG, PNG, WEBP. Khi sửa mà bỏ trống, hệ thống giữ ảnh hiện tại.</div>
            </div>
          </div>

          <div class="catalog-actions">
            <button class="catalog-button catalog-button--primary" type="submit"><%= catalogForm.service_id ? "Lưu thay đổi" : "Tạo dịch vụ" %></button>
            <% if (catalogForm.service_id) { %>
              <a class="catalog-button" href="/service/catalog/manage<%= baseQuery.toString() ? `?${baseQuery.toString()}` : "" %>">Tạo mới</a>
            <% } %>
          </div>
        </form>
      </aside>

      <section class="catalog-card">
        <h2>Danh sách dịch vụ</h2>
        <p class="catalog-muted">Hiển thị <strong><%= catalog.length %></strong> dịch vụ phù hợp bộ lọc. Mỗi card cho thấy trạng thái, lượt phát sinh, doanh thu 30 ngày và hướng xử lý.</p>

        <% if (!catalog.length) { %>
          <div class="catalog-empty">Không có dịch vụ nào khớp bộ lọc hiện tại.</div>
        <% } else { %>
          <div class="catalog-list">
            <% catalog.forEach((item) => { %>
              <article class="catalog-service-card <%= statusClass(item.trangThai) %>">
                <div class="catalog-service-head">
                  <% if (item.imageUrl) { %>
                    <img class="catalog-img" src="<%= item.imageUrl %>" alt="Ảnh <%= item.tenDichVu %>" onerror="this.replaceWith(Object.assign(document.createElement('div'), { className: 'catalog-img-fallback', textContent: 'DV' }))" />
                  <% } else { %>
                    <div class="catalog-img-fallback" aria-hidden="true">DV</div>
                  <% } %>
                  <div>
                    <h3 class="catalog-service-title"><%= item.tenDichVu %></h3>
                    <div class="catalog-service-meta">
                      <span class="catalog-badge <%= item.trangThai === "HoatDong" ? "" : (item.trangThai === "BaoTri" ? "catalog-badge--amber" : "catalog-badge--danger") %>"><%= item.statusLabel %></span>
                      <span class="catalog-badge catalog-badge--blue"><%= item.category?.label || "Trải nghiệm khác" %></span>
                      <% if (serviceHotelScopeSupported) { %><span class="catalog-badge catalog-badge--violet"><%= item.hotelLabel %></span><% } %>
                    </div>
                    <strong class="catalog-price"><%= item.giaDichVuFormatted %></strong>
                  </div>
                </div>

                <p class="catalog-rec"><%= item.recommendation %></p>
                <div class="catalog-metrics">
                  <div class="catalog-metric"><strong><%= item.orderCount || 0 %></strong><span>Tổng lượt</span></div>
                  <div class="catalog-metric"><strong><%= item.orderCount30Days || 0 %></strong><span>30 ngày</span></div>
                  <div class="catalog-metric"><strong><%= item.revenue30DaysFormatted %></strong><span>Doanh thu 30 ngày</span></div>
                </div>
                <div class="catalog-muted" style="margin-top:10px">
                  <%= item.moTa || "Chưa có mô tả. Nên bổ sung để lễ tân/khách hiểu rõ điều kiện phục vụ." %>
                </div>

                <div class="catalog-inline-actions">
                  <a class="catalog-mini-button" href="/service/catalog/manage<%= withEditQuery(item.id) %>">Sửa</a>
                  <% if (Number(item.orderCount || 0) > 0 && item.trangThai !== "NgungBan") { %>
                    <form method="post" action="/service/catalog">
                      <input type="hidden" name="service_id" value="<%= item.id %>" />
                      <input type="hidden" name="hotel_id" value="<%= item.hotelId || 0 %>" />
                      <input type="hidden" name="ten_dich_vu" value="<%= item.tenDichVu %>" />
                      <input type="hidden" name="gia_dich_vu" value="<%= item.giaDichVu %>" />
                      <input type="hidden" name="mo_ta" value="<%= item.moTa || "" %>" />
                      <input type="hidden" name="hinh_anh" value="<%= item.hinhAnh || "" %>" />
                      <input type="hidden" name="trang_thai" value="NgungBan" />
                      <button class="catalog-mini-button" type="submit">Ngưng bán</button>
                    </form>
                  <% } %>
                  <form method="post" action="/service/catalog/<%= item.id %>/delete" onsubmit="return confirm('Xóa dịch vụ này? Chỉ dịch vụ chưa phát sinh giao dịch mới được xóa.');">
                    <input type="hidden" name="hotel_id" value="<%= activeHotelId || item.hotelId || 0 %>" />
                    <button class="catalog-mini-button catalog-mini-button--danger" type="submit" <%= Number(item.orderCount || 0) > 0 ? "disabled title='Dịch vụ đã phát sinh, hãy ngưng bán thay vì xóa.'" : "" %>>Xóa</button>
                  </form>
                </div>
              </article>
            <% }) %>
          </div>
        <% } %>
      </section>
    </div>
  </div>
</main>

<%- include("../partials/footer") %>
