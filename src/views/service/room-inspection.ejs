<%
  const roomFeed = payload.roomFeed || { summary: {}, items: [], byHotel: [], priorityQueue: [] };
  const rooms = roomFeed.items || [];
  const inspectionHistory = payload.inspectionHistory || [];
  const draft = (typeof inspectionDraft !== "undefined" && inspectionDraft) ? inspectionDraft : {};
  const selectedRoomId = Number(draft.room_id || query?.room_id || 0);
  const selectedRoom = selectedRoomId ? rooms.find((item) => Number(item.id) === selectedRoomId) : null;
  const isRoomLocked = (room) => Boolean(room?.isLocked) || Boolean(room?.transactionId) || ["Booked", "Stayed"].includes(room?.trangThaiRealtime || room?.trangThai || "");
  const isRoomActionable = (room) => room?.canInspect !== false && !isRoomLocked(room);
  const actionableRooms = rooms.filter(isRoomActionable);
  const lockedRooms = rooms.filter((room) => !isRoomActionable(room));
  const conditionValue = draft.room_condition || query?.room_condition || "Tot";
  const noteValue = draft.note || "";
  const conditionOptions = [
    { value: "Tot", label: "Tốt", target: "Available", tone: "ok", summary: "Sạch, đủ tiêu chuẩn, mở bán được.", note: "Đưa phòng về Available và sẵn sàng nhận khách." },
    { value: "CanVeSinh", label: "Cần vệ sinh", target: "Cleaning", tone: "cleaning", summary: "Cần housekeeping xử lý trước lượt khách mới.", note: "Giữ phòng trong luồng Cleaning, chưa nên nhận khách." },
    { value: "HuHaiNhe", label: "Hư hại nhẹ", target: "Maintenance", tone: "warning", summary: "Có lỗi nhỏ cần bảo trì kiểm tra.", note: "Khóa bán tạm thời, ghi rõ hạng mục cần sửa." },
    { value: "HuHaiNang", label: "Hư hại nặng", target: "Maintenance", tone: "danger", summary: "Không đạt tiêu chuẩn vận hành.", note: "Khóa khỏi inventory đến khi bảo trì xác nhận xong." },
    { value: "DangBaoTri", label: "Đang bảo trì", target: "Maintenance", tone: "danger", summary: "Phòng đang được xử lý kỹ thuật.", note: "Tiếp tục giữ trạng thái bảo trì và ghi tiến độ." }
  ];
  const conditionLabel = (value) => (conditionOptions.find((item) => item.value === value)?.label || value || "Không rõ");
  const realtimeClass = (value) => {
    if (value === "Available") return "inspect-pill--ok";
    if (value === "Cleaning") return "inspect-pill--cleaning";
    if (value === "Maintenance") return "inspect-pill--danger";
    if (value === "Booked") return "inspect-pill--booked";
    if (value === "Stayed") return "inspect-pill--stayed";
    return "inspect-pill--muted";
  };
  const formatDateTime = (value) => {
    if (!value) return "Chưa rõ";
    try {
      return new Intl.DateTimeFormat("vi-VN", {
        day: "2-digit",
        month: "2-digit",
        year: "numeric",
        hour: "2-digit",
        minute: "2-digit"
      }).format(new Date(value));
    } catch (_err) {
      return value;
    }
  };
%>

<style>
