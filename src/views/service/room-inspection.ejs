    background:linear-gradient(180deg,#ffffff,#f4fbff);
    color:var(--ink-dark);
    box-shadow:0 12px 28px rgba(0,0,0,.10);
  }
  .inspect-condition strong{color:#0b253f}
  .inspect-condition span{color:var(--muted-dark)}
  .inspect-condition[data-active="true"]{
    border-color:#22d3ee;
    box-shadow:0 0 0 5px rgba(34,211,238,.16),0 16px 36px rgba(0,0,0,.14);
  }
  .inspect-pill{
    border:1px solid rgba(100,116,139,.18);
    background:#eef6ff;
    color:#334155;
  }
  .inspect-pill--ok{background:#d1fae5;color:#047857;border-color:#86efac}
  .inspect-pill--cleaning{background:#cffafe;color:#0e7490;border-color:#67e8f9}
  .inspect-pill--warning{background:#fff7d6;color:#854d0e;border-color:#fde68a}
  .inspect-pill--danger{background:#ffe4e6;color:#be123c;border-color:#fda4af}
  .inspect-pill--booked{background:#ede9fe;color:#6d28d9;border-color:#c4b5fd}
  .inspect-pill--stayed{background:#ccfbf1;color:#0f766e;border-color:#5eead4}
  .inspect-pill--muted{background:#f1f5f9;color:#475569;border-color:#cbd5e1}
  .inspect-snapshot{
    border:1px solid rgba(148,210,255,.24);
    background:
      radial-gradient(circle at 74% 28%,rgba(34,211,238,.18),transparent 28%),
      linear-gradient(145deg,rgba(5,12,31,.96),rgba(16,28,69,.88));
    box-shadow:var(--shadow),inset 0 0 90px rgba(34,211,238,.10);
  }
  .inspect-snapshot h3{color:#fff}
  .inspect-queue-item,
  .inspect-room,
  .inspect-log,
  .inspect-empty{
    border:1px solid rgba(183,207,225,.78);
    background:linear-gradient(180deg,#ffffff,#eef8ff);
    color:var(--ink-dark);
    box-shadow:0 20px 48px rgba(0,0,0,.18);
  }
  .inspect-queue-item strong,
  .inspect-room h3,
  .inspect-log strong{
    color:#0b253f;
  }
  .inspect-queue-item .inspect-muted,
  .inspect-room p,
  .inspect-log p,
  .inspect-source,
  .inspect-empty{
    color:var(--muted-dark);
  }
  .inspect-room-top{
    align-items:flex-start;
    flex-wrap:wrap;
  }
  .inspect-room .inspect-mini,
  .inspect-queue-item .inspect-mini{
    color:#0b253f;
    border-color:rgba(183,207,225,.85);
    background:#ffffff;
    box-shadow:0 10px 22px rgba(0,0,0,.08);
  }
  .inspect-room .inspect-actions{
    gap:8px;
  }
  @keyframes inspect-star-drift{
    from{background-position:12px 24px,70px 42px,28px 96px}
    to{background-position:132px 144px,250px 222px,288px 356px}
  }
  @media(max-width:1080px){
    .inspect-hero,
    .inspect-layout{grid-template-columns:1fr}
    .inspect-stats{grid-template-columns:repeat(3,minmax(0,1fr))}
    .inspect-filter{grid-template-columns:repeat(2,minmax(0,1fr))}
    .inspect-condition-grid,
    .inspect-room-grid{grid-template-columns:repeat(2,minmax(0,1fr))}
    .inspect-queue{grid-template-columns:1fr}
  }
  @media(max-width:720px){
    .inspect-shell{padding:22px 12px 44px}
    .inspect-hero,
    .inspect-panel{padding:22px;border-radius:26px}
    .inspect-hero{min-height:auto}
    .inspect-hero::after{width:230px;height:150px;right:-90px;bottom:-64px}
    .inspect-hero h1{font-size:42px}
    .inspect-hero-board,
    .inspect-stats,
    .inspect-filter,
    .inspect-form-grid,
    .inspect-condition-grid,
    .inspect-room-grid,
    .inspect-history{grid-template-columns:1fr}
    .inspect-snapshot dl{grid-template-columns:1fr}
    .inspect-button{width:100%}
  }
</style>

<main class="inspect-shell">
  <div class="inspect-wrap">
    <% if (notice?.error) { %><div class="inspect-alert inspect-alert--error"><%= notice.error %></div><% } %>
    <% if (notice?.success) { %><div class="inspect-alert inspect-alert--success"><%= notice.success %></div><% } %>

    <section class="inspect-hero" aria-label="Kiểm tra tình trạng phòng">
      <div>
        <span class="inspect-chip">Room inspection</span>
        <h1>Kiểm tra <span>tình trạng phòng</span></h1>
        <p class="inspect-lead">Cập nhật Available, Cleaning hoặc Maintenance sau khi kiểm tra thực tế.</p>
        <div class="inspect-actions">
          <a class="inspect-button inspect-button--primary" href="/service/room-board-live">Mở Room board live</a>
          <a class="inspect-button" href="/dashboard/dichvu">Dashboard dịch vụ</a>
        </div>
      </div>
      <div class="inspect-hero-board" aria-label="Tóm tắt vận hành">
        <div class="inspect-hero-metric"><strong><%= roomFeed.summary?.needsAttention || 0 %></strong><span>Phòng cần xử lý</span></div>
        <div class="inspect-hero-metric"><strong><%= actionableRooms.length %></strong><span>Có thể kiểm tra ngay</span></div>
        <div class="inspect-hero-metric"><strong><%= roomFeed.summary?.available || 0 %></strong><span>Available</span></div>
        <div class="inspect-hero-metric"><strong><%= lockedRooms.length %></strong><span>Đang khóa thao tác</span></div>
      </div>
    </section>

    <section class="inspect-stats" aria-label="KPI tình trạng phòng">
      <div class="inspect-stat"><strong><%= rooms.length %></strong><span>Tổng phòng</span></div>
      <div class="inspect-stat"><strong><%= roomFeed.summary?.cleaning || 0 %></strong><span>Cleaning</span></div>
      <div class="inspect-stat"><strong><%= roomFeed.summary?.maintenance || 0 %></strong><span>Maintenance</span></div>
      <div class="inspect-stat"><strong><%= roomFeed.summary?.booked || 0 %></strong><span>Booked</span></div>
      <div class="inspect-stat"><strong><%= roomFeed.summary?.stayed || 0 %></strong><span>Đang ở</span></div>
    </section>

    <section class="inspect-filter" aria-label="Lọc phòng kiểm tra">
      <div class="inspect-field">
        <label for="roomSearch">Tìm phòng</label>
        <input id="roomSearch" type="search" placeholder="Số phòng, khách sạn, khách, mã booking...">
      </div>
      <div class="inspect-field">
        <label for="statusFilter">Trạng thái</label>
        <select id="statusFilter">
          <option value="all">Tất cả</option>
          <option value="Maintenance">Maintenance</option>
          <option value="Cleaning">Cleaning</option>
          <option value="Available">Available</option>
          <option value="Booked">Booked</option>
          <option value="Stayed">Đang ở</option>
        </select>
      </div>
      <div class="inspect-field">
        <label for="hotelFilter">Cơ sở</label>
        <select id="hotelFilter">
          <option value="all">Toàn bộ cơ sở</option>
          <% (roomFeed.byHotel || []).forEach((hotel) => { %>
            <option value="<%= hotel.hotelId %>"><%= hotel.hotelName %></option>
          <% }) %>
        </select>
      </div>
      <label class="inspect-toggle" for="actionableOnly">
        <input id="actionableOnly" type="checkbox">
        Phòng cập nhật được
      </label>
      <button class="inspect-button" type="button" id="resetFilters">Đặt lại</button>
    </section>

    <section class="inspect-layout" aria-label="Cập nhật inspection">
      <div class="inspect-panel">
        <h2>Cập nhật tình trạng sau kiểm tra</h2>
        <p class="inspect-muted">Phòng có booking mở hoặc khách đang ở sẽ bị khóa cập nhật.</p>

        <form method="post" action="/service/inspection" id="inspectionForm">
          <div class="inspect-form-grid">
            <div class="inspect-field">
              <label for="room_id">Phòng</label>
              <select id="room_id" name="room_id" required>
                <option value="">Chọn phòng cần kiểm tra</option>
                <% actionableRooms.forEach((room) => { %>
                  <option value="<%= room.id %>" <%= Number(selectedRoomId) === Number(room.id) ? "selected" : "" %>>
                    P<%= room.soPhong %> · <%= room.hotelName %> · <%= room.statusLabel || room.trangThaiRealtime %>
                  </option>
                <% }) %>
                <% if (lockedRooms.length) { %>
                  <optgroup label="Đang có booking/khách ở, chỉ xem">
                    <% lockedRooms.forEach((room) => { %>
                      <option value="<%= room.id %>" disabled>P<%= room.soPhong %> · <%= room.hotelName %> · <%= room.statusLabel || room.trangThaiRealtime %></option>
                    <% }) %>
                  </optgroup>
                <% } %>
              </select>
            </div>
            <div class="inspect-field">
              <label for="room_condition">Kết quả kiểm tra</label>
              <select id="room_condition" name="room_condition" required>
                <% conditionOptions.forEach((option) => { %>
                  <option value="<%= option.value %>" <%= conditionValue === option.value ? "selected" : "" %> data-target="<%= option.target %>"><%= option.label %> · <%= option.target %></option>
                <% }) %>
              </select>
            </div>
            <div class="inspect-field inspect-field--wide">
              <label for="note">Ghi chú</label>
              <textarea id="note" name="note" placeholder="VD: minibar đủ, toilet sạch, điều hòa lỗi E4, thảm ướt cần xử lý..."><%= noteValue %></textarea>
              <span class="inspect-muted" id="noteHint">Bắt buộc khi chọn hư hại hoặc bảo trì.</span>
            </div>
          </div>

          <div class="inspect-condition-grid" aria-label="Rule chuyển trạng thái">
            <% conditionOptions.forEach((option) => { %>
              <div class="inspect-condition" data-condition="<%= option.value %>" data-active="<%= conditionValue === option.value ? "true" : "false" %>">
                <span class="inspect-pill <%= option.tone === "ok" ? "inspect-pill--ok" : option.tone === "cleaning" ? "inspect-pill--cleaning" : option.tone === "warning" ? "inspect-pill--warning" : "inspect-pill--danger" %>"><%= option.target %></span>
                <strong><%= option.label %></strong>
                <span><%= option.summary %></span>
              </div>
            <% }) %>
          </div>

          <div class="inspect-actions">
            <button class="inspect-button inspect-button--primary" type="submit">Lưu inspection</button>
            <a class="inspect-button" href="/service/room-inspection">Làm mới</a>
          </div>
        </form>
      </div>

      <aside class="inspect-snapshot" aria-label="Snapshot phòng đang chọn">
        <span id="snapshotStatus" class="inspect-pill <%= selectedRoom ? realtimeClass(selectedRoom.trangThaiRealtime || selectedRoom.trangThai) : "inspect-pill--muted" %>">
          <%= selectedRoom ? (selectedRoom.statusLabel || selectedRoom.trangThaiRealtime || selectedRoom.trangThai) : "Chưa chọn phòng" %>
        </span>
        <h3 id="snapshotTitle"><%= selectedRoom ? `Phòng ${selectedRoom.soPhong}` : "Chọn phòng" %></h3>
        <p id="snapshotHotel"><%= selectedRoom ? `${selectedRoom.hotelName}${selectedRoom.hotelCity ? ` · ${selectedRoom.hotelCity}` : ""}` : "Xem nhanh trước khi cập nhật." %></p>
        <p id="snapshotGuest"><%= selectedRoom ? (selectedRoom.occupancyLabel || selectedRoom.bookingCode || "Không có giao dịch mở") : "Phòng có khách/booking sẽ bị khóa." %></p>
        <dl>
          <div>
            <dt>Loại phòng</dt>
            <dd id="snapshotType"><%= selectedRoom?.loaiPhong || "Chưa chọn" %></dd>
          </div>
          <div>
            <dt>Tình trạng</dt>
            <dd id="snapshotCondition"><%= selectedRoom?.conditionLabel || "Chưa chọn" %></dd>
          </div>
          <div>
            <dt>Ưu tiên</dt>
            <dd id="snapshotPriority"><%= selectedRoom?.priorityLabel || "Chưa chọn" %></dd>
          </div>
          <div>
            <dt>Khả dụng</dt>
            <dd id="snapshotAccess"><%= selectedRoom ? (isRoomActionable(selectedRoom) ? "Có thể cập nhật" : "Đang khóa") : "Chưa chọn" %></dd>
          </div>
        </dl>
        <p style="margin-top:18px" id="snapshotAction"><%= selectedRoom?.suggestedAction || "Chọn phòng để bắt đầu." %></p>
        <p>Kết quả sẽ ghi nhận: <strong id="snapshotConditionTarget"><%= conditionLabel(conditionValue) %></strong></p>
      </aside>
    </section>

    <% if ((roomFeed.priorityQueue || []).length) { %>
      <section class="inspect-panel" style="margin-top:16px" aria-label="Hàng ưu tiên kiểm tra">
        <h2>Hàng ưu tiên</h2>
        <p class="inspect-muted">Phòng cần xử lý trước.</p>
        <div class="inspect-queue">
          <% roomFeed.priorityQueue.slice(0, 6).forEach((room) => { %>
            <div class="inspect-queue-item">
              <span class="inspect-pill <%= realtimeClass(room.trangThaiRealtime) %>"><%= room.statusLabel || room.trangThaiRealtime %></span>
              <strong><%= room.hotelName %> · P<%= room.soPhong %></strong>
              <p class="inspect-muted"><%= room.priorityLabel %> · <%= room.conditionLabel %></p>
              <% if (isRoomActionable(room)) { %>
                <button class="inspect-mini" type="button" data-room-select="<%= room.id %>">Chọn kiểm tra</button>
              <% } else { %>
                <span class="inspect-mini" aria-disabled="true">Chỉ theo dõi</span>
              <% } %>
            </div>
          <% }) %>
        </div>
      </section>
    <% } %>

    <div class="inspect-board-head">
      <div>
        <h2>Danh sách phòng</h2>
        <p class="inspect-muted"><span id="visibleCount"><%= rooms.length %></span>/<%= rooms.length %> phòng phù hợp bộ lọc.</p>
      </div>
    </div>

    <% if (!rooms.length) { %>
      <div class="inspect-empty">Chưa có dữ liệu phòng trong room feed.</div>
    <% } else { %>
      <section class="inspect-room-grid" id="roomGrid" aria-label="Danh sách phòng kiểm tra">
        <% rooms.forEach((room) => { %>
          <article
            class="inspect-room"
            data-room-card
            data-room-id="<%= room.id %>"
            data-status="<%= room.trangThaiRealtime || room.trangThai %>"
            data-hotel="<%= room.hotelId || 0 %>"
            data-actionable="<%= isRoomActionable(room) ? "1" : "0" %>"
            data-search="<%= room.searchText || [room.soPhong, room.hotelName, room.hotelCity, room.bookingCode, room.guestName, room.loaiPhong].filter(Boolean).join(" ").toLowerCase() %>"
          >
            <div class="inspect-room-top">
              <span class="inspect-pill <%= realtimeClass(room.trangThaiRealtime || room.trangThai) %>"><%= room.statusLabel || room.trangThaiRealtime || room.trangThai %></span>
              <span class="inspect-pill <%= isRoomActionable(room) ? "inspect-pill--ok" : "inspect-pill--muted" %>"><%= isRoomActionable(room) ? "Có thể kiểm tra" : "Đang khóa" %></span>
            </div>
            <h3><%= room.hotelName %> · P<%= room.soPhong %></h3>
            <p><%= room.loaiPhong %> · <%= room.hotelCity || "Chưa rõ cơ sở" %></p>
            <p><%= room.occupancyLabel || room.bookingCode || "Không có giao dịch mở" %></p>
            <p><strong><%= room.priorityLabel || "Theo dõi" %></strong> · <%= room.conditionLabel || room.tinhTrangPhong || "Không rõ" %></p>
            <div class="inspect-actions">
              <% if (isRoomActionable(room)) { %>
                <button class="inspect-mini" type="button" data-room-select="<%= room.id %>">Chọn kiểm tra</button>
              <% } else { %>
                <span class="inspect-mini" aria-disabled="true">Chỉ xem</span>
              <% } %>
              <a class="inspect-mini" href="/service/room-board-live">Room board</a>
            </div>
          </article>
        <% }) %>
      </section>
    <% } %>

    <section class="inspect-panel" style="margin-top:16px" aria-label="Lịch sử kiểm tra gần đây">
      <h2>Lịch sử inspection gần đây</h2>
      <p class="inspect-muted">Các lần cập nhật phòng gần nhất.</p>
      <% if (!inspectionHistory.length) { %>
        <div class="inspect-empty">Chưa có log inspection gần đây.</div>
      <% } else { %>
        <div class="inspect-history">
          <% inspectionHistory.forEach((item) => { %>
            <article class="inspect-log">
              <span class="inspect-source"><%= formatDateTime(item.happenedAt) %> · <%= item.source || "HeThong" %></span>
              <strong><%= item.hotelName %> · P<%= item.roomNumber %></strong>
              <p><%= item.fromStatus || "?" %> → <%= item.toStatus || "?" %></p>
              <p><%= item.note || "Không có ghi chú." %></p>
            </article>
          <% }) %>
        </div>
      <% } %>
    </section>
  </div>
</main>

<script>
  (() => {
    const rooms = <%- JSON.stringify(rooms).replace(/</g, "\\u003c") %>;
    const conditions = <%- JSON.stringify(conditionOptions).replace(/</g, "\\u003c") %>;
    const byId = new Map(rooms.map((room) => [String(room.id), room]));
    const cards = Array.from(document.querySelectorAll("[data-room-card]"));
    const search = document.getElementById("roomSearch");
    const statusFilter = document.getElementById("statusFilter");
    const hotelFilter = document.getElementById("hotelFilter");
    const actionableOnly = document.getElementById("actionableOnly");
    const resetFilters = document.getElementById("resetFilters");
    const visibleCount = document.getElementById("visibleCount");
    const roomSelect = document.getElementById("room_id");
    const conditionSelect = document.getElementById("room_condition");
    const note = document.getElementById("note");
    const noteHint = document.getElementById("noteHint");

    const statusClass = (value) => {
      if (value === "Available") return "inspect-pill inspect-pill--ok";
      if (value === "Cleaning") return "inspect-pill inspect-pill--cleaning";
      if (value === "Maintenance") return "inspect-pill inspect-pill--danger";
      if (value === "Booked") return "inspect-pill inspect-pill--booked";
      if (value === "Stayed") return "inspect-pill inspect-pill--stayed";
      return "inspect-pill inspect-pill--muted";
    };

    const applyFilters = () => {
      const keyword = (search?.value || "").trim().toLowerCase();
      const status = statusFilter?.value || "all";
      const hotel = hotelFilter?.value || "all";
      const actionable = Boolean(actionableOnly?.checked);
      let count = 0;

      cards.forEach((card) => {
        const matchesKeyword = !keyword || (card.dataset.search || "").includes(keyword);
        const matchesStatus = status === "all" || card.dataset.status === status;
        const matchesHotel = hotel === "all" || card.dataset.hotel === hotel;
        const matchesActionable = !actionable || card.dataset.actionable === "1";
        const visible = matchesKeyword && matchesStatus && matchesHotel && matchesActionable;
        card.dataset.hidden = visible ? "false" : "true";
        if (visible) count += 1;
      });

      if (visibleCount) visibleCount.textContent = String(count);
    };

    const updateCondition = () => {
      const selected = conditions.find((item) => item.value === conditionSelect?.value) || conditions[0];
      document.querySelectorAll("[data-condition]").forEach((node) => {
        node.dataset.active = node.dataset.condition === selected.value ? "true" : "false";
      });
      const target = document.getElementById("snapshotConditionTarget");
      if (target) target.textContent = selected.label;
      if (note && noteHint) {
        const needsNote = ["HuHaiNhe", "HuHaiNang", "DangBaoTri"].includes(selected.value);
        note.required = needsNote;
        note.minLength = needsNote ? 8 : 0;
        noteHint.textContent = needsNote ? "Bắt buộc ghi rõ lỗi, vị trí và mức độ để bảo trì xử lý." : selected.note;
      }
    };

    const updateSnapshot = () => {
      const room = byId.get(String(roomSelect?.value || ""));
      const status = document.getElementById("snapshotStatus");
      const title = document.getElementById("snapshotTitle");
      const hotel = document.getElementById("snapshotHotel");
      const guest = document.getElementById("snapshotGuest");
      const type = document.getElementById("snapshotType");
      const condition = document.getElementById("snapshotCondition");
      const priority = document.getElementById("snapshotPriority");
      const access = document.getElementById("snapshotAccess");
      const action = document.getElementById("snapshotAction");

      if (!room) {
        if (status) {
          status.className = "inspect-pill inspect-pill--muted";
          status.textContent = "Chưa chọn phòng";
        }
        if (title) title.textContent = "Chọn phòng để xem nhanh";
        if (hotel) hotel.textContent = "Xem nhanh trước khi cập nhật.";
        if (guest) guest.textContent = "Phòng có khách/booking sẽ bị khóa.";
        if (type) type.textContent = "Chưa chọn";
        if (condition) condition.textContent = "Chưa chọn";
        if (priority) priority.textContent = "Chưa chọn";
        if (access) access.textContent = "Chưa chọn";
        if (action) action.textContent = "Chọn phòng để bắt đầu.";
        return;
      }

      const realtime = room.trangThaiRealtime || room.trangThai || "Unknown";
      if (status) {
        status.className = statusClass(realtime);
        status.textContent = room.statusLabel || realtime;
      }
      if (title) title.textContent = `Phòng ${room.soPhong}`;
      if (hotel) hotel.textContent = [room.hotelName, room.hotelCity].filter(Boolean).join(" · ");
      if (guest) guest.textContent = room.occupancyLabel || room.bookingCode || "Không có giao dịch mở";
      if (type) type.textContent = room.loaiPhong || "Chưa rõ";
      if (condition) condition.textContent = room.conditionLabel || room.tinhTrangPhong || "Không rõ";
      if (priority) priority.textContent = room.priorityLabel || "Theo dõi";
      if (access) access.textContent = room.canInspect === false || room.isLocked ? "Đang khóa" : "Có thể cập nhật";
      if (action) action.textContent = room.suggestedAction || "Kiểm tra thực tế rồi cập nhật kết quả.";
    };

    [search, statusFilter, hotelFilter, actionableOnly].forEach((node) => node?.addEventListener("input", applyFilters));
    resetFilters?.addEventListener("click", () => {
      if (search) search.value = "";
      if (statusFilter) statusFilter.value = "all";
      if (hotelFilter) hotelFilter.value = "all";
      if (actionableOnly) actionableOnly.checked = false;
      applyFilters();
    });
    document.querySelectorAll("[data-room-select]").forEach((button) => {
      button.addEventListener("click", () => {
        if (!roomSelect) return;
        roomSelect.value = button.getAttribute("data-room-select") || "";
        roomSelect.dispatchEvent(new Event("change", { bubbles: true }));
        document.getElementById("inspectionForm")?.scrollIntoView({ behavior: "smooth", block: "center" });
      });
    });
    roomSelect?.addEventListener("change", updateSnapshot);
    conditionSelect?.addEventListener("change", updateCondition);
    applyFilters();
    updateCondition();
    updateSnapshot();
  })();
</script>

<%- include("../partials/footer") %>
