<%- include("../partials/head") %>
<%- include("../partials/header") %>
<%
  const roomFeed = payload.roomFeed || { summary: {}, items: [] };
  const rooms = roomFeed.items || [];
  const draft = (typeof inspectionDraft !== "undefined" && inspectionDraft) ? inspectionDraft : {};
  const selectedRoomId = Number(draft.room_id || query?.room_id || 0);
  const selectedRoom = selectedRoomId ? rooms.find((item) => Number(item.id) === selectedRoomId) : null;
  const isRoomLocked = (room) => Boolean(room?.transactionId) || ["Booked", "Stayed"].includes(room?.trangThai || "");
  const isRoomActionable = (room) => !isRoomLocked(room);
  const actionableRooms = rooms.filter(isRoomActionable);
  const lockedRooms = rooms.filter(isRoomLocked);
  const conditionValue = draft.room_condition || query?.room_condition || "Tot";
  const noteValue = draft.note || "";
  const conditionOptions = [
    { value: "Tot", label: "Tốt", target: "Available", tone: "ok", description: "Phòng sạch, sẵn sàng vận hành." },
    { value: "CanVeSinh", label: "Cần vệ sinh", target: "Cleaning", tone: "cleaning", description: "Cần housekeeping xử lý trước khi bán/nhận khách tiếp." },
    { value: "HuHaiNhe", label: "Hư hại nhẹ", target: "Maintenance", tone: "warning", description: "Có hư hại nhỏ, cần ghi chú để bảo trì kiểm tra." },
    { value: "HuHaiNang", label: "Hư hại nặng", target: "Maintenance", tone: "danger", description: "Khóa bán, ưu tiên bảo trì trước khi đưa về trạng thái sẵn sàng." },
    { value: "DangBaoTri", label: "Đang bảo trì", target: "Maintenance", tone: "danger", description: "Phòng đang trong luồng bảo trì, không phục vụ khách." }
  ];
  const conditionLabel = (value) => (conditionOptions.find((item) => item.value === value)?.label || value || "Không rõ");
  const realtimeClass = (value) => {
    if (value === "Available") return "inspect-badge--ok";
    if (value === "Cleaning") return "inspect-badge--cleaning";
    if (value === "Maintenance") return "inspect-badge--danger";
    return "inspect-badge--muted";
  };
  const roomPriority = (room) => {
    if (room.trangThaiRealtime === "Maintenance" || room.trangThai === "BaoTri") return "Ưu tiên bảo trì";
    if (room.trangThaiRealtime === "Cleaning") return "Cần vệ sinh";
    if (room.trangThai === "Stayed") return "Đang có khách";
    if (room.trangThai === "Booked") return "Sắp nhận khách";
    return "Theo dõi";
  };
%>

<style>
  .inspect-shell{
    --ink:#102033;
    --muted:#667085;
    --line:rgba(16,32,51,.10);
    --card:rgba(255,255,255,.82);
    --teal:#14b8a6;
    --blue:#0ea5e9;
    --lime:#a3e635;
    --amber:#f59e0b;
    --rose:#fb7185;
    --shadow:0 26px 76px rgba(15,23,42,.16);
    min-height:calc(100vh - 84px);
    padding:34px 18px 56px;
    color:var(--ink);
    background:
      radial-gradient(circle at 7% 8%,rgba(14,165,233,.25),transparent 32%),
      radial-gradient(circle at 86% 10%,rgba(20,184,166,.26),transparent 34%),
      radial-gradient(circle at 46% 105%,rgba(163,230,53,.20),transparent 40%),
      linear-gradient(135deg,#fbfffb 0%,#eefcf7 44%,#f7fbff 100%);
  }
  .inspect-wrap{max-width:1220px;margin:0 auto}
  .inspect-hero,.inspect-card,.inspect-room-card,.inspect-stat{border:1px solid var(--line);background:var(--card);box-shadow:var(--shadow);backdrop-filter:blur(22px)}
  .inspect-hero{position:relative;overflow:hidden;border-radius:34px;padding:34px;margin-bottom:18px}
  .inspect-chip{display:inline-flex;align-items:center;border-radius:999px;padding:7px 12px;background:rgba(14,165,233,.12);border:1px solid rgba(14,165,233,.22);color:#0369a1;font-size:12px;font-weight:1000;letter-spacing:.08em;text-transform:uppercase}
  .inspect-hero h1{max-width:780px;margin:22px 0 12px;font-size:clamp(38px,5.8vw,68px);line-height:.92;letter-spacing:-.07em}
  .inspect-hero h1 span{color:transparent;background:linear-gradient(100deg,#0284c7,#0f766e 52%,#65a30d);-webkit-background-clip:text;background-clip:text}
  .inspect-lead{max-width:760px;margin:0;color:var(--muted);font-size:16px;line-height:1.7}
  .inspect-actions{display:flex;flex-wrap:wrap;gap:10px;margin-top:24px}
  .inspect-button,.inspect-mini-button{display:inline-flex;align-items:center;justify-content:center;border-radius:999px;text-decoration:none;font-weight:950;cursor:pointer}
  .inspect-button{min-height:44px;padding:10px 17px;border:1px solid rgba(16,32,51,.12);background:rgba(255,255,255,.76);color:var(--ink)}
  .inspect-button--primary{color:#fff;border-color:transparent;background:linear-gradient(135deg,#0891b2,#14b8a6);box-shadow:0 18px 38px rgba(20,184,166,.22)}
  .inspect-card{border-radius:30px;padding:22px;margin-bottom:18px}
  .inspect-card h2{margin:0 0 8px;font-size:24px;letter-spacing:-.04em}
  .inspect-muted{color:var(--muted);font-size:13px;line-height:1.55}
  .inspect-alert{border-radius:18px;padding:12px 14px;margin-bottom:14px;border:1px solid transparent}
  .inspect-alert--error{background:rgba(251,113,133,.14);color:#be123c;border-color:rgba(251,113,133,.30)}
  .inspect-alert--success{background:rgba(20,184,166,.14);color:#0f766e;border-color:rgba(20,184,166,.30)}
  .inspect-grid{display:grid;grid-template-columns:repeat(12,1fr);gap:16px}
  .inspect-form-grid{display:grid;grid-template-columns:1.2fr 1fr;gap:16px;align-items:start}
  .inspect-field{display:flex;flex-direction:column;gap:6px;margin-top:10px}
  .inspect-field label{font-size:13px;font-weight:900;color:#344054}
  .inspect-field input,.inspect-field select,.inspect-field textarea{width:100%;border:1px solid rgba(16,32,51,.14);border-radius:16px;padding:12px 14px;background:rgba(255,255,255,.76);color:var(--ink);font:inherit;outline:none}
  .inspect-field textarea{min-height:94px;resize:vertical}
  .inspect-field input:focus,.inspect-field select:focus,.inspect-field textarea:focus{border-color:rgba(14,165,233,.50);box-shadow:0 0 0 3px rgba(14,165,233,.10)}
  .inspect-summary{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px;margin:16px 0}
  .inspect-stat{border-radius:22px;padding:16px;background:rgba(255,255,255,.58);border:1px solid rgba(16,32,51,.08)}
  .inspect-stat strong{display:block;font-size:28px;line-height:1;letter-spacing:-.05em}
  .inspect-stat span{display:block;margin-top:8px;color:var(--muted);font-size:12px;font-weight:900;text-transform:uppercase;letter-spacing:.06em}
  .inspect-preview{border-radius:24px;padding:18px;background:linear-gradient(145deg,rgba(15,23,42,.88),rgba(12,74,110,.72));color:#eef6ff;min-height:260px}
  .inspect-preview h3{margin:18px 0 10px;font-size:30px;letter-spacing:-.05em}
  .inspect-preview p{margin:0 0 8px;color:rgba(238,246,255,.76)}
  .inspect-badge{display:inline-flex;border-radius:999px;padding:5px 9px;background:rgba(20,184,166,.14);color:#0f766e;font-size:11px;font-weight:1000;letter-spacing:.04em}
  .inspect-badge--ok{background:rgba(20,184,166,.14);color:#0f766e}
  .inspect-badge--cleaning{background:rgba(14,165,233,.14);color:#0369a1}
  .inspect-badge--warning{background:rgba(245,158,11,.15);color:#b45309}
  .inspect-badge--danger{background:rgba(251,113,133,.15);color:#be123c}
  .inspect-badge--muted{background:rgba(100,116,139,.12);color:#475569}
  .inspect-room-card{grid-column:span 4;border-radius:26px;padding:18px;background:rgba(255,255,255,.72)}
  .inspect-room-card h3{margin:12px 0 8px;font-size:22px;letter-spacing:-.04em}
  .inspect-room-card p{margin:0 0 6px;color:var(--muted);font-size:13px;line-height:1.5}
  .inspect-mini-button{min-height:34px;padding:7px 11px;border:1px solid rgba(16,32,51,.12);background:rgba(255,255,255,.75);color:var(--ink);font-size:12px}
  .inspect-empty{border:1px dashed rgba(16,32,51,.14);border-radius:22px;padding:22px;background:rgba(255,255,255,.58);color:var(--muted)}
  @media(max-width:980px){.inspect-form-grid{grid-template-columns:1fr}.inspect-room-card{grid-column:span 6}}
  @media(max-width:760px){.inspect-shell{padding:20px 12px 42px}.inspect-hero{padding:24px}.inspect-summary{grid-template-columns:1fr}.inspect-room-card{grid-column:1/-1}}
</style>

<main class="inspect-shell">
  <div class="inspect-wrap">
    <% if (notice?.error) { %><div class="inspect-alert inspect-alert--error"><%= notice.error %></div><% } %>
    <% if (notice?.success) { %><div class="inspect-alert inspect-alert--success"><%= notice.success %></div><% } %>

    <section class="inspect-hero" aria-label="Kiểm tra tình trạng phòng">
      <span class="inspect-chip">Kiểm tra tình trạng phòng</span>
      <h1>Room inspection <span>riêng biệt.</span></h1>
      <p class="inspect-lead">
        Trang này chỉ xử lý kiểm tra và cập nhật tình trạng phòng: chọn phòng, ghi nhận trạng thái thực tế,
        đồng bộ room status realtime và tạo log vận hành để lễ tân/quản lý theo dõi.
      </p>
      <div class="inspect-actions">
        <a class="inspect-button inspect-button--primary" href="/dashboard/dichvu">Quay lại dashboard</a>
        <a class="inspect-button" href="/service/room-board-live">Mở Room board live</a>
      </div>
    </section>

    <section class="inspect-card">
      <h2>Cập nhật tình trạng sau kiểm tra</h2>
      <p class="inspect-muted">Logic cập nhật giữ đúng nghiệp vụ hiện có: chỉ phòng không có booking/khách ở mới được cập nhật. Tốt đưa về Available; Cần vệ sinh giữ ở Cleaning; hư hại/bảo trì khóa sang Maintenance.</p>

      <div class="inspect-summary">
        <div class="inspect-stat"><strong><%= rooms.length %></strong><span>Tổng phòng feed</span></div>
        <div class="inspect-stat"><strong><%= actionableRooms.length %></strong><span>Có thể kiểm tra</span></div>
        <div class="inspect-stat"><strong><%= roomFeed.summary.cleaning || 0 %></strong><span>Cần vệ sinh</span></div>
        <div class="inspect-stat"><strong><%= lockedRooms.length %></strong><span>Đang khóa</span></div>
      </div>

      <div class="inspect-form-grid">
        <form method="post" action="/service/inspection">
          <div class="inspect-field">
            <label for="room_id">Phòng cần kiểm tra <span style="color:#be123c">*</span></label>
            <select id="room_id" name="room_id" required>
              <option value="">-- Chọn phòng --</option>
              <% actionableRooms.forEach((room) => { %>
                <option value="<%= room.id %>" <%= Number(selectedRoomId) === Number(room.id) ? "selected" : "" %>>
                  P<%= room.soPhong %> · <%= room.hotelName %> · <%= room.trangThaiRealtime || room.trangThai %>
                </option>
              <% }) %>
              <% if (lockedRooms.length) { %>
                <optgroup label="Đang có booking/khách ở - chỉ xem">
                  <% lockedRooms.forEach((room) => { %>
                    <option value="<%= room.id %>" disabled>
                      P<%= room.soPhong %> · <%= room.hotelName %> · <%= room.trangThaiRealtime || room.trangThai %>
                    </option>
                  <% }) %>
                </optgroup>
              <% } %>
            </select>
          </div>
          <div class="inspect-field">
            <label for="room_condition">Tình trạng thực tế <span style="color:#be123c">*</span></label>
            <select id="room_condition" name="room_condition" required>
              <% conditionOptions.forEach((option) => { %>
                <option value="<%= option.value %>" <%= conditionValue === option.value ? "selected" : "" %>>
                  <%= option.label %> · realtime: <%= option.target %>
                </option>
              <% }) %>
            </select>
          </div>
          <div class="inspect-field">
            <label for="note">Ghi chú kiểm tra</label>
            <textarea id="note" name="note" placeholder="VD: thay khăn, kiểm tra điều hòa, khóa bán vì thấm nước..."><%= noteValue %></textarea>
          </div>
          <div class="inspect-actions">
            <button class="inspect-button inspect-button--primary" type="submit">Cập nhật tình trạng</button>
          </div>
        </form>

        <aside class="inspect-preview" aria-label="Tóm tắt phòng đang chọn">
          <span class="inspect-badge <%= selectedRoom ? realtimeClass(selectedRoom.trangThaiRealtime || selectedRoom.trangThai) : "inspect-badge--muted" %>">
            <%= selectedRoom ? (selectedRoom.trangThaiRealtime || selectedRoom.trangThai) : "Chưa chọn phòng" %>
          </span>
          <h3><%= selectedRoom ? `Phòng ${selectedRoom.soPhong}` : "Chọn phòng để xem snapshot" %></h3>
          <% if (selectedRoom) { %>
            <p><strong><%= selectedRoom.hotelName %></strong><%= selectedRoom.hotelCity ? ` · ${selectedRoom.hotelCity}` : "" %></p>
            <p><%= selectedRoom.loaiPhong %> · trạng thái PMS: <%= selectedRoom.trangThai %></p>
            <p><%= selectedRoom.bookingCode || "Không có giao dịch mở" %> · <%= selectedRoom.guestName || "Chưa gắn khách" %></p>
            <p>Gợi ý ưu tiên: <%= roomPriority(selectedRoom) %></p>
            <% if (isRoomLocked(selectedRoom)) { %>
              <p><strong>Phòng đang khóa thao tác:</strong> cần checkout/hủy booking trước khi cập nhật inspection.</p>
            <% } %>
          <% } else { %>
            <p>Form này sẽ cập nhật trực tiếp bảng phòng, ghi log `room_status_log` và phát realtime event cho các bộ phận liên quan.</p>
          <% } %>
          <p style="margin-top:18px">Tình trạng sẽ ghi nhận: <strong><%= conditionLabel(conditionValue) %></strong></p>
        </aside>
      </div>
    </section>

    <section class="inspect-card">
      <h2>Danh sách phòng cần theo dõi</h2>
      <p class="inspect-muted">Chọn nhanh một phòng để kiểm tra. Danh sách ưu tiên các phòng bảo trì, cleaning, đang ở và booked trước.</p>
      <% if (!rooms.length) { %>
        <div class="inspect-empty">Chưa có dữ liệu phòng trong room feed.</div>
      <% } else { %>
        <div class="inspect-grid">
          <% rooms.slice(0, 24).forEach((room) => { %>
            <article class="inspect-room-card">
              <span class="inspect-badge <%= realtimeClass(room.trangThaiRealtime || room.trangThai) %>"><%= room.trangThaiRealtime || room.trangThai %></span>
              <h3><%= room.hotelName %> · P<%= room.soPhong %></h3>
              <p><%= room.loaiPhong %> · <%= room.hotelCity || "Chưa rõ cơ sở" %></p>
              <p><%= room.bookingCode || "Không có giao dịch mở" %> · <%= room.guestName || "Chưa gắn khách" %></p>
              <p><strong><%= roomPriority(room) %></strong></p>
              <div class="inspect-actions" style="margin-top:12px">
                <% if (isRoomActionable(room)) { %>
                  <a class="inspect-mini-button" href="/service/room-inspection?room_id=<%= room.id %>">Chọn kiểm tra</a>
                <% } else { %>
                  <span class="inspect-mini-button" aria-disabled="true">Đang khóa</span>
                <% } %>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </section>
  </div>
</main>

<%- include("../partials/footer") %>
