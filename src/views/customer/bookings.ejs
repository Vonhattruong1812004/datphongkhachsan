<%- include("../partials/head") %>
<%- include("../partials/header") %>
<%
  const money = (value) => Number(value || 0).toLocaleString("vi-VN") + " đ";
  const statusClass = (status) => {
    const value = String(status || "");
    if (["DaHuy", "Cancelled"].includes(value)) return "is-cancelled";
    if (["Paid", "CheckedOut"].includes(value)) return "is-paid";
    if (["Stayed", "CheckedIn"].includes(value)) return "is-stay";
    if (["Booked", "Moi"].includes(value)) return "is-booked";
    return "is-muted";
  };
%>
<style>
  body{background:radial-gradient(circle at 9% 8%,rgba(20,184,166,.26),transparent 28%),radial-gradient(circle at 87% 12%,rgba(14,165,233,.22),transparent 32%),radial-gradient(circle at 50% 100%,rgba(251,191,36,.16),transparent 34%),linear-gradient(135deg,#fffef8 0%,#edfffb 38%,#f3f9ff 100%);color:#123047}
  .history-shell{position:relative;overflow:hidden;max-width:1220px;margin:0 auto;padding:34px 18px 64px}
  .history-shell::before,.history-shell::after{content:"";position:absolute;width:500px;height:500px;border-radius:999px;pointer-events:none;z-index:-1;opacity:.43;animation:history-float 13s ease-in-out infinite alternate}
  .history-shell::before{right:-160px;top:-230px;background:conic-gradient(from 120deg,rgba(14,165,233,.44),rgba(20,184,166,.35),rgba(250,204,21,.28),rgba(251,113,133,.22),rgba(14,165,233,.44))}
  .history-shell::after{left:-190px;bottom:-250px;background:conic-gradient(from 30deg,rgba(251,113,133,.25),rgba(245,158,11,.25),rgba(45,212,191,.28),rgba(59,130,246,.20),rgba(251,113,133,.25));animation-delay:-5s}
  .history-hero,.history-panel,.history-card{border:1px solid rgba(18,48,71,.12);background:linear-gradient(180deg,rgba(255,255,255,.90),rgba(255,255,255,.70));box-shadow:0 26px 72px rgba(12,39,64,.13);backdrop-filter:blur(22px)}
  .history-hero{position:relative;overflow:hidden;border-radius:34px;padding:32px;margin-bottom:20px}
  .history-hero::before{content:"";position:absolute;right:36px;top:28px;width:120px;height:120px;border-radius:999px;background:radial-gradient(circle,#fff7d6 0 18%,#fde68a 35%,#f59e0b 64%,transparent 70%);box-shadow:0 0 0 22px rgba(253,224,71,.12),0 0 80px rgba(251,191,36,.26);animation:history-sun 7s ease-in-out infinite}
  .history-kicker{display:inline-flex;border-radius:999px;padding:7px 12px;background:rgba(20,184,166,.12);border:1px solid rgba(20,184,166,.18);color:#0f766e;font-size:12px;font-weight:1000;letter-spacing:.08em;text-transform:uppercase}
  .history-hero h1{position:relative;margin:20px 0 10px;color:#102033;font-size:clamp(40px,6vw,72px);line-height:.92;letter-spacing:-.07em}
  .history-hero h1 span{color:transparent;background:linear-gradient(110deg,#0ea5e9,#14b8a6 50%,#65a30d);-webkit-background-clip:text;background-clip:text}
  .history-muted{color:#5f778f;line-height:1.65;font-size:14px}
  .history-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:18px}
  .history-button{display:inline-flex;align-items:center;justify-content:center;min-height:42px;border-radius:999px;border:1px solid rgba(18,48,71,.12);background:linear-gradient(135deg,rgba(255,255,255,.96),rgba(242,251,255,.86));color:#14314b;padding:9px 15px;font-size:13px;font-weight:900;text-decoration:none;cursor:pointer;box-shadow:0 12px 28px rgba(12,39,64,.08)}
  .history-button--primary{border-color:transparent;color:#fff;background:linear-gradient(135deg,#0ea5e9,#14b8a6 50%,#22c55e)}
  .history-summary{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:14px;margin:18px 0 20px}
  .history-stat{border-radius:24px;border:1px solid rgba(18,48,71,.10);background:rgba(255,255,255,.72);padding:17px;box-shadow:0 18px 44px rgba(12,39,64,.09)}
  .history-stat span{display:block;color:#5f778f;font-size:12px;font-weight:900;text-transform:uppercase;letter-spacing:.07em}
  .history-stat strong{display:block;margin-top:8px;color:#102033;font-size:28px;letter-spacing:-.05em}
  .history-panel{border-radius:28px;padding:18px;margin-bottom:18px}
  .history-filter{display:grid;grid-template-columns:minmax(220px,1fr) 180px 180px auto;gap:12px;align-items:end}
  .history-field{display:grid;gap:7px}
  .history-field label{font-size:12px;font-weight:900;text-transform:uppercase;letter-spacing:.07em;color:#173651}
  .history-field input,.history-field select{min-height:46px;border-radius:16px;border:1px solid rgba(18,48,71,.12);background:rgba(255,255,255,.92);color:#102033;padding:10px 13px;font:inherit;outline:none}
  .history-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px}
  .history-card{position:relative;overflow:hidden;border-radius:30px;padding:20px;transition:transform .18s ease,box-shadow .18s ease,border-color .18s ease}
  .history-card:hover{transform:translateY(-5px);border-color:rgba(14,165,233,.32);box-shadow:0 30px 82px rgba(12,39,64,.17)}
  .history-card::before{content:"";position:absolute;width:180px;height:180px;right:-70px;top:-80px;border-radius:999px;background:radial-gradient(circle,rgba(14,165,233,.15),transparent 68%)}
  .history-card-head{position:relative;display:flex;justify-content:space-between;gap:14px;align-items:flex-start}
  .history-code{margin:10px 0 7px;color:#102033;font-size:25px;letter-spacing:-.045em}
  .history-meta{display:flex;gap:8px;flex-wrap:wrap;color:#5f778f;font-size:13px}
  .history-badge{display:inline-flex;border-radius:999px;padding:6px 10px;font-size:12px;font-weight:1000;border:1px solid rgba(18,48,71,.10);background:rgba(255,255,255,.70)}
  .history-badge.is-booked{color:#0369a1;background:rgba(14,165,233,.10);border-color:rgba(14,165,233,.20)}
  .history-badge.is-paid{color:#047857;background:rgba(34,197,94,.11);border-color:rgba(34,197,94,.20)}
  .history-badge.is-stay{color:#b45309;background:rgba(245,158,11,.12);border-color:rgba(245,158,11,.22)}
  .history-badge.is-cancelled{color:#be123c;background:rgba(244,63,94,.10);border-color:rgba(244,63,94,.18)}
  .history-badge.is-muted{color:#475569;background:rgba(148,163,184,.12)}
  .history-lines{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;margin-top:16px}
  .history-line{border-radius:18px;border:1px solid rgba(18,48,71,.09);background:rgba(255,255,255,.62);padding:12px}
  .history-line span{display:block;color:#5f778f;font-size:11px;font-weight:900;text-transform:uppercase;letter-spacing:.06em}
  .history-line strong{display:block;margin-top:6px;color:#102033;font-size:16px}
  .history-total{color:#0f766e!important;font-size:22px!important}
  .history-empty{border:1px dashed rgba(18,48,71,.18);border-radius:26px;padding:24px;background:rgba(255,255,255,.58);color:#5f778f}
  @keyframes history-float{from{transform:translate3d(0,0,0) rotate(0)}to{transform:translate3d(28px,24px,0) rotate(14deg)}}
  @keyframes history-sun{0%,100%{transform:translateY(0) scale(1)}50%{transform:translateY(-8px) scale(1.04)}}
  @media(max-width:980px){.history-summary{grid-template-columns:repeat(2,minmax(0,1fr))}.history-filter{grid-template-columns:1fr 1fr}.history-grid{grid-template-columns:1fr}}
  @media(max-width:640px){.history-shell{padding:22px 12px 48px}.history-hero,.history-panel,.history-card{border-radius:26px;padding:20px}.history-summary,.history-filter,.history-lines{grid-template-columns:1fr}.history-hero::before{width:82px;height:82px;right:18px}}
</style>

<main class="history-shell">
  <section class="history-hero">
    <span class="history-kicker">UC02 · Lịch sử và hóa đơn</span>
    <h1>Nhật ký lưu trú <span>rõ từng giao dịch.</span></h1>
    <p class="history-muted">Theo dõi booking, hóa đơn, trạng thái thanh toán, phòng đã đặt, dịch vụ bổ sung và các hành động có thể thực hiện như sửa hoặc hủy booking.</p>
    <div class="history-actions">
      <a class="history-button history-button--primary" href="/booking/search">Đặt phòng mới</a>
      <a class="history-button" href="/customer/dashboard">Về dashboard</a>
      <a class="history-button" href="/customer/services">Dịch vụ bổ sung</a>
    </div>
  </section>

  <section class="history-summary">
    <div class="history-stat"><span>Tổng booking</span><strong><%= summary.total %></strong></div>
    <div class="history-stat"><span>Đang đặt</span><strong><%= summary.booked %></strong></div>
    <div class="history-stat"><span>Đã thanh toán</span><strong><%= summary.paid %></strong></div>
    <div class="history-stat"><span>Đã hủy</span><strong><%= summary.cancelled %></strong></div>
    <div class="history-stat"><span>Tổng chi tiêu</span><strong><%= money(summary.spend) %></strong></div>
  </section>

  <section class="history-panel">
    <div class="history-filter">
      <div class="history-field">
        <label for="historyKeyword">Tìm nhanh</label>
        <input id="historyKeyword" type="search" placeholder="Mã booking, khách sạn, trạng thái..." />
      </div>
      <div class="history-field">
        <label for="historyStatus">Trạng thái</label>
        <select id="historyStatus">
          <option value="">Tất cả</option>
          <option value="Booked">Đã đặt</option>
          <option value="Paid">Đã thanh toán</option>
          <option value="Stayed">Đang ở</option>
          <option value="Cancelled">Đã hủy</option>
        </select>
      </div>
      <div class="history-field">
        <label for="historySort">Sắp xếp</label>
        <select id="historySort">
          <option value="newest">Mới nhất</option>
          <option value="amount_desc">Giá trị cao</option>
          <option value="amount_asc">Giá trị thấp</option>
        </select>
      </div>
      <button class="history-button" type="button" id="historyReset">Làm mới lọc</button>
    </div>
  </section>

  <% if (!bookings.length) { %>
    <div class="history-empty">Bạn chưa có booking nào. Khi đặt phòng thành công, toàn bộ hóa đơn và lịch sử sẽ xuất hiện tại đây.</div>
  <% } else { %>
    <section class="history-grid" id="historyGrid">
      <% bookings.forEach((booking) => { %>
        <article
          class="history-card"
          data-status="<%= booking.status %>"
          data-amount="<%= booking.total %>"
          data-search="<%= [booking.bookingCode, booking.hotelNames, booking.statusLabel, booking.paymentMethodLabel, booking.promotion?.name].filter(Boolean).join(' ').toLowerCase() %>"
        >
          <div class="history-card-head">
            <div>
              <span class="history-badge <%= statusClass(booking.status) %>"><%= booking.statusLabel %></span>
              <h2 class="history-code"><%= booking.bookingCode || `GD-${booking.id}` %></h2>
              <div class="history-meta">
                <span>Tạo lúc <%= booking.createdAtLabel %></span>
                <span><%= booking.roomCount %> phòng</span>
                <span><%= booking.serviceCount %> dịch vụ</span>
              </div>
            </div>
            <strong class="history-total"><%= booking.totalFormatted %></strong>
          </div>
          <div class="history-lines">
            <div class="history-line"><span>Cơ sở</span><strong><%= booking.hotelNames || "Chưa có tên cơ sở" %></strong></div>
            <div class="history-line"><span>Thời gian</span><strong><%= booking.checkinLabel || "-" %> → <%= booking.checkoutLabel || "-" %></strong></div>
            <div class="history-line"><span>Thanh toán</span><strong><%= booking.paymentMethodLabel %></strong></div>
            <div class="history-line"><span>Khuyến mãi</span><strong><%= booking.promotion ? booking.promotion.name : "Không áp dụng" %></strong></div>
            <div class="history-line"><span>Tiền phòng</span><strong><%= booking.roomTotalFormatted %></strong></div>
            <div class="history-line"><span>Dịch vụ</span><strong><%= booking.serviceTotalFormatted %></strong></div>
          </div>
          <div class="history-actions">
            <a class="history-button history-button--primary" href="/customer/bookings/<%= booking.id %>">Xem chi tiết</a>
            <a class="history-button" href="<%= booking.invoiceUrl %>">Hóa đơn</a>
            <% if (booking.editable) { %>
              <a class="history-button" href="/customer/bookings/<%= booking.id %>/edit">Sửa booking</a>
            <% } %>
            <% if (booking.cancelable) { %>
              <form method="post" action="/customer/bookings/<%= booking.id %>/cancel">
                <button class="history-button" type="submit">Hủy booking</button>
              </form>
            <% } %>
          </div>
        </article>
      <% }) %>
    </section>
  <% } %>
</main>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const keyword = document.getElementById("historyKeyword");
  const status = document.getElementById("historyStatus");
  const sort = document.getElementById("historySort");
  const reset = document.getElementById("historyReset");
  const grid = document.getElementById("historyGrid");
  if (!grid) return;
  const cards = Array.from(grid.querySelectorAll(".history-card"));

  function applyFilter() {
    const text = String(keyword?.value || "").trim().toLowerCase();
    const statusValue = String(status?.value || "");
    const sorted = [...cards].sort((a, b) => {
      const amountA = Number(a.dataset.amount || 0);
      const amountB = Number(b.dataset.amount || 0);
      if (sort?.value === "amount_desc") return amountB - amountA;
      if (sort?.value === "amount_asc") return amountA - amountB;
      return 0;
    });

    sorted.forEach((card) => grid.appendChild(card));
    cards.forEach((card) => {
      const matchText = !text || String(card.dataset.search || "").includes(text);
      const rawStatus = String(card.dataset.status || "");
      const matchStatus = !statusValue
        || rawStatus === statusValue
        || (statusValue === "Cancelled" && ["DaHuy", "Cancelled"].includes(rawStatus))
        || (statusValue === "Stayed" && ["Stayed", "CheckedIn", "CheckedOut"].includes(rawStatus));
      card.style.display = matchText && matchStatus ? "" : "none";
    });
  }

  keyword?.addEventListener("input", applyFilter);
  status?.addEventListener("change", applyFilter);
  sort?.addEventListener("change", applyFilter);
  reset?.addEventListener("click", () => {
    if (keyword) keyword.value = "";
    if (status) status.value = "";
    if (sort) sort.value = "newest";
    applyFilter();
  });
});
</script>
<%- include("../partials/footer") %>
