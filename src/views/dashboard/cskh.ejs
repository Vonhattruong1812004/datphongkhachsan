<%- include("../partials/head") %>
<%- include("../partials/header") %>
<%
  const staffName = (typeof currentUser !== "undefined" && currentUser ? (currentUser.displayName || currentUser.username) : "") || "CSKH";
  const primaryActions = actions || [];
  const ucAccentClasses = ["guest-feedback", "guest-advisory", "guest-broadcast", "guest-promo"];
%>

<style>
  .guest-home {
    --guest-ink: #112233;
    --guest-muted: #667085;
    --guest-card: rgba(255, 255, 255, .74);
    --guest-line: rgba(17, 34, 51, .10);
    --guest-cyan: #18bff2;
    --guest-mint: #21cfa6;
    --guest-lime: #b7ef4a;
    --guest-peach: #ff9f7a;
    --guest-pink: #ff6fa3;
    --guest-violet: #8b6bff;
    --guest-yellow: #ffd166;
    --guest-shadow: 0 28px 86px rgba(18, 38, 63, .17);
    min-height: calc(100vh - 84px);
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: 34px 18px 58px;
    color: var(--guest-ink);
    background:
      radial-gradient(circle at 9% 12%, rgba(255, 111, 163, .26), transparent 27%),
      radial-gradient(circle at 82% 10%, rgba(255, 209, 102, .24), transparent 30%),
      radial-gradient(circle at 46% 104%, rgba(33, 207, 166, .22), transparent 38%),
      linear-gradient(135deg, #fffafa 0%, #fff7ed 39%, #eafcff 100%);
  }

  .guest-home::before,
  .guest-home::after {
    content: "";
    position: absolute;
    pointer-events: none;
    z-index: -1;
  }

  .guest-home::before {
    width: 620px;
    height: 620px;
    top: -310px;
    right: -170px;
    border-radius: 48% 52% 42% 58%;
    opacity: .46;
    background: conic-gradient(from 180deg, rgba(255,111,163,.44), rgba(255,209,102,.34), rgba(33,207,166,.32), rgba(24,191,242,.28), rgba(255,111,163,.44));
    animation: guest-blob 16s ease-in-out infinite alternate;
  }

  .guest-home::after {
    width: 520px;
    height: 520px;
    left: -230px;
    bottom: -260px;
    border-radius: 999px;
    opacity: .38;
    background: conic-gradient(from 20deg, rgba(24,191,242,.30), rgba(139,107,255,.26), rgba(255,159,122,.32), rgba(183,239,74,.26), rgba(24,191,242,.30));
    animation: guest-orb-bg 14s ease-in-out infinite alternate;
  }

  .guest-wrap {
    max-width: 1240px;
    margin: 0 auto;
    position: relative;
  }

  .guest-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) 390px;
    gap: 22px;
    align-items: stretch;
    margin-bottom: 20px;
  }

  .guest-hero-card,
  .guest-live-card,
  .guest-uc-card,
  .guest-focus-card,
  .guest-booking-card {
    border: 1px solid var(--guest-line);
    background: var(--guest-card);
    box-shadow: var(--guest-shadow);
    backdrop-filter: blur(26px);
  }

  .guest-hero-card {
    min-height: 360px;
    border-radius: 38px;
    padding: 36px;
    position: relative;
    overflow: hidden;
  }

  .guest-hero-card::before {
    content: "";
    position: absolute;
    inset: -1px;
    pointer-events: none;
    background:
      linear-gradient(120deg, rgba(255, 255, 255, .70), transparent 28%),
      radial-gradient(circle at 86% 20%, rgba(255, 111, 163, .22), transparent 30%),
      radial-gradient(circle at 16% 88%, rgba(255, 209, 102, .18), transparent 28%);
  }

  .guest-chip {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-radius: 999px;
    padding: 7px 12px;
    border: 1px solid rgba(255, 111, 163, .24);
    background: rgba(255, 111, 163, .12);
    color: #be123c;
    font-size: 12px;
    font-weight: 1000;
    letter-spacing: .09em;
    text-transform: uppercase;
  }

  .guest-pulse {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--guest-pink);
    box-shadow: 0 0 0 7px rgba(255, 111, 163, .14);
    animation: guest-pulse 1.8s ease-in-out infinite;
  }

  .guest-hero h1 {
    position: relative;
    z-index: 1;
    max-width: 760px;
    margin: 26px 0 14px;
    color: var(--guest-ink);
    font-size: clamp(42px, 6.4vw, 78px);
    line-height: .90;
    letter-spacing: -.075em;
  }

  .guest-hero h1 span {
    color: transparent;
    background: linear-gradient(96deg, #ec4899 0%, #f59e0b 44%, #10b981 74%, #0891b2 100%);
    -webkit-background-clip: text;
    background-clip: text;
  }

  .guest-lead {
    position: relative;
    z-index: 1;
    max-width: 690px;
    margin: 0;
    color: var(--guest-muted);
    font-size: 16px;
    line-height: 1.72;
  }

  .guest-tags,
  .guest-hero-actions {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .guest-tags {
    margin-top: 22px;
  }

  .guest-tag {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 8px 11px;
    color: var(--guest-ink);
    background: rgba(255, 255, 255, .66);
    border: 1px solid rgba(17, 34, 51, .08);
    font-size: 12px;
    font-weight: 950;
  }

  .guest-tag--live {
    color: #be123c;
    background: rgba(255, 111, 163, .11);
    border-color: rgba(255, 111, 163, .18);
  }

  .guest-hero-actions {
    margin-top: 28px;
  }

  .guest-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 45px;
    border-radius: 999px;
    padding: 10px 18px;
    border: 1px solid rgba(17, 34, 51, .12);
    background: rgba(255, 255, 255, .76);
    color: var(--guest-ink);
    text-decoration: none;
    font-size: 14px;
    font-weight: 950;
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
  }

  .guest-button:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 111, 163, .34);
    box-shadow: 0 18px 44px rgba(255, 111, 163, .16);
  }

  .guest-button--primary {
    color: #fff;
    border-color: transparent;
    background: linear-gradient(135deg, #fb7185, #f59e0b);
    box-shadow: 0 18px 42px rgba(251, 113, 133, .24);
  }

  .guest-mini-stats {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-top: 34px;
  }

  .guest-mini-stat {
    border-radius: 23px;
    padding: 16px;
    background: rgba(255, 255, 255, .58);
    border: 1px solid rgba(17, 34, 51, .08);
  }

  .guest-mini-stat strong {
    display: block;
    color: var(--guest-ink);
    font-size: 30px;
    line-height: 1;
    letter-spacing: -.055em;
  }

  .guest-mini-stat span {
    display: block;
    margin-top: 8px;
    color: var(--guest-muted);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .06em;
    text-transform: uppercase;
  }

  .guest-live-card {
    min-height: 360px;
    border-radius: 38px;
    padding: 22px;
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(160deg, rgba(255, 255, 255, .86), rgba(255, 247, 237, .58)),
      radial-gradient(circle at 30% 18%, rgba(33, 207, 166, .18), transparent 28%);
  }

  .guest-live-card::before {
    content: "";
    position: absolute;
    inset: 22px;
    border-radius: 32px;
    background:
      linear-gradient(145deg, rgba(63, 23, 43, .90), rgba(124, 45, 18, .74)),
      radial-gradient(circle at 22% 18%, rgba(255,209,102,.24), transparent 32%);
  }

  .guest-live-ring {
    position: absolute;
    inset: 48px;
    border: 1px dashed rgba(255, 255, 255, .25);
    border-radius: 999px;
    animation: guest-spin 22s linear infinite;
  }

  .guest-live-core {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 158px;
    height: 158px;
    border-radius: 46px;
    transform: translate(-50%, -50%) rotate(14deg);
    background: linear-gradient(135deg, rgba(251, 113, 133, .96), rgba(255, 209, 102, .86));
    box-shadow: 0 26px 76px rgba(251, 113, 133, .32);
    animation: guest-core 4.8s ease-in-out infinite;
  }

  .guest-live-word {
    position: absolute;
    z-index: 2;
    border-radius: 999px;
    padding: 9px 12px;
    color: #fff7ed;
    background: rgba(15, 23, 42, .48);
    border: 1px solid rgba(255, 255, 255, .18);
    backdrop-filter: blur(16px);
    font-size: 12px;
    font-weight: 1000;
  }

  .guest-live-word:nth-child(4) { left: 34px; top: 42px; animation: guest-drift-a 5.5s ease-in-out infinite; }
  .guest-live-word:nth-child(5) { right: 30px; top: 98px; animation: guest-drift-b 6.2s ease-in-out infinite; }
  .guest-live-word:nth-child(6) { left: 44px; bottom: 78px; animation: guest-drift-b 5.8s ease-in-out infinite reverse; }
  .guest-live-word:nth-child(7) { right: 42px; bottom: 44px; animation: guest-drift-a 6.5s ease-in-out infinite reverse; }

  .guest-focus-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 16px;
    align-items: center;
    border-radius: 30px;
    padding: 18px 20px;
    margin-bottom: 18px;
    background: rgba(255, 255, 255, .66);
  }

  .guest-focus-card strong {
    display: block;
    color: var(--guest-ink);
    font-size: 18px;
    letter-spacing: -.02em;
  }

  .guest-focus-card span {
    display: block;
    margin-top: 4px;
    color: var(--guest-muted);
    font-size: 13px;
  }

  .guest-flow {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .guest-flow a {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 8px 11px;
    color: #be123c;
    background: rgba(255, 111, 163, .11);
    border: 1px solid rgba(255, 111, 163, .18);
    text-decoration: none;
    font-size: 12px;
    font-weight: 950;
  }

  .guest-section {
    margin-top: 20px;
  }

  .guest-section-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 14px;
    margin: 0 0 14px;
  }

  .guest-section-head h2 {
    margin: 0;
    color: var(--guest-ink);
    font-size: 26px;
    letter-spacing: -.05em;
  }

  .guest-section-head p {
    margin: 5px 0 0;
    color: var(--guest-muted);
    font-size: 13px;
  }

  .guest-bento {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: minmax(210px, auto);
    gap: 16px;
  }

  .guest-uc-card {
    --accent: var(--guest-pink);
    --accent-soft: rgba(251, 113, 133, .20);
    grid-column: span 6;
    position: relative;
    overflow: hidden;
    border-radius: 32px;
    padding: 22px;
    text-decoration: none;
    color: var(--guest-ink);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, .88), rgba(255, 255, 255, .62)),
      radial-gradient(circle at 100% 0%, var(--accent-soft), transparent 34%);
    transform: translateY(20px);
    opacity: 0;
    animation: guest-rise .72s cubic-bezier(.22, 1, .36, 1) forwards;
    transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
  }

  .guest-uc-card:nth-child(2) { animation-delay: .08s; }

  .guest-uc-card:hover {
    transform: translateY(-7px) rotate(-.24deg);
    border-color: color-mix(in srgb, var(--accent) 36%, transparent);
    box-shadow: 0 34px 92px rgba(18, 38, 63, .22);
  }

  .guest-uc-card::before {
    content: "";
    position: absolute;
    width: 190px;
    height: 190px;
    right: -64px;
    top: -64px;
    border-radius: 999px;
    background: radial-gradient(circle, var(--accent-soft), transparent 68%);
    transition: transform .25s ease;
  }

  .guest-uc-card:hover::before {
    transform: scale(1.24);
  }

  .guest-uc-card::after {
    content: "";
    position: absolute;
    left: 22px;
    right: 22px;
    bottom: 18px;
    height: 4px;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--accent), transparent);
    opacity: .62;
  }

  .guest-uc-top {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
  }

  .guest-uc-code {
    display: inline-flex;
    border-radius: 999px;
    padding: 6px 10px;
    background: rgba(255, 255, 255, .74);
    border: 1px solid rgba(17, 34, 51, .08);
    color: var(--accent);
    font-size: 12px;
    font-weight: 1000;
    letter-spacing: .06em;
  }

  .guest-uc-orb {
    width: 52px;
    height: 52px;
    border-radius: 19px;
    background: linear-gradient(135deg, var(--accent), rgba(255, 255, 255, .36));
    box-shadow: 0 16px 36px var(--accent-soft);
    transform: rotate(8deg);
  }

  .guest-uc-card h3 {
    position: relative;
    z-index: 1;
    margin: 28px 0 10px;
    max-width: 420px;
    color: var(--guest-ink);
    font-size: 28px;
    line-height: 1.05;
    letter-spacing: -.05em;
  }

  .guest-uc-card p {
    position: relative;
    z-index: 1;
    max-width: 520px;
    margin: 0;
    color: var(--guest-muted);
    font-size: 14px;
    line-height: 1.62;
  }

  .guest-open {
    position: absolute;
    z-index: 1;
    right: 22px;
    bottom: 25px;
    color: var(--accent);
    font-size: 13px;
    font-weight: 1000;
  }

  .guest-feedback { --accent: var(--guest-mint); --accent-soft: rgba(33,207,166,.22); }
  .guest-advisory { --accent: var(--guest-cyan); --accent-soft: rgba(24,191,242,.22); }
  .guest-broadcast { --accent: var(--guest-yellow); --accent-soft: rgba(255,209,102,.24); }
  .guest-promo { --accent: var(--guest-pink); --accent-soft: rgba(255,111,163,.22); }

  .guest-booking-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .guest-booking-card {
    border-radius: 28px;
    padding: 20px;
    background: rgba(255, 255, 255, .70);
  }

  .guest-booking-card h3 {
    margin: 12px 0 8px;
    color: var(--guest-ink);
    font-size: 21px;
    line-height: 1.1;
    letter-spacing: -.04em;
  }

  .guest-booking-card p {
    margin: 0 0 6px;
    color: var(--guest-muted);
    font-size: 13px;
    line-height: 1.5;
  }

  .guest-booking-card strong {
    display: block;
    margin-top: 10px;
    color: var(--guest-ink);
    font-size: 21px;
  }

  .guest-booking-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
  }

  .guest-booking-actions .guest-button {
    min-height: 38px;
    padding: 8px 12px;
    font-size: 12px;
  }

  .guest-badge {
    display: inline-flex;
    border-radius: 999px;
    padding: 5px 9px;
    background: rgba(255, 111, 163, .12);
    color: #be123c;
    font-size: 11px;
    font-weight: 1000;
    letter-spacing: .04em;
  }

  @keyframes guest-blob {
    0% { transform: translate3d(0, 0, 0) rotate(0deg); border-radius: 48% 52% 42% 58%; }
    100% { transform: translate3d(26px, 30px, 0) rotate(18deg); border-radius: 56% 44% 60% 40%; }
  }

  @keyframes guest-orb-bg {
    from { transform: translate3d(0, 0, 0) rotate(0deg); }
    to { transform: translate3d(34px, -18px, 0) rotate(-14deg); }
  }

  @keyframes guest-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(.72); opacity: .68; }
  }

  @keyframes guest-spin {
    to { transform: rotate(360deg); }
  }

  @keyframes guest-core {
    0%, 100% { transform: translate(-50%, -50%) rotate(14deg) scale(1); border-radius: 46px; }
    50% { transform: translate(-50%, -50%) rotate(24deg) scale(1.07); border-radius: 72px; }
  }

  @keyframes guest-drift-a {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(12px, -10px, 0); }
  }

  @keyframes guest-drift-b {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(-10px, 12px, 0); }
  }

  @keyframes guest-rise {
    to { transform: translateY(0); opacity: 1; }
  }

  @media (max-width: 1080px) {
    .guest-hero { grid-template-columns: 1fr; }
    .guest-live-card { min-height: 320px; }
    .guest-uc-card { grid-column: span 6; }
    .guest-booking-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 760px) {
    .guest-home { padding: 20px 12px 42px; }
    .guest-hero-card { min-height: auto; padding: 24px; border-radius: 30px; }
    .guest-hero h1 { font-size: 44px; }
    .guest-mini-stats,
    .guest-focus-card,
    .guest-booking-grid { grid-template-columns: 1fr; }
    .guest-live-card { min-height: 280px; }
    .guest-uc-card {
      grid-column: 1 / -1;
      min-height: 220px;
    }
    .guest-section-head { display: block; }
  }

  @media (prefers-reduced-motion: reduce) {
    .guest-home::before,
    .guest-home::after,
    .guest-pulse,
    .guest-live-ring,
    .guest-live-core,
    .guest-live-word,
    .guest-uc-card {
      animation: none;
    }
    .guest-uc-card {
      transform: none;
      opacity: 1;
    }
  }

  /* CSKH dashboard visual pass only: galaxy theme with clear support workflows. */
  body {
    background:
      radial-gradient(circle at 12% 13%, rgba(34, 211, 238, .18), transparent 28%),
      radial-gradient(circle at 78% 7%, rgba(168, 85, 247, .22), transparent 32%),
      radial-gradient(circle at 86% 88%, rgba(250, 204, 21, .12), transparent 32%),
      linear-gradient(135deg, #04111f 0%, #11153c 48%, #210c35 100%);
    color: #f8fafc;
  }

  .guest-home {
    --guest-ink: #f8fafc;
    --guest-muted: #dbeafe;
    --guest-card: rgba(10, 20, 40, .84);
    --guest-line: rgba(125, 211, 252, .34);
    --guest-cyan: #67e8f9;
    --guest-mint: #5eead4;
    --guest-lime: #a7f3d0;
    --guest-peach: #fda4af;
    --guest-pink: #fb7185;
    --guest-violet: #a78bfa;
    --guest-yellow: #fde68a;
    --guest-shadow: 0 26px 72px rgba(0, 0, 0, .34);
    background:
      radial-gradient(circle at 13% 14%, rgba(34, 211, 238, .18), transparent 28%),
      radial-gradient(circle at 78% 8%, rgba(168, 85, 247, .22), transparent 32%),
      radial-gradient(circle at 84% 86%, rgba(251, 191, 36, .13), transparent 30%),
      linear-gradient(135deg, #04111f 0%, #11153c 48%, #210c35 100%);
    color: #f8fafc;
  }

  .guest-home::before {
    inset: 0;
    width: auto;
    height: auto;
    right: auto;
    top: auto;
    border-radius: 0;
    opacity: .60;
    background:
      radial-gradient(circle at 8% 22%, rgba(255, 255, 255, .72) 0 1px, transparent 2px),
      radial-gradient(circle at 28% 62%, rgba(125, 211, 252, .74) 0 1px, transparent 2px),
      radial-gradient(circle at 52% 18%, rgba(255, 255, 255, .68) 0 1px, transparent 2px),
      radial-gradient(circle at 74% 36%, rgba(253, 230, 138, .72) 0 1px, transparent 2px),
      radial-gradient(circle at 92% 76%, rgba(255, 255, 255, .66) 0 1px, transparent 2px);
    animation: none;
  }

  .guest-home::after {
    width: 780px;
    height: 780px;
    left: auto;
    right: -270px;
    bottom: -350px;
    border-radius: 999px;
    opacity: .42;
    background:
      radial-gradient(circle at 42% 45%, rgba(103, 232, 249, .28), transparent 0 24%, rgba(167, 139, 250, .20) 25% 42%, transparent 43%),
      conic-gradient(from 140deg, rgba(34, 211, 238, .24), rgba(251, 113, 133, .18), rgba(250, 204, 21, .15), rgba(34, 211, 238, .24));
    animation: guest-orb-bg 18s ease-in-out infinite alternate;
  }

  .guest-wrap {
    max-width: 1280px;
  }

  .guest-hero {
    gap: 22px;
    margin-bottom: 22px;
  }

  .guest-hero-card,
  .guest-live-card,
  .guest-focus-card {
    border: 1px solid rgba(125, 211, 252, .34);
    background:
      radial-gradient(circle at 12% 18%, rgba(34, 211, 238, .16), transparent 30%),
      radial-gradient(circle at 90% 6%, rgba(168, 85, 247, .18), transparent 34%),
      linear-gradient(145deg, rgba(8, 18, 36, .94), rgba(14, 24, 52, .88));
    box-shadow: 0 24px 70px rgba(0, 0, 0, .36), inset 0 1px 0 rgba(255, 255, 255, .08);
    backdrop-filter: blur(22px);
  }

  .guest-hero-card {
    border-radius: 28px;
    padding: 36px;
  }

  .guest-hero-card::before {
    background:
      linear-gradient(120deg, rgba(255, 255, 255, .12), transparent 25%),
      radial-gradient(circle at 82% 20%, rgba(94, 234, 212, .24), transparent 28%),
      radial-gradient(circle at 12% 86%, rgba(251, 191, 36, .16), transparent 28%);
    opacity: 1;
  }

  .guest-chip {
    border: 1px solid rgba(125, 211, 252, .38);
    background: rgba(8, 18, 36, .72);
    color: #a7f3d0;
    letter-spacing: 0;
    box-shadow: 0 16px 34px rgba(8, 145, 178, .16);
  }

  .guest-pulse {
    background: #5eead4;
    box-shadow: 0 0 0 7px rgba(94, 234, 212, .16);
  }

  .guest-hero h1,
  .guest-section-head h2,
  .guest-focus-card strong {
    color: #ffffff;
    letter-spacing: 0;
    text-shadow: 0 12px 34px rgba(0, 0, 0, .38);
  }

  .guest-hero h1 {
    max-width: 760px;
    font-size: clamp(44px, 5.8vw, 76px);
    line-height: .96;
  }

  .guest-hero h1 span {
    background: linear-gradient(96deg, #67e8f9 0%, #86efac 34%, #fde68a 66%, #f9a8d4 100%);
    -webkit-background-clip: text;
    background-clip: text;
  }

  .guest-lead,
  .guest-section-head p,
  .guest-focus-card span {
    color: #dbeafe;
    font-weight: 800;
  }

  .guest-tag {
    border: 1px solid rgba(186, 230, 253, .42);
    background: rgba(255, 255, 255, .94);
    color: #071626;
    letter-spacing: 0;
    box-shadow: 0 10px 26px rgba(0, 0, 0, .14);
  }

  .guest-tag--live {
    background: linear-gradient(135deg, #67e8f9 0%, #a7f3d0 52%, #fde68a 100%);
