  }

  .guest-button {
    min-height: 48px;
    border: 1px solid rgba(186, 230, 253, .42);
    background: rgba(255, 255, 255, .94);
    color: #071626;
    font-size: 14px;
    font-weight: 1000;
    box-shadow: 0 14px 36px rgba(0, 0, 0, .18);
  }

  .guest-button:hover {
    border-color: rgba(253, 230, 138, .72);
    box-shadow: 0 18px 48px rgba(34, 211, 238, .20);
  }

  .guest-button--primary {
    color: #061826;
    border-color: rgba(255, 255, 255, .38);
    background: linear-gradient(135deg, #facc15 0%, #fb7185 50%, #8b5cf6 100%);
    box-shadow: 0 20px 54px rgba(251, 113, 133, .26);
  }

  .guest-mini-stats {
    gap: 14px;
  }

  .guest-mini-stat {
    border: 2px solid rgba(255, 255, 255, .34);
    background: rgba(255, 255, 255, .10);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, .12);
  }

  .guest-mini-stat strong,
  .guest-mini-stat span {
    color: #ffffff;
    letter-spacing: 0;
    text-shadow: 0 2px 12px rgba(0, 0, 0, .30);
  }

  .guest-live-card {
    border-radius: 28px;
    background:
      radial-gradient(circle at 50% 50%, rgba(103, 232, 249, .34), transparent 0 15%, rgba(139, 92, 246, .20) 16% 32%, transparent 33%),
      radial-gradient(circle at 18% 24%, rgba(253, 230, 138, .18), transparent 20%),
      linear-gradient(145deg, rgba(3, 7, 18, .94), rgba(14, 25, 59, .82));
  }

  .guest-live-card::before {
    background:
      radial-gradient(circle at 50% 50%, rgba(34, 211, 238, .22), transparent 0 18%, rgba(251, 113, 133, .18) 19% 34%, transparent 35%),
      linear-gradient(145deg, rgba(3, 7, 18, .78), rgba(14, 25, 59, .58));
  }

  .guest-live-ring {
    border-color: rgba(186, 230, 253, .34);
  }

  .guest-live-core {
    background: conic-gradient(from 90deg, #22d3ee, #8b5cf6, #fb7185, #fde68a, #22d3ee);
    box-shadow: 0 28px 82px rgba(34, 211, 238, .32);
  }

  .guest-live-word {
    color: #f8fafc;
    background: rgba(9, 15, 30, .76);
    border: 1px solid rgba(186, 230, 253, .28);
    box-shadow: 0 16px 32px rgba(0, 0, 0, .26);
  }

  .guest-focus-card {
    margin-bottom: 0;
    border-radius: 26px;
    padding: 22px;
  }

  .guest-flow {
    gap: 10px;
  }

  .guest-flow a {
    border: 1px solid rgba(186, 230, 253, .42);
    background: rgba(255, 255, 255, .94);
    color: #071626;
    box-shadow: 0 10px 26px rgba(0, 0, 0, .14);
  }

  .guest-section {
    margin-top: 22px;
  }

  .guest-section-head {
    margin-bottom: 16px;
  }

  .guest-bento {
    gap: 18px;
  }

  .guest-uc-card {
    min-height: 258px;
    border: 2px solid rgba(255, 255, 255, .36);
    border-radius: 24px;
    color: #ffffff;
    background: linear-gradient(135deg, #38bdf8 0%, #2dd4bf 52%, #22c55e 100%);
    box-shadow: 0 20px 48px rgba(0, 0, 0, .24), inset 0 1px 0 rgba(255, 255, 255, .22);
  }

  .guest-uc-card:nth-child(1) {
    background: linear-gradient(135deg, #38bdf8 0%, #2dd4bf 52%, #22c55e 100%);
  }

  .guest-uc-card:nth-child(2) {
    background: linear-gradient(135deg, #facc15 0%, #fb7185 56%, #8b5cf6 100%);
  }

  .guest-uc-card:nth-child(3) {
    background: linear-gradient(135deg, #60a5fa 0%, #818cf8 52%, #c084fc 100%);
  }

  .guest-uc-card:nth-child(4) {
    background: linear-gradient(135deg, #34d399 0%, #22d3ee 52%, #3b82f6 100%);
  }

  .guest-uc-card::before {
    width: 170px;
    height: 170px;
    background: radial-gradient(circle, rgba(255, 255, 255, .28), transparent 70%);
  }

  .guest-uc-card::after {
    background: linear-gradient(90deg, rgba(255, 255, 255, .88), transparent);
    opacity: .74;
  }

  .guest-uc-code {
    border: 1px solid rgba(255, 255, 255, .28);
    background: rgba(8, 18, 36, .72);
    color: #ffffff;
    letter-spacing: 0;
  }

  .guest-uc-orb {
    background: radial-gradient(circle at 35% 30%, rgba(255, 255, 255, .92), rgba(255, 255, 255, .30) 34%, rgba(8, 18, 36, .22) 35%), linear-gradient(135deg, rgba(255, 255, 255, .40), rgba(255, 255, 255, .10));
    box-shadow: 0 18px 42px rgba(0, 0, 0, .20);
  }

  .guest-uc-card h3,
  .guest-uc-card p,
  .guest-open {
    color: #ffffff;
    letter-spacing: 0;
    text-shadow: 0 2px 14px rgba(0, 0, 0, .26);
  }

  .guest-uc-card p {
    font-weight: 850;
  }

  .guest-booking-grid {
    gap: 18px;
  }

  .guest-booking-card {
    border: 2px solid rgba(186, 230, 253, .70);
    border-radius: 20px;
    background: rgba(255, 255, 255, .95);
    color: #0f2d42;
    box-shadow: 0 14px 36px rgba(0, 0, 0, .13);
  }

  .guest-booking-card h3,
  .guest-booking-card strong {
    color: #0f2d42;
    letter-spacing: 0;
  }

  .guest-booking-card p {
    color: #5b7184;
    font-weight: 800;
  }

  .guest-badge {
    background: rgba(14, 165, 233, .13);
    border: 1px solid rgba(14, 165, 233, .22);
    color: #075985;
    letter-spacing: 0;
  }

  .guest-booking-actions .guest-button {
    min-height: 40px;
  }

  @media (max-width: 1080px) {
    .guest-hero {
      grid-template-columns: 1fr;
    }

    .guest-uc-card {
      grid-column: span 6;
    }
  }

  @media (max-width: 760px) {
    .guest-home {
      padding: 20px 12px 46px;
    }

    .guest-hero-card,
    .guest-live-card,
    .guest-focus-card {
      border-radius: 22px;
      padding: 18px;
    }

    .guest-hero h1 {
      font-size: 42px;
    }

    .guest-mini-stats,
    .guest-focus-card,
    .guest-booking-grid {
      grid-template-columns: 1fr;
    }

    .guest-bento {
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .guest-uc-card {
      grid-column: 1 / -1;
      min-height: auto;
    }

    .guest-button {
      width: 100%;
    }
  }

  /* CSKH home cleanup: keep only the galaxy hero, remove workflow clutter. */
  .guest-home{
    min-height:calc(100vh - 84px);
    display:block;
  }

  .guest-wrap{
    width:100%;
  }

  .guest-hero{
    grid-template-columns:minmax(0,.92fr) minmax(390px,.72fr);
    margin-bottom:26px;
  }

  .guest-hero-card{
    min-height:430px;
    display:flex;
    flex-direction:column;
    justify-content:center;
  }

  .guest-hero .guest-lead{
    max-width:760px;
  }

  .guest-live-card{
    min-height:430px;
    border:1px solid rgba(125,211,252,.34);
    border-radius:28px;
    background:
      radial-gradient(circle at 18% 18%,rgba(255,255,255,.90) 0 1px,transparent 2px),
      radial-gradient(circle at 74% 20%,rgba(186,230,253,.82) 0 1px,transparent 2px),
      radial-gradient(circle at 84% 66%,rgba(255,255,255,.76) 0 1px,transparent 2px),
      radial-gradient(circle at 21% 76%,rgba(125,211,252,.82) 0 1px,transparent 2px),
      radial-gradient(circle at 52% 42%,rgba(34,211,238,.25),transparent 26%),
      linear-gradient(145deg,rgba(2,6,23,.98),rgba(15,23,42,.90) 52%,rgba(30,27,75,.82));
    box-shadow:0 30px 90px rgba(0,0,0,.36),inset 0 1px 0 rgba(255,255,255,.08);
  }

  .guest-live-card::before{
    inset:24px;
    border:1px solid rgba(125,211,252,.18);
    border-radius:32px;
    background:
      radial-gradient(circle at 50% 48%,rgba(14,165,233,.24),transparent 28%),
      radial-gradient(circle at 20% 18%,rgba(255,255,255,.78) 0 1px,transparent 2px),
      radial-gradient(circle at 78% 22%,rgba(253,230,138,.76) 0 1px,transparent 2px),
      radial-gradient(circle at 88% 70%,rgba(255,255,255,.70) 0 1px,transparent 2px),
      radial-gradient(circle at 18% 78%,rgba(125,211,252,.74) 0 1px,transparent 2px),
      linear-gradient(145deg,rgba(2,6,23,.96),rgba(15,23,42,.86) 48%,rgba(30,27,75,.76));
  }

  .guest-live-ring,
  .guest-live-core,
  .guest-live-word{
    display:none;
  }

  .guest-galaxy-nebula{
    position:absolute;
    z-index:1;
    inset:17% 7% auto 8%;
    height:50%;
    border-radius:999px;
    background:
      radial-gradient(ellipse at 30% 50%,rgba(45,212,191,.22),transparent 58%),
      radial-gradient(ellipse at 70% 50%,rgba(139,92,246,.20),transparent 60%);
    filter:blur(14px);
    opacity:.86;
    transform:rotate(-16deg);
    animation:guest-nebula-breathe 9s ease-in-out infinite alternate;
  }

  .guest-orbit{
    position:absolute;
    z-index:2;
    left:50%;
    top:52%;
    border:1px solid rgba(125,211,252,.18);
    border-radius:999px;
    transform:translate(-50%,-50%) rotate(var(--orbit-tilt, -12deg));
    pointer-events:none;
  }

  .guest-orbit--one{width:56%;height:34%;--orbit-tilt:-13deg}
  .guest-orbit--two{width:74%;height:45%;--orbit-tilt:15deg}
  .guest-orbit--three{width:88%;height:58%;--orbit-tilt:-24deg}

  .guest-earth-3d{
    position:absolute;
    z-index:4;
    left:50%;
    top:54%;
    width:min(72%,330px);
    aspect-ratio:1;
    transform:translate(-50%,-50%);
    border-radius:999px;
    filter:drop-shadow(0 30px 44px rgba(0,0,0,.38));
    animation:guest-earth-float 8s ease-in-out infinite;
  }

  .guest-earth-3d::before,
  .guest-earth-3d::after{
    content:"";
    position:absolute;
    inset:6%;
    border-radius:999px;
    border:1px solid rgba(125,211,252,.24);
    transform:rotate(-12deg) scaleX(1.38);
    pointer-events:none;
  }

  .guest-earth-3d::after{
    inset:-6%;
    border-color:rgba(255,255,255,.14);
    transform:rotate(18deg) scaleX(1.58);
  }

  .guest-earth-3d canvas{
    position:absolute;
    inset:0;
    width:100%;
    height:100%;
    display:block;
  }

  .guest-galaxy-moon{
    position:absolute;
    right:15%;
    top:30%;
    width:42px;
    height:42px;
    border-radius:999px;
    z-index:5;
    background:
      radial-gradient(circle at 34% 30%,#fff 0 10%,transparent 11%),
      radial-gradient(circle at 40% 38%,#f8fafc 0%,#cbd5e1 52%,#64748b 100%);
    box-shadow:0 0 28px rgba(226,232,240,.42);
    animation:guest-moon-float 6.8s ease-in-out infinite;
  }

  .guest-planet{
    position:absolute;
    z-index:3;
    border-radius:999px;
    box-shadow:inset -8px -10px 18px rgba(0,0,0,.28),0 0 24px rgba(125,211,252,.20);
    pointer-events:none;
  }

  .guest-planet--mercury{
    left:21%;
    top:29%;
    width:18px;
    height:18px;
    background:radial-gradient(circle at 32% 28%,#f8fafc,#94a3b8 55%,#475569);
    animation:guest-planet-drift-a 9s ease-in-out infinite;
  }

  .guest-planet--venus{
    right:22%;
    top:24%;
    width:26px;
    height:26px;
    background:radial-gradient(circle at 34% 30%,#fff7cc,#f59e0b 58%,#92400e);
    animation:guest-planet-drift-b 10s ease-in-out infinite;
  }

  .guest-planet--mars{
    left:15%;
    bottom:25%;
    width:24px;
    height:24px;
    background:radial-gradient(circle at 34% 30%,#fecaca,#ef4444 58%,#7f1d1d);
    animation:guest-planet-drift-b 8.5s ease-in-out infinite reverse;
  }

  .guest-planet--saturn{
    right:12%;
    bottom:22%;
    width:44px;
    height:44px;
    background:radial-gradient(circle at 36% 30%,#fff7d6,#fbbf24 52%,#92400e);
    animation:guest-planet-drift-a 11s ease-in-out infinite reverse;
  }

  .guest-planet--saturn::before{
    content:"";
    position:absolute;
    left:-16px;
    right:-16px;
    top:17px;
    height:9px;
    border-radius:999px;
    border:2px solid rgba(253,230,138,.62);
    transform:rotate(-16deg);
  }

  .guest-comet{
    position:absolute;
    z-index:6;
    width:96px;
    height:2px;
    border-radius:999px;
    background:linear-gradient(90deg,transparent,rgba(255,255,255,.96),rgba(125,211,252,.70));
    filter:drop-shadow(0 0 8px rgba(125,211,252,.68));
    opacity:.86;
  }

  .guest-comet--one{left:-18%;top:20%;animation:guest-comet-horizontal 7.8s linear infinite}
  .guest-comet--two{right:-18%;bottom:24%;transform:rotate(180deg);animation:guest-comet-horizontal-reverse 8.8s linear infinite 1.2s}
  .guest-comet--three{left:30%;top:-14%;transform:rotate(90deg);animation:guest-comet-fall 9s linear infinite 2s}

  @keyframes guest-nebula-breathe{from{transform:rotate(-16deg) scale(.96);opacity:.58}to{transform:rotate(-12deg) scale(1.05);opacity:.92}}
  @keyframes guest-earth-float{0%,100%{transform:translate(-50%,-50%) scale(1)}50%{transform:translate(-50%,-54%) scale(1.035)}}
  @keyframes guest-moon-float{0%,100%{transform:translate3d(0,0,0)}50%{transform:translate3d(-12px,10px,0)}}
  @keyframes guest-planet-drift-a{0%,100%{transform:translate3d(0,0,0)}50%{transform:translate3d(12px,-10px,0)}}
  @keyframes guest-planet-drift-b{0%,100%{transform:translate3d(0,0,0)}50%{transform:translate3d(-10px,12px,0)}}
  @keyframes guest-comet-horizontal{0%,8%{transform:translate3d(-24vw,0,0);opacity:0}14%,76%{opacity:.86}92%,100%{transform:translate3d(80vw,0,0);opacity:0}}
  @keyframes guest-comet-horizontal-reverse{0%,8%{transform:translate3d(24vw,0,0) rotate(180deg);opacity:0}14%,76%{opacity:.86}92%,100%{transform:translate3d(-80vw,0,0) rotate(180deg);opacity:0}}
  @keyframes guest-comet-fall{0%,8%{transform:translate3d(0,-36vh,0) rotate(90deg);opacity:0}14%,76%{opacity:.86}92%,100%{transform:translate3d(0,78vh,0) rotate(90deg);opacity:0}}

  @media (max-width:1080px){
    .guest-home{display:block}
    .guest-hero{grid-template-columns:1fr}
  }

  @media (max-width:760px){
    .guest-live-card{min-height:420px}
    .guest-hero-card{min-height:auto}
    .guest-earth-3d{width:min(76%,280px)}
  }

  .guest-home .guest-section{
    margin-top:28px;
  }

  .guest-home .guest-section-head h2{
    font-size:32px;
  }

  .guest-home .guest-bento{
    grid-auto-rows:minmax(236px, auto);
    gap:22px;
  }

  .guest-home .guest-uc-card{
    padding:26px;
  }

  .guest-home .guest-uc-card h3{
    font-size:31px;
  }

  .guest-home .guest-uc-card p{
    font-size:15px;
  }
</style>

<main class="guest-home">
  <div class="guest-wrap">
    <section class="guest-hero" aria-label="Dashboard CSKH">
      <div class="guest-hero-card">
        <div class="guest-chip"><span class="guest-pulse"></span> Care journey center</div>
        <h1>Xin chào <span><%= staffName %></span></h1>
        <p class="guest-lead">
          Một dashboard CSKH gọn theo mẫu khách hàng: tiếp nhận phản hồi,
          trả lời tư vấn, gửi outbound chăm sóc khách và quản lý khuyến mãi.
        </p>
      </div>

      <aside class="guest-live-card" aria-label="Minh họa vũ trụ CSKH">
        <span class="guest-galaxy-nebula"></span>
        <span class="guest-comet guest-comet--one"></span>
        <span class="guest-comet guest-comet--two"></span>
        <span class="guest-comet guest-comet--three"></span>
        <span class="guest-orbit guest-orbit--one"></span>
        <span class="guest-orbit guest-orbit--two"></span>
        <span class="guest-orbit guest-orbit--three"></span>
        <span class="guest-planet guest-planet--mercury"></span>
        <span class="guest-planet guest-planet--venus"></span>
        <span class="guest-planet guest-planet--mars"></span>
        <span class="guest-planet guest-planet--saturn"></span>
        <div class="guest-earth-3d" data-earth-3d>
          <canvas aria-label="Trái Đất 3D xoay"></canvas>
        </div>
        <span class="guest-galaxy-moon"></span>
      </aside>
    </section>

    <section class="guest-section" aria-label="Các UC CSKH">
      <div class="guest-section-head">
        <div>
          <h2>UC CSKH</h2>
          <p>Mở nhanh các nghiệp vụ chăm sóc khách hàng.</p>
        </div>
      </div>
      <div class="guest-bento">
        <% primaryActions.forEach((item, index) => { %>
          <a class="guest-uc-card <%= ucAccentClasses[index] || "" %>" href="<%= item.href %>">
            <div class="guest-uc-top">
              <span class="guest-uc-code"><%= String(index + 1).padStart(2, "0") %></span>
              <span class="guest-uc-orb" aria-hidden="true"></span>
            </div>
            <h3><%= item.label %></h3>
            <p><%= item.note %></p>
            <span class="guest-open">Mở</span>
          </a>
        <% }) %>
      </div>
    </section>
  </div>
</main>

<script type="module" src="/js/home-galaxy-earth.js"></script>
<%- include("../partials/footer") %>
