<%- include("../partials/head") %>
<%- include("../partials/header") %>
<%
  const staffName = (typeof currentUser !== "undefined" && currentUser ? (currentUser.displayName || currentUser.username) : "") || "Nhân viên dịch vụ";
  const primaryActions = actions || [];
  const todayLabel = new Date().toLocaleDateString("vi-VN", {
    weekday: "long",
    day: "2-digit",
    month: "2-digit",
    year: "numeric"
  });
%>

<style>
  .svc-home {
    --svc-ink: #102033;
    --svc-muted: #667085;
    --svc-card: rgba(255, 255, 255, .75);
    --svc-line: rgba(16, 32, 51, .10);
    --svc-blue: #0ea5e9;
    --svc-teal: #14b8a6;
    --svc-lime: #a3e635;
    --svc-amber: #f59e0b;
    --svc-coral: #fb7185;
    --svc-violet: #8b5cf6;
    --svc-shadow: 0 28px 86px rgba(18, 38, 63, .17);
    min-height: calc(100vh - 84px);
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: 34px 18px 58px;
    color: var(--svc-ink);
    background:
      radial-gradient(circle at 7% 10%, rgba(20, 184, 166, .30), transparent 28%),
      radial-gradient(circle at 84% 12%, rgba(14, 165, 233, .25), transparent 31%),
      radial-gradient(circle at 48% 105%, rgba(163, 230, 53, .23), transparent 40%),
      linear-gradient(135deg, #fbfffb 0%, #e9fbf6 42%, #f7fbff 100%);
  }

  .svc-home::before,
  .svc-home::after {
    content: "";
    position: absolute;
    pointer-events: none;
    z-index: -1;
    opacity: .42;
  }

  .svc-home::before {
    width: 620px;
    height: 620px;
    top: -310px;
    right: -170px;
    border-radius: 48% 52% 42% 58%;
    background: conic-gradient(from 180deg, rgba(14,165,233,.46), rgba(20,184,166,.36), rgba(163,230,53,.32), rgba(139,92,246,.25), rgba(14,165,233,.46));
    animation: svc-blob 16s ease-in-out infinite alternate;
  }

  .svc-home::after {
    width: 520px;
    height: 520px;
    left: -230px;
    bottom: -260px;
    border-radius: 999px;
    background: conic-gradient(from 20deg, rgba(251,113,133,.28), rgba(245,158,11,.28), rgba(20,184,166,.30), rgba(14,165,233,.24), rgba(251,113,133,.28));
    animation: svc-orb-bg 14s ease-in-out infinite alternate;
  }

  .svc-wrap {
    max-width: 1240px;
    margin: 0 auto;
    position: relative;
  }

  .svc-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) 390px;
    gap: 22px;
    align-items: stretch;
    margin-bottom: 20px;
  }

  .svc-hero-card,
  .svc-live-card,
  .svc-uc-card {
    border: 1px solid var(--svc-line);
    background: var(--svc-card);
    box-shadow: var(--svc-shadow);
    backdrop-filter: blur(24px);
  }

  .svc-hero-card {
    min-height: 310px;
    border-radius: 38px;
    padding: 36px;
    position: relative;
    overflow: hidden;
  }

  .svc-hero-card::before {
    content: "";
    position: absolute;
    inset: -1px;
    pointer-events: none;
    background:
      linear-gradient(120deg, rgba(255, 255, 255, .72), transparent 28%),
      radial-gradient(circle at 86% 20%, rgba(20, 184, 166, .22), transparent 30%),
      radial-gradient(circle at 16% 88%, rgba(163, 230, 53, .18), transparent 28%);
  }

  .svc-chip {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-radius: 999px;
    padding: 7px 12px;
    border: 1px solid rgba(20, 184, 166, .24);
    background: rgba(20, 184, 166, .12);
    color: #0f766e;
    font-size: 12px;
    font-weight: 1000;
    letter-spacing: .09em;
    text-transform: uppercase;
  }

  .svc-pulse {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--svc-teal);
    box-shadow: 0 0 0 7px rgba(20, 184, 166, .14);
    animation: svc-pulse 1.8s ease-in-out infinite;
  }

  .svc-hero h1 {
    position: relative;
    z-index: 1;
    max-width: 760px;
    margin: 26px 0 0;
    color: var(--svc-ink);
    font-size: clamp(42px, 6.4vw, 78px);
    line-height: .90;
    letter-spacing: -.075em;
  }

  .svc-hero h1 span {
    color: transparent;
    background: linear-gradient(96deg, #0284c7 0%, #0f766e 44%, #65a30d 73%, #f59e0b 100%);
    -webkit-background-clip: text;
    background-clip: text;
  }

  .svc-lead {
    position: relative;
    z-index: 1;
    max-width: 690px;
    margin: 0;
    color: var(--svc-muted);
    font-size: 16px;
    line-height: 1.72;
  }

  .svc-tags,
  .svc-hero-actions {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .svc-tags {
    margin-top: 18px;
  }

  .svc-tag {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 8px 11px;
    color: var(--svc-ink);
    background: rgba(255, 255, 255, .66);
    border: 1px solid rgba(17, 34, 51, .08);
    font-size: 12px;
    font-weight: 950;
  }

  .svc-tag--live {
    color: #0f766e;
    background: rgba(20, 184, 166, .11);
    border-color: rgba(20, 184, 166, .18);
  }

  .svc-hero-actions {
    margin-top: 24px;
  }

  .svc-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 45px;
    border-radius: 999px;
    padding: 10px 18px;
    border: 1px solid rgba(17, 34, 51, .12);
    background: rgba(255, 255, 255, .76);
    color: var(--svc-ink);
    text-decoration: none;
    font-size: 14px;
    font-weight: 950;
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
  }

  .svc-button:hover {
    transform: translateY(-2px);
    border-color: rgba(14, 165, 233, .34);
    box-shadow: 0 18px 44px rgba(14, 165, 233, .16);
  }

  .svc-button--primary {
    color: #fff;
    border-color: transparent;
    background: linear-gradient(135deg, #0891b2, #14b8a6);
    box-shadow: 0 18px 42px rgba(20, 184, 166, .24);
  }

  .svc-live-card {
    min-height: 360px;
    border-radius: 38px;
    padding: 22px;
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(160deg, rgba(255, 255, 255, .86), rgba(236, 253, 245, .58)),
      radial-gradient(circle at 30% 18%, rgba(163, 230, 53, .20), transparent 28%);
  }

  .svc-live-card::before {
    content: "";
    position: absolute;
    inset: 22px;
    border-radius: 32px;
    background:
      linear-gradient(145deg, rgba(14, 38, 58, .90), rgba(12, 86, 110, .74)),
      radial-gradient(circle at 22% 18%, rgba(163,230,53,.24), transparent 32%);
  }

  .svc-live-ring {
    position: absolute;
    inset: 48px;
    border: 1px dashed rgba(255, 255, 255, .25);
    border-radius: 999px;
    animation: svc-spin 22s linear infinite;
  }

  .svc-live-core {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 158px;
    height: 158px;
    border-radius: 46px;
    transform: translate(-50%, -50%) rotate(14deg);
    background: linear-gradient(135deg, rgba(103, 232, 249, .96), rgba(163, 230, 53, .86));
    box-shadow: 0 26px 76px rgba(20, 184, 166, .34);
    animation: svc-core 4.8s ease-in-out infinite;
  }

  .svc-live-word {
    position: absolute;
    z-index: 2;
    border-radius: 999px;
    padding: 9px 12px;
    color: #f8fbff;
    background: rgba(15, 23, 42, .48);
    border: 1px solid rgba(255, 255, 255, .18);
    backdrop-filter: blur(12px);
    font-size: 12px;
    font-weight: 1000;
  }

  .svc-live-word:nth-child(4) { left: 34px; top: 42px; animation: svc-drift-a 5.5s ease-in-out infinite; }
  .svc-live-word:nth-child(5) { right: 30px; top: 98px; animation: svc-drift-b 6.2s ease-in-out infinite; }
  .svc-live-word:nth-child(6) { left: 44px; bottom: 78px; animation: svc-drift-b 5.8s ease-in-out infinite reverse; }
  .svc-live-word:nth-child(7) { right: 42px; bottom: 44px; animation: svc-drift-a 6.5s ease-in-out infinite reverse; }

  .svc-section {
    margin-top: 20px;
  }

  .svc-section-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 14px;
    margin: 0 0 14px;
  }

  .svc-section-head h2 {
    margin: 0;
    color: var(--svc-ink);
    font-size: 26px;
    letter-spacing: -.05em;
  }

  .svc-section-head p {
    margin: 5px 0 0;
    color: var(--svc-muted);
    font-size: 13px;
  }

  .svc-bento {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: minmax(196px, auto);
    gap: 16px;
  }

  .svc-uc-card {
    --accent: var(--svc-blue);
    --accent-soft: rgba(14, 165, 233, .20);
    grid-column: span 4;
    position: relative;
    overflow: hidden;
    border-radius: 32px;
    padding: 22px;
    text-decoration: none;
    color: var(--svc-ink);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, .92), rgba(255, 255, 255, .68)),
      radial-gradient(circle at 100% 0%, var(--accent-soft), transparent 34%);
    transform: translateY(20px);
    opacity: 0;
    animation: svc-rise .72s cubic-bezier(.22, 1, .36, 1) forwards;
    transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
  }

  .svc-uc-card:nth-child(1) { animation-delay: .02s; }
  .svc-uc-card:nth-child(2) { animation-delay: .08s; }
  .svc-uc-card:nth-child(3) { animation-delay: .14s; }
  .svc-uc-card:nth-child(1) {
    grid-column: span 5;
  }

  .svc-uc-card:nth-child(2) {
    grid-column: span 3;
  }

  .svc-uc-card:hover {
    transform: translateY(-7px) rotate(-.24deg);
    border-color: color-mix(in srgb, var(--accent) 36%, transparent);
    box-shadow: 0 34px 92px rgba(18, 38, 63, .22);
  }

  .svc-uc-card::before {
    content: "";
    position: absolute;
    width: 190px;
    height: 190px;
    right: -64px;
    top: -64px;
    border-radius: 999px;
    background: radial-gradient(circle, var(--accent-soft), transparent 68%);
    transition: transform .25s ease;
  }

  .svc-uc-card:hover::before {
    transform: scale(1.24);
  }

  .svc-uc-card::after {
    content: "";
    position: absolute;
    left: 22px;
    right: 22px;
    bottom: 18px;
    height: 4px;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--accent), transparent);
    opacity: .66;
  }

  .svc-uc-top {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
  }

  .svc-uc-code {
    display: inline-flex;
    border-radius: 999px;
    padding: 6px 10px;
    background: rgba(255, 255, 255, .74);
    border: 1px solid rgba(17, 34, 51, .08);
    color: var(--accent);
    font-size: 12px;
    font-weight: 1000;
    letter-spacing: .06em;
  }

  .svc-uc-orb {
    width: 52px;
    height: 52px;
    border-radius: 19px;
    background: linear-gradient(135deg, var(--accent), rgba(255, 255, 255, .36));
    box-shadow: 0 16px 36px var(--accent-soft);
    transform: rotate(8deg);
  }

  .svc-uc-card h3 {
    position: relative;
    z-index: 1;
    margin: 30px 0 10px;
    max-width: 360px;
    color: var(--svc-ink);
    font-size: 25px;
    line-height: 1.05;
    letter-spacing: -.05em;
  }

  .svc-uc-card p {
    position: relative;
    z-index: 1;
    max-width: 500px;
    margin: 0;
    color: var(--svc-muted);
    font-size: 14px;
    line-height: 1.58;
    font-weight: 750;
  }

  .svc-open {
    position: absolute;
    z-index: 1;
    right: 22px;
    bottom: 25px;
    color: var(--accent);
    font-size: 13px;
    font-weight: 1000;
  }

  .svc-uc-card:nth-child(1) { --accent: var(--svc-teal); --accent-soft: rgba(20,184,166,.22); }
  .svc-uc-card:nth-child(2) { --accent: var(--svc-blue); --accent-soft: rgba(14,165,233,.22); }
  .svc-uc-card:nth-child(3) { --accent: var(--svc-violet); --accent-soft: rgba(139,92,246,.20); }

  @keyframes svc-blob {
    0% { transform: translate3d(0, 0, 0) rotate(0deg); border-radius: 48% 52% 42% 58%; }
    100% { transform: translate3d(26px, 30px, 0) rotate(18deg); border-radius: 56% 44% 60% 40%; }
  }

  @keyframes svc-orb-bg {
    from { transform: translate3d(0, 0, 0) rotate(0deg); }
    to { transform: translate3d(34px, -18px, 0) rotate(-14deg); }
  }

  @keyframes svc-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(.72); opacity: .68; }
  }

  @keyframes svc-spin { to { transform: rotate(360deg); } }

  @keyframes svc-core {
    0%, 100% { transform: translate(-50%, -50%) rotate(14deg) scale(1); border-radius: 46px; }
    50% { transform: translate(-50%, -50%) rotate(24deg) scale(1.07); border-radius: 72px; }
  }

  @keyframes svc-drift-a {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(12px, -10px, 0); }
  }

  @keyframes svc-drift-b {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(-10px, 12px, 0); }
  }

  @keyframes svc-rise {
    to { transform: translateY(0); opacity: 1; }
  }

  @media (max-width: 1080px) {
    .svc-hero { grid-template-columns: 1fr; }
    .svc-live-card { min-height: 320px; }
    .svc-uc-card,
    .svc-uc-card:nth-child(1),
    .svc-uc-card:nth-child(2) { grid-column: span 6; }
  }

  @media (max-width: 760px) {
    .svc-home { padding: 20px 12px 42px; }
    .svc-hero-card { min-height: auto; padding: 24px; border-radius: 30px; }
    .svc-hero h1 { font-size: 44px; }
    .svc-live-card { min-height: 280px; }
    .svc-uc-card,
    .svc-uc-card:nth-child(1),
    .svc-uc-card:nth-child(2) {
      grid-column: 1 / -1;
      min-height: 220px;
    }
    .svc-section-head { display: block; }
  }

  @media (prefers-reduced-motion: reduce) {
    .svc-home::before,
    .svc-home::after,
    .svc-pulse,
    .svc-live-ring,
    .svc-live-core,
    .svc-live-word,
    .svc-uc-card {
      animation: none;
    }
    .svc-uc-card {
      transform: none;
      opacity: 1;
    }
  }

  /* Service dashboard galaxy pass only: visual refresh, keep actions/routes untouched. */
  .svc-home {
    --svc-ink: #f8fbff;
    --svc-ink-dark: #102033;
    --svc-muted: #b7c9df;
    --svc-card: rgba(9, 22, 49, .78);
    --svc-line: rgba(148, 210, 255, .24);
    --svc-blue: #22d3ee;
    --svc-teal: #34d399;
    --svc-lime: #bef264;
    --svc-amber: #facc15;
    --svc-coral: #fb7185;
    --svc-violet: #a78bfa;
    --svc-shadow: 0 30px 90px rgba(0, 0, 0, .38);
    background:
      radial-gradient(circle at 10% 8%, rgba(34, 211, 238, .22), transparent 27%),
      radial-gradient(circle at 82% 10%, rgba(167, 139, 250, .18), transparent 30%),
      radial-gradient(circle at 72% 92%, rgba(251, 113, 133, .14), transparent 30%),
      linear-gradient(145deg, #061321 0%, #0a1731 48%, #190e37 100%);
  }

  .svc-home::before {
    inset: 0;
    width: auto;
    height: auto;
    top: 0;
    right: 0;
    border-radius: 0;
    opacity: .86;
    background-image:
      radial-gradient(circle, #f8fbff 0 1.1px, transparent 1.7px),
      radial-gradient(circle, #93e8ff 0 1px, transparent 1.5px),
      radial-gradient(circle, rgba(255,255,255,.86) 0 1px, transparent 1.5px);
    background-size: 120px 120px, 180px 180px, 260px 260px;
    background-position: 12px 24px, 70px 42px, 28px 96px;
    animation: svc-star-drift 46s linear infinite;
  }

  .svc-home::after {
    inset: 0;
    width: auto;
    height: auto;
    left: 0;
    bottom: 0;
    border-radius: 0;
    opacity: .55;
    background:
      linear-gradient(112deg, transparent 0 38%, rgba(34,211,238,.16) 39%, transparent 40% 100%),
      linear-gradient(26deg, transparent 0 63%, rgba(250,204,21,.11) 64%, transparent 65% 100%),
      radial-gradient(circle at 18% 90%, rgba(52,211,153,.12), transparent 28%);
    animation: none;
  }

  .svc-wrap {
    max-width: 1320px;
    z-index: 1;
  }

  .svc-hero {
    grid-template-columns: minmax(0, 1.05fr) minmax(360px, .95fr);
    gap: 24px;
    margin-bottom: 24px;
  }

  .svc-hero-card,
  .svc-live-card,
  .svc-uc-card {
    border-color: var(--svc-line);
    background: linear-gradient(180deg, rgba(12, 28, 61, .88), rgba(6, 16, 36, .78));
    box-shadow: var(--svc-shadow);
  }

  .svc-hero-card {
    min-height: 340px;
    border-radius: 34px;
    padding: 38px;
  }

  .svc-hero-card::before {
    background:
      radial-gradient(circle at 86% 22%, rgba(34, 211, 238, .18), transparent 30%),
      radial-gradient(circle at 12% 88%, rgba(52, 211, 153, .14), transparent 28%),
      linear-gradient(120deg, rgba(255, 255, 255, .08), transparent 34%);
  }

  .svc-chip {
    border-color: rgba(34, 211, 238, .36);
    background: rgba(34, 211, 238, .14);
    color: #cffafe;
    box-shadow: 0 0 0 7px rgba(34, 211, 238, .07);
  }

  .svc-pulse {
    background: var(--svc-teal);
    box-shadow: 0 0 0 7px rgba(52, 211, 153, .14);
  }

  .svc-hero h1 {
    color: #f8fbff;
    font-size: clamp(46px, 6vw, 76px);
    letter-spacing: -.055em;
  }

  .svc-hero h1 span {
    background: linear-gradient(96deg, #22d3ee 0%, #34d399 40%, #facc15 70%, #fb7185 100%);
    -webkit-background-clip: text;
    background-clip: text;
  }

  .svc-lead {
    color: #c4d7ea;
  }

  .svc-tag {
    color: #eaf8ff;
    background: rgba(255, 255, 255, .08);
    border-color: rgba(148, 210, 255, .22);
  }

  .svc-tag--live {
    color: #d1fae5;
    background: rgba(52, 211, 153, .13);
    border-color: rgba(52, 211, 153, .26);
  }

  .svc-button {
    color: #f8fbff;
    border-color: rgba(148, 210, 255, .24);
    background: rgba(255, 255, 255, .08);
    box-shadow: 0 14px 34px rgba(0, 0, 0, .16);
  }

  .svc-button--primary {
    color: #04111f;
    background: linear-gradient(135deg, #22d3ee, #34d399);
    box-shadow: 0 20px 48px rgba(52, 211, 153, .24);
  }

  .svc-live-card {
    min-height: 382px;
    border-radius: 34px;
    background:
      linear-gradient(180deg, rgba(12, 28, 61, .88), rgba(6, 16, 36, .78)),
      radial-gradient(circle at 32% 20%, rgba(34,211,238,.16), transparent 30%);
  }

  .svc-live-card::before {
    inset: 22px;
    border-radius: 30px;
    background:
      radial-gradient(circle at 50% 50%, rgba(34, 211, 238, .14), transparent 28%),
      radial-gradient(circle at 80% 74%, rgba(250, 204, 21, .12), transparent 24%),
      linear-gradient(145deg, rgba(5, 12, 31, .96), rgba(16, 28, 69, .88));
    box-shadow: inset 0 0 90px rgba(34, 211, 238, .10);
  }

  .svc-live-card::after {
    display:none;
  }

  .svc-earth-3d {
    position: absolute;
    z-index: 4;
    left: 50%;
    top: 52%;
    width: 210px;
    height: 210px;
    border-radius: 999px;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle at 42% 42%, rgba(14,165,233,.20), rgba(2,6,23,.08) 70%);
    filter: drop-shadow(0 28px 48px rgba(0, 0, 0, .38));
    animation: svc-earth-float 8s ease-in-out infinite;
  }

  .svc-earth-3d::before,
  .svc-earth-3d::after {
    content: "";
    position: absolute;
    pointer-events: none;
    border-radius: 999px;
  }

  .svc-earth-3d::before {
    inset: -24px;
    background: radial-gradient(circle, transparent 58%, rgba(103,232,249,.18) 68%, transparent 74%);
    filter: blur(2px);
  }

  .svc-earth-3d::after {
    left: -48px;
    right: -48px;
    top: 78px;
    height: 46px;
    border-top: 2px solid rgba(191,219,254,.42);
    transform: rotate(-14deg);
    opacity: .58;
  }

  .svc-earth-3d canvas {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: 100%;
  }

  .svc-live-ring {
    inset: 58px;
    border-color: rgba(148, 210, 255, .30);
    box-shadow: 0 0 60px rgba(34, 211, 238, .11);
  }

  .svc-live-core {
    width: 230px;
    height: 66px;
    border-radius: 50%;
    background: transparent;
    border: 1px solid rgba(148, 210, 255, .38);
    box-shadow: 0 0 50px rgba(34, 211, 238, .10);
    animation: svc-orbit-tilt 18s linear infinite;
  }

  .svc-live-word {
    color: #f8fbff;
    background: rgba(15, 23, 42, .68);
    border-color: rgba(148, 210, 255, .26);
    box-shadow: 0 14px 34px rgba(0, 0, 0, .24);
  }

  .svc-live-word:nth-child(4) { left: 40px; top: 48px; }
  .svc-live-word:nth-child(5) { right: 34px; top: 92px; }
  .svc-live-word:nth-child(6) { left: 46px; bottom: 68px; }
  .svc-live-word:nth-child(7) { right: 42px; bottom: 48px; }
  .svc-live-word:nth-of-type(1) { left: 34px; top: 32px; }
  .svc-live-word:nth-of-type(2) { left: 56px; top: 72px; }
  .svc-live-word:nth-of-type(3) { right: 34px; top: 98px; }
  .svc-live-word:nth-of-type(4) { left: 48px; bottom: 54px; }

  .svc-section {
    margin-top: 24px;
  }

  .svc-section-head h2 {
    color: #f8fbff;
    font-size: 30px;
    letter-spacing: -.03em;
  }

  .svc-bento {
    grid-auto-rows: minmax(230px, auto);
    gap: 18px;
  }

  .svc-uc-card {
    min-height: 238px;
    border-radius: 30px;
    padding: 24px;
    color: #fff;
    background: linear-gradient(135deg, #22d3ee, #2563eb);
    border-color: rgba(255, 255, 255, .18);
    box-shadow: 0 24px 62px rgba(0, 0, 0, .28);
  }

  .svc-uc-card:nth-child(1) {
    --accent: #22d3ee;
    --accent-soft: rgba(34, 211, 238, .28);
    background: linear-gradient(135deg, #22d3ee 0%, #2563eb 100%);
  }

  .svc-uc-card:nth-child(2) {
    --accent: #34d399;
    --accent-soft: rgba(52, 211, 153, .28);
    background: linear-gradient(135deg, #34d399 0%, #14b8a6 48%, #2563eb 100%);
  }

  .svc-uc-card:nth-child(3) {
    --accent: #fb7185;
    --accent-soft: rgba(251, 113, 133, .28);
    background: linear-gradient(135deg, #facc15 0%, #fb7185 52%, #a78bfa 100%);
  }

  .svc-uc-card::before {
    background: radial-gradient(circle, rgba(255,255,255,.28), transparent 68%);
  }

  .svc-uc-card::after {
    background: linear-gradient(90deg, rgba(255,255,255,.86), rgba(255,255,255,.16));
  }

  .svc-uc-code {
    color: #fff;
    background: rgba(255, 255, 255, .18);
    border-color: rgba(255, 255, 255, .26);
  }

  .svc-uc-orb {
    background: rgba(255, 255, 255, .18);
    border: 1px solid rgba(255, 255, 255, .28);
    box-shadow: inset 0 0 0 1px rgba(255,255,255,.08), 0 18px 42px rgba(0,0,0,.14);
  }

  .svc-uc-card h3 {
    color: #fff;
    font-size: 29px;
    line-height: 1.08;
    letter-spacing: -.025em;
    text-shadow: 0 2px 16px rgba(0, 0, 0, .16);
  }

  .svc-uc-card p {
    color: rgba(255, 255, 255, .86);
  }

  .svc-open {
    color: #fff;
    right: 24px;
  }

  @keyframes svc-star-drift {
    from { background-position: 12px 24px, 70px 42px, 28px 96px; }
    to { background-position: 132px 144px, 250px 222px, 288px 356px; }
  }

  @keyframes svc-planet-breathe {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.04); }
  }

  @keyframes svc-earth-float {
    0%, 100% { transform: translate(-50%, -50%) scale(1); }
    50% { transform: translate(-50%, -54%) scale(1.035); }
  }

  @keyframes svc-orbit-tilt {
    from { transform: translate(-50%, -50%) rotate(-18deg); }
    to { transform: translate(-50%, -50%) rotate(342deg); }
  }

  @media (max-width: 1080px) {
    .svc-hero {
      grid-template-columns: 1fr;
    }
    .svc-live-card {
      min-height: 330px;
    }
    .svc-uc-card,
    .svc-uc-card:nth-child(1),
    .svc-uc-card:nth-child(2) {
      grid-column: span 6;
    }
  }

  @media (max-width: 760px) {
    .svc-home {
      padding: 22px 12px 44px;
    }
    .svc-hero-card {
      padding: 24px;
      border-radius: 28px;
    }
    .svc-hero h1 {
      font-size: 42px;
      letter-spacing: -.035em;
    }
    .svc-live-card {
      min-height: 300px;
      border-radius: 28px;
    }
    .svc-live-card::after {
      display:none;
    }
    .svc-earth-3d {
      width: 164px;
      height: 164px;
    }
    .svc-live-core {
      width: 184px;
      height: 54px;
    }
    .svc-live-word {
      font-size: 11px;
      padding: 8px 10px;
    }
    .svc-live-word:nth-of-type(1) { left: 24px; top: 24px; }
    .svc-live-word:nth-of-type(2) { left: 42px; top: 58px; }
    .svc-live-word:nth-of-type(3) { right: 24px; top: 86px; }
    .svc-live-word:nth-of-type(4) { left: 42px; bottom: 24px; }
    .svc-uc-card,
    .svc-uc-card:nth-child(1),
    .svc-uc-card:nth-child(2) {
      grid-column: 1 / -1;
      min-height: 218px;
    }
    .svc-uc-card h3 {
      font-size: 25px;
    }
  }
</style>

<main class="svc-home">
  <div class="svc-wrap">
    <section class="svc-hero" aria-label="Dashboard nhân viên dịch vụ">
      <div class="svc-hero-card">
        <div class="svc-chip"><span class="svc-pulse"></span> Service operations center</div>
        <h1>Xin chào <span><%= staffName %></span></h1>

        <div class="svc-tags" aria-label="Thông tin nhanh">
          <span class="svc-tag svc-tag--live">Ca dịch vụ: sẵn sàng</span>
          <span class="svc-tag"><%= todayLabel %></span>
        </div>

        <div class="svc-hero-actions">
          <% if (primaryActions[0]) { %><a class="svc-button svc-button--primary" href="<%= primaryActions[0].href %>"><%= primaryActions[0].label %></a><% } %>
          <% if (primaryActions[1]) { %><a class="svc-button" href="<%= primaryActions[1].href %>"><%= primaryActions[1].label %></a><% } %>
          <% if (primaryActions[2]) { %><a class="svc-button" href="<%= primaryActions[2].href %>"><%= primaryActions[2].label %></a><% } %>
        </div>
      </div>

      <aside class="svc-live-card" aria-label="Minh họa vận hành dịch vụ">
        <div class="svc-live-ring"></div>
        <div class="svc-live-core"></div>
        <div class="svc-earth-3d" data-earth-3d>
          <canvas aria-label="Trái Đất 3D xoay"></canvas>
        </div>
        <span class="svc-live-word">Catalog</span>
        <span class="svc-live-word">Room Check</span>
        <span class="svc-live-word">Inspection</span>
        <span class="svc-live-word">Live Board</span>
      </aside>
    </section>

    <section class="svc-section" aria-label="Nghiệp vụ nhân viên dịch vụ">
      <div class="svc-section-head">
        <div>
          <h2>Tác vụ chính</h2>
        </div>
      </div>

      <div class="svc-bento">
        <% primaryActions.forEach((item, index) => { %>
          <a class="svc-uc-card" href="<%= item.href %>">
            <div class="svc-uc-top">
              <span class="svc-uc-code"><%= String(index + 1).padStart(2, "0") %></span>
              <span class="svc-uc-orb"></span>
            </div>
            <h3><%= item.label %></h3>
            <span class="svc-open">Mở</span>
          </a>
        <% }) %>
      </div>
    </section>
  </div>
</main>

<script type="module" src="/js/home-galaxy-earth.js"></script>
<%- include("../partials/footer") %>
