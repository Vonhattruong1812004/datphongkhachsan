<%- include("../partials/head") %>
<%- include("../partials/header") %>
<%
  const staffName = (typeof currentUser !== "undefined" && currentUser ? (currentUser.displayName || currentUser.username) : "") || "Nhân viên dịch vụ";
  const primaryActions = actions || [];
  const focusCards = cards || [];
  const todayLabel = new Date().toLocaleDateString("vi-VN", {
    weekday: "long",
    day: "2-digit",
    month: "2-digit",
    year: "numeric"
  });
  const shiftCards = [
    {
      badge: "Đầu ca",
      title: "Mở Room board live",
      line1: "Xem nhanh các phòng đang ở, cần vệ sinh, hư hại hoặc bảo trì.",
      line2: "Ưu tiên phòng có tín hiệu cần xử lý trước khi chuyển ca.",
      strong: "Room board live",
      href: "/service/room-board-live",
      action: "Xem feed"
    },
    {
      badge: "Trong ca",
      title: "Quản lý dịch vụ",
      line1: "Rà soát tên, giá, mô tả, hình ảnh và trạng thái của từng dịch vụ.",
      line2: "Dịch vụ không sẵn sàng cần chuyển ngưng bán hoặc bảo trì.",
      strong: "Catalog rõ ràng",
      href: "/service/catalog/manage",
      action: "Quản lý"
    },
    {
      badge: "Cuối ca",
      title: "Kiểm tra tình trạng phòng",
      line1: "Chọn phòng đang ở hoặc cần kiểm tra và cập nhật tình trạng thực tế.",
      line2: "Ghi nhận phòng tốt, hư hại hoặc cần bảo trì để bộ phận liên quan tiếp tục xử lý.",
      strong: "Room check rõ ràng",
      href: "/service/room-inspection",
      action: "Cập nhật"
    }
  ];
%>

<style>
  .svc-home {
    --svc-ink: #102033;
    --svc-muted: #667085;
    --svc-card: rgba(255, 255, 255, .75);
    --svc-line: rgba(16, 32, 51, .10);
    --svc-blue: #0ea5e9;
    --svc-teal: #14b8a6;
    --svc-lime: #a3e635;
    --svc-amber: #f59e0b;
    --svc-coral: #fb7185;
    --svc-violet: #8b5cf6;
    --svc-shadow: 0 28px 86px rgba(18, 38, 63, .17);
    min-height: calc(100vh - 84px);
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: 34px 18px 58px;
    color: var(--svc-ink);
    background:
      radial-gradient(circle at 7% 10%, rgba(20, 184, 166, .30), transparent 28%),
      radial-gradient(circle at 84% 12%, rgba(14, 165, 233, .25), transparent 31%),
      radial-gradient(circle at 48% 105%, rgba(163, 230, 53, .23), transparent 40%),
      linear-gradient(135deg, #fbfffb 0%, #e9fbf6 42%, #f7fbff 100%);
  }

  .svc-home::before,
  .svc-home::after {
    content: "";
    position: absolute;
    pointer-events: none;
    z-index: -1;
    opacity: .42;
  }

  .svc-home::before {
    width: 620px;
    height: 620px;
    top: -310px;
    right: -170px;
    border-radius: 48% 52% 42% 58%;
    background: conic-gradient(from 180deg, rgba(14,165,233,.46), rgba(20,184,166,.36), rgba(163,230,53,.32), rgba(139,92,246,.25), rgba(14,165,233,.46));
    animation: svc-blob 16s ease-in-out infinite alternate;
  }

  .svc-home::after {
    width: 520px;
    height: 520px;
    left: -230px;
    bottom: -260px;
    border-radius: 999px;
    background: conic-gradient(from 20deg, rgba(251,113,133,.28), rgba(245,158,11,.28), rgba(20,184,166,.30), rgba(14,165,233,.24), rgba(251,113,133,.28));
    animation: svc-orb-bg 14s ease-in-out infinite alternate;
  }

  .svc-wrap {
    max-width: 1240px;
    margin: 0 auto;
    position: relative;
  }

  .svc-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) 390px;
    gap: 22px;
    align-items: stretch;
    margin-bottom: 20px;
  }

  .svc-hero-card,
  .svc-live-card,
  .svc-uc-card,
  .svc-focus-card,
  .svc-shift-card {
    border: 1px solid var(--svc-line);
    background: var(--svc-card);
    box-shadow: var(--svc-shadow);
    backdrop-filter: blur(24px);
  }

  .svc-hero-card {
    min-height: 360px;
    border-radius: 38px;
    padding: 36px;
    position: relative;
    overflow: hidden;
  }

  .svc-hero-card::before {
    content: "";
    position: absolute;
    inset: -1px;
    pointer-events: none;
    background:
      linear-gradient(120deg, rgba(255, 255, 255, .72), transparent 28%),
      radial-gradient(circle at 86% 20%, rgba(20, 184, 166, .22), transparent 30%),
      radial-gradient(circle at 16% 88%, rgba(163, 230, 53, .18), transparent 28%);
  }

  .svc-chip {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-radius: 999px;
    padding: 7px 12px;
    border: 1px solid rgba(20, 184, 166, .24);
    background: rgba(20, 184, 166, .12);
    color: #0f766e;
    font-size: 12px;
    font-weight: 1000;
    letter-spacing: .09em;
    text-transform: uppercase;
  }

  .svc-pulse {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--svc-teal);
    box-shadow: 0 0 0 7px rgba(20, 184, 166, .14);
    animation: svc-pulse 1.8s ease-in-out infinite;
  }

  .svc-hero h1 {
    position: relative;
    z-index: 1;
    max-width: 760px;
    margin: 26px 0 14px;
    color: var(--svc-ink);
    font-size: clamp(42px, 6.4vw, 78px);
    line-height: .90;
    letter-spacing: -.075em;
  }

  .svc-hero h1 span {
    color: transparent;
    background: linear-gradient(96deg, #0284c7 0%, #0f766e 44%, #65a30d 73%, #f59e0b 100%);
    -webkit-background-clip: text;
    background-clip: text;
  }

  .svc-lead {
    position: relative;
    z-index: 1;
    max-width: 690px;
    margin: 0;
    color: var(--svc-muted);
    font-size: 16px;
    line-height: 1.72;
  }

  .svc-tags,
  .svc-hero-actions {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .svc-tags {
    margin-top: 22px;
  }

  .svc-tag {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 8px 11px;
    color: var(--svc-ink);
    background: rgba(255, 255, 255, .66);
    border: 1px solid rgba(17, 34, 51, .08);
    font-size: 12px;
    font-weight: 950;
  }

  .svc-tag--live {
    color: #0f766e;
    background: rgba(20, 184, 166, .11);
    border-color: rgba(20, 184, 166, .18);
  }

  .svc-hero-actions {
    margin-top: 28px;
  }

  .svc-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 45px;
    border-radius: 999px;
    padding: 10px 18px;
    border: 1px solid rgba(17, 34, 51, .12);
    background: rgba(255, 255, 255, .76);
    color: var(--svc-ink);
    text-decoration: none;
    font-size: 14px;
    font-weight: 950;
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
  }

  .svc-button:hover {
    transform: translateY(-2px);
    border-color: rgba(14, 165, 233, .34);
    box-shadow: 0 18px 44px rgba(14, 165, 233, .16);
  }

  .svc-button--primary {
    color: #fff;
    border-color: transparent;
    background: linear-gradient(135deg, #0891b2, #14b8a6);
    box-shadow: 0 18px 42px rgba(20, 184, 166, .24);
  }

  .svc-mini-stats {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-top: 34px;
  }

  .svc-mini-stat {
    border-radius: 23px;
    padding: 16px;
    background: rgba(255, 255, 255, .58);
    border: 1px solid rgba(17, 34, 51, .08);
  }

  .svc-mini-stat strong {
    display: block;
    color: var(--svc-ink);
    font-size: 30px;
    line-height: 1;
    letter-spacing: -.055em;
  }

  .svc-mini-stat span {
    display: block;
    margin-top: 8px;
    color: var(--svc-muted);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .06em;
    text-transform: uppercase;
  }

  .svc-live-card {
    min-height: 360px;
    border-radius: 38px;
    padding: 22px;
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(160deg, rgba(255, 255, 255, .86), rgba(236, 253, 245, .58)),
      radial-gradient(circle at 30% 18%, rgba(163, 230, 53, .20), transparent 28%);
  }

  .svc-live-card::before {
    content: "";
    position: absolute;
    inset: 22px;
    border-radius: 32px;
    background:
      linear-gradient(145deg, rgba(14, 38, 58, .90), rgba(12, 86, 110, .74)),
      radial-gradient(circle at 22% 18%, rgba(163,230,53,.24), transparent 32%);
  }

  .svc-live-ring {
    position: absolute;
    inset: 48px;
    border: 1px dashed rgba(255, 255, 255, .25);
    border-radius: 999px;
    animation: svc-spin 22s linear infinite;
  }

  .svc-live-core {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 158px;
    height: 158px;
    border-radius: 46px;
    transform: translate(-50%, -50%) rotate(14deg);
    background: linear-gradient(135deg, rgba(103, 232, 249, .96), rgba(163, 230, 53, .86));
    box-shadow: 0 26px 76px rgba(20, 184, 166, .34);
    animation: svc-core 4.8s ease-in-out infinite;
  }

  .svc-live-word {
    position: absolute;
    z-index: 2;
    border-radius: 999px;
    padding: 9px 12px;
    color: #f8fbff;
    background: rgba(15, 23, 42, .48);
    border: 1px solid rgba(255, 255, 255, .18);
    backdrop-filter: blur(12px);
    font-size: 12px;
    font-weight: 1000;
  }

  .svc-live-word:nth-child(4) { left: 34px; top: 42px; animation: svc-drift-a 5.5s ease-in-out infinite; }
  .svc-live-word:nth-child(5) { right: 30px; top: 98px; animation: svc-drift-b 6.2s ease-in-out infinite; }
  .svc-live-word:nth-child(6) { left: 44px; bottom: 78px; animation: svc-drift-b 5.8s ease-in-out infinite reverse; }
  .svc-live-word:nth-child(7) { right: 42px; bottom: 44px; animation: svc-drift-a 6.5s ease-in-out infinite reverse; }

  .svc-focus-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 16px;
    align-items: center;
    border-radius: 30px;
    padding: 18px 20px;
    margin-bottom: 18px;
    background: rgba(255, 255, 255, .66);
  }

  .svc-focus-card strong {
    display: block;
    color: var(--svc-ink);
    font-size: 18px;
    letter-spacing: -.02em;
  }

  .svc-focus-card span {
    display: block;
    margin-top: 4px;
    color: var(--svc-muted);
    font-size: 13px;
  }

  .svc-flow {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .svc-flow a {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 8px 11px;
    color: #0f766e;
    background: rgba(20, 184, 166, .11);
    border: 1px solid rgba(20, 184, 166, .18);
    text-decoration: none;
    font-size: 12px;
    font-weight: 950;
  }

  .svc-section {
    margin-top: 20px;
  }

  .svc-section-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 14px;
    margin: 0 0 14px;
  }

  .svc-section-head h2 {
    margin: 0;
    color: var(--svc-ink);
    font-size: 26px;
    letter-spacing: -.05em;
  }

  .svc-section-head p {
    margin: 5px 0 0;
    color: var(--svc-muted);
    font-size: 13px;
  }

  .svc-bento {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: minmax(196px, auto);
    gap: 16px;
  }

  .svc-uc-card {
    --accent: var(--svc-blue);
    --accent-soft: rgba(14, 165, 233, .20);
    grid-column: span 4;
    position: relative;
    overflow: hidden;
    border-radius: 32px;
    padding: 22px;
    text-decoration: none;
    color: var(--svc-ink);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, .92), rgba(255, 255, 255, .68)),
      radial-gradient(circle at 100% 0%, var(--accent-soft), transparent 34%);
    transform: translateY(20px);
    opacity: 0;
    animation: svc-rise .72s cubic-bezier(.22, 1, .36, 1) forwards;
    transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
  }

  .svc-uc-card:nth-child(1) { animation-delay: .02s; }
  .svc-uc-card:nth-child(2) { animation-delay: .08s; }
  .svc-uc-card:nth-child(3) { animation-delay: .14s; }
  .svc-uc-card:nth-child(1) {
    grid-column: span 5;
  }

  .svc-uc-card:nth-child(2) {
    grid-column: span 3;
  }

  .svc-uc-card:hover {
    transform: translateY(-7px) rotate(-.24deg);
    border-color: color-mix(in srgb, var(--accent) 36%, transparent);
    box-shadow: 0 34px 92px rgba(18, 38, 63, .22);
  }

  .svc-uc-card::before {
    content: "";
    position: absolute;
    width: 190px;
    height: 190px;
    right: -64px;
    top: -64px;
    border-radius: 999px;
    background: radial-gradient(circle, var(--accent-soft), transparent 68%);
    transition: transform .25s ease;
  }

  .svc-uc-card:hover::before {
    transform: scale(1.24);
  }

  .svc-uc-card::after {
    content: "";
    position: absolute;
    left: 22px;
    right: 22px;
    bottom: 18px;
    height: 4px;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--accent), transparent);
    opacity: .66;
  }

  .svc-uc-top {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
  }

  .svc-uc-code {
    display: inline-flex;
    border-radius: 999px;
    padding: 6px 10px;
    background: rgba(255, 255, 255, .74);
    border: 1px solid rgba(17, 34, 51, .08);
    color: var(--accent);
    font-size: 12px;
    font-weight: 1000;
    letter-spacing: .06em;
  }

  .svc-uc-orb {
    width: 52px;
    height: 52px;
    border-radius: 19px;
    background: linear-gradient(135deg, var(--accent), rgba(255, 255, 255, .36));
    box-shadow: 0 16px 36px var(--accent-soft);
    transform: rotate(8deg);
  }

  .svc-uc-card h3 {
    position: relative;
    z-index: 1;
    margin: 30px 0 10px;
    max-width: 360px;
    color: var(--svc-ink);
    font-size: 25px;
    line-height: 1.05;
    letter-spacing: -.05em;
  }

  .svc-uc-card p {
    position: relative;
    z-index: 1;
    max-width: 500px;
    margin: 0;
    color: var(--svc-muted);
    font-size: 14px;
    line-height: 1.58;
    font-weight: 750;
  }

  .svc-open {
    position: absolute;
    z-index: 1;
    right: 22px;
    bottom: 25px;
    color: var(--accent);
    font-size: 13px;
    font-weight: 1000;
  }

  .svc-uc-card:nth-child(1) { --accent: var(--svc-teal); --accent-soft: rgba(20,184,166,.22); }
  .svc-uc-card:nth-child(2) { --accent: var(--svc-blue); --accent-soft: rgba(14,165,233,.22); }
  .svc-uc-card:nth-child(3) { --accent: var(--svc-violet); --accent-soft: rgba(139,92,246,.20); }

  .svc-shift-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .svc-shift-card {
    border-radius: 28px;
    padding: 20px;
    background: rgba(255, 255, 255, .70);
  }

  .svc-shift-card h3 {
    margin: 12px 0 8px;
    color: var(--svc-ink);
    font-size: 21px;
    line-height: 1.1;
    letter-spacing: -.04em;
  }

  .svc-shift-card p {
    margin: 0 0 6px;
    color: var(--svc-muted);
    font-size: 13px;
    line-height: 1.5;
  }

  .svc-shift-card strong {
    display: block;
    margin-top: 10px;
    color: var(--svc-ink);
    font-size: 21px;
  }

  .svc-badge {
    display: inline-flex;
    border-radius: 999px;
    padding: 5px 9px;
    background: rgba(20, 184, 166, .12);
    color: #0f766e;
    font-size: 11px;
    font-weight: 1000;
    letter-spacing: .04em;
  }

  @keyframes svc-blob {
    0% { transform: translate3d(0, 0, 0) rotate(0deg); border-radius: 48% 52% 42% 58%; }
    100% { transform: translate3d(26px, 30px, 0) rotate(18deg); border-radius: 56% 44% 60% 40%; }
  }

  @keyframes svc-orb-bg {
    from { transform: translate3d(0, 0, 0) rotate(0deg); }
    to { transform: translate3d(34px, -18px, 0) rotate(-14deg); }
  }

  @keyframes svc-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(.72); opacity: .68; }
  }

  @keyframes svc-spin { to { transform: rotate(360deg); } }

  @keyframes svc-core {
    0%, 100% { transform: translate(-50%, -50%) rotate(14deg) scale(1); border-radius: 46px; }
    50% { transform: translate(-50%, -50%) rotate(24deg) scale(1.07); border-radius: 72px; }
  }

  @keyframes svc-drift-a {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(12px, -10px, 0); }
  }

  @keyframes svc-drift-b {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(-10px, 12px, 0); }
  }

  @keyframes svc-rise {
    to { transform: translateY(0); opacity: 1; }
  }

  @media (max-width: 1080px) {
    .svc-hero { grid-template-columns: 1fr; }
    .svc-live-card { min-height: 320px; }
    .svc-uc-card,
    .svc-uc-card:nth-child(1),
    .svc-uc-card:nth-child(2) { grid-column: span 6; }
    .svc-shift-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 760px) {
    .svc-home { padding: 20px 12px 42px; }
    .svc-hero-card { min-height: auto; padding: 24px; border-radius: 30px; }
    .svc-hero h1 { font-size: 44px; }
    .svc-mini-stats,
    .svc-focus-card,
    .svc-shift-grid { grid-template-columns: 1fr; }
    .svc-live-card { min-height: 280px; }
    .svc-uc-card,
    .svc-uc-card:nth-child(1),
    .svc-uc-card:nth-child(2) {
      grid-column: 1 / -1;
      min-height: 220px;
    }
    .svc-section-head { display: block; }
  }

  @media (prefers-reduced-motion: reduce) {
    .svc-home::before,
    .svc-home::after,
    .svc-pulse,
    .svc-live-ring,
    .svc-live-core,
    .svc-live-word,
    .svc-uc-card {
      animation: none;
    }
    .svc-uc-card {
      transform: none;
      opacity: 1;
    }
  }
</style>

<main class="svc-home">
  <div class="svc-wrap">
    <section class="svc-hero" aria-label="Dashboard nhân viên dịch vụ">
      <div class="svc-hero-card">
        <div class="svc-chip"><span class="svc-pulse"></span> Service operations center</div>
        <h1>Xin chào <span><%= staffName %></span></h1>
        <p class="svc-lead">
          Dashboard cho ca dịch vụ: quản lý dịch vụ, kiểm tra tình trạng phòng
          và theo dõi Room board live đúng phạm vi actor Nhân viên dịch vụ.
        </p>

        <div class="svc-tags" aria-label="Thông tin nhanh">
          <span class="svc-tag svc-tag--live">Ca dịch vụ: sẵn sàng</span>
          <span class="svc-tag"><%= todayLabel %></span>
          <span class="svc-tag">3 nghiệp vụ chính</span>
        </div>

        <div class="svc-hero-actions">
          <% if (primaryActions[0]) { %><a class="svc-button svc-button--primary" href="<%= primaryActions[0].href %>"><%= primaryActions[0].label %></a><% } %>
          <% if (primaryActions[1]) { %><a class="svc-button" href="<%= primaryActions[1].href %>"><%= primaryActions[1].label %></a><% } %>
          <% if (primaryActions[2]) { %><a class="svc-button" href="<%= primaryActions[2].href %>"><%= primaryActions[2].label %></a><% } %>
        </div>

        <div class="svc-mini-stats" aria-label="Tóm tắt dịch vụ">
          <div class="svc-mini-stat"><strong>03</strong><span>Nghiệp vụ chính</span></div>
          <div class="svc-mini-stat"><strong>Live</strong><span>Room feed</span></div>
          <div class="svc-mini-stat"><strong>Room</strong><span>Inspection</span></div>
        </div>
      </div>

      <aside class="svc-live-card" aria-label="Minh họa vận hành dịch vụ">
        <div class="svc-live-ring"></div>
        <div class="svc-live-core"></div>
        <span class="svc-live-word">Catalog</span>
        <span class="svc-live-word">Room Check</span>
        <span class="svc-live-word">Inspection</span>
        <span class="svc-live-word">Live Board</span>
      </aside>
    </section>

    <section class="svc-focus-card">
      <div>
        <strong>Luồng ưu tiên trong một ca dịch vụ</strong>
        <span>Mở room board live, rà soát danh mục dịch vụ và cập nhật tình trạng phòng sau kiểm tra.</span>
      </div>
      <div class="svc-flow" aria-label="Luồng nghiệp vụ dịch vụ">
        <a href="/service/catalog/manage">Quản lý dịch vụ</a>
        <a href="/service/room-inspection">Kiểm tra phòng</a>
        <a href="/service/room-board-live">Room board live</a>
      </div>
    </section>

    <section class="svc-section" aria-label="Nghiệp vụ nhân viên dịch vụ">
      <div class="svc-section-head">
        <div>
          <h2>Use case chính</h2>
          <p>Chỉ giữ 3 UC của actor Nhân viên dịch vụ theo code2, không gộp thêm luồng của lễ tân hoặc khách hàng.</p>
        </div>
      </div>

      <div class="svc-bento">
        <% primaryActions.forEach((item, index) => { %>
          <a class="svc-uc-card" href="<%= item.href %>">
            <div class="svc-uc-top">
              <span class="svc-uc-code">UC<%= String(index + 1).padStart(2, "0") %></span>
              <span class="svc-uc-orb"></span>
            </div>
            <h3><%= item.label %></h3>
            <p><%= item.note %></p>
            <span class="svc-open">Mở nghiệp vụ</span>
          </a>
        <% }) %>
      </div>
    </section>

    <section class="svc-section" aria-label="Ca dịch vụ hôm nay">
      <div class="svc-section-head">
        <div>
          <h2>Ca dịch vụ hôm nay</h2>
          <p>Các điểm vận hành quan trọng xoay quanh catalog dịch vụ, kiểm tra phòng và room board live.</p>
        </div>
        <a class="svc-button" href="/service">Vào workspace dịch vụ</a>
      </div>

      <div class="svc-shift-grid">
        <% shiftCards.forEach((card) => { %>
          <article class="svc-shift-card">
            <span class="svc-badge"><%= card.badge %></span>
            <h3><%= card.title %></h3>
            <p><%= card.line1 %></p>
            <p><%= card.line2 %></p>
            <strong><%= card.strong %></strong>
            <div class="svc-hero-actions" style="margin-top:14px">
              <a class="svc-button" href="<%= card.href %>"><%= card.action %></a>
            </div>
          </article>
        <% }) %>
      </div>
    </section>

    <section class="svc-section" aria-label="Nền nghiệp vụ">
      <div class="svc-section-head">
        <div>
          <h2>Nền nghiệp vụ đang có</h2>
          <p>Ba nhóm khả năng đúng phạm vi actor Dịch vụ, dùng làm nền để phát triển tiếp mà không lệch nghiệp vụ.</p>
        </div>
      </div>

      <div class="svc-shift-grid">
        <% focusCards.forEach((card) => { %>
          <article class="svc-shift-card">
            <span class="svc-badge"><%= card.label %></span>
            <h3><%= card.value %></h3>
            <p><%= card.note %></p>
          </article>
        <% }) %>
      </div>
    </section>
  </div>
</main>

<%- include("../partials/footer") %>
