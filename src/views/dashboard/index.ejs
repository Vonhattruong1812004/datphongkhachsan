<%- include("../partials/head") %>
<%- include("../partials/header") %>
<%
  const scopeMeta = {
    admin: { label: "Admin", accent: "#0ea5e9", soft: "rgba(14,165,233,.18)", gradient: "linear-gradient(135deg,#0ea5e9,#2563eb)", words: ["Users", "Health", "Backup", "Restore"] },
    letan: { label: "Lễ tân", accent: "#14b8a6", soft: "rgba(20,184,166,.18)", gradient: "linear-gradient(135deg,#0891b2,#14b8a6)", words: ["Booking", "Check-in", "Service", "Check-out"] },
    ketoan: { label: "Kế toán", accent: "#f59e0b", soft: "rgba(245,158,11,.18)", gradient: "linear-gradient(135deg,#f59e0b,#fb7185)", words: ["Revenue", "Expense", "Debt", "Cashflow"] },
    dichvu: { label: "Dịch vụ", accent: "#65a30d", soft: "rgba(101,163,13,.18)", gradient: "linear-gradient(135deg,#65a30d,#14b8a6)", words: ["Catalog", "Order", "Inspect", "Room feed"] },
    quanly: { label: "Quản lý", accent: "#06b6d4", soft: "rgba(6,182,212,.18)", gradient: "linear-gradient(135deg,#06b6d4,#22c55e 48%,#f59e0b)", words: ["CRM", "Rooms", "eKYC", "Board"] },
    cskh: { label: "CSKH", accent: "#fb7185", soft: "rgba(251,113,133,.18)", gradient: "linear-gradient(135deg,#fb7185,#f59e0b)", words: ["Feedback", "Reply", "Promo", "Broadcast"] }
  };
  const meta = scopeMeta[scope] || scopeMeta.letan;
  const isLetan = scope === "letan";
  const isCskh = scope === "cskh";
  const isAdmin = scope === "admin";
  const isQuanly = scope === "quanly";
  const isKetoan = scope === "ketoan";
  const isManagerLayout = isQuanly || isKetoan;
  const isCommandCenter = isLetan || isAdmin || isKetoan;
  const primaryActions = actions;
  const showActionSection = !isCskh;
  const showLiveSections = !isCskh;
%>

<style>
  .role-dash {
    --dash-ink: #102033;
    --dash-muted: #667085;
    --dash-card: rgba(255,255,255,.78);
    --dash-card-strong: rgba(255,255,255,.92);
    --dash-line: rgba(16,32,51,.10);
    --dash-accent: <%= meta.accent %>;
    --dash-soft: <%= meta.soft %>;
    --dash-gradient: <%= meta.gradient %>;
    --dash-shadow: 0 24px 70px rgba(15,23,42,.16);
    min-height: calc(100vh - 84px);
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: 34px 18px 56px;
    color: var(--dash-ink);
    background:
      radial-gradient(circle at 6% 8%, rgba(20,184,166,.30), transparent 31%),
      radial-gradient(circle at 84% 12%, rgba(14,165,233,.26), transparent 34%),
      radial-gradient(circle at 48% 102%, rgba(163,230,53,.24), transparent 42%),
      radial-gradient(circle at 18% 82%, rgba(251,113,133,.18), transparent 30%),
      linear-gradient(135deg, #fbfffb 0%, #e9fbf6 42%, #f7fbff 100%);
  }
  .role-dash.is-letan{
    background:
      radial-gradient(circle at 8% 10%, rgba(20,184,166,.34), transparent 28%),
      radial-gradient(circle at 88% 12%, rgba(251,113,133,.24), transparent 30%),
      radial-gradient(circle at 52% 100%, rgba(251,191,36,.20), transparent 34%),
      radial-gradient(circle at 28% 78%, rgba(14,165,233,.22), transparent 24%),
      linear-gradient(135deg, #fcfffb 0%, #ecfff8 36%, #eef8ff 68%, #fff6eb 100%);
  }
  .role-dash.is-cskh{
    background:
      radial-gradient(circle at 8% 10%, rgba(251,113,133,.30), transparent 28%),
      radial-gradient(circle at 86% 8%, rgba(245,158,11,.22), transparent 31%),
      radial-gradient(circle at 50% 104%, rgba(20,184,166,.22), transparent 38%),
      radial-gradient(circle at 16% 82%, rgba(14,165,233,.18), transparent 26%),
      linear-gradient(135deg, #fffafa 0%, #fff7ed 38%, #eefcff 100%);
  }
  .role-dash.is-admin{
    background:
      radial-gradient(circle at 8% 10%, rgba(14,165,233,.32), transparent 28%),
      radial-gradient(circle at 88% 12%, rgba(99,102,241,.22), transparent 30%),
      radial-gradient(circle at 52% 100%, rgba(20,184,166,.20), transparent 36%),
      radial-gradient(circle at 24% 80%, rgba(251,191,36,.16), transparent 26%),
      linear-gradient(135deg, #f8fcff 0%, #eef8ff 38%, #f3fff9 72%, #fffaf0 100%);
  }
  .role-dash.is-ketoan{
    background:
      radial-gradient(circle at 8% 10%, rgba(245,158,11,.26), transparent 28%),
      radial-gradient(circle at 86% 12%, rgba(20,184,166,.22), transparent 30%),
      radial-gradient(circle at 52% 100%, rgba(14,165,233,.18), transparent 36%),
      radial-gradient(circle at 24% 80%, rgba(251,113,133,.16), transparent 25%),
      linear-gradient(135deg, #fffdf7 0%, #f6fff8 38%, #eefaff 72%, #fff7ed 100%);
  }
  .role-dash::before,.role-dash::after{content:"";position:absolute;width:520px;height:520px;border-radius:999px;pointer-events:none;z-index:-1;opacity:.44;animation:dash-float 12s ease-in-out infinite alternate}
  .role-dash::before{top:-240px;right:-140px;background:conic-gradient(from 160deg,rgba(14,165,233,.42),rgba(20,184,166,.32),rgba(163,230,53,.34),rgba(139,92,246,.28),rgba(14,165,233,.42))}
  .role-dash::after{left:-220px;bottom:-260px;background:conic-gradient(from 20deg,rgba(251,113,133,.30),rgba(245,158,11,.28),rgba(20,184,166,.30),rgba(14,165,233,.24),rgba(251,113,133,.30));animation-delay:-4s}
  .role-dash.is-letan::before{opacity:.58;background:conic-gradient(from 130deg,rgba(14,165,233,.56),rgba(20,184,166,.38),rgba(250,204,21,.34),rgba(251,113,133,.32),rgba(14,165,233,.56))}
  .role-dash.is-letan::after{opacity:.52;background:conic-gradient(from 18deg,rgba(251,113,133,.34),rgba(245,158,11,.30),rgba(45,212,191,.30),rgba(59,130,246,.26),rgba(251,113,133,.34))}
  .role-dash.is-ketoan::before{opacity:.48;background:conic-gradient(from 140deg,rgba(245,158,11,.42),rgba(20,184,166,.30),rgba(14,165,233,.24),rgba(251,113,133,.22),rgba(245,158,11,.42))}
  .role-dash.is-ketoan::after{opacity:.44;background:conic-gradient(from 22deg,rgba(20,184,166,.28),rgba(14,165,233,.22),rgba(245,158,11,.26),rgba(251,113,133,.22),rgba(20,184,166,.28))}
  .dash-shell{max-width:1220px;margin:0 auto;position:relative}
  .dash-fantasy-scene{
    position:absolute;
    inset:0;
    pointer-events:none;
    z-index:0;
    overflow:hidden;
  }
  .dash-fantasy-scene > *{position:absolute}
  .dash-sun{
    top:18px;
    right:62px;
    width:116px;
    height:116px;
    border-radius:999px;
    background:radial-gradient(circle at 35% 35%, #fffbe8 0 18%, #fde68a 34%, #f59e0b 62%, rgba(245,158,11,.14) 76%, transparent 78%);
    box-shadow:0 0 0 22px rgba(253,224,71,.16), 0 0 80px rgba(251,191,36,.32);
    animation:dash-sunfloat 7s ease-in-out infinite;
  }
  .dash-sun::before,
  .dash-sun::after{
    content:"";
    position:absolute;
    inset:-18px;
    border-radius:999px;
    border:2px dashed rgba(251,191,36,.32);
    animation:dash-spin 18s linear infinite;
  }
  .dash-sun::after{
    inset:-34px;
    border-color:rgba(245,158,11,.18);
    animation-direction:reverse;
    animation-duration:24s;
  }
  .dash-cloud{
    height:42px;
    border-radius:999px;
    background:rgba(255,255,255,.68);
    box-shadow:0 20px 50px rgba(148,163,184,.16);
    filter:blur(.2px);
  }
  .dash-cloud::before,
  .dash-cloud::after{
    content:"";
    position:absolute;
    border-radius:999px;
    background:inherit;
  }
  .dash-cloud--one{
    top:58px;
    left:48px;
    width:132px;
    animation:dash-cloud-sway 11s ease-in-out infinite;
  }
  .dash-cloud--one::before{width:58px;height:58px;left:18px;top:-24px}
  .dash-cloud--one::after{width:74px;height:74px;right:16px;top:-30px}
  .dash-cloud--two{
    top:134px;
    right:204px;
    width:108px;
    opacity:.78;
    animation:dash-cloud-sway 13s ease-in-out infinite reverse;
  }
  .dash-cloud--two::before{width:48px;height:48px;left:14px;top:-20px}
  .dash-cloud--two::after{width:60px;height:60px;right:12px;top:-24px}
  .dash-rainbow{
    top:88px;
    right:128px;
    width:240px;
    height:128px;
    border-radius:240px 240px 0 0;
    border-top:12px solid rgba(244,114,182,.36);
    border-left:12px solid rgba(251,191,36,.28);
    border-right:12px solid rgba(59,130,246,.28);
    opacity:.62;
    transform:rotate(-4deg);
    filter:blur(.2px);
  }
  .dash-rainbow::before{
    content:"";
    position:absolute;
    inset:12px 14px 0;
    border-radius:inherit;
    border-top:10px solid rgba(45,212,191,.34);
    border-left:10px solid rgba(251,113,133,.20);
    border-right:10px solid rgba(14,165,233,.22);
  }
  .dash-wave{
    left:-4%;
    right:-4%;
    bottom:126px;
    height:84px;
    background:
      radial-gradient(circle at 10% 18%, rgba(255,255,255,.36), transparent 18%),
      radial-gradient(circle at 40% 44%, rgba(255,255,255,.24), transparent 14%),
      linear-gradient(180deg, rgba(125,211,252,.12), rgba(14,165,233,.10));
    border-radius:46% 54% 0 0 / 100% 100% 0 0;
    opacity:.72;
    animation:dash-wave-sway 8s ease-in-out infinite;
  }
  .dash-leaf{
    width:84px;
    height:34px;
    border-radius:100% 0 100% 0;
    background:linear-gradient(135deg, rgba(74,222,128,.64), rgba(20,184,166,.52));
    box-shadow:0 18px 34px rgba(20,184,166,.16);
    transform-origin:left center;
  }
  .dash-leaf::after{
    content:"";
    position:absolute;
    left:10px;
    right:12px;
    top:50%;
    height:1.5px;
    background:rgba(255,255,255,.52);
    transform:translateY(-50%) rotate(-16deg);
  }
  .dash-leaf--one{left:18px;bottom:168px;transform:rotate(-18deg);animation:dash-leaf-sway 6s ease-in-out infinite}
  .dash-leaf--two{left:60px;bottom:132px;transform:rotate(8deg) scale(.92);animation:dash-leaf-sway 7.4s ease-in-out infinite reverse}
  .dash-leaf--three{right:26px;bottom:184px;transform:rotate(196deg);animation:dash-leaf-sway 6.8s ease-in-out infinite}
  .dash-leaf--four{right:84px;bottom:138px;transform:rotate(172deg) scale(.88);animation:dash-leaf-sway 8s ease-in-out infinite reverse}
  .dash-flower{
    width:18px;
    height:18px;
    border-radius:999px;
    background:radial-gradient(circle, #fff 0 18%, #f9a8d4 26%, #fb7185 60%, transparent 62%);
    box-shadow:
      0 -12px 0 rgba(253,164,175,.82),
      0 12px 0 rgba(253,164,175,.78),
      12px 0 0 rgba(251,191,36,.72),
      -12px 0 0 rgba(45,212,191,.72);
    opacity:.82;
    filter:drop-shadow(0 6px 18px rgba(244,114,182,.16));
  }
  .dash-flower--one{left:138px;bottom:144px;animation:dash-petal-float 9s ease-in-out infinite}
  .dash-flower--two{right:148px;bottom:118px;transform:scale(.86);animation:dash-petal-float 10s ease-in-out infinite reverse}
  .dash-petal{
    width:14px;
    height:14px;
    border-radius:14px 0 14px 0;
    background:linear-gradient(135deg, rgba(253,164,175,.84), rgba(251,191,36,.62));
    opacity:.68;
  }
  .dash-petal--one{top:210px;left:16%;animation:dash-fall 12s linear infinite}
  .dash-petal--two{top:160px;left:32%;animation:dash-fall 9.5s linear infinite reverse}
  .dash-petal--three{top:220px;right:18%;animation:dash-fall 11.5s linear infinite}
  .dash-petal--four{top:190px;right:34%;animation:dash-fall 10.2s linear infinite reverse}
  .role-dash.is-letan .dash-shell::before,
  .role-dash.is-letan .dash-shell::after{
    content:"";
    position:absolute;
    inset:auto;
    pointer-events:none;
    border-radius:999px;
    filter:blur(6px);
    opacity:.55;
    z-index:0;
  }
  .role-dash.is-letan .dash-shell::before{
    width:12px;height:12px;top:34px;right:320px;
    background:#fff7c2;
    box-shadow:
      -120px 48px 0 2px rgba(255,255,255,.78),
      60px 120px 0 1px rgba(190,242,255,.76),
      -220px 220px 0 2px rgba(255,228,230,.72),
      140px 260px 0 1px rgba(255,249,196,.76);
    animation:dash-sparkle 7s ease-in-out infinite;
  }
  .role-dash.is-letan .dash-shell::after{
    width:10px;height:10px;left:140px;bottom:180px;
    background:#d9f99d;
    box-shadow:
      180px -90px 0 1px rgba(191,219,254,.76),
      320px -40px 0 2px rgba(253,224,71,.68),
      440px -180px 0 1px rgba(255,255,255,.86);
    animation:dash-sparkle 6.2s ease-in-out infinite reverse;
  }
  .dash-hero{display:grid;grid-template-columns:minmax(0,1.08fr) 430px;gap:22px;align-items:stretch;margin-bottom:22px}
  .dash-hero.is-compact{grid-template-columns:minmax(0,1fr) 340px}
  .dash-card,.dash-hero-main,.dash-orbit,.dash-strip,.dash-action,.dash-stat,.dash-room,.dash-event{border:1px solid var(--dash-line);background:var(--dash-card);box-shadow:var(--dash-shadow);backdrop-filter:blur(24px)}
  .admin-watch{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:14px}
  .admin-watch-card{position:relative;overflow:hidden;border-radius:26px;padding:18px;border:1px solid var(--dash-line);background:rgba(255,255,255,.74);box-shadow:0 18px 48px rgba(15,23,42,.10);color:var(--dash-ink)}
  .admin-watch-card::before{content:"";position:absolute;inset:0 0 auto;height:5px;background:var(--dash-gradient)}
  .admin-watch-card small{display:block;color:var(--dash-muted);font-size:11px;font-weight:900;text-transform:uppercase;letter-spacing:.08em}
  .admin-watch-card strong{display:block;margin-top:8px;font-size:21px;letter-spacing:-.04em}
  .admin-watch-card p{margin:8px 0 14px;color:var(--dash-muted);font-size:13px;line-height:1.5}
  .admin-watch-card a{display:inline-flex;border-radius:999px;padding:8px 12px;background:rgba(14,165,233,.10);color:#0369a1;font-size:12px;font-weight:1000;text-decoration:none}
  .dash-hero-main{position:relative;overflow:hidden;min-height:350px;border-radius:34px;padding:34px}
  .dash-hero-main.is-compact{min-height:300px;padding:30px}
  .role-dash.is-letan .dash-hero-main.is-compact{
    background:
      linear-gradient(180deg, rgba(255,255,255,.86), rgba(255,255,255,.72)),
      radial-gradient(circle at 88% 20%, rgba(251,191,36,.16), transparent 20%);
  }
  .role-dash.is-admin .dash-hero-main.is-compact{
    background:
      linear-gradient(180deg, rgba(255,255,255,.90), rgba(255,255,255,.74)),
      radial-gradient(circle at 88% 20%, rgba(14,165,233,.18), transparent 22%);
  }
  .role-dash.is-ketoan .dash-hero-main.is-compact{
    background:
      linear-gradient(180deg, rgba(255,255,255,.92), rgba(255,255,255,.76)),
      radial-gradient(circle at 88% 20%, rgba(245,158,11,.18), transparent 22%);
  }
  .dash-hero-main::before{content:"";position:absolute;inset:-1px;background:linear-gradient(120deg,rgba(255,255,255,.66),transparent 28%),radial-gradient(circle at 88% 18%,var(--dash-soft),transparent 31%);pointer-events:none}
  .dash-eyebrow{display:inline-flex;align-items:center;gap:8px;position:relative;z-index:1;border-radius:999px;padding:7px 12px;background:var(--dash-soft);border:1px solid rgba(16,32,51,.08);color:var(--dash-accent);font-size:12px;font-weight:1000;letter-spacing:.08em;text-transform:uppercase}
  .dash-dot{width:8px;height:8px;border-radius:999px;background:var(--dash-accent);box-shadow:0 0 0 7px var(--dash-soft);animation:dash-pulse 1.8s ease-in-out infinite}
  .dash-hero h1{position:relative;z-index:1;max-width:720px;margin:24px 0 14px;color:var(--dash-ink);font-size:clamp(38px,5.8vw,70px);line-height:.92;letter-spacing:-.07em}
  .dash-hero h1 span{color:transparent;background:var(--dash-gradient);-webkit-background-clip:text;background-clip:text}
  .dash-lead{position:relative;z-index:1;max-width:690px;margin:0;color:var(--dash-muted);font-size:16px;line-height:1.72}
  .dash-lead.is-compact{max-width:760px;font-size:15px;line-height:1.64}
  .dash-hero-actions{position:relative;z-index:1;display:flex;flex-wrap:wrap;gap:10px;margin-top:28px}
  .dash-button{display:inline-flex;align-items:center;justify-content:center;min-height:44px;border-radius:999px;padding:10px 17px;color:var(--dash-ink);text-decoration:none;font-size:14px;font-weight:900;border:1px solid rgba(16,32,51,.12);background:rgba(255,255,255,.74);transition:transform .18s ease,box-shadow .18s ease,border-color .18s ease}
  .dash-button:hover{transform:translateY(-2px);border-color:var(--dash-accent);box-shadow:0 18px 42px var(--dash-soft)}
  .dash-button--primary{color:#fff;border-color:transparent;background:var(--dash-gradient);box-shadow:0 18px 38px var(--dash-soft)}
  .dash-pulse-grid{position:relative;z-index:1;display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;margin-top:34px}
  .dash-pulse-grid.is-compact{grid-template-columns:repeat(2,minmax(0,1fr));margin-top:24px}
  .dash-pulse{border-radius:22px;padding:16px;background:rgba(255,255,255,.58);border:1px solid rgba(16,32,51,.08)}
  .dash-pulse strong{display:block;font-size:28px;line-height:1;letter-spacing:-.05em;color:var(--dash-ink)}
  .dash-pulse span{display:block;margin-top:8px;color:var(--dash-muted);font-size:12px;font-weight:900;text-transform:uppercase;letter-spacing:.06em}
  .dash-orbit{position:relative;overflow:hidden;border-radius:34px;min-height:350px;background:linear-gradient(160deg,rgba(255,255,255,.84),rgba(236,253,245,.62))}
  .dash-orbit.is-compact{min-height:300px}
  .role-dash.is-letan .dash-orbit.is-compact{
    background:
      linear-gradient(160deg, rgba(255,255,255,.88), rgba(239,253,250,.74)),
      radial-gradient(circle at 26% 18%, rgba(251,191,36,.18), transparent 22%);
  }
  .role-dash.is-admin .dash-orbit.is-compact{
    background:
      linear-gradient(160deg, rgba(255,255,255,.90), rgba(239,246,255,.76)),
      radial-gradient(circle at 28% 18%, rgba(20,184,166,.14), transparent 24%);
  }
  .role-dash.is-ketoan .dash-orbit.is-compact{
    background:
      linear-gradient(160deg, rgba(255,255,255,.90), rgba(255,247,237,.76)),
      radial-gradient(circle at 28% 18%, rgba(20,184,166,.14), transparent 24%);
  }
  .dash-orbit-stage{position:absolute;inset:24px;border-radius:32px;background:linear-gradient(145deg,rgba(15,23,42,.86),rgba(12,74,110,.72));overflow:hidden}
  .dash-orbit-stage::before{content:"";position:absolute;inset:24px;border:1px dashed rgba(226,232,240,.24);border-radius:999px;animation:dash-spin 18s linear infinite}
  .dash-orbit-stage::after{content:"";position:absolute;width:160px;height:160px;left:calc(50% - 80px);top:calc(50% - 80px);border-radius:42px;background:var(--dash-gradient);box-shadow:0 24px 70px var(--dash-soft);transform:rotate(14deg);animation:dash-breathe 4.2s ease-in-out infinite}
  .dash-orbit-word{position:absolute;z-index:2;display:inline-flex;align-items:center;border-radius:999px;padding:9px 12px;color:#eff6ff;background:rgba(15,23,42,.48);border:1px solid rgba(255,255,255,.18);backdrop-filter:blur(14px);font-size:12px;font-weight:1000}
  .dash-orbit-word:nth-child(1){left:28px;top:36px;animation:dash-drift-a 5.5s ease-in-out infinite}
  .dash-orbit-word:nth-child(2){right:34px;top:88px;animation:dash-drift-b 6s ease-in-out infinite}
  .dash-orbit-word:nth-child(3){left:46px;bottom:62px;animation:dash-drift-b 5.8s ease-in-out infinite reverse}
  .dash-orbit-word:nth-child(4){right:42px;bottom:42px;animation:dash-drift-a 6.4s ease-in-out infinite reverse}
  .dash-strip{display:grid;grid-template-columns:1fr auto;gap:14px;align-items:center;border-radius:28px;padding:18px 20px;margin-bottom:22px;background:rgba(255,255,255,.66)}
  .dash-strip strong{display:block;color:var(--dash-ink);font-size:18px}
  .dash-strip span{display:block;margin-top:4px;color:var(--dash-muted);font-size:13px}
  .dash-flow{display:flex;flex-wrap:wrap;gap:8px}
  .dash-flow a,.dash-flow span{display:inline-flex;align-items:center;border-radius:999px;padding:8px 11px;background:var(--dash-soft);border:1px solid rgba(16,32,51,.08);color:var(--dash-accent);text-decoration:none;font-size:12px;font-weight:1000}
  .dash-section{margin-top:22px}
  .dash-section.is-compact{margin-top:18px}
  .dash-section-head{display:flex;align-items:flex-end;justify-content:space-between;gap:14px;margin-bottom:14px}
  .dash-section-head h2{margin:0;color:var(--dash-ink);font-size:24px;letter-spacing:-.04em}
  .dash-section-head p{margin:4px 0 0;color:var(--dash-muted);font-size:13px}
  .dash-grid{display:grid;grid-template-columns:repeat(12,1fr);gap:16px}
  .dash-grid.is-compact{gap:14px}
  .dash-action{--card-accent:#0ea5e9;--card-glow:rgba(14,165,233,.20);position:relative;overflow:hidden;min-height:245px;grid-column:span 4;border-radius:30px;padding:22px;text-decoration:none;color:var(--dash-ink);transform:translateY(18px);opacity:0;animation:dash-rise .7s cubic-bezier(.22,1,.36,1) forwards;transition:transform .2s ease,box-shadow .2s ease,border-color .2s ease;background:linear-gradient(180deg,rgba(255,255,255,.86),rgba(255,255,255,.66))}
  .dash-grid.is-compact .dash-action{min-height:208px;padding:20px}
