  .manager-action h3{position:relative;z-index:1;margin:56px 0 10px;color:var(--mgr-ink);font-size:27px;line-height:1.04;letter-spacing:-.055em}
  .manager-action p{position:relative;z-index:1;max-width:520px;margin:0;color:#5f6b7d;font-size:14px;line-height:1.58;font-weight:720}
  .manager-open{position:absolute;z-index:1;right:22px;bottom:28px;color:var(--mgr-action);font-size:13px;font-weight:1000}
  .manager-live-grid{display:grid;grid-template-columns:1fr;gap:16px}
  .manager-live-panel{border-radius:30px;padding:20px;background:rgba(255,255,255,.72)}
  .manager-live-panel .dash-grid{gap:14px}
  .manager-live-panel .dash-stat{grid-column:span 4;background:rgba(255,255,255,.76);box-shadow:0 18px 44px rgba(15,23,42,.09)}
  .manager-live-panel .dash-event{grid-column:span 6;background:rgba(255,255,255,.74);box-shadow:0 18px 44px rgba(15,23,42,.08)}
  .manager-room-panel{border-radius:30px;padding:20px;background:rgba(255,255,255,.72)}
  .manager-room-panel .dash-stat{grid-column:span 2;background:rgba(255,255,255,.74);box-shadow:0 16px 40px rgba(15,23,42,.08)}
  .manager-room-panel .dash-room{grid-column:span 3;background:rgba(255,255,255,.72);box-shadow:0 16px 40px rgba(15,23,42,.08)}
  @keyframes mgr-blob{from{transform:translate3d(0,0,0) rotate(0)}to{transform:translate3d(-24px,28px,0) rotate(16deg)}}
  @keyframes mgr-orbit{from{transform:translate3d(0,0,0) scale(1)}to{transform:translate3d(32px,-18px,0) scale(1.04)}}
  @keyframes dash-float{from{transform:translate3d(0,0,0) rotate(0)}to{transform:translate3d(32px,24px,0) rotate(16deg)}}
  @keyframes dash-sunfloat{0%,100%{transform:translate3d(0,0,0) scale(1)}50%{transform:translate3d(0,-8px,0) scale(1.04)}}
  @keyframes dash-pulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(.72);opacity:.68}}
  @keyframes dash-spin{to{transform:rotate(360deg)}}
  @keyframes dash-breathe{0%,100%{transform:rotate(14deg) scale(1);border-radius:42px}50%{transform:rotate(22deg) scale(1.06);border-radius:64px}}
  @keyframes dash-drift-a{0%,100%{transform:translate3d(0,0,0)}50%{transform:translate3d(12px,-10px,0)}}
  @keyframes dash-drift-b{0%,100%{transform:translate3d(0,0,0)}50%{transform:translate3d(-10px,12px,0)}}
  @keyframes dash-rise{to{transform:translateY(0);opacity:1}}
  @keyframes dash-sparkle{0%,100%{transform:scale(1);opacity:.42}50%{transform:scale(1.26);opacity:.88}}
  @keyframes dash-cloud-sway{0%,100%{transform:translate3d(0,0,0)}50%{transform:translate3d(22px,-6px,0)}}
  @keyframes dash-wave-sway{0%,100%{transform:translate3d(0,0,0)}50%{transform:translate3d(0,8px,0) scaleX(1.02)}}
  @keyframes dash-leaf-sway{0%,100%{transform:rotate(var(--leaf-rot,0deg)) translate3d(0,0,0)}50%{transform:rotate(calc(var(--leaf-rot,0deg) + 8deg)) translate3d(2px,-8px,0)}}
  @keyframes dash-petal-float{0%,100%{transform:translate3d(0,0,0) scale(1)}50%{transform:translate3d(0,-10px,0) scale(1.08)}}
  @keyframes dash-fall{0%{transform:translate3d(0,0,0) rotate(0);opacity:0}10%{opacity:.72}100%{transform:translate3d(24px,340px,0) rotate(320deg);opacity:0}}
  @media(max-width:1080px){.manager-hero,.manager-live-grid{grid-template-columns:1fr}.manager-radar,.manager-visual-card{min-height:320px}.manager-action,.manager-action:nth-child(1),.manager-action:nth-child(4){grid-column:span 6}.manager-room-panel .dash-stat,.manager-room-panel .dash-room{grid-column:span 4}}
  @media(max-width:720px){.manager-dash{padding:20px 12px 42px}.manager-hero-main{min-height:auto;padding:24px;border-radius:28px}.manager-hero h1{font-size:42px}.manager-mini-grid,.manager-command{grid-template-columns:1fr}.manager-section-head{display:block}.manager-action,.manager-action:nth-child(1),.manager-action:nth-child(4),.manager-live-panel .dash-stat,.manager-live-panel .dash-event,.manager-room-panel .dash-stat,.manager-room-panel .dash-room{grid-column:1/-1}.manager-radar,.manager-visual-card{display:none}}
  @media(max-width:1080px){.dash-hero{grid-template-columns:1fr}.dash-orbit{min-height:320px}.admin-watch{grid-template-columns:repeat(2,minmax(0,1fr))}.dash-action,.dash-action:nth-child(1),.dash-action:nth-child(2),.dash-action:nth-child(4),.dash-action:nth-child(5),.dash-stat,.dash-event,.dash-room{grid-column:span 6}}
  @media(max-width:720px){.role-dash{padding:20px 12px 42px}.dash-hero-main{min-height:auto;padding:24px;border-radius:28px}.dash-hero h1{font-size:42px}.dash-pulse-grid,.dash-strip,.admin-watch{grid-template-columns:1fr}.dash-action,.dash-stat,.dash-event,.dash-room{grid-column:1/-1}.dash-section-head{display:block}.dash-sun{right:24px;top:34px;width:84px;height:84px}.dash-rainbow{right:10px;top:112px;width:156px;height:84px}.dash-cloud--two,.dash-leaf--three,.dash-leaf--four,.dash-flower--two{display:none}}
  @media(prefers-reduced-motion:reduce){.role-dash::before,.role-dash::after,.dash-dot,.dash-orbit-stage::before,.dash-orbit-stage::after,.dash-orbit-word,.dash-action,.dash-sun,.dash-cloud,.dash-wave,.dash-leaf,.dash-flower,.dash-petal{animation:none}.dash-action{transform:none;opacity:1}}
</style>

<% if (isQuanly) { %>
<main class="manager-dash">
  <div class="manager-shell">
    <section class="manager-hero" aria-label="Dashboard quản lý">
      <div class="manager-hero-main">
        <div class="manager-chip"><span class="manager-dot"></span> <%= meta.label %> command center</div>
        <h1>Quản lý vận hành <span>realtime.</span></h1>
        <p class="manager-lead"><%= hero.description %></p>
        <div class="manager-actions">
          <% if (actions[0]) { %><a class="manager-button manager-button--primary" href="<%= actions[0].href %>"><%= actions[0].label %></a><% } %>
          <% if (actions[1]) { %><a class="manager-button" href="<%= actions[1].href %>"><%= actions[1].label %></a><% } %>
          <% if (actions[2]) { %><a class="manager-button" href="<%= actions[2].href %>"><%= actions[2].label %></a><% } %>
        </div>
      </div>
      <aside class="manager-visual-card" aria-label="Minh họa dashboard quản lý">
        <div class="manager-visual-scene">
          <div class="manager-visual-core"></div>
          <span class="manager-visual-chip">Quản lý khách</span>
          <span class="manager-visual-chip">Quản lý phòng</span>
          <span class="manager-visual-chip">Duyệt eKYC</span>
          <span class="manager-visual-chip">Live</span>
          <div class="manager-visual-wave"></div>
        </div>
      </aside>
    </section>

    <section class="manager-section">
      <div class="manager-section-head">
        <div>
          <h2>UC chính của Quản lý</h2>
          <p>Chỉ giữ các chức năng đúng actor: quản lý khách hàng, quản lý phòng và duyệt eKYC.</p>
        </div>
      </div>
      <div class="manager-action-grid">
        <% primaryActions.forEach((item, index) => { %>
          <a class="manager-action" href="<%= item.href %>">
            <span class="manager-code"><%= String(index + 1).padStart(2, "0") %></span>
            <h3><%= item.label %></h3>
            <p><%= item.note %></p>
            <span class="manager-open">Mở chức năng</span>
          </a>
        <% }) %>
      </div>
    </section>

    <section class="manager-section">
      <div class="manager-section-head">
        <div>
          <h2>Tổng quan vận hành</h2>
          <p>Một cụm KPI đủ để phát hiện vấn đề, không kéo dài thành báo cáo chi tiết.</p>
        </div>
      </div>
      <div class="manager-live-grid">
        <section class="manager-live-panel" aria-label="KPI quản lý">
          <div class="dash-grid" id="live-overview">
            <article class="dash-stat"><strong>...</strong><h3>Đang tải KPI</h3><p>Đang đọc dashboard stats từ database.</p></article>
          </div>
        </section>
      </div>
    </section>

    <section class="manager-section">
      <div class="manager-section-head">
        <div>
          <h2>Tình trạng phòng</h2>
          <p>Chỉ giữ số liệu tổng hợp. Chi tiết phòng xử lý trong UC Quản lý phòng.</p>
        </div>
      </div>
      <section class="manager-room-panel" aria-label="Room board quản lý">
        <div class="dash-grid" id="live-room-summary">
          <article class="dash-stat"><strong>...</strong><h3>Đang tải room board</h3><p>Đang đồng bộ trạng thái phòng.</p></article>
        </div>
      </section>
    </section>
  </div>
</main>
<% } else { %>
<main class="role-dash <%= isLetan ? 'is-letan' : '' %> <%= isAdmin ? 'is-admin' : '' %> <%= isCskh ? 'is-cskh' : '' %>">
  <div class="dash-shell">
    <% if (isLetan) { %>
    <div class="dash-fantasy-scene" aria-hidden="true">
      <div class="dash-sun"></div>
      <div class="dash-rainbow"></div>
      <div class="dash-cloud dash-cloud--one"></div>
      <div class="dash-cloud dash-cloud--two"></div>
      <div class="dash-wave"></div>
      <div class="dash-leaf dash-leaf--one" style="--leaf-rot:-18deg"></div>
      <div class="dash-leaf dash-leaf--two" style="--leaf-rot:8deg"></div>
      <div class="dash-leaf dash-leaf--three" style="--leaf-rot:196deg"></div>
      <div class="dash-leaf dash-leaf--four" style="--leaf-rot:172deg"></div>
      <div class="dash-flower dash-flower--one"></div>
      <div class="dash-flower dash-flower--two"></div>
      <div class="dash-petal dash-petal--one"></div>
      <div class="dash-petal dash-petal--two"></div>
      <div class="dash-petal dash-petal--three"></div>
      <div class="dash-petal dash-petal--four"></div>
    </div>
    <% } %>
    <section class="dash-hero <%= isCommandCenter ? 'is-compact' : '' %>">
      <div class="dash-hero-main <%= isCommandCenter ? 'is-compact' : '' %>">
        <div class="dash-eyebrow"><span class="dash-dot"></span> <%= meta.label %> command center</div>
        <h1><%= hero.title %> <span><%= isLetan ? "Gọn hơn." : (isAdmin ? "Điều phối." : "Sạch hơn.") %></span></h1>
        <p class="dash-lead <%= isCommandCenter ? 'is-compact' : '' %>">
          <%= isLetan
            ? "Dashboard lễ tân đã được gom lại để tập trung vào các tác vụ cần dùng liên tục trong ca trực: đặt phòng trực tiếp, check-in, check-out, sửa hoặc hủy booking và xử lý dịch vụ theo phòng."
            : isAdmin
              ? "Quản trị tài khoản, kiểm tra hệ thống, sao lưu và phục hồi dữ liệu trong một màn gọn."
            : hero.description %>
        </p>
        <div class="dash-hero-actions">
          <% if (actions[0]) { %><a class="dash-button dash-button--primary" href="<%= actions[0].href %>"><%= actions[0].label %></a><% } %>
          <% if (actions[1]) { %><a class="dash-button" href="<%= actions[1].href %>"><%= actions[1].label %></a><% } %>
          <% if (actions[2]) { %><a class="dash-button" href="<%= actions[2].href %>"><%= actions[2].label %></a><% } %>
        </div>
        <div class="dash-pulse-grid <%= isCommandCenter ? 'is-compact' : '' %>">
          <div class="dash-pulse"><strong><%= primaryActions.length %></strong><span>Lối vào nhanh</span></div>
          <div class="dash-pulse"><strong><%= isLetan ? "Core" : (isAdmin ? "Admin" : cards.length) %></strong><span><%= isLetan ? "Màn hình gọn" : (isAdmin ? "Quyền hệ thống" : "Trọng tâm") %></span></div>
          <% if (!isLetan && !isAdmin) { %>
          <div class="dash-pulse"><strong><%= isAdmin ? "Control" : (enableRoomBoard ? "Live" : "Focus") %></strong><span>Chế độ</span></div>
          <% } %>
        </div>
      </div>
      <aside class="dash-orbit <%= isCommandCenter ? 'is-compact' : '' %>" aria-label="Minh họa scope dashboard">
        <div class="dash-orbit-stage">
          <% meta.words.forEach((word) => { %><span class="dash-orbit-word"><%= word %></span><% }) %>
        </div>
      </aside>
    </section>

    <% if (!isLetan && !isAdmin) { %>
    <section class="dash-strip">
      <div>
        <strong>Không gian làm việc của <%= meta.label %></strong>
        <span>Các tác vụ chính được gom lại rõ ràng, KPI cập nhật live từ database.</span>
      </div>
      <div class="dash-flow">
        <% actions.slice(0, 4).forEach((item) => { %>
          <a href="<%= item.href %>"><%= item.label %></a>
        <% }) %>
      </div>
    </section>
    <% } %>

    <% if (!isLetan && !isAdmin) { %>
    <section class="dash-section">
      <div class="dash-section-head">
        <div>
          <h2>Trọng tâm vận hành</h2>
          <p>Các việc chính cần theo dõi trong ca.</p>
        </div>
      </div>
      <div class="dash-grid">
        <% cards.forEach((card) => { %>
          <article class="dash-stat">
            <span class="dash-badge"><%= scope %></span>
            <strong><%= card.value %></strong>
            <h3><%= card.label %></h3>
            <p><%= card.note %></p>
          </article>
        <% }) %>
      </div>
    </section>
    <% } %>

    <% if (showLiveSections) { %>
    <section class="dash-section <%= isCommandCenter ? 'is-compact' : '' %>">
      <div class="dash-section-head">
        <div>
          <h2><%= (isLetan || isCskh || isAdmin) ? "Tác vụ chính" : "Lối vào nhanh" %></h2>
          <p><%= isLetan ? "Các thao tác lễ tân dùng nhiều nhất." : (isCskh ? "Mở nhanh phản hồi, tư vấn và eKYC." : (isAdmin ? "Các UC Admin cần dùng, không trộn nghiệp vụ chi tiết của actor khác." : "Nhấn thẳng vào tác vụ cần xử lý.")) %></p>
        </div>
      </div>
      <div class="dash-grid <%= isCommandCenter ? 'is-compact' : '' %>">
        <% primaryActions.forEach((item, index) => { %>
          <a class="dash-action" href="<%= item.href %>">
            <span class="dash-code"><%= String(index + 1).padStart(2, "0") %></span>
            <h3><%= item.label %></h3>
            <p><%= item.note %></p>
            <span class="dash-open">Mở</span>
          </a>
        <% }) %>
      </div>
    </section>
    <% } %>

    <% if (!isAdmin) { %>
    <section class="dash-section <%= isCommandCenter ? 'is-compact' : '' %>">
      <div class="dash-section-head">
        <div>
          <h2><%= isLetan ? "Realtime vận hành" : (isAdmin ? "KPI cần theo dõi" : "Live KPI") %></h2>
          <p><%= isLetan ? "Gộp các chỉ số điều phối chính vào một cụm duy nhất để nhìn nhanh tình trạng phòng và lưu trú." : (isAdmin ? "Chỉ giữ các chỉ số vận hành đủ để Admin phát hiện bất thường nhanh." : "Dữ liệu đọc trực tiếp từ hệ thống và tự làm mới khi có sự kiện realtime.") %></p>
        </div>
      </div>
      <div class="dash-grid <%= isCommandCenter ? 'is-compact' : '' %>" id="live-overview">
        <article class="dash-stat"><strong>...</strong><h3>Đang tải KPI</h3><p>Đang đọc dashboard stats từ database.</p></article>
      </div>
    </section>
    <% } %>

    <% if (enableRoomBoard && !isAdmin) { %>
      <section class="dash-section <%= isLetan ? 'is-compact' : '' %>">
        <div class="dash-section-head">
          <div>
            <h2><%= isLetan ? "Phòng cần chú ý" : "Room Board" %></h2>
            <p><%= isLetan ? "Chỉ giữ danh sách phòng gần nhất cần theo dõi, không lặp lại cụm số liệu ở trên." : "Trạng thái phòng realtime cho các actor cần điều phối vận hành." %></p>
          </div>
        </div>
        <% if (!isLetan) { %>
        <div class="dash-grid <%= isLetan ? 'is-compact' : '' %>" id="live-room-summary">
          <article class="dash-stat"><strong>...</strong><h3>Đang tải room board</h3><p>Đang đồng bộ trạng thái phòng.</p></article>
        </div>
        <% } %>
        <div class="dash-grid <%= isLetan ? 'is-compact' : '' %>" id="live-room-board" style="margin-top:16px"></div>
      </section>
    <% } %>

    <% if (!isLetan && !isAdmin && showLiveSections) { %>
    <section class="dash-section">
      <div class="dash-section-head">
        <div>
          <h2><%= isAdmin ? "Nhật ký gần đây" : "Hoạt động gần đây" %></h2>
          <p><%= isAdmin ? "Chỉ hiển thị các sự kiện mới nhất, rút gọn ghi chú dài để dễ rà soát." : "Các thay đổi phòng, booking, dịch vụ và vận hành mới nhất." %></p>
        </div>
      </div>
      <div class="dash-grid" id="recent-room-events">
        <article class="dash-event">
          <span class="dash-badge">Loading</span>
          <h3>Đang tải sự kiện phòng</h3>
          <p>Sẽ hiển thị các thay đổi booking, check-in, checkout và kiểm tra phòng mới nhất.</p>
        </article>
      </div>
    </section>
    <% } %>
  </div>
</main>
<% } %>

<script>
  (() => {
    const scope = "<%= scope %>";
    const enableRoomBoard = <%= enableRoomBoard ? "true" : "false" %>;
    const showLiveSections = <%= showLiveSections ? "true" : "false" %>;
    const overview = document.getElementById("live-overview");
    const roomSummary = document.getElementById("live-room-summary");
    const roomBoard = document.getElementById("live-room-board");
    const recentEvents = document.getElementById("recent-room-events");
    const escapeHtml = (value) => String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");

    const renderOverview = (data) => {
      const overviewItems = scope === "quanly"
        ? [
            { label: "Khách hàng", value: data.overview.totalCustomers, note: "Hồ sơ đang quản lý" },
            { label: "Giao dịch", value: data.overview.totalTransactions, note: "Booking và thanh toán" },
            { label: "Phòng trống", value: data.overview.availableRooms, note: "Sẵn sàng mở bán" },
            { label: "Đã đặt", value: data.overview.bookedRooms, note: "Booking đang mở" },
            { label: "Đang ở", value: data.overview.stayedRooms, note: "Khách đang lưu trú" },
            { label: "Bảo trì", value: data.overview.maintenanceRooms, note: "Cần theo dõi vận hành" }
          ]
        : scope === "admin"
          ? [
            { label: "Phòng trống", value: data.overview.availableRooms, note: "Sẵn sàng mở bán" },
            { label: "Đã đặt", value: data.overview.bookedRooms, note: "Booking đang mở" },
            { label: "Đang ở", value: data.overview.stayedRooms, note: "Khách đang lưu trú" },
            { label: "Cần xử lý phòng", value: Number(data.overview.cleaningRooms || 0) + Number(data.overview.maintenanceRooms || 0), note: "Dọn phòng + bảo trì" },
            { label: "Doanh thu tháng", value: new Intl.NumberFormat("vi-VN").format(data.overview.monthlyRevenue || 0), note: "Giao dịch đã chốt Paid" },
            { label: "Còn phải thu", value: new Intl.NumberFormat("vi-VN").format(data.overview.outstandingMonthlyRevenue || 0), note: "Booking/lưu trú chưa chốt" }
            ]
        : scope === "letan"
          ? [
            { label: "Phòng trống", value: data.overview.availableRooms, note: "Sẵn sàng nhận khách" },
            { label: "Đã đặt", value: data.overview.bookedRooms, note: "Booking chờ đến" },
            { label: "Đang ở", value: data.overview.stayedRooms, note: "Khách đang lưu trú" },
            { label: "Cần dọn", value: data.overview.cleaningRooms, note: "Chờ vệ sinh để mở lại" }
            ]
          : [
            { label: "Phòng trống", value: data.overview.availableRooms, note: "Sẵn sàng mở bán" },
            { label: "Đã đặt", value: data.overview.bookedRooms, note: "Phòng đã giữ chỗ" },
            { label: "Đang ở", value: data.overview.stayedRooms, note: "Khách đang lưu trú" },
            { label: "Cần dọn", value: data.overview.cleaningRooms, note: "Đang chờ vệ sinh" },
            { label: "Bảo trì", value: data.overview.maintenanceRooms, note: "Không thể mở bán" },
            { label: "Đã thu tháng", value: new Intl.NumberFormat("vi-VN").format(data.overview.monthlyRevenue || 0), note: "Chỉ tính giao dịch Paid" },
            { label: "Còn phải thu", value: new Intl.NumberFormat("vi-VN").format(data.overview.outstandingMonthlyRevenue || 0), note: "Booking/lưu trú chưa thanh toán" }
          ];

      overview.innerHTML = overviewItems.map((item) => `
        <article class="dash-stat">
          <strong>${escapeHtml(item.value)}</strong>
          <h3>${escapeHtml(item.label)}</h3>
          <p>${escapeHtml(item.note)}</p>
        </article>
      `).join("");

      if (scope === "letan" || !recentEvents) return;

      const eventLimit = scope === "admin" ? 6 : 12;
      recentEvents.innerHTML = (data.recentEvents || []).slice(0, eventLimit).map((item) => {
        const happenedAt = item.happenedAt
          ? new Date(item.happenedAt).toLocaleString("vi-VN", { hour: "2-digit", minute: "2-digit", day: "2-digit", month: "2-digit" })
          : "";
        const note = scope === "admin" && item.note && String(item.note).length > 90
          ? `${String(item.note).slice(0, 90)}...`
          : item.note;
        const meta = [note || "", happenedAt].filter(Boolean).join(" · ");

        return `
          <article class="dash-event">
            <span class="dash-badge">${escapeHtml(item.source || item.category || "System")}</span>
            <h3>${escapeHtml(item.title || [item.hotelName, item.roomNumber ? `P${item.roomNumber}` : ""].filter(Boolean).join(" · "))}</h3>
            <p>${escapeHtml(item.detail || `${item.fromStatus || "?"} -> ${item.toStatus || "?"}`)}</p>
            <p>${escapeHtml(meta || "Không có ghi chú")}</p>
          </article>
        `;
      }).join("") || `
        <article class="dash-empty">Chưa có sự kiện gần đây. Nhật ký trạng thái phòng sẽ xuất hiện tại đây khi có biến động.</article>
      `;
    };

    const renderOverviewError = () => {
      if (!overview) return;
      overview.innerHTML = `
        <article class="dash-empty">
          Chưa tải được KPI realtime lúc này. Bạn vẫn có thể mở các chức năng lễ tân bình thường và tải lại trang sau.
        </article>
      `;
    };

    const renderRoomBoard = (data) => {
      if (!enableRoomBoard) return;

      if (roomSummary && scope !== "letan") {
        roomSummary.innerHTML = [
          { label: "Phòng trống", value: data.summary.available },
          { label: "Đã đặt", value: data.summary.booked },
          { label: "Đang ở", value: data.summary.stayed },
          { label: "Cần dọn", value: data.summary.cleaning },
          { label: "Bảo trì", value: data.summary.maintenance }
        ].map((item) => `
          <article class="dash-stat">
            <strong>${escapeHtml(item.value)}</strong>
            <h3>${escapeHtml(item.label)}</h3>
            <p>Theo room board thời gian thực</p>
          </article>
        `).join("");
      }

      if (!roomBoard) return;

      roomBoard.innerHTML = data.items.slice(0, scope === "letan" ? 8 : 18).map((item) => `
        <article class="dash-room">
          <span class="dash-badge">${escapeHtml(item.trangThaiRealtime || item.trangThai)}</span>
          <h3>${escapeHtml(item.khachSan)} · P${escapeHtml(item.soPhong)}</h3>
          <p>${escapeHtml(item.loaiPhong)} · ${escapeHtml(item.tinhThanh)}</p>
          <p>Trạng thái: ${escapeHtml(item.trangThai)} · Tình trạng: ${escapeHtml(item.tinhTrangPhong)}</p>
        </article>
      `).join("");
    };

    const renderRoomBoardError = () => {
      if (roomSummary && scope !== "letan") {
        roomSummary.innerHTML = `
          <article class="dash-empty">
            Chưa tải được room board realtime. Các lối vào nghiệp vụ vẫn hoạt động bình thường.
          </article>
        `;
      }

      if (roomBoard) {
        roomBoard.innerHTML = "";
      }
    };

    const loadStats = async () => {
      if (!showLiveSections || !overview) return;
      try {
        const response = await fetch(`/api/dashboard/stats?scope=${scope}`, { credentials: "same-origin" });
        const payload = await response.json();
        if (payload.ok) {
          renderOverview(payload.data);
          return;
        }
      } catch (_error) {
      }

      renderOverviewError();
    };

    const loadRoomBoard = async () => {
      if (!showLiveSections || !enableRoomBoard) return;
      try {
        const response = await fetch(`/api/dashboard/room-board?scope=${scope}`, { credentials: "same-origin" });
        const payload = await response.json();
        if (payload.ok) {
          renderRoomBoard(payload.data);
          return;
        }
      } catch (_error) {
      }

      renderRoomBoardError();
    };

    if (showLiveSections) {
      loadStats();
      loadRoomBoard();
    }

    if (showLiveSections && window.EventSource) {
      const stream = new EventSource(`/api/realtime/stream?scope=${scope}`);
      ["room_status_changed", "booking_created", "service_order_created", "service_catalog_updated"].forEach((eventName) => {
        stream.addEventListener(eventName, () => {
          loadStats();
          loadRoomBoard();
        });
      });
    }
  })();
</script>
<%- include("../partials/footer") %>
