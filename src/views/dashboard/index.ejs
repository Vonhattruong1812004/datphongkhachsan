<script>
  (() => {
    const scope = "<%= scope %>";
    const enableRoomBoard = <%= enableRoomBoard && !isLetan ? "true" : "false" %>;
    const showLiveSections = <%= showLiveSections && !isLetan ? "true" : "false" %>;
    const overview = document.getElementById("live-overview");
    const roomSummary = document.getElementById("live-room-summary");
    const roomBoard = document.getElementById("live-room-board");
    const recentEvents = document.getElementById("recent-room-events");
    const escapeHtml = (value) => String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
    const chartColors = ["#0ea5e9", "#10b981", "#f59e0b", "#ec4899", "#7c3aed", "#65a30d", "#14b8a6"];
    let latestFinanceCharts = null;
    const moneyShort = (value) => {
      const amount = Number(value || 0);
      if (Math.abs(amount) >= 1000000000) return `${(amount / 1000000000).toLocaleString("vi-VN", { maximumFractionDigits: 1 })} tỷ`;
      if (Math.abs(amount) >= 1000000) return `${(amount / 1000000).toLocaleString("vi-VN", { maximumFractionDigits: 1 })} tr`;
      if (Math.abs(amount) >= 1000) return `${(amount / 1000).toLocaleString("vi-VN", { maximumFractionDigits: 0 })}k`;
      return amount.toLocaleString("vi-VN");
    };
    const chartSetup = (id) => {
      const canvas = document.getElementById(id);
      if (!canvas) return null;
      const parent = canvas.parentElement;
      const width = Math.max(parent.clientWidth, 280);
      const height = Math.max(parent.clientHeight, 220);
      const ratio = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = Math.floor(width * ratio);
      canvas.height = Math.floor(height * ratio);
      canvas.style.width = `${width}px`;
      canvas.style.height = `${height}px`;
      const ctx = canvas.getContext("2d");
      ctx.setTransform(ratio, 0, 0, ratio, 0, 0);
      ctx.clearRect(0, 0, width, height);
      return { ctx, width, height };
    };
    const drawText = (ctx, value, x, y, size = 12, color = "#64748b", weight = 800, align = "left") => {
      ctx.fillStyle = color;
      ctx.font = `${weight} ${size}px system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif`;
      ctx.textAlign = align;
      ctx.textBaseline = "middle";
      ctx.fillText(String(value), x, y);
    };
    const roundRect = (ctx, x, y, width, height, radius) => {
      const r = Math.min(radius, width / 2, height / 2);
      ctx.beginPath();
      ctx.moveTo(x + r, y);
      ctx.arcTo(x + width, y, x + width, y + height, r);
      ctx.arcTo(x + width, y + height, x, y + height, r);
      ctx.arcTo(x, y + height, x, y, r);
      ctx.arcTo(x, y, x + width, y, r);
      ctx.closePath();
    };
    const drawEmptyChart = (ctx, width, height) => {
      ctx.fillStyle = "rgba(255,255,255,.62)";
      ctx.strokeStyle = "rgba(16,32,51,.13)";
      roundRect(ctx, 18, 18, width - 36, height - 36, 20);
      ctx.fill();
      ctx.stroke();
      drawText(ctx, "Chưa có dữ liệu biểu đồ", width / 2, height / 2, 13, "#64748b", 900, "center");
    };
    const drawLineChart = (payload) => {
      const chart = chartSetup("ketoanTrendChart");
      if (!chart) return;
      const { ctx, width, height } = chart;
      const rows = payload?.trend || [];
      if (!rows.length) return drawEmptyChart(ctx, width, height);
      const pad = { left: 62, right: 36, top: 22, bottom: 50 };
      const plotW = width - pad.left - pad.right;
      const plotH = height - pad.top - pad.bottom;
      const maxMoney = Math.max(1, ...rows.flatMap((row) => [row.total, row.paid, row.outstanding, row.expense]));
      const maxRooms = Math.max(1, ...rows.map((row) => row.roomNights));
      const x = (index) => pad.left + (rows.length === 1 ? plotW / 2 : (index / (rows.length - 1)) * plotW);
      const yMoney = (value) => pad.top + plotH - (Number(value || 0) / maxMoney) * plotH;
      const yRooms = (value) => pad.top + plotH - (Number(value || 0) / maxRooms) * plotH;

      ctx.strokeStyle = "rgba(16,32,51,.10)";
      ctx.lineWidth = 1;
      for (let i = 0; i <= 4; i += 1) {
        const y = pad.top + (plotH / 4) * i;
        ctx.beginPath();
        ctx.moveTo(pad.left, y);
        ctx.lineTo(width - pad.right, y);
        ctx.stroke();
        drawText(ctx, moneyShort(maxMoney - (maxMoney / 4) * i), 8, y, 11);
      }
      rows.forEach((row, index) => {
        if (index % Math.ceil(rows.length / 7) === 0 || index === rows.length - 1) {
          drawText(ctx, row.label, x(index), height - 24, 11, "#64748b", 800, "center");
        }
      });
      const drawSeries = (key, color, yFn, lineWidth = 3) => {
        ctx.strokeStyle = color;
        ctx.lineWidth = lineWidth;
        ctx.lineJoin = "round";
        ctx.lineCap = "round";
        ctx.beginPath();
        rows.forEach((row, index) => {
          const px = x(index);
          const py = yFn(row[key]);
          if (index === 0) ctx.moveTo(px, py);
          else ctx.lineTo(px, py);
        });
        ctx.stroke();
      };
      drawSeries("total", "#0ea5e9", yMoney, 4);
      drawSeries("paid", "#10b981", yMoney, 3);
      drawSeries("outstanding", "#ec4899", yMoney, 3);
      drawSeries("expense", "#f59e0b", yMoney, 3);
      drawSeries("roomNights", "#7c3aed", yRooms, 2);
    };
    const drawDonutChart = (id, rows, centerLabel) => {
      const chart = chartSetup(id);
      if (!chart) return;
      const { ctx, width, height } = chart;
      const values = (rows || []).filter((row) => Number(row.value || 0) > 0);
      if (!values.length) return drawEmptyChart(ctx, width, height);
      const total = values.reduce((sum, row) => sum + Number(row.value || 0), 0);
      const cx = Math.min(width * .35, 145);
      const cy = height / 2;
      const radius = Math.min(width * .23, height * .34, 86);
      let start = -Math.PI / 2;
      values.forEach((row, index) => {
        const end = start + (Number(row.value || 0) / total) * Math.PI * 2;
        ctx.beginPath();
        ctx.moveTo(cx, cy);
        ctx.arc(cx, cy, radius, start, end);
        ctx.closePath();
        ctx.fillStyle = chartColors[index % chartColors.length];
        ctx.fill();
        start = end;
      });
      ctx.globalCompositeOperation = "destination-out";
      ctx.beginPath();
      ctx.arc(cx, cy, radius * .58, 0, Math.PI * 2);
      ctx.fill();
      ctx.globalCompositeOperation = "source-over";
      drawText(ctx, centerLabel, cx, cy - 8, 12, "#64748b", 900, "center");
      drawText(ctx, moneyShort(total), cx, cy + 12, 15, "#102033", 1000, "center");
      const legendX = Math.min(width * .62, cx + radius + 26);
      values.slice(0, 5).forEach((row, index) => {
        const y = 40 + index * 29;
        ctx.fillStyle = chartColors[index % chartColors.length];
        ctx.beginPath();
        ctx.arc(legendX, y, 5, 0, Math.PI * 2);
        ctx.fill();
        drawText(ctx, row.label, legendX + 13, y - 5, 12, "#102033", 900);
        drawText(ctx, `${Math.round((row.value / total) * 100)}% · ${moneyShort(row.value)}`, legendX + 13, y + 10, 11);
      });
    };
    const drawBarChart = (id, rows, key = "value", includeZero = false) => {
      const chart = chartSetup(id);
      if (!chart) return;
      const { ctx, width, height } = chart;
      const values = (rows || []).filter((row) => includeZero || Number(row[key] || 0) > 0).slice(0, 7);
      if (!values.length) return drawEmptyChart(ctx, width, height);
      const pad = { left: 112, right: 28, top: 24, bottom: 22 };
      const max = Math.max(1, ...values.map((row) => Number(row[key] || 0)));
      const rowH = Math.min(42, (height - pad.top - pad.bottom) / values.length);
      values.forEach((row, index) => {
        const y = pad.top + index * rowH + 6;
        const barW = ((width - pad.left - pad.right) * Number(row[key] || 0)) / max;
        drawText(ctx, row.label, 12, y + rowH / 2 - 2, 12, "#102033", 900);
        roundRect(ctx, pad.left, y, width - pad.left - pad.right, Math.max(16, rowH - 14), 999);
        ctx.fillStyle = "rgba(16,32,51,.07)";
        ctx.fill();
        if (barW > 0) {
          roundRect(ctx, pad.left, y, Math.max(10, barW), Math.max(16, rowH - 14), 999);
          const gradient = ctx.createLinearGradient(pad.left, 0, width - pad.right, 0);
          gradient.addColorStop(0, chartColors[index % chartColors.length]);
          gradient.addColorStop(1, chartColors[(index + 1) % chartColors.length]);
          ctx.fillStyle = gradient;
          ctx.fill();
        }
        drawText(ctx, moneyShort(row[key]), width - pad.right, y + rowH / 2 - 2, 12, "#102033", 1000, "right");
      });
    };
    const renderFinanceCharts = (charts) => {
      if (scope !== "ketoan" || !charts) return;
      latestFinanceCharts = charts;
      drawLineChart(charts);
      drawDonutChart("ketoanMixChart", charts.revenueMix || [], "Doanh thu");
      drawDonutChart("ketoanPaymentChart", charts.payments || [], "Đã thu");
      drawBarChart("ketoanSourceChart", charts.sources || [], "value");
      drawBarChart("ketoanWeekdayChart", charts.weekdays || [], "value", true);
      const note = document.getElementById("ketoanChartNotes");
      if (note) {
        const topSource = (charts.sources || []).slice().sort((a, b) => Number(b.value || 0) - Number(a.value || 0))[0];
        const topWeekday = (charts.weekdays || []).slice().sort((a, b) => Number(b.value || 0) - Number(a.value || 0))[0];
        note.innerHTML = [
          topSource ? `<span>Nguồn mạnh: ${escapeHtml(topSource.label)} · ${escapeHtml(moneyShort(topSource.value))}</span>` : "",
          topWeekday ? `<span>Ngày mạnh: ${escapeHtml(topWeekday.label)} · ${escapeHtml(moneyShort(topWeekday.value))}</span>` : "",
          `<span>Chu kỳ: tháng hiện tại và 14 ngày gần nhất</span>`
        ].filter(Boolean).join("");
      }
    };

    const renderOverview = (data) => {
      const money = (value) => new Intl.NumberFormat("vi-VN").format(value || 0);
      const overviewItems = scope === "ketoan"
        ? [
            { label: "Doanh thu ghi nhận", value: money(data.overview.recognizedMonthlyRevenue), note: "Booked, Stayed và Paid trong tháng" },
            { label: "Đã thu tháng", value: money(data.overview.monthlyRevenue), note: "Giao dịch đã chốt Paid" },
            { label: "Còn phải thu", value: money(data.overview.outstandingMonthlyRevenue), note: "Booking/lưu trú chưa chốt thanh toán" },
            { label: "Giao dịch đã thu", value: data.overview.paidTransactions, note: "Số giao dịch Paid toàn hệ thống" },
            { label: "Tổng giao dịch", value: data.overview.totalTransactions, note: "Nguồn để mở UC Quản lý doanh thu khi cần chi tiết" },
            { label: "Khách hàng", value: data.overview.totalCustomers, note: "Đối tượng liên quan tới thu, công nợ và hoàn tiền" }
          ]
        : scope === "quanly"
        ? [
            { label: "Khách hàng", value: data.overview.totalCustomers, note: "Hồ sơ đang quản lý" },
            { label: "Giao dịch", value: data.overview.totalTransactions, note: "Booking và thanh toán" },
            { label: "Phòng trống", value: data.overview.availableRooms, note: "Sẵn sàng mở bán" },
            { label: "Đã đặt", value: data.overview.bookedRooms, note: "Booking đang mở" },
            { label: "Đang ở", value: data.overview.stayedRooms, note: "Khách đang lưu trú" },
            { label: "Bảo trì", value: data.overview.maintenanceRooms, note: "Cần theo dõi vận hành" }
          ]
        : scope === "admin"
          ? [
            { label: "Phòng trống", value: data.overview.availableRooms, note: "Sẵn sàng mở bán" },
            { label: "Đã đặt", value: data.overview.bookedRooms, note: "Booking đang mở" },
            { label: "Đang ở", value: data.overview.stayedRooms, note: "Khách đang lưu trú" },
            { label: "Cần xử lý phòng", value: Number(data.overview.cleaningRooms || 0) + Number(data.overview.maintenanceRooms || 0), note: "Dọn phòng + bảo trì" },
            { label: "Doanh thu tháng", value: money(data.overview.monthlyRevenue), note: "Giao dịch đã chốt Paid" },
            { label: "Còn phải thu", value: money(data.overview.outstandingMonthlyRevenue), note: "Booking/lưu trú chưa chốt" }
            ]
        : scope === "letan"
          ? [
            { label: "Phòng trống", value: data.overview.availableRooms, note: "Sẵn sàng nhận khách" },
            { label: "Đã đặt", value: data.overview.bookedRooms, note: "Booking chờ đến" },
            { label: "Đang ở", value: data.overview.stayedRooms, note: "Khách đang lưu trú" },
            { label: "Cần dọn", value: data.overview.cleaningRooms, note: "Chờ vệ sinh để mở lại" }
            ]
          : [
            { label: "Phòng trống", value: data.overview.availableRooms, note: "Sẵn sàng mở bán" },
            { label: "Đã đặt", value: data.overview.bookedRooms, note: "Phòng đã giữ chỗ" },
            { label: "Đang ở", value: data.overview.stayedRooms, note: "Khách đang lưu trú" },
            { label: "Cần dọn", value: data.overview.cleaningRooms, note: "Đang chờ vệ sinh" },
            { label: "Bảo trì", value: data.overview.maintenanceRooms, note: "Không thể mở bán" },
            { label: "Đã thu tháng", value: money(data.overview.monthlyRevenue), note: "Chỉ tính giao dịch Paid" },
            { label: "Còn phải thu", value: money(data.overview.outstandingMonthlyRevenue), note: "Booking/lưu trú chưa thanh toán" }
          ];

      overview.innerHTML = overviewItems.map((item) => `
        <article class="dash-stat">
          <strong>${escapeHtml(item.value)}</strong>
          <h3>${escapeHtml(item.label)}</h3>
          <p>${escapeHtml(item.note)}</p>
        </article>
      `).join("");

      if (scope === "letan" || !recentEvents) return;

      const eventLimit = scope === "admin" ? 6 : 12;
      recentEvents.innerHTML = (data.recentEvents || []).slice(0, eventLimit).map((item) => {
        const happenedAt = item.happenedAt
          ? new Date(item.happenedAt).toLocaleString("vi-VN", { hour: "2-digit", minute: "2-digit", day: "2-digit", month: "2-digit" })
          : "";
        const note = scope === "admin" && item.note && String(item.note).length > 90
          ? `${String(item.note).slice(0, 90)}...`
          : item.note;
        const meta = [note || "", happenedAt].filter(Boolean).join(" · ");

        return `
          <article class="dash-event">
            <span class="dash-badge">${escapeHtml(item.source || item.category || "System")}</span>
            <h3>${escapeHtml(item.title || [item.hotelName, item.roomNumber ? `P${item.roomNumber}` : ""].filter(Boolean).join(" · "))}</h3>
            <p>${escapeHtml(item.detail || `${item.fromStatus || "?"} -> ${item.toStatus || "?"}`)}</p>
            <p>${escapeHtml(meta || "Không có ghi chú")}</p>
          </article>
        `;
      }).join("") || `
        <article class="dash-empty">Chưa có sự kiện gần đây. Nhật ký trạng thái phòng sẽ xuất hiện tại đây khi có biến động.</article>
      `;
    };

    const renderOverviewError = () => {
      if (!overview) return;
      overview.innerHTML = `
        <article class="dash-empty">
          Chưa tải được KPI realtime lúc này. Bạn vẫn có thể mở các chức năng lễ tân bình thường và tải lại trang sau.
        </article>
      `;
    };

    const renderRoomBoard = (data) => {
      if (!enableRoomBoard) return;

      if (roomSummary && scope !== "letan") {
        roomSummary.innerHTML = [
          { label: "Phòng trống", value: data.summary.available },
          { label: "Đã đặt", value: data.summary.booked },
          { label: "Đang ở", value: data.summary.stayed },
          { label: "Cần dọn", value: data.summary.cleaning },
          { label: "Bảo trì", value: data.summary.maintenance }
        ].map((item) => `
          <article class="dash-stat">
            <strong>${escapeHtml(item.value)}</strong>
            <h3>${escapeHtml(item.label)}</h3>
            <p>Theo room board thời gian thực</p>
          </article>
        `).join("");
      }

      if (!roomBoard) return;

      roomBoard.innerHTML = data.items.slice(0, scope === "letan" ? 8 : 18).map((item) => `
        <article class="dash-room">
          <span class="dash-badge">${escapeHtml(item.trangThaiRealtime || item.trangThai)}</span>
          <h3>${escapeHtml(item.khachSan)} · P${escapeHtml(item.soPhong)}</h3>
          <p>${escapeHtml(item.loaiPhong)} · ${escapeHtml(item.tinhThanh)}</p>
          <p>Trạng thái: ${escapeHtml(item.trangThai)} · Tình trạng: ${escapeHtml(item.tinhTrangPhong)}</p>
        </article>
      `).join("");
    };

    const renderRoomBoardError = () => {
      if (roomSummary && scope !== "letan") {
        roomSummary.innerHTML = `
          <article class="dash-empty">
            Chưa tải được room board realtime. Các lối vào nghiệp vụ vẫn hoạt động bình thường.
          </article>
        `;
      }

      if (roomBoard) {
        roomBoard.innerHTML = "";
      }
    };

    const loadStats = async () => {
      if (!showLiveSections || !overview) return;
      try {
        const response = await fetch(`/api/dashboard/stats?scope=${scope}`, { credentials: "same-origin" });
        const payload = await response.json();
        if (payload.ok) {
          renderOverview(payload.data);
          return;
        }
      } catch (_error) {
      }

      renderOverviewError();
    };

    const loadRoomBoard = async () => {
      if (!showLiveSections || !enableRoomBoard) return;
      try {
        const response = await fetch(`/api/dashboard/room-board?scope=${scope}`, { credentials: "same-origin" });
        const payload = await response.json();
        if (payload.ok) {
          renderRoomBoard(payload.data);
          return;
        }
      } catch (_error) {
      }

      renderRoomBoardError();
    };

    if (showLiveSections) {
      loadStats();
      loadRoomBoard();
    }

    if (showLiveSections && window.EventSource) {
      const stream = new EventSource(`/api/realtime/stream?scope=${scope}`);
      ["room_status_changed", "booking_created", "service_order_created", "service_catalog_updated"].forEach((eventName) => {
        stream.addEventListener(eventName, () => {
          loadStats();
          loadRoomBoard();
        });
      });
    }
  })();
</script>
<script type="module" src="/js/home-galaxy-earth.js"></script>
