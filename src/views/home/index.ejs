<%- include("../partials/head") %>
<%- include("../partials/header") %>
<%
  const featuredRooms = home.rooms || [];
  const cities = home.hotelCities || [];
  const hotels = home.hotels || [];
  const bedTypes = home.bedTypes || [];
  const roomTypes = home.roomTypes || [];
  const viewTypes = home.viewTypes || [];
  const accentCities = cities.slice(0, 5);
  const amenities = [
    "Hồ bơi vô cực ngoài trời nhìn thẳng ra biển.",
    "Spa, xông hơi, jacuzzi và massage thư giãn.",
    "Nhà hàng buffet sáng cùng thực đơn Au - A.",
    "Rooftop bar và nhạc live cuối tuần.",
    "Khu vui chơi trẻ em và phòng gym hiện đại.",
    "Tour tham quan, thuê xe và đưa đón sân bay."
  ];
%>

<style>
  .site-header {
    background: rgba(234, 251, 255, 0.72);
    border-bottom-color: rgba(14, 73, 118, 0.10);
    box-shadow: 0 16px 34px rgba(77, 132, 171, 0.08);
  }

  .site-header__inner {
    min-height: 78px;
  }

  .brand strong {
    color: #0b3255;
  }

  .brand span {
    color: #51758f;
  }

  .nav-links .chip,
  .nav-links .button {
    background: rgba(255, 255, 255, 0.72);
    color: #0b3255;
    border-color: rgba(14, 73, 118, 0.10);
  }

  .nav-links .button--primary {
    color: #ffffff;
    border-color: transparent;
    background: linear-gradient(135deg, #0ea5e9, #14b8a6 48%, #22c55e);
  }

  body.travel-night .site-header {
    background: rgba(12, 22, 48, 0.86);
    border-bottom-color: rgba(148, 163, 184, 0.20);
    box-shadow: 0 16px 34px rgba(2, 6, 23, 0.24);
  }

  body.travel-night .brand strong,
  body.travel-night .nav-links .chip,
  body.travel-night .nav-links .button {
    color: #eef6ff;
  }

  body.travel-night .brand span {
    color: #a8c5df;
  }

  body.travel-night .nav-links .chip,
  body.travel-night .nav-links .button {
    background: rgba(255, 255, 255, 0.10);
    border-color: rgba(226, 232, 240, 0.14);
  }

  .travel-home {
    --travel-ink: #0b3255;
    --travel-muted: #5b7790;
    --travel-line: rgba(14, 73, 118, 0.12);
    --travel-card: rgba(255, 255, 255, 0.72);
    --travel-card-strong: rgba(255, 255, 255, 0.86);
    --travel-cyan: #38bdf8;
    --travel-sky: #7dd3fc;
    --travel-sea: #14b8a6;
    --travel-mint: #6ee7b7;
    --travel-sun: #fbbf24;
    --travel-coral: #fb7185;
    --travel-peach: #fdba74;
    --travel-violet: #a78bfa;
    --travel-shadow: 0 28px 80px rgba(20, 84, 122, 0.20);
    position: relative;
    overflow: hidden;
    color: var(--travel-ink);
    transition: background 0.7s ease, color 0.35s ease;
    background:
      linear-gradient(135deg, rgba(6, 182, 212, 0.16) 0 25%, transparent 25% 50%, rgba(251, 113, 133, 0.10) 50% 75%, transparent 75% 100%),
      radial-gradient(circle at 12% 6%, rgba(34, 211, 238, 0.58), transparent 26%),
      radial-gradient(circle at 88% 14%, rgba(251, 191, 36, 0.36), transparent 22%),
      radial-gradient(circle at 18% 70%, rgba(52, 211, 153, 0.30), transparent 28%),
      linear-gradient(180deg, #b8f2ff 0%, #d7fff2 34%, #fff2bd 68%, #ffe3ef 100%);
  }

  .travel-home[data-theme="night"] {
    --travel-ink: #eef6ff;
    --travel-muted: #b6c7dc;
    --travel-line: rgba(226, 232, 240, 0.18);
    --travel-card: rgba(15, 23, 42, 0.70);
    --travel-card-strong: rgba(18, 29, 55, 0.86);
    --travel-shadow: 0 28px 80px rgba(2, 6, 23, 0.36);
    background:
      linear-gradient(135deg, rgba(14, 165, 233, 0.10) 0 25%, transparent 25% 50%, rgba(168, 85, 247, 0.12) 50% 75%, transparent 75% 100%),
      radial-gradient(circle at 78% 8%, rgba(196, 181, 253, 0.32), transparent 24%),
      radial-gradient(circle at 18% 16%, rgba(56, 189, 248, 0.18), transparent 22%),
      radial-gradient(circle at 50% 72%, rgba(20, 184, 166, 0.16), transparent 30%),
      linear-gradient(180deg, #041226 0%, #082348 36%, #11395a 70%, #172947 100%);
  }

  .travel-home::before,
  .travel-home::after {
    content: "";
    position: absolute;
    inset: auto;
    width: 520px;
    height: 520px;
    border-radius: 999px;
    pointer-events: none;
    z-index: 0;
    filter: blur(14px);
    opacity: 0.65;
    animation: travel-float-orb 14s ease-in-out infinite alternate;
  }

  .travel-home::before {
    top: -220px;
    right: -140px;
    background: radial-gradient(circle, rgba(110, 231, 183, 0.34), rgba(56, 189, 248, 0.12), transparent 68%);
  }

  .travel-home::after {
    left: -180px;
    bottom: -240px;
    background: radial-gradient(circle, rgba(251, 113, 133, 0.20), rgba(253, 186, 116, 0.16), transparent 70%);
    animation-delay: -4s;
  }

  .travel-shell {
    width: min(1220px, calc(100vw - 28px));
    margin: 0 auto;
    position: relative;
    z-index: 1;
    padding: 28px 0 72px;
  }

  .travel-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(420px, 0.98fr);
    gap: 26px;
    align-items: stretch;
  }

  .travel-panel,
  .travel-search-card,
  .travel-room-card,
  .travel-city-card {
    border: 1px solid var(--travel-line);
    background: var(--travel-card);
    backdrop-filter: blur(22px);
    box-shadow: var(--travel-shadow);
  }

  .travel-panel {
    position: relative;
    overflow: hidden;
    border-radius: 40px;
    padding: 34px;
    min-height: 640px;
    background:
      linear-gradient(155deg, rgba(255, 255, 255, 0.88), rgba(255, 255, 255, 0.58)),
      radial-gradient(circle at 95% 12%, rgba(251, 191, 36, 0.24), transparent 22%);
  }

  .travel-panel::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 84% 14%, rgba(255, 255, 255, 0.68), transparent 18%),
      linear-gradient(120deg, rgba(255, 255, 255, 0.62), transparent 34%);
    pointer-events: none;
  }

  .travel-home[data-theme="night"] .travel-panel {
    background:
      linear-gradient(155deg, rgba(15, 23, 42, 0.90), rgba(30, 41, 59, 0.68)),
      radial-gradient(circle at 96% 10%, rgba(196, 181, 253, 0.18), transparent 24%);
  }

  .travel-home[data-theme="night"] .travel-panel::before {
    background:
      radial-gradient(circle at 84% 14%, rgba(191, 219, 254, 0.14), transparent 18%),
      linear-gradient(120deg, rgba(255, 255, 255, 0.08), transparent 34%);
  }

  .travel-home[data-theme="night"] .travel-search-card,
  .travel-home[data-theme="night"] .travel-info-card,
  .travel-home[data-theme="night"] .travel-contact-card,
  .travel-home[data-theme="night"] .travel-room-card,
  .travel-home[data-theme="night"] .travel-city-card {
    border-color: var(--travel-line);
    background: var(--travel-card);
  }

  .travel-home[data-theme="night"] .travel-eyebrow,
  .travel-home[data-theme="night"] .travel-chip,
  .travel-home[data-theme="night"] .travel-room-pill,
  .travel-home[data-theme="night"] .travel-mini-pill,
  .travel-home[data-theme="night"] .travel-scene-badge,
  .travel-home[data-theme="night"] .travel-scene-copy {
    color: var(--travel-ink);
    background: rgba(15, 23, 42, 0.62);
    border-color: rgba(226, 232, 240, 0.16);
  }

  .travel-home[data-theme="night"] .travel-field input,
  .travel-home[data-theme="night"] .travel-field select {
    color: var(--travel-ink);
    background: rgba(15, 23, 42, 0.64);
    border-color: rgba(226, 232, 240, 0.18);
  }

  .travel-home[data-theme="night"] .travel-field input::placeholder {
    color: rgba(226, 232, 240, 0.60);
  }

  .travel-home[data-theme="night"] .travel-button--secondary,
  .travel-home[data-theme="night"] .travel-room-link {
    color: var(--travel-ink);
    background: rgba(15, 23, 42, 0.66);
    border-color: rgba(226, 232, 240, 0.16);
  }

  .travel-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-radius: 999px;
    padding: 8px 14px;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(56, 189, 248, 0.16);
    color: #0284c7;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .travel-eyebrow-dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--travel-sun), var(--travel-coral));
    box-shadow: 0 0 0 6px rgba(251, 191, 36, 0.16);
    animation: travel-pulse 2s ease-in-out infinite;
  }

  .travel-title {
    margin: 24px 0 14px;
    max-width: 640px;
    color: var(--travel-ink);
    font-size: clamp(42px, 6vw, 78px);
    line-height: 0.93;
    letter-spacing: -0.08em;
  }

  .travel-title span {
    display: inline-block;
    color: transparent;
    background: linear-gradient(135deg, #0ea5e9, #14b8a6 38%, #fb7185 72%, #f59e0b);
    -webkit-background-clip: text;
    background-clip: text;
  }

  .travel-description {
    max-width: 620px;
    margin: 0;
    color: var(--travel-muted);
    font-size: 16px;
    line-height: 1.8;
  }

  .travel-highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 20px;
  }

  .travel-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(14, 73, 118, 0.10);
    color: var(--travel-ink);
    font-size: 12px;
    font-weight: 800;
  }

  .travel-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 26px;
  }

  .travel-button,
  .travel-button:link,
  .travel-button:visited {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 12px 20px;
    border-radius: 999px;
    border: 1px solid transparent;
    font-size: 14px;
    font-weight: 900;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }

  .travel-button:hover {
    transform: translateY(-2px);
  }

  .travel-button--primary {
    color: #ffffff;
    background: linear-gradient(135deg, #0ea5e9, #14b8a6 45%, #22c55e);
    box-shadow: 0 20px 38px rgba(20, 184, 166, 0.26);
  }

  .travel-button--secondary {
    color: var(--travel-ink);
    background: rgba(255, 255, 255, 0.84);
    border-color: rgba(14, 73, 118, 0.12);
  }

  .travel-button--install {
    color: #0b3255;
    background: linear-gradient(135deg, #fde68a, #f9a8d4 54%, #7dd3fc);
    box-shadow: 0 18px 34px rgba(244, 114, 182, 0.18);
  }

  .travel-kpi-row {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin-top: 26px;
  }

  .travel-kpi {
    border-radius: 24px;
    padding: 16px 18px;
    background: rgba(255, 255, 255, 0.76);
    border: 1px solid rgba(14, 73, 118, 0.08);
  }

  .travel-kpi strong {
    display: block;
    font-size: 28px;
    line-height: 1;
    letter-spacing: -0.05em;
    color: var(--travel-ink);
  }

  .travel-kpi span {
    display: block;
    margin-top: 8px;
    color: var(--travel-muted);
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .travel-search-card {
    margin-top: 24px;
    border-radius: 30px;
    padding: 20px;
    background: rgba(255, 255, 255, 0.80);
  }

  .travel-search-card form {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .travel-field {
    display: grid;
    gap: 8px;
  }

  .travel-field--wide {
    grid-column: 1 / -1;
  }

  .travel-field label {
    color: var(--travel-ink);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .travel-field input,
  .travel-field select {
    width: 100%;
    min-height: 50px;
    padding: 0 16px;
    border-radius: 16px;
    border: 1px solid rgba(14, 73, 118, 0.14);
    background: rgba(255, 255, 255, 0.92);
    color: var(--travel-ink);
    font: inherit;
    outline: none;
  }

  .travel-field input:focus,
  .travel-field select:focus {
    border-color: rgba(14, 165, 233, 0.55);
    box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.12);
  }

  .travel-search-actions {
    grid-column: 1 / -1;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding-top: 4px;
  }

  .travel-search-note {
    margin: 10px 0 0;
    color: var(--travel-muted);
    font-size: 13px;
    line-height: 1.7;
  }

  .travel-scene-card {
    position: relative;
    overflow: hidden;
    min-height: 640px;
    border-radius: 42px;
    border: 1px solid rgba(14, 165, 233, 0.26);
    box-shadow: 0 32px 90px rgba(14, 165, 233, 0.24), 0 22px 72px rgba(244, 114, 182, 0.12);
    transition: background 0.7s ease, border-color 0.35s ease, box-shadow 0.35s ease;
    background:
      radial-gradient(circle at 15% 18%, rgba(255, 255, 255, 0.74), transparent 22%),
      radial-gradient(circle at 82% 14%, rgba(255, 214, 102, 0.55), transparent 18%),
      linear-gradient(180deg, #54dfff 0%, #9ff4ff 24%, #d8fbff 45%, #fff8df 58%, #19d5f2 59%, #06aeca 100%);
  }

  .travel-home[data-theme="night"] .travel-scene-card {
    border-color: rgba(226, 232, 240, 0.18);
    background:
      radial-gradient(circle at 78% 16%, rgba(196,181,253,0.20), transparent 18%),
      linear-gradient(180deg, #08152f 0%, #111f42 30%, #172a50 49%, #1e3a5f 58%, #123f5a 100%);
    box-shadow: 0 32px 92px rgba(59, 130, 246, 0.22), 0 18px 80px rgba(168, 85, 247, 0.18);
  }

  .travel-scene-card::after {
    content: "";
    position: absolute;
    inset: -18%;
    z-index: 2;
    pointer-events: none;
    background:
      conic-gradient(from 160deg at 50% 50%, rgba(255,255,255,0), rgba(255,255,255,.24), rgba(20,184,166,.14), rgba(251,113,133,.12), rgba(255,255,255,0)),
      radial-gradient(circle at 20% 70%, rgba(34,211,238,.18), transparent 24%),
      radial-gradient(circle at 82% 42%, rgba(251,191,36,.18), transparent 18%);
    mix-blend-mode: soft-light;
    opacity: 0.86;
    animation: travel-5d-glow 9s ease-in-out infinite alternate;
  }

  .travel-scene-3d {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .travel-scene-3d::before,
  .travel-scene-3d::after {
    content: "";
    position: absolute;
    inset: -18%;
    z-index: 2;
    pointer-events: none;
  }

  .travel-scene-3d::before {
    background: linear-gradient(115deg, transparent 0 34%, rgba(255,255,255,.34) 42%, rgba(34,211,238,.18) 48%, transparent 58% 100%);
    mix-blend-mode: screen;
    transform: translateX(-44%) rotate(0deg);
    animation: travel-light-sweep 5.8s ease-in-out infinite;
  }

  .travel-scene-3d::after {
    background:
      radial-gradient(circle at 22% 26%, rgba(255,255,255,.38) 0 1px, transparent 2px),
      radial-gradient(circle at 74% 34%, rgba(255,255,255,.32) 0 1px, transparent 2px),
      radial-gradient(circle at 48% 68%, rgba(255,255,255,.30) 0 1px, transparent 2px),
      radial-gradient(circle at 82% 72%, rgba(255,255,255,.26) 0 1px, transparent 2px);
    opacity: .76;
    animation: travel-sparkle-field 4.4s ease-in-out infinite alternate;
  }

  .travel-scene-3d canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  .travel-scene-loading {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    color: rgba(16, 32, 51, 0.72);
    font-size: 13px;
    font-weight: 900;
    background: linear-gradient(180deg, rgba(255,255,255,0.32), rgba(255,255,255,0));
  }

  .travel-scene-depth {
    position: absolute;
    inset: auto 24px 24px 24px;
    z-index: 3;
    display: grid;
    gap: 10px;
    pointer-events: none;
  }

  .travel-scene-depth__title {
    width: max-content;
    max-width: 100%;
    border-radius: 999px;
    padding: 8px 12px;
    color: #052f48;
    background: linear-gradient(135deg, rgba(255,255,255,.86), rgba(207,250,254,.68));
    border: 1px solid rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(14px);
    box-shadow: 0 16px 38px rgba(8, 47, 73, 0.12), 0 0 28px rgba(34, 211, 238, 0.22);
    font-size: 12px;
    font-weight: 1000;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .travel-scene-depth__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .travel-scene-depth__chips span {
    border-radius: 999px;
    padding: 7px 10px;
    color: #102033;
    background: linear-gradient(135deg, rgba(255,255,255,.78), rgba(255,247,237,.62));
    border: 1px solid rgba(255, 255, 255, 0.52);
    backdrop-filter: blur(12px);
    font-size: 12px;
    font-weight: 900;
    box-shadow: 0 12px 28px rgba(14, 165, 233, 0.12);
  }

  .travel-home[data-theme="night"] .travel-scene-depth__title,
  .travel-home[data-theme="night"] .travel-scene-depth__chips span {
    color: #f8fbff;
    background: rgba(15, 23, 42, 0.48);
    border-color: rgba(255, 255, 255, 0.14);
  }

  .travel-scene-card::before {
    content: "";
    position: absolute;
    inset: auto 0 0 0;
    height: 42%;
    z-index: 1;
    pointer-events: none;
    background:
      radial-gradient(circle at 20% 0%, rgba(255, 255, 255, 0.34), transparent 26%),
      linear-gradient(180deg, rgba(255,255,255,0.16), rgba(23,177,202,0));
  }

  .travel-home[data-theme="night"] .travel-scene-card::before {
    background:
      radial-gradient(circle at 24% 0%, rgba(147, 197, 253, 0.16), transparent 28%),
      linear-gradient(180deg, rgba(15,23,42,0.04), rgba(7,18,36,0.18));
  }

  .travel-scene-top {
    position: absolute;
    inset: 24px 24px auto 24px;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    z-index: 2;
  }

  .travel-scene-badge {
    border-radius: 20px;
    padding: 12px 14px;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(14, 73, 118, 0.08);
    backdrop-filter: blur(12px);
    color: var(--travel-ink);
    max-width: 220px;
  }

  .travel-scene-badge strong {
    display: block;
    font-size: 14px;
    margin-bottom: 4px;
  }

  .travel-scene-badge span {
    color: var(--travel-muted);
    font-size: 12px;
    line-height: 1.5;
  }

  .travel-sun {
    position: absolute;
    top: 52px;
    right: 88px;
    width: 108px;
    height: 108px;
    border-radius: 999px;
    background: radial-gradient(circle at 34% 34%, #fff7bf, #ffd45c 52%, #f59e0b 100%);
    box-shadow: 0 0 0 18px rgba(251, 191, 36, 0.14), 0 0 68px rgba(251, 191, 36, 0.42);
    animation: travel-sun-breathe 5s ease-in-out infinite;
    transition: opacity 0.45s ease, transform 0.45s ease;
  }

  .travel-home[data-theme="night"] .travel-sun,
  .travel-home[data-theme="night"] .travel-sun-rays,
  .travel-home[data-theme="night"] .travel-rainbow {
    opacity: 0;
    transform: translateY(18px) scale(0.86);
  }

  .travel-sun-rays {
    position: absolute;
    top: 18px;
    right: 54px;
    width: 178px;
    height: 178px;
    border-radius: 999px;
    background: conic-gradient(from 0deg, rgba(255,255,255,0), rgba(255,244,177,0.58), rgba(255,255,255,0) 18%, rgba(255,244,177,0.34) 28%, rgba(255,255,255,0) 42%, rgba(255,244,177,0.48), rgba(255,255,255,0));
    opacity: 0.48;
    animation: travel-rays-spin 34s linear infinite;
    transition: opacity 0.45s ease, transform 0.45s ease;
  }

  .travel-moon {
    position: absolute;
    top: 56px;
    right: 92px;
    width: 102px;
    height: 102px;
    border-radius: 999px;
    background: radial-gradient(circle at 32% 28%, #ffffff, #dbeafe 58%, #93c5fd 100%);
    box-shadow: 0 0 0 18px rgba(147, 197, 253, 0.10), 0 0 76px rgba(191, 219, 254, 0.42);
    opacity: 0;
    transform: translateY(-16px) scale(0.88);
    transition: opacity 0.5s ease, transform 0.5s ease;
    z-index: 1;
  }

  .travel-moon::after {
    content: "";
    position: absolute;
    right: -8px;
    top: -4px;
    width: 84px;
    height: 84px;
    border-radius: inherit;
    background: #08152f;
  }

  .travel-home[data-theme="night"] .travel-moon {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .travel-stars {
    position: absolute;
    inset: 40px 28px auto 28px;
    height: 230px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.55s ease;
    z-index: 1;
  }

  .travel-star {
    position: absolute;
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: #fff7cc;
