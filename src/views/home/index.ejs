<script>
  (() => {
    const JOURNEY_KEY = "bento_home_recent_journeys_v1";
    const THEME_KEY = "bento_home_day_night_theme_v1";
    const MAX_JOURNEYS = 5;
    const homeRoot = document.getElementById("travel-home");
    const themeToggle = document.getElementById("travel-theme-toggle");
    const themeLabel = themeToggle?.querySelector("[data-theme-label]");
    const installButtons = [
      document.getElementById("travel-install-app"),
      document.getElementById("travel-install-app-cta")
    ].filter(Boolean);
    const pwaMeta = document.getElementById("travel-pwa-meta");
    const pwaNote = document.getElementById("travel-pwa-note");
    const pwaPrimary = document.getElementById("travel-pwa-primary");
    const searchForm = document.querySelector("#travel-search form");
    const journeyList = document.getElementById("travel-journey-list");
    const journeyEmpty = document.getElementById("travel-journey-empty");
    const clearJourneys = document.getElementById("travel-clear-journeys");

    function readTheme() {
      const saved = localStorage.getItem(THEME_KEY);
      return saved === "night" ? "night" : "day";
    }

    function applyTheme(theme, persist = true) {
      if (!homeRoot) return;
      const nextTheme = theme === "night" ? "night" : "day";
      homeRoot.dataset.theme = nextTheme;
      document.body.classList.toggle("travel-night", nextTheme === "night");
      themeToggle?.setAttribute("aria-pressed", nextTheme === "night" ? "true" : "false");
      themeToggle?.setAttribute("title", nextTheme === "night" ? "Kéo rèm lên để mở ban ngày" : "Kéo rèm xuống để mở ban đêm");
      themeToggle?.setAttribute("aria-label", nextTheme === "night" ? "Kéo rèm lên để mở ban ngày" : "Kéo rèm xuống để mở ban đêm");
      if (themeLabel) themeLabel.textContent = nextTheme === "night" ? "Kéo mở ngày" : "Kéo xuống đêm";
      if (persist) localStorage.setItem(THEME_KEY, nextTheme);
    }

    function readJourneys() {
      try {
        return JSON.parse(localStorage.getItem(JOURNEY_KEY) || "[]");
      } catch {
        return [];
      }
    }

    function writeJourneys(items) {
      localStorage.setItem(JOURNEY_KEY, JSON.stringify(items.slice(0, MAX_JOURNEYS)));
    }

    function summarizeFilters(formData) {
      const city = String(formData.get("hotel_city") || "").trim();
      const roomType = String(formData.get("loai_phong") || "").trim();
      const guests = String(formData.get("so_khach") || "").trim();
      const view = String(formData.get("view_phong") || "").trim();
      return {
        city,
        roomType,
        guests,
        view,
        label: city || roomType || "Tìm phòng gần đây"
      };
    }

    function saveJourney(formData) {
      const summary = summarizeFilters(formData);
      const meaningful = Object.values(summary).some((value) => String(value).trim() !== "");
      if (!meaningful) return;

      const nextItem = {
        id: `journey_${Date.now()}`,
        summary,
        saved_at: Date.now()
      };

      const current = readJourneys().filter((item) => JSON.stringify(item.summary) !== JSON.stringify(summary));
      current.unshift(nextItem);
      writeJourneys(current);
      renderJourneys();
    }

    function applyJourney(summary) {
      if (!searchForm || !summary) return;
      const mapping = {
        hotel_city: summary.city || "",
        loai_phong: summary.roomType || "",
        so_khach: summary.guests || "",
        view_phong: summary.view || ""
      };
      Object.entries(mapping).forEach(([key, value]) => {
        const field = searchForm.querySelector(`[name="${key}"]`);
        if (field) field.value = value;
      });
      document.getElementById("travel-search")?.scrollIntoView({ behavior: "smooth", block: "start" });
    }

    function renderJourneys() {
      if (!journeyList || !journeyEmpty) return;
      const items = readJourneys();
      journeyList.innerHTML = "";
      journeyEmpty.hidden = items.length > 0;

      items.forEach((item) => {
        const summary = item.summary || {};
        const card = document.createElement("article");
        card.className = "travel-journey-card";
        const bits = [summary.roomType, summary.view, summary.guests ? `${summary.guests} khách` : ""].filter(Boolean).join(" · ");
        card.innerHTML = `
          <strong>${summary.label || "Tìm phòng gần đây"}</strong>
          <span>${bits || "Bộ lọc tìm kiếm được lưu để quay lại nhanh."}</span>
          <div class="travel-journey-actions">
            <button type="button" class="travel-journey-link" data-journey-id="${item.id}">Dùng lại bộ lọc</button>
          </div>
        `;
        journeyList.appendChild(card);
      });
    }

    const updateInstallButtons = () => {
      const state = window.__abcPwaState || {};
      const canInstall = Boolean(state.installAvailable && typeof window.__abcPwaInstall === "function");
      const installed = Boolean(state.installed);

      if (pwaMeta) {
        pwaMeta.innerHTML = `
          <span class="travel-pwa-chip">${installed ? "App mode" : "Web mode"}</span>
          <span class="travel-pwa-chip">${state.online === false ? "Offline" : "Online"}</span>
          ${canInstall ? '<span class="travel-pwa-chip">Install ready</span>' : ""}
          ${state.hasWaitingUpdate ? '<span class="travel-pwa-chip">Có bản mới</span>' : ""}
        `;
      }

      if (pwaNote) {
        pwaNote.textContent = installed
          ? "Bạn đang dùng Bento ở app mode, phù hợp để mở nhanh mobile hub và theo dõi hành trình đặt phòng."
          : "Mở như app để đặt phòng, theo dõi lịch sử và dùng Bento thuận tiện hơn trên điện thoại.";
      }

      installButtons.forEach((button) => {
        if (!button) return;
        if (installed) {
          button.textContent = "Đã ở app mode";
          button.disabled = true;
          button.style.opacity = "0.72";
          button.style.cursor = "default";
          return;
        }

        button.disabled = false;
        button.style.opacity = "1";
        button.style.cursor = "pointer";
        button.textContent = canInstall ? "Cài app Bento" : "Mở Mobile Hub";
      });

      if (pwaPrimary) {
        pwaPrimary.textContent = installed ? "Đã ở app mode" : (canInstall ? "Cài app Bento" : "Mở Mobile Hub");
        pwaPrimary.disabled = installed;
        pwaPrimary.style.opacity = installed ? "0.72" : "1";
        pwaPrimary.style.cursor = installed ? "default" : "pointer";
      }
    };

    const handleInstall = async () => {
      const state = window.__abcPwaState || {};
      if (state.installAvailable && typeof window.__abcPwaInstall === "function") {
        await window.__abcPwaInstall();
        updateInstallButtons();
        return;
      }

      window.location.href = "<%= user ? "/customer/mobile-hub" : "/auth/login" %>";
    };

    installButtons.forEach((button) => {
      button.addEventListener("click", handleInstall);
    });

    pwaPrimary?.addEventListener("click", handleInstall);

    searchForm?.addEventListener("submit", () => {
      saveJourney(new FormData(searchForm));
    });

    journeyList?.addEventListener("click", (event) => {
      const button = event.target.closest("[data-journey-id]");
      if (!button) return;
      const entry = readJourneys().find((item) => item.id === button.getAttribute("data-journey-id"));
      if (entry?.summary) applyJourney(entry.summary);
    });

    clearJourneys?.addEventListener("click", () => {
      localStorage.removeItem(JOURNEY_KEY);
      renderJourneys();
    });

    themeToggle?.addEventListener("click", () => {
      const current = homeRoot?.dataset.theme === "night" ? "night" : "day";
      applyTheme(current === "night" ? "day" : "night");
    });

    window.addEventListener("abc:pwa-state", updateInstallButtons);
    applyTheme(readTheme(), false);
    renderJourneys();
    updateInstallButtons();
  })();
</script>

<%- include("../partials/footer") %>
