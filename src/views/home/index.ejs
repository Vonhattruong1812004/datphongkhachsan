    z-index: 1;
    margin-top: 8px;
    color: var(--travel-muted);
    font-size: 13px;
    line-height: 1.6;
  }

  .travel-room-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .travel-room-card {
    overflow: hidden;
    border-radius: 30px;
    background: var(--travel-card-strong);
  }

  .travel-room-media {
    position: relative;
    height: 224px;
    overflow: hidden;
    background: linear-gradient(180deg, rgba(224,247,255,0.16), rgba(23,177,202,0.18));
  }

  .travel-room-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease;
  }

  .travel-room-card:hover .travel-room-media img {
    transform: scale(1.06);
  }

  .travel-room-overlay {
    position: absolute;
    inset: auto 16px 16px 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }

  .travel-room-badge,
  .travel-room-price {
    border-radius: 999px;
    padding: 8px 12px;
    background: rgba(255, 255, 255, 0.84);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(14, 73, 118, 0.10);
    font-size: 12px;
    font-weight: 900;
  }

  .travel-room-price {
    color: #0f766e;
  }

  .travel-room-body {
    padding: 18px;
  }

  .travel-room-body h3 {
    margin: 0;
    font-size: 24px;
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .travel-room-meta {
    margin-top: 8px;
    color: var(--travel-muted);
    font-size: 14px;
    line-height: 1.7;
  }

  .travel-room-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
  }

  .travel-room-pill {
    padding: 7px 10px;
    border-radius: 999px;
    background: rgba(20, 184, 166, 0.09);
    border: 1px solid rgba(20, 184, 166, 0.14);
    color: #0f766e;
    font-size: 12px;
    font-weight: 800;
  }

  .travel-room-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 18px;
  }

  .travel-room-link {
    color: #0284c7;
    font-size: 13px;
    font-weight: 900;
  }

  .travel-info-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.95fr);
    gap: 16px;
  }

  .travel-info-card,
  .travel-contact-card {
    border-radius: 28px;
    padding: 22px;
  }

  .travel-info-card h3,
  .travel-contact-card h3 {
    margin: 0 0 10px;
    font-size: 22px;
    line-height: 1.05;
    letter-spacing: -0.05em;
  }

  .travel-info-card p,
  .travel-contact-card p {
    margin: 0 0 10px;
    color: var(--travel-muted);
    font-size: 14px;
    line-height: 1.8;
  }

  .travel-list {
    margin: 10px 0 0;
    padding-left: 18px;
    color: var(--travel-ink);
    font-size: 14px;
    line-height: 1.8;
  }

  .travel-amenities-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    margin-top: 12px;
  }

  .travel-amenity-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: var(--travel-ink);
    font-size: 14px;
    line-height: 1.6;
  }

  .travel-amenity-dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    margin-top: 8px;
    background: linear-gradient(135deg, #0ea5e9, #14b8a6);
    box-shadow: 0 0 0 6px rgba(20, 184, 166, 0.10);
  }

  .travel-promo-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 14px;
    border-radius: 22px;
    padding: 16px 18px;
    color: #fff7ed;
    background: linear-gradient(135deg, #f97316, #fb7185);
    box-shadow: 0 20px 40px rgba(251, 113, 133, 0.18);
  }

  .travel-promo-banner strong {
    display: block;
    font-size: 18px;
  }

  .travel-promo-banner span {
    display: block;
    margin-top: 6px;
    font-size: 13px;
    line-height: 1.7;
    color: rgba(255, 247, 237, 0.88);
  }

  .travel-promo-chip {
    padding: 8px 12px;
    border-radius: 999px;
    border: 1px solid rgba(255, 247, 237, 0.55);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @keyframes travel-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(0.78); opacity: 0.68; }
  }

  @keyframes travel-float-orb {
    from { transform: translate3d(0, 0, 0) rotate(0deg); }
    to { transform: translate3d(28px, 20px, 0) rotate(12deg); }
  }

  @keyframes travel-5d-glow {
    0% { transform: translate3d(-2%, -1%, 0) rotate(0deg) scale(1); opacity: 0.62; }
    50% { transform: translate3d(2%, 1.5%, 0) rotate(10deg) scale(1.05); opacity: 0.95; }
    100% { transform: translate3d(4%, -2%, 0) rotate(18deg) scale(1.08); opacity: 0.72; }
  }

  @keyframes travel-light-sweep {
    0%, 100% { transform: translateX(-48%) rotate(0deg); opacity: 0; }
    18% { opacity: .86; }
    54% { opacity: .48; }
    78% { transform: translateX(44%) rotate(0deg); opacity: 0; }
  }

  @keyframes travel-sparkle-field {
    0% { transform: translate3d(-1%, 1%, 0) scale(1); opacity: .38; }
    100% { transform: translate3d(1.8%, -1.2%, 0) scale(1.05); opacity: .9; }
  }

  @keyframes travel-sun-breathe {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.06); }
  }

  @keyframes travel-rays-spin {
    from { transform: rotate(0deg) scale(1); }
    to { transform: rotate(360deg) scale(1); }
  }

  @keyframes travel-cloud {
    0% { transform: translateX(0); }
    50% { transform: translateX(24px); }
    100% { transform: translateX(0); }
  }

  @keyframes travel-palm-wave {
    0%, 100% { transform: rotate(12deg); }
    50% { transform: rotate(24deg); }
  }

  @keyframes travel-wave {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(0, -10px, 0); }
  }

  @keyframes travel-dolphin-jump {
    0%, 100% { transform: translate3d(0, 0, 0) rotate(0deg); }
    30% { transform: translate3d(14px, -26px, 0) rotate(-10deg); }
    52% { transform: translate3d(28px, 4px, 0) rotate(4deg); }
  }

  @keyframes travel-splash {
    0%, 100% { opacity: 0.14; transform: scaleX(0.88); }
    40% { opacity: 0.72; transform: scaleX(1); }
  }

  @keyframes travel-star-twinkle {
    0%, 100% { opacity: 0.42; transform: scale(0.86); }
    50% { opacity: 1; transform: scale(1.2); }
  }

  @keyframes travel-shooting-star {
    0%, 70%, 100% { opacity: 0; transform: rotate(-28deg) translateX(-90px); }
    78% { opacity: 1; }
    92% { opacity: 0; transform: rotate(-28deg) translateX(120px); }
  }

  @keyframes travel-reflection {
    0%, 100% { transform: translateX(-50%) scaleX(0.96); opacity: 0.46; }
    50% { transform: translateX(-50%) scaleX(1.08); opacity: 0.62; }
  }

  @keyframes travel-sailboat {
    0%, 100% { transform: translate3d(0, 0, 0) rotate(-1deg); }
    50% { transform: translate3d(18px, -8px, 0) rotate(2deg); }
  }

  @keyframes travel-cord-sway {
    0%, 100% { transform: rotate(0deg); }
    26% { transform: rotate(7deg); }
    56% { transform: rotate(-5deg); }
    78% { transform: rotate(3deg); }
  }

  @media (max-width: 1120px) {
    .travel-hero,
    .travel-city-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .travel-room-grid,
    .travel-info-grid {
      grid-template-columns: 1fr 1fr;
    }

    .travel-panel,
    .travel-scene-card {
      min-height: auto;
    }
  }

  @media (max-width: 760px) {
    .travel-shell {
      width: min(100vw - 18px, 100%);
      padding: 18px 0 52px;
    }

    .travel-hero,
    .travel-kpi-row,
    .travel-city-grid,
    .travel-room-grid,
    .travel-info-grid,
    .travel-amenities-grid,
    .travel-search-card form {
      grid-template-columns: 1fr;
    }

    .travel-panel,
    .travel-scene-card {
      border-radius: 28px;
      padding: 22px;
    }

    .travel-title {
      font-size: 42px;
    }

    .travel-search-actions,
    .travel-room-actions,
    .travel-section-head,
    .travel-scene-caption {
      display: flex;
      flex-direction: column;
      align-items: stretch;
    }

    .travel-scene-card {
      min-height: 560px;
    }

    .travel-sun {
      right: 44px;
      width: 84px;
      height: 84px;
    }

    .travel-sun-rays {
      right: 18px;
      width: 134px;
      height: 134px;
    }

    .travel-rainbow {
      right: -12px;
      width: 172px;
      height: 90px;
    }

    .travel-moon {
      right: 48px;
      width: 80px;
      height: 80px;
    }

    .travel-resort-row {
      transform: translateX(-50%) scale(0.82);
    }

    .travel-sailboat {
      left: 50%;
      transform: scale(0.82);
    }

    .travel-scene-top {
      display: none;
    }

    .travel-curtain-toggle {
      top: 98px;
      right: 12px;
      width: 78px;
      height: 166px;
    }

    .travel-pull-cord {
      height: 126px;
      transform: scale(0.86);
    }

    .travel-pull-label {
      top: 184px;
      left: auto;
      right: 42px;
      min-width: 82px;
      border-radius: 14px 14px 4px 14px;
      text-align: right;
    }

    .travel-pull-label::before {
      left: auto;
      right: -8px;
      border-left: 0;
      border-bottom: 0;
      border-right: 1px solid rgba(251, 191, 36, 0.30);
      border-top: 1px solid rgba(251, 191, 36, 0.30);
    }

    .travel-scene-caption {
      left: 18px;
      right: 18px;
      bottom: 16px;
    }

    .travel-scene-depth {
      left: 20px;
      right: 20px;
      bottom: 18px;
    }

    .travel-mini-pill,
    .travel-scene-badge {
      width: 100%;
      max-width: none;
    }

    .travel-room-media {
      height: 210px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .travel-home::before,
    .travel-home::after,
    .travel-eyebrow-dot,
    .travel-sun,
    .travel-cloud,
    .travel-palm::before,
    .travel-palm::after,
    .travel-palm-frond,
    .travel-wave,
    .travel-dolphin,
    .travel-splash,
    .travel-star,
    .travel-shooting-star,
    .travel-sailboat,
    .travel-water-reflection,
    .travel-sun-rays,
    .travel-pull-cord {
      animation: none !important;
    }

    .travel-button,
    .travel-room-media img {
      transition: none;
    }
  }
</style>

<main class="travel-home" id="travel-home" data-theme="day">
  <div class="travel-shell">
    <section class="travel-hero">
      <div class="travel-panel">
        <div class="travel-eyebrow">
          <span class="travel-eyebrow-dot"></span>
          Bento Resort
        </div>

        <h1 class="travel-title">
          Bento Resort
        </h1>

        <div class="travel-actions">
          <a class="travel-button travel-button--primary" href="#travel-search">Tìm phòng ngay</a>
          <a class="travel-button travel-button--secondary" href="/booking/multi">Mở đặt phòng online</a>
          <button class="travel-button travel-button--install" type="button" id="travel-install-app">Cài app Bento</button>
          <% if (roleMenu) { %>
            <a class="travel-button travel-button--secondary" href="<%= roleMenu.href %>"><%= roleMenu.label %></a>
          <% } %>
        </div>

        <div class="travel-kpi-row">
          <article class="travel-kpi">
            <strong><%= featuredRooms.length %></strong>
            <span>Phòng nổi bật</span>
          </article>
          <article class="travel-kpi">
            <strong><%= hotels.length %></strong>
            <span>Khách sạn nội bộ</span>
          </article>
          <article class="travel-kpi">
            <strong><%= cities.length %></strong>
            <span>Điểm đến</span>
          </article>
          <article class="travel-kpi">
            <strong><%= roomTypes.length %></strong>
            <span>Dòng phòng</span>
          </article>
        </div>

        <section class="travel-search-card" id="travel-search">
          <form action="/booking/multi" method="get">
            <div class="travel-field">
              <label for="hotel_city">Thành phố</label>
              <select id="hotel_city" name="hotel_city">
                <option value="">Tất cả điểm đến</option>
                <% cities.forEach((city) => { %>
                  <option value="<%= city %>"><%= city %></option>
                <% }) %>
              </select>
            </div>

            <div class="travel-field">
              <label for="loai_phong">Loại phòng</label>
              <select id="loai_phong" name="loai_phong">
                <option value="">Chọn loại phòng</option>
                <% roomTypes.forEach((type) => { %>
                  <option value="<%= type %>"><%= type %></option>
                <% }) %>
              </select>
            </div>

            <div class="travel-field">
              <label for="ngay_nhan">Ngày nhận</label>
              <input id="ngay_nhan" type="date" name="ngay_nhan" />
            </div>

            <div class="travel-field">
              <label for="ngay_tra">Ngày trả</label>
              <input id="ngay_tra" type="date" name="ngay_tra" />
            </div>

            <div class="travel-field">
              <label for="so_khach">Số khách</label>
              <input id="so_khach" type="number" min="1" max="12" step="1" name="so_khach" placeholder="2 khách" />
            </div>

            <div class="travel-field">
              <label for="view_phong">View yêu thích</label>
              <select id="view_phong" name="view_phong">
                <option value="">Không giới hạn</option>
                <% viewTypes.forEach((view) => { %>
                  <option value="<%= view %>"><%= view %></option>
                <% }) %>
              </select>
            </div>

            <div class="travel-field travel-field--wide">
              <label for="loai_giuong">Kiểu giường</label>
              <select id="loai_giuong" name="loai_giuong">
                <option value="">Chọn kiểu giường</option>
                <% bedTypes.forEach((bed) => { %>
                  <option value="<%= bed %>"><%= bed %></option>
                <% }) %>
              </select>
            </div>

            <div class="travel-search-actions">
              <button class="travel-button travel-button--primary" type="submit">Khám phá phòng phù hợp</button>
              <a class="travel-button travel-button--secondary" href="/ai/concierge">Nhờ AI gợi ý chuyến đi</a>
            </div>
          </form>
          <p class="travel-search-note">
            Bộ lọc chỉ giữ thông tin cần thiết: điểm đến, ngày ở, số khách, loại phòng, view và kiểu giường.
          </p>
        </section>
      </div>

      <aside class="travel-scene-card" aria-label="Minh họa cảnh quan nghỉ dưỡng">
        <div class="travel-scene-3d" data-resort-3d>
          <canvas aria-label="Mô phỏng 3D Bento Resort ven biển"></canvas>
          <div class="travel-scene-loading" data-resort-3d-loading>Đang dựng Bento Resort 3D...</div>
        </div>
        <div class="travel-curtain" aria-hidden="true">
          <span class="travel-curtain-valance"></span>
        </div>
        <button class="travel-curtain-toggle" type="button" id="travel-theme-toggle" aria-pressed="false" title="Kéo rèm xuống để mở ban đêm">
          <span class="travel-pull-cord" aria-hidden="true">
            <span class="travel-pull-knot"></span>
            <span class="travel-pull-handle"></span>
          </span>
          <span class="travel-pull-label" data-theme-label>Kéo xuống đêm</span>
        </button>
        <div class="travel-scene-top">
          <div class="travel-scene-badge">
            <strong>3D Resort View</strong>
            <span>Biển, hồ bơi và khối phòng chuyển động theo thời gian thực.</span>
          </div>
          <div class="travel-scene-badge">
            <strong>Day / Night</strong>
            <span>Kéo rèm để đổi ánh sáng nghỉ dưỡng ban ngày và ban đêm.</span>
          </div>
        </div>
        <div class="travel-scene-depth" aria-hidden="true">
          <div class="travel-scene-depth__title">Bento Resort cinematic 3D</div>
          <div class="travel-scene-depth__chips">
            <span>Ocean motion</span>
            <span>Pool deck</span>
            <span>Resort blocks</span>
            <span>Palm breeze</span>
          </div>
        </div>
      </aside>
    </section>

    <section class="travel-section">
      <div class="travel-section-head">
        <div>
          <h2>Điểm đến nổi bật</h2>
          <p>Các thành phố đang có khách sạn trong hệ thống, giúp khách bắt đầu tìm phòng theo khu vực.</p>
        </div>
      </div>

      <div class="travel-city-grid">
        <% accentCities.forEach((city, index) => { %>
          <a class="travel-city-card" href="/booking/multi?hotel_city=<%= encodeURIComponent(city) %>">
            <strong><%= city %></strong>
            <span>Chọn phòng tại <%= city %>, sau đó đặt nhiều phòng và dịch vụ đi kèm nếu cần.</span>
          </a>
        <% }) %>
      </div>
    </section>

    <section class="travel-section">
      <div class="travel-section-head">
        <div>
          <h2>Phòng nổi bật đang mời gọi</h2>
          <p>Ưu tiên các phòng đang trống, có giá rõ và đủ thông tin sức chứa để khách quyết định nhanh.</p>
        </div>
        <a class="travel-link" href="/booking/multi">Xem tất cả phòng</a>
      </div>

      <div class="travel-room-grid">
        <% featuredRooms.slice(0, 6).forEach((room) => { %>
          <article class="travel-room-card">
            <div class="travel-room-media">
              <img src="<%= room.imageUrl %>" alt="Phòng <%= room.soPhong %> - <%= room.loaiPhong %>" loading="lazy" onerror="this.onerror=null;this.src='/uploads/phong/1.png';" />
              <div class="travel-room-overlay">
                <span class="travel-room-badge"><%= room.khachSan %></span>
                <span class="travel-room-price"><%= Number(room.gia || 0).toLocaleString("vi-VN") %> đ / đêm</span>
              </div>
            </div>
            <div class="travel-room-body">
              <h3><%= room.loaiPhong %></h3>
              <div class="travel-room-meta">
                Phòng <%= room.soPhong %> · <%= room.tinhThanh %> · tối đa <%= room.soKhachToiDa %> khách
              </div>
              <div class="travel-room-pills">
                <% if (room.loaiGiuong) { %><span class="travel-room-pill"><%= room.loaiGiuong %></span><% } %>
                <% if (room.viewPhong) { %><span class="travel-room-pill">View <%= room.viewPhong %></span><% } %>
                <span class="travel-room-pill">Resort ready</span>
              </div>
              <div class="travel-room-actions">
                <a class="travel-button travel-button--primary" href="/booking/rooms/<%= room.id %>/detail?hotel_city=<%= encodeURIComponent(room.tinhThanh || "") %>&so_khach=<%= encodeURIComponent(room.soKhachToiDa || 1) %>">Xem chi tiết</a>
                <a class="travel-room-link" href="/booking/multi?hotel_city=<%= encodeURIComponent(room.tinhThanh) %>">Xem cùng khu vực</a>
              </div>
            </div>
          </article>
        <% }) %>
      </div>
    </section>

    <section class="travel-section">
      <div class="travel-section-head">
        <div>
          <h2>Về Bento Resort</h2>
          <p>Thông tin ngắn gọn về không gian nghỉ dưỡng, tiện ích và lý do nên đặt trực tiếp.</p>
        </div>
      </div>

      <div class="travel-info-grid">
        <article class="travel-info-card">
          <h3>Không gian nghỉ dưỡng sát biển, đủ sang trọng và đủ dễ chịu</h3>
          <p>
            Bento Resort được định hình như một điểm đến nghỉ dưỡng hiện đại: gần biển, tiện đi lại, thiết kế sáng thoáng
            và đủ dịch vụ để khách có thể ở trọn kỳ nghỉ mà không thấy thiếu trải nghiệm.
          </p>
          <p>
            Khi đặt trực tiếp trên website, khách xem được phòng nổi bật, ưu đãi hiện hành và các lựa chọn dịch vụ đi kèm
            trước khi chuyển sang bước xác nhận.
          </p>
          <ul class="travel-list">
            <li>Giá trực tiếp tốt hơn các kênh OTA trong nhiều thời điểm.</li>
            <li>Ưu tiên nhận phòng sớm hoặc trả phòng trễ khi điều kiện cho phép.</li>
            <li>Dễ nối sang spa, nhà hàng, dịch vụ sân bay và mobile hub.</li>
          </ul>
        </article>

        <article class="travel-info-card">
          <h3>Tiện ích & dịch vụ được khách quan tâm nhiều</h3>
          <div class="travel-amenities-grid">
            <% amenities.forEach((item) => { %>
              <div class="travel-amenity-item">
                <span class="travel-amenity-dot"></span>
                <span><%= item %></span>
              </div>
            <% }) %>
          </div>
