    min-height: 160px;
    background:
      radial-gradient(circle at 82% 16%, rgba(251, 191, 36, 0.22), transparent 20%),
      linear-gradient(180deg, rgba(255,255,255,0.86), rgba(255,255,255,0.66));
  }

  .travel-city-card::before {
    content: "";
    position: absolute;
    inset: auto auto 20px 18px;
    width: 82px;
    height: 82px;
    border-radius: 999px 999px 999px 0;
    background: linear-gradient(135deg, rgba(56,189,248,0.24), rgba(20,184,166,0.14));
    transform: rotate(20deg);
  }

  .travel-city-card strong {
    display: block;
    position: relative;
    z-index: 1;
    font-size: 20px;
    letter-spacing: -0.04em;
  }

  .travel-city-card span {
    display: block;
    position: relative;
    z-index: 1;
    margin-top: 8px;
    color: var(--travel-muted);
    font-size: 13px;
    line-height: 1.6;
  }

  .travel-room-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .travel-room-card {
    overflow: hidden;
    border-radius: 30px;
    background: var(--travel-card-strong);
  }

  .travel-room-media {
    position: relative;
    height: 224px;
    overflow: hidden;
    background: linear-gradient(180deg, rgba(224,247,255,0.16), rgba(23,177,202,0.18));
  }

  .travel-room-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease;
  }

  .travel-room-card:hover .travel-room-media img {
    transform: scale(1.06);
  }

  .travel-room-overlay {
    position: absolute;
    inset: auto 16px 16px 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }

  .travel-room-badge,
  .travel-room-price {
    border-radius: 999px;
    padding: 8px 12px;
    background: rgba(255, 255, 255, 0.84);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(14, 73, 118, 0.10);
    font-size: 12px;
    font-weight: 900;
  }

  .travel-room-price {
    color: #0f766e;
  }

  .travel-room-body {
    padding: 18px;
  }

  .travel-room-body h3 {
    margin: 0;
    font-size: 24px;
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .travel-room-meta {
    margin-top: 8px;
    color: var(--travel-muted);
    font-size: 14px;
    line-height: 1.7;
  }

  .travel-room-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
  }

  .travel-room-pill {
    padding: 7px 10px;
    border-radius: 999px;
    background: rgba(20, 184, 166, 0.09);
    border: 1px solid rgba(20, 184, 166, 0.14);
    color: #0f766e;
    font-size: 12px;
    font-weight: 800;
  }

  .travel-room-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 18px;
  }

  .travel-room-link {
    color: #0284c7;
    font-size: 13px;
    font-weight: 900;
  }

  .travel-story-grid,
  .travel-promise-grid,
  .travel-testimonial-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .travel-story-card,
  .travel-promise-card,
  .travel-testimonial-card {
    border-radius: 28px;
    padding: 22px;
  }

  .travel-story-card {
    background:
      radial-gradient(circle at top right, rgba(125, 211, 252, 0.24), transparent 24%),
      linear-gradient(180deg, rgba(255,255,255,0.86), rgba(255,255,255,0.66));
  }

  .travel-story-card strong,
  .travel-promise-card strong {
    display: block;
    font-size: 21px;
    line-height: 1.1;
    letter-spacing: -0.04em;
  }

  .travel-story-card p,
  .travel-promise-card p {
    margin: 10px 0 0;
    color: var(--travel-muted);
    font-size: 14px;
    line-height: 1.7;
  }

  .travel-promise-card {
    background:
      radial-gradient(circle at top left, rgba(251, 113, 133, 0.16), transparent 22%),
      linear-gradient(180deg, rgba(255,255,255,0.86), rgba(255,255,255,0.68));
  }

  .travel-testimonial-card {
    background:
      radial-gradient(circle at top right, rgba(253, 186, 116, 0.18), transparent 24%),
      linear-gradient(180deg, rgba(255,255,255,0.88), rgba(255,255,255,0.68));
  }

  .travel-testimonial-stars {
    color: #f59e0b;
    font-size: 18px;
    letter-spacing: 0.16em;
  }

  .travel-testimonial-quote {
    margin: 14px 0 0;
    color: var(--travel-ink);
    font-size: 15px;
    line-height: 1.8;
  }

  .travel-testimonial-meta {
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px solid rgba(14, 73, 118, 0.08);
  }

  .travel-testimonial-meta strong {
    display: block;
    font-size: 17px;
    line-height: 1.2;
  }

  .travel-testimonial-meta span {
    display: block;
    margin-top: 6px;
    color: var(--travel-muted);
    font-size: 13px;
  }

  .travel-promise-icon {
    width: 52px;
    height: 52px;
    border-radius: 18px;
    display: grid;
    place-items: center;
    margin-bottom: 16px;
    color: #ffffff;
    font-size: 24px;
    background: linear-gradient(135deg, #0ea5e9, #14b8a6, #fb7185);
    box-shadow: 0 18px 34px rgba(14, 165, 233, 0.20);
  }

  .travel-hotel-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
  }

  .travel-info-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.95fr);
    gap: 16px;
  }

  .travel-info-card,
  .travel-contact-card {
    border-radius: 28px;
    padding: 22px;
  }

  .travel-info-card h3,
  .travel-contact-card h3 {
    margin: 0 0 10px;
    font-size: 22px;
    line-height: 1.05;
    letter-spacing: -0.05em;
  }

  .travel-info-card p,
  .travel-contact-card p {
    margin: 0 0 10px;
    color: var(--travel-muted);
    font-size: 14px;
    line-height: 1.8;
  }

  .travel-list {
    margin: 10px 0 0;
    padding-left: 18px;
    color: var(--travel-ink);
    font-size: 14px;
    line-height: 1.8;
  }

  .travel-amenities-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    margin-top: 12px;
  }

  .travel-amenity-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: var(--travel-ink);
    font-size: 14px;
    line-height: 1.6;
  }

  .travel-amenity-dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    margin-top: 8px;
    background: linear-gradient(135deg, #0ea5e9, #14b8a6);
    box-shadow: 0 0 0 6px rgba(20, 184, 166, 0.10);
  }

  .travel-promo-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 14px;
    border-radius: 22px;
    padding: 16px 18px;
    color: #fff7ed;
    background: linear-gradient(135deg, #f97316, #fb7185);
    box-shadow: 0 20px 40px rgba(251, 113, 133, 0.18);
  }

  .travel-promo-banner strong {
    display: block;
    font-size: 18px;
  }

  .travel-promo-banner span {
    display: block;
    margin-top: 6px;
    font-size: 13px;
    line-height: 1.7;
    color: rgba(255, 247, 237, 0.88);
  }

  .travel-promo-chip {
    padding: 8px 12px;
    border-radius: 999px;
    border: 1px solid rgba(255, 247, 237, 0.55);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .travel-hotel-card {
    border-radius: 26px;
    padding: 20px;
  }

  .travel-hotel-card strong {
    display: block;
    font-size: 18px;
    line-height: 1.2;
  }

  .travel-hotel-card span {
    display: block;
    margin-top: 8px;
    color: var(--travel-muted);
    font-size: 13px;
  }

  .travel-cta-band {
    position: relative;
    overflow: hidden;
    border-radius: 36px;
    padding: 28px;
    border: 1px solid rgba(14, 73, 118, 0.10);
    box-shadow: var(--travel-shadow);
    background:
      radial-gradient(circle at 10% 18%, rgba(125, 211, 252, 0.36), transparent 20%),
      radial-gradient(circle at 86% 22%, rgba(251, 191, 36, 0.24), transparent 18%),
      linear-gradient(135deg, rgba(255,255,255,0.84), rgba(255,255,255,0.68));
  }

  .travel-cta-band::before {
    content: "";
    position: absolute;
    inset: auto -20px -40px auto;
    width: 240px;
    height: 120px;
    border-radius: 50%;
    background: rgba(20, 184, 166, 0.12);
    transform: rotate(-10deg);
  }

  .travel-cta-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 18px;
    align-items: center;
  }

  .travel-cta-band h2 {
    margin: 0;
    font-size: clamp(28px, 4vw, 42px);
    line-height: 0.98;
    letter-spacing: -0.06em;
  }

  .travel-cta-band p {
    margin: 10px 0 0;
    color: var(--travel-muted);
    font-size: 14px;
    line-height: 1.8;
    max-width: 620px;
  }

  .travel-cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: flex-end;
  }

  @keyframes travel-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(0.78); opacity: 0.68; }
  }

  @keyframes travel-float-orb {
    from { transform: translate3d(0, 0, 0) rotate(0deg); }
    to { transform: translate3d(28px, 20px, 0) rotate(12deg); }
  }

  @keyframes travel-sun-breathe {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.06); }
  }

  @keyframes travel-rays-spin {
    from { transform: rotate(0deg) scale(1); }
    to { transform: rotate(360deg) scale(1); }
  }

  @keyframes travel-cloud {
    0% { transform: translateX(0); }
    50% { transform: translateX(24px); }
    100% { transform: translateX(0); }
  }

  @keyframes travel-palm-wave {
    0%, 100% { transform: rotate(12deg); }
    50% { transform: rotate(24deg); }
  }

  @keyframes travel-wave {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(0, -10px, 0); }
  }

  @keyframes travel-dolphin-jump {
    0%, 100% { transform: translate3d(0, 0, 0) rotate(0deg); }
    30% { transform: translate3d(14px, -26px, 0) rotate(-10deg); }
    52% { transform: translate3d(28px, 4px, 0) rotate(4deg); }
  }

  @keyframes travel-splash {
    0%, 100% { opacity: 0.14; transform: scaleX(0.88); }
    40% { opacity: 0.72; transform: scaleX(1); }
  }

  @keyframes travel-star-twinkle {
    0%, 100% { opacity: 0.42; transform: scale(0.86); }
    50% { opacity: 1; transform: scale(1.2); }
  }

  @keyframes travel-shooting-star {
    0%, 70%, 100% { opacity: 0; transform: rotate(-28deg) translateX(-90px); }
    78% { opacity: 1; }
    92% { opacity: 0; transform: rotate(-28deg) translateX(120px); }
  }

  @keyframes travel-reflection {
    0%, 100% { transform: translateX(-50%) scaleX(0.96); opacity: 0.46; }
    50% { transform: translateX(-50%) scaleX(1.08); opacity: 0.62; }
  }

  @keyframes travel-sailboat {
    0%, 100% { transform: translate3d(0, 0, 0) rotate(-1deg); }
    50% { transform: translate3d(18px, -8px, 0) rotate(2deg); }
  }

  @keyframes travel-cord-sway {
    0%, 100% { transform: rotate(0deg); }
    26% { transform: rotate(7deg); }
    56% { transform: rotate(-5deg); }
    78% { transform: rotate(3deg); }
  }

  @media (max-width: 1120px) {
    .travel-hero,
    .travel-city-grid,
    .travel-hotel-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .travel-room-grid,
    .travel-story-grid,
    .travel-promise-grid,
    .travel-testimonial-grid,
    .travel-info-grid {
      grid-template-columns: 1fr 1fr;
    }

    .travel-panel,
    .travel-scene-card {
      min-height: auto;
    }
  }

  @media (max-width: 760px) {
    .travel-shell {
      width: min(100vw - 18px, 100%);
      padding: 18px 0 52px;
    }

    .travel-hero,
    .travel-kpi-row,
    .travel-city-grid,
    .travel-room-grid,
    .travel-story-grid,
    .travel-promise-grid,
    .travel-testimonial-grid,
    .travel-hotel-grid,
    .travel-info-grid,
    .travel-amenities-grid,
    .travel-cta-grid,
    .travel-search-card form {
      grid-template-columns: 1fr;
    }

    .travel-panel,
    .travel-scene-card,
    .travel-cta-band {
      border-radius: 28px;
      padding: 22px;
    }

    .travel-title {
      font-size: 42px;
    }

    .travel-search-actions,
    .travel-cta-actions,
    .travel-room-actions,
    .travel-section-head,
    .travel-scene-caption {
      display: flex;
      flex-direction: column;
      align-items: stretch;
    }

    .travel-scene-card {
      min-height: 560px;
    }

    .travel-sun {
      right: 44px;
      width: 84px;
      height: 84px;
    }

    .travel-sun-rays {
      right: 18px;
      width: 134px;
      height: 134px;
    }

    .travel-rainbow {
      right: -12px;
      width: 172px;
      height: 90px;
    }

    .travel-moon {
      right: 48px;
      width: 80px;
      height: 80px;
    }

    .travel-resort-row {
      transform: translateX(-50%) scale(0.82);
    }

    .travel-sailboat {
      left: 50%;
      transform: scale(0.82);
    }

    .travel-scene-top {
      inset: 78px 18px auto 18px;
    }

    .travel-curtain-toggle {
      top: 16px;
      right: 12px;
      width: 78px;
      height: 166px;
    }

    .travel-pull-cord {
      height: 126px;
      transform: scale(0.86);
    }

    .travel-pull-label {
      top: 104px;
      left: auto;
      right: 42px;
      min-width: 82px;
      border-radius: 14px 14px 4px 14px;
      text-align: right;
    }

    .travel-pull-label::before {
      left: auto;
      right: -8px;
      border-left: 0;
      border-bottom: 0;
      border-right: 1px solid rgba(251, 191, 36, 0.30);
      border-top: 1px solid rgba(251, 191, 36, 0.30);
    }

    .travel-scene-caption {
      left: 18px;
      right: 18px;
      bottom: 16px;
    }

    .travel-mini-pill,
    .travel-scene-badge {
      width: 100%;
      max-width: none;
    }

    .travel-room-media {
      height: 210px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .travel-home::before,
    .travel-home::after,
    .travel-eyebrow-dot,
    .travel-sun,
    .travel-cloud,
    .travel-palm::before,
    .travel-palm::after,
    .travel-palm-frond,
    .travel-wave,
    .travel-dolphin,
    .travel-splash,
    .travel-star,
    .travel-shooting-star,
    .travel-sailboat,
    .travel-water-reflection,
    .travel-sun-rays,
    .travel-pull-cord {
      animation: none !important;
    }

    .travel-button,
    .travel-room-media img {
      transition: none;
    }
  }
</style>

<main class="travel-home" id="travel-home" data-theme="day">
  <div class="travel-shell">
    <section class="travel-hero">
      <div class="travel-panel">
        <div class="travel-eyebrow">
          <span class="travel-eyebrow-dot"></span>
          Resort travel mood
        </div>

        <h1 class="travel-title">
          Một trang chủ <span>đầy nắng, gió, sóng</span> cho khách vừa nhìn đã muốn đi nghỉ.
        </h1>

        <p class="travel-description">
          Bento Resort được làm lại theo tinh thần nghỉ dưỡng hiện đại: sạch, tươi, dễ dùng, đậm chất du lịch
          và vẫn đủ chuyên nghiệp để khách tìm phòng, xem điểm đến và chuyển vào luồng đặt phòng chỉ trong vài nhịp chạm.
        </p>

        <div class="travel-highlights">
          <span class="travel-chip">Biển xanh • Núi xa • Mây nhẹ</span>
          <span class="travel-chip">Fresh booking experience</span>
          <span class="travel-chip">PWA mobile-ready</span>
          <span class="travel-chip">Tông màu nghỉ dưỡng vui tươi</span>
        </div>

        <div class="travel-actions">
          <a class="travel-button travel-button--primary" href="#travel-search">Tìm phòng ngay</a>
          <a class="travel-button travel-button--secondary" href="/booking/search">Mở trang booking đầy đủ</a>
          <button class="travel-button travel-button--install" type="button" id="travel-install-app">Cài app Bento</button>
          <% if (roleMenu) { %>
            <a class="travel-button travel-button--secondary" href="<%= roleMenu.href %>"><%= roleMenu.label %></a>
          <% } %>
        </div>

        <div class="travel-kpi-row">
          <article class="travel-kpi">
            <strong><%= featuredRooms.length %></strong>
            <span>Phòng nổi bật</span>
          </article>
          <article class="travel-kpi">
            <strong><%= hotels.length %></strong>
            <span>Khách sạn nội bộ</span>
          </article>
          <article class="travel-kpi">
            <strong><%= cities.length %></strong>
            <span>Điểm đến</span>
          </article>
          <article class="travel-kpi">
            <strong><%= roomTypes.length %></strong>
            <span>Dòng phòng</span>
          </article>
        </div>

        <section class="travel-search-card" id="travel-search">
          <form action="/booking/search" method="get">
            <div class="travel-field">
              <label for="hotel_city">Thành phố</label>
              <select id="hotel_city" name="hotel_city">
                <option value="">Tất cả điểm đến</option>
                <% cities.forEach((city) => { %>
                  <option value="<%= city %>"><%= city %></option>
                <% }) %>
              </select>
            </div>

            <div class="travel-field">
              <label for="loai_phong">Loại phòng</label>
              <select id="loai_phong" name="loai_phong">
                <option value="">Chọn loại phòng</option>
                <% roomTypes.forEach((type) => { %>
                  <option value="<%= type %>"><%= type %></option>
                <% }) %>
              </select>
            </div>

            <div class="travel-field">
              <label for="ngay_nhan">Ngày nhận</label>
              <input id="ngay_nhan" type="date" name="ngay_nhan" />
            </div>

            <div class="travel-field">
              <label for="ngay_tra">Ngày trả</label>
              <input id="ngay_tra" type="date" name="ngay_tra" />
            </div>

            <div class="travel-field">
              <label for="so_khach">Số khách</label>
              <input id="so_khach" type="number" min="1" max="12" step="1" name="so_khach" placeholder="2 khách" />
            </div>

            <div class="travel-field">
              <label for="view_phong">View yêu thích</label>
              <select id="view_phong" name="view_phong">
                <option value="">Không giới hạn</option>
                <% viewTypes.forEach((view) => { %>
                  <option value="<%= view %>"><%= view %></option>
                <% }) %>
              </select>
            </div>

            <div class="travel-field travel-field--wide">
              <label for="loai_giuong">Kiểu giường</label>
              <select id="loai_giuong" name="loai_giuong">
                <option value="">Chọn kiểu giường</option>
                <% bedTypes.forEach((bed) => { %>
                  <option value="<%= bed %>"><%= bed %></option>
                <% }) %>
              </select>
            </div>

            <div class="travel-search-actions">
              <button class="travel-button travel-button--primary" type="submit">Khám phá phòng phù hợp</button>
              <a class="travel-button travel-button--secondary" href="/ai/concierge">Nhờ AI gợi ý chuyến đi</a>
            </div>
          </form>
          <p class="travel-search-note">
            Bộ lọc gọn gàng để khách bắt đầu ngay từ trang chủ, rồi đi tiếp sang trang booking chi tiết khi cần.
          </p>
        </section>
      </div>

      <aside class="travel-scene-card" aria-label="Minh họa cảnh quan nghỉ dưỡng">
        <div class="travel-curtain" aria-hidden="true">
          <span class="travel-curtain-valance"></span>
        </div>
        <button class="travel-curtain-toggle" type="button" id="travel-theme-toggle" aria-pressed="false" title="Kéo rèm xuống để mở ban đêm">
          <span class="travel-pull-cord" aria-hidden="true">
            <span class="travel-pull-knot"></span>
            <span class="travel-pull-handle"></span>
          </span>
          <span class="travel-pull-label" data-theme-label>Kéo xuống đêm</span>
        </button>
        <div class="travel-scene-top">
          <div class="travel-scene-badge">
            <strong>Visual du lịch mới</strong>
            <span>Tông biển trời, màu trái cây, chuyển động mềm và cảm giác kỳ nghỉ tươi sáng.</span>
          </div>
          <div class="travel-scene-badge">
            <strong>Fresh + Professional</strong>
            <span>Đủ xinh để cuốn hút, đủ sạch để khách tin tưởng đặt phòng.</span>
