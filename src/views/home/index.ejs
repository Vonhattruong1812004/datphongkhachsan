  }

  @keyframes galaxy-comet-horizontal-reverse {
    0%, 8% { transform: translate3d(58vw, 0, 0); opacity: 0; }
    14%, 74% { opacity: 0.9; }
    92%, 100% { transform: translate3d(-32vw, 0, 0); opacity: 0; }
  }

  @keyframes galaxy-comet-fall {
    0%, 6% { transform: translate3d(0, -44vh, 0); opacity: 0; }
    12%, 84% { opacity: 0.9; }
    96%, 100% { transform: translate3d(0, 115vh, 0); opacity: 0; }
  }

  @keyframes galaxy-comet-rise {
    0%, 6% { transform: translate3d(0, 115vh, 0); opacity: 0; }
    12%, 84% { opacity: 0.9; }
    96%, 100% { transform: translate3d(0, -44vh, 0); opacity: 0; }
  }

  @keyframes galaxy-spin-slow {
    to { transform: rotate(360deg); }
  }

  @keyframes galaxy-core-breathe {
    0%, 100% { transform: translate(-50%, -50%) scale(1); }
    50% { transform: translate(-50%, -50%) scale(1.06); }
  }

  @keyframes galaxy-sun-pulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1); filter: brightness(1); }
    50% { transform: translate(-50%, -50%) scale(1.08); filter: brightness(1.12); }
  }

  @keyframes galaxy-sun-rays {
    to { transform: translate(-50%, -50%) rotate(360deg); }
  }

  @keyframes galaxy-belt-drift {
    to { transform: translate(-50%, -50%) rotate(344deg); }
  }

  @keyframes galaxy-orbit-spin {
    to { transform: translate(-50%, -50%) rotate(360deg); }
  }

  @keyframes galaxy-solar-orbit {
    to { transform: translate(-50%, -50%) rotate(348deg); }
  }

  @keyframes galaxy-moon-orbit {
    to { transform: translate(-50%, -50%) rotate(342deg); }
  }

  @keyframes galaxy-earth-center-drift {
    0%, 100% { transform: translate(-50%, -50%) scale(1); }
    50% { transform: translate(-50%, -51.5%) scale(1.025); }
  }

  @keyframes galaxy-float-small {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-16px); }
  }

  @keyframes galaxy-band-flow {
    from { transform: rotate(-17deg) translateX(-24px) scale(0.98); opacity: 0.42; }
    to { transform: rotate(-12deg) translateX(28px) scale(1.04); opacity: 0.62; }
  }

  @keyframes galaxy-twinkle {
    0%, 100% { opacity: 0.46; transform: scale(0.72); }
    50% { opacity: 1; transform: scale(1.14); }
  }

  @keyframes galaxy-cluster-pulse {
    0%, 100% { opacity: 0.5; transform: scale(0.96); }
    50% { opacity: 1; transform: scale(1.04); }
  }

  @keyframes galaxy-earth-drift {
    0%, 100% { transform: translateY(0) rotate(-4deg); }
    50% { transform: translateY(18px) rotate(6deg); }
  }

  @keyframes galaxy-ufo-hover {
    0%, 100% { transform: translate3d(0, 0, 0) rotate(-4deg); }
    50% { transform: translate3d(-18px, -14px, 0) rotate(5deg); }
  }

  @keyframes galaxy-ufo-beam {
    0%, 100% { opacity: 0.25; transform: scaleX(0.78); }
    50% { opacity: 0.7; transform: scaleX(1.08); }
  }

  @keyframes galaxy-satellite-float {
    0%, 100% { transform: rotate(-18deg) translateY(0); }
    50% { transform: rotate(-9deg) translateY(14px); }
  }

  @keyframes galaxy-astronaut-float {
    0%, 100% { transform: rotate(12deg) translate3d(0, 0, 0); }
    50% { transform: rotate(-8deg) translate3d(18px, -18px, 0); }
  }

  @media (max-width: 760px) {
    .galaxy-nebula {
      min-width: 320px;
      min-height: 220px;
    }

    .cosmic-orbit--three,
    .cosmic-orbit--four {
      transform: translate(-50%, -50%) scale(0.74);
    }

    .travel-scene-card {
      min-height: 520px;
    }

    .cosmic-earth {
      width: 138px;
      height: 138px;
    }

    .cosmic-core {
      width: 76px;
      height: 76px;
      left: 78%;
      top: 26%;
    }

    .solar-orbit--jupiter {
      width: 390px;
      height: 258px;
    }

    .solar-orbit--saturn {
      width: 480px;
      height: 318px;
    }

    .moon-orbit {
      width: 196px;
      height: 128px;
    }
  }

  /* Home performance pass: one static star field, four directional comets. */
  .system-galaxy-background {
    display: none;
  }

  .galaxy-background::before,
  .galaxy-background::after,
  .galaxy-deep-field,
  .galaxy-near-field,
  .galaxy-dust,
  .galaxy-lens-field,
  .galaxy-nebula,
  .galaxy-milkyway,
  .galaxy-star-cluster,
  .galaxy-constellation i {
    animation: none !important;
  }

  .galaxy-nebula {
    opacity: 0.26;
    filter: blur(42px);
  }

  .galaxy-background::before,
  .galaxy-background::after {
    transform: none !important;
  }

  .travel-scene-card::before,
  .travel-scene-card::after,
  .cosmic-asteroid-belt,
  .solar-light-ray,
  .cosmic-core,
  .solar-orbit,
  .moon-orbit,
  .cosmic-earth {
    animation: none !important;
  }

  .galaxy-comet {
    animation-duration: 14s;
    will-change: transform, opacity;
  }

  .galaxy-comet--one {
    top: 16%;
    left: -12%;
    animation-duration: 10.5s;
    animation-delay: -1s;
  }

  .galaxy-comet--two {
    top: 40%;
    left: 78%;
    animation-duration: 12s;
    animation-delay: -5.2s;
  }

  .galaxy-comet--three {
    top: -16%;
    left: 72%;
    animation-duration: 13.5s;
    animation-delay: -3s;
  }

  .galaxy-comet--five {
    top: auto;
    bottom: -16%;
    left: 24%;
    animation-duration: 14.5s;
    animation-delay: -7.4s;
  }

  /* Keep the hero illustration alive while the background star field stays static. */
  .cosmic-asteroid-belt {
    animation: galaxy-belt-drift 58s linear infinite !important;
  }

  .solar-light-ray {
    animation: galaxy-sun-rays 26s linear infinite !important;
  }

  .cosmic-core {
    animation: galaxy-sun-pulse 6.4s ease-in-out infinite !important;
  }

  .solar-orbit--mercury {
    animation: galaxy-solar-orbit 24s linear infinite -5s !important;
  }

  .solar-orbit--venus {
    animation: galaxy-solar-orbit 34s linear infinite reverse -12s !important;
  }

  .solar-orbit--mars {
    animation: galaxy-solar-orbit 44s linear infinite -19s !important;
  }

  .solar-orbit--jupiter {
    animation: galaxy-solar-orbit 66s linear infinite reverse -28s !important;
  }

  .solar-orbit--saturn {
    animation: galaxy-solar-orbit 82s linear infinite -43s !important;
  }

  .cosmic-earth {
    animation: galaxy-earth-center-drift 10s ease-in-out infinite !important;
  }

  .moon-orbit {
    animation: galaxy-moon-orbit 18s linear infinite !important;
  }

  .travel-room-badge {
    color: #102033;
    background: rgba(255, 255, 255, 0.92);
    border-color: rgba(15, 23, 42, 0.18);
    text-shadow: none;
  }

  .travel-room-price {
    color: #0f766e;
    background: rgba(255, 255, 255, 0.94);
  }

  @media (prefers-reduced-motion: reduce) {
    .galaxy-background::before,
    .galaxy-background::after,
    .galaxy-nebula,
    .galaxy-comet,
    .travel-scene-card::before,
    .travel-scene-card::after,
    .cosmic-core,
    .cosmic-orbit,
    .solar-orbit,
    .moon-orbit,
    .cosmic-planet,
    .cosmic-earth,
    .cosmic-ufo,
    .cosmic-ufo-beam,
    .cosmic-satellite-craft,
    .cosmic-astronaut,
    .galaxy-milkyway,
    .galaxy-constellation i,
    .galaxy-star-cluster {
      animation: none;
    }
  }
</style>

<main class="travel-home" id="travel-home" data-theme="day">
  <div class="galaxy-background" aria-hidden="true">
    <span class="galaxy-milkyway"></span>
    <span class="galaxy-deep-field"></span>
    <span class="galaxy-dust"></span>
    <span class="galaxy-near-field"></span>
    <span class="galaxy-lens-field"></span>
    <span class="galaxy-nebula galaxy-nebula--one"></span>
    <span class="galaxy-nebula galaxy-nebula--two"></span>
    <span class="galaxy-star-cluster galaxy-star-cluster--one"></span>
    <span class="galaxy-star-cluster galaxy-star-cluster--two"></span>
    <span class="galaxy-constellation"><i></i><i></i><i></i><i></i></span>
    <span class="galaxy-comet galaxy-comet--one"></span>
    <span class="galaxy-comet galaxy-comet--reverse galaxy-comet--two"></span>
    <span class="galaxy-comet galaxy-comet--fall galaxy-comet--three"></span>
    <span class="galaxy-comet galaxy-comet--fall galaxy-comet--rise galaxy-comet--five"></span>
  </div>
  <div class="travel-shell">
    <section class="travel-hero">
      <div class="travel-panel">
        <div class="travel-eyebrow">
          <span class="travel-eyebrow-dot"></span>
          Hệ thống đặt phòng
        </div>

        <h1 class="travel-title">
          Bento Resort
        </h1>

        <div class="travel-actions">
          <a class="travel-button travel-button--primary" href="#travel-search">Tìm phòng ngay</a>
          <a class="travel-button travel-button--secondary" href="/booking/multi">Mở đặt phòng online</a>
          <button class="travel-button travel-button--install" type="button" id="travel-install-app">Cài app Bento</button>
          <% if (roleMenu) { %>
            <a class="travel-button travel-button--secondary" href="<%= roleMenu.href %>"><%= roleMenu.label %></a>
          <% } %>
        </div>

        <section class="travel-search-card" id="travel-search">
          <form action="/booking/multi" method="get">
            <div class="travel-field">
              <label for="hotel_city">Thành phố</label>
              <select id="hotel_city" name="hotel_city">
                <option value="">Tất cả điểm đến</option>
                <% cities.forEach((city) => { %>
                  <option value="<%= city %>"><%= city %></option>
                <% }) %>
              </select>
            </div>

            <div class="travel-field">
              <label for="loai_phong">Loại phòng</label>
              <select id="loai_phong" name="loai_phong">
                <option value="">Chọn loại phòng</option>
                <% roomTypes.forEach((type) => { %>
                  <option value="<%= type %>"><%= type %></option>
                <% }) %>
              </select>
            </div>

            <div class="travel-field">
              <label for="ngay_nhan">Ngày nhận</label>
              <input id="ngay_nhan" type="date" name="ngay_nhan" />
            </div>

            <div class="travel-field">
              <label for="ngay_tra">Ngày trả</label>
              <input id="ngay_tra" type="date" name="ngay_tra" />
            </div>

            <div class="travel-field">
              <label for="so_khach">Số khách</label>
              <input id="so_khach" type="number" min="1" max="12" step="1" name="so_khach" placeholder="2 khách" />
            </div>

            <div class="travel-field">
              <label for="view_phong">View yêu thích</label>
              <select id="view_phong" name="view_phong">
                <option value="">Không giới hạn</option>
                <% viewTypes.forEach((view) => { %>
                  <option value="<%= view %>"><%= view %></option>
                <% }) %>
              </select>
            </div>

            <div class="travel-field travel-field--wide">
              <label for="loai_giuong">Kiểu giường</label>
              <select id="loai_giuong" name="loai_giuong">
                <option value="">Chọn kiểu giường</option>
                <% bedTypes.forEach((bed) => { %>
                  <option value="<%= bed %>"><%= bed %></option>
                <% }) %>
              </select>
            </div>

            <div class="travel-search-actions">
              <button class="travel-button travel-button--primary" type="submit">Khám phá phòng phù hợp</button>
              <a class="travel-button travel-button--secondary" href="/ai/concierge">Nhờ AI gợi ý chuyến đi</a>
            </div>
          </form>
          <p class="travel-search-note">
            Bộ lọc chỉ giữ thông tin cần thiết: điểm đến, ngày ở, số khách, loại phòng, view và kiểu giường.
          </p>
        </section>
      </div>

      <aside class="travel-scene-card" aria-label="Minh họa ngân hà Bento Resort">
        <div class="cosmic-scene" aria-hidden="true">
          <span class="cosmic-star-dust"></span>
          <span class="cosmic-depth-plane cosmic-depth-plane--one"></span>
          <span class="cosmic-depth-plane cosmic-depth-plane--two"></span>
          <span class="cosmic-depth-plane cosmic-depth-plane--three"></span>
          <span class="cosmic-asteroid-belt"></span>
          <span class="solar-light-ray"></span>
          <div class="cosmic-core"></div>
          <div class="solar-orbit solar-orbit--mercury"><span class="solar-planet solar-planet--mercury"></span></div>
          <div class="solar-orbit solar-orbit--venus"><span class="solar-planet solar-planet--venus"></span></div>
          <div class="solar-orbit solar-orbit--mars"><span class="solar-planet solar-planet--mars"></span></div>
          <div class="solar-orbit solar-orbit--jupiter"><span class="solar-planet solar-planet--jupiter"></span></div>
          <div class="solar-orbit solar-orbit--saturn"><span class="solar-planet solar-planet--saturn"></span></div>
          <div class="cosmic-earth" data-earth-3d>
            <canvas aria-label="Trái Đất 3D dùng texture vệ tinh"></canvas>
          </div>
          <div class="moon-orbit"><span class="cosmic-moon"></span></div>
          <span class="cosmic-asteroid cosmic-asteroid--one"></span>
          <span class="cosmic-asteroid cosmic-asteroid--two"></span>
          <span class="cosmic-asteroid cosmic-asteroid--three"></span>
          <span class="cosmic-asteroid cosmic-asteroid--four"></span>
          <span class="cosmic-asteroid cosmic-asteroid--five"></span>
          <span class="cosmic-asteroid cosmic-asteroid--six"></span>
        </div>
        <button class="travel-curtain-toggle" type="button" id="travel-theme-toggle" aria-pressed="false" title="Đổi chiều sâu ngân hà">
          <span class="travel-pull-label" data-theme-label>Đổi ngân hà</span>
        </button>
      </aside>
    </section>

    <section class="travel-section">
      <div class="travel-section-head">
        <div>
          <h2>Điểm đến nổi bật</h2>
          <p>Các thành phố đang có khách sạn trong hệ thống, giúp khách bắt đầu tìm phòng theo khu vực.</p>
        </div>
      </div>

      <div class="travel-city-grid">
        <% accentCities.forEach((city, index) => { %>
          <a class="travel-city-card" href="/booking/multi?hotel_city=<%= encodeURIComponent(city) %>">
            <strong><%= city %></strong>
            <span>Chọn phòng tại <%= city %>, sau đó đặt nhiều phòng và dịch vụ đi kèm nếu cần.</span>
          </a>
        <% }) %>
      </div>
    </section>

    <section class="travel-section">
      <div class="travel-section-head">
        <div>
          <h2>Phòng nổi bật đang mời gọi</h2>
          <p>Ưu tiên các phòng đang trống, có giá rõ và đủ thông tin sức chứa để khách quyết định nhanh.</p>
        </div>
        <a class="travel-link" href="/booking/multi">Xem tất cả phòng</a>
      </div>

      <div class="travel-room-grid">
        <% featuredRooms.slice(0, 6).forEach((room) => { %>
          <article class="travel-room-card">
            <div class="travel-room-media">
              <img src="<%= room.imageUrl %>" alt="Phòng <%= room.soPhong %> - <%= room.loaiPhong %>" loading="lazy" onerror="this.onerror=null;this.src='/uploads/phong/1.png';" />
              <div class="travel-room-overlay">
                <span class="travel-room-badge"><%= room.khachSan %></span>
                <span class="travel-room-price"><%= Number(room.gia || 0).toLocaleString("vi-VN") %> đ / đêm</span>
              </div>
            </div>
            <div class="travel-room-body">
              <h3><%= room.loaiPhong %></h3>
              <div class="travel-room-meta">
                Phòng <%= room.soPhong %> · <%= room.tinhThanh %> · tối đa <%= room.soKhachToiDa %> khách
              </div>
              <div class="travel-room-pills">
                <% if (room.loaiGiuong) { %><span class="travel-room-pill"><%= room.loaiGiuong %></span><% } %>
                <% if (room.viewPhong) { %><span class="travel-room-pill">View <%= room.viewPhong %></span><% } %>
                <span class="travel-room-pill">Resort ready</span>
              </div>
              <div class="travel-room-actions">
                <a class="travel-button travel-button--primary" href="/booking/rooms/<%= room.id %>/detail?hotel_city=<%= encodeURIComponent(room.tinhThanh || "") %>&so_khach=<%= encodeURIComponent(room.soKhachToiDa || 1) %>">Xem chi tiết</a>
                <a class="travel-room-link" href="/booking/multi?hotel_city=<%= encodeURIComponent(room.tinhThanh) %>">Xem cùng khu vực</a>
              </div>
            </div>
          </article>
        <% }) %>
      </div>
    </section>

    <section class="travel-section">
      <div class="travel-section-head">
        <div>
          <h2>Về Bento Resort</h2>
          <p>Thông tin ngắn gọn về không gian nghỉ dưỡng, tiện ích và lý do nên đặt trực tiếp.</p>
        </div>
      </div>

      <div class="travel-info-grid">
        <article class="travel-info-card">
          <h3>Không gian nghỉ dưỡng sát biển, đủ sang trọng và đủ dễ chịu</h3>
          <p>
            Bento Resort được định hình như một điểm đến nghỉ dưỡng hiện đại: gần biển, tiện đi lại, thiết kế sáng thoáng
            và đủ dịch vụ để khách có thể ở trọn kỳ nghỉ mà không thấy thiếu trải nghiệm.
          </p>
          <p>
            Khi đặt trực tiếp trên website, khách xem được phòng nổi bật, ưu đãi hiện hành và các lựa chọn dịch vụ đi kèm
            trước khi chuyển sang bước xác nhận.
          </p>
          <ul class="travel-list">
            <li>Giá trực tiếp tốt hơn các kênh OTA trong nhiều thời điểm.</li>
            <li>Ưu tiên nhận phòng sớm hoặc trả phòng trễ khi điều kiện cho phép.</li>
            <li>Dễ nối sang spa, nhà hàng, dịch vụ sân bay và mobile hub.</li>
          </ul>
        </article>

        <article class="travel-info-card">
          <h3>Tiện ích & dịch vụ được khách quan tâm nhiều</h3>
          <div class="travel-amenities-grid">
            <% amenities.forEach((item) => { %>
              <div class="travel-amenity-item">
                <span class="travel-amenity-dot"></span>
                <span><%= item %></span>
              </div>
            <% }) %>
          </div>
        </article>
      </div>
    </section>

    <section class="travel-section">
      <div class="travel-info-card">
        <h3>Ưu đãi đang chạy trên kênh trực tiếp</h3>
        <p>Ưu đãi nổi bật giúp khách có thêm lý do đặt trực tiếp trên website thay vì đi vòng qua kênh khác.</p>
        <div class="travel-promo-banner">
          <div>
            <strong>Combo Stay & Dine giảm tới 30%</strong>
            <span>Đặt từ 2 đêm trở lên: ưu đãi bữa tối set menu, cộng thêm khả năng nhận phòng sớm tùy tình trạng thực tế.</span>
          </div>
          <div class="travel-promo-chip">Áp dụng mùa này</div>
        </div>
        <ul class="travel-list">
          <li>Khách mới có thể nhận thêm ưu đãi khi đăng ký tài khoản.</li>
          <li>Ở dài ngày có thể mở rộng quyền lợi spa hoặc dịch vụ đi kèm.</li>
          <li>Gia đình có trẻ nhỏ phù hợp với các gói linh hoạt hơn về bữa sáng và extra bed.</li>
        </ul>
      </div>
    </section>

    <section class="travel-section">
      <div class="travel-contact-card">
        <h3>Liên hệ & hỗ trợ đặt phòng</h3>
        <p>Khách cần xác nhận nhanh về phòng, ưu đãi hoặc dịch vụ đi kèm có thể liên hệ trực tiếp.</p>
        <ul class="travel-list">
          <li><strong>Hotline:</strong> 1900 1234 567</li>
          <li><strong>Email:</strong> reservation@bentoresort.vn</li>
          <li><strong>Địa chỉ:</strong> 123 Đường Biển, Thành phố Du lịch, Việt Nam</li>
        </ul>
      </div>
    </section>

  </div>
</main>

<script type="module" src="/js/home-galaxy-earth.js"></script>
<script>
  (() => {
    const THEME_KEY = "bento_home_day_night_theme_v1";
    const homeRoot = document.getElementById("travel-home");
    const themeToggle = document.getElementById("travel-theme-toggle");
    const themeLabel = themeToggle?.querySelector("[data-theme-label]");
    const installButtons = [
      document.getElementById("travel-install-app")
    ].filter(Boolean);

    function readTheme() {
      const saved = localStorage.getItem(THEME_KEY);
      return saved === "night" ? "night" : "day";
    }

    function applyTheme(theme, persist = true) {
      if (!homeRoot) return;
      const nextTheme = theme === "night" ? "night" : "day";
      homeRoot.dataset.theme = nextTheme;
      document.body.classList.toggle("travel-night", nextTheme === "night");
      themeToggle?.setAttribute("aria-pressed", nextTheme === "night" ? "true" : "false");
      themeToggle?.setAttribute("title", nextTheme === "night" ? "Kéo rèm lên để mở ban ngày" : "Kéo rèm xuống để mở ban đêm");
      themeToggle?.setAttribute("aria-label", nextTheme === "night" ? "Kéo rèm lên để mở ban ngày" : "Kéo rèm xuống để mở ban đêm");
      if (themeLabel) themeLabel.textContent = nextTheme === "night" ? "Kéo mở ngày" : "Kéo xuống đêm";
      if (persist) localStorage.setItem(THEME_KEY, nextTheme);
    }

    const updateInstallButtons = () => {
      const state = window.__abcPwaState || {};
      const canInstall = Boolean(state.installAvailable && typeof window.__abcPwaInstall === "function");
      const installed = Boolean(state.installed);

      installButtons.forEach((button) => {
        if (!button) return;
        if (installed) {
          button.textContent = "Đã ở app mode";
          button.disabled = true;
          button.style.opacity = "0.72";
          button.style.cursor = "default";
          return;
        }

        button.disabled = false;
        button.style.opacity = "1";
        button.style.cursor = "pointer";
        button.textContent = canInstall ? "Cài app Bento" : "Mở Mobile Hub";
      });

    };

    const handleInstall = async () => {
      const state = window.__abcPwaState || {};
      if (state.installAvailable && typeof window.__abcPwaInstall === "function") {
        await window.__abcPwaInstall();
        updateInstallButtons();
        return;
      }

      window.location.href = "<%= user ? "/customer/mobile-hub" : "/auth/login" %>";
    };

    installButtons.forEach((button) => {
      button.addEventListener("click", handleInstall);
    });

    themeToggle?.addEventListener("click", () => {
      const current = homeRoot?.dataset.theme === "night" ? "night" : "day";
      applyTheme(current === "night" ? "day" : "night");
    });

    window.addEventListener("abc:pwa-state", updateInstallButtons);
    applyTheme(readTheme(), false);
    updateInstallButtons();
  })();
</script>

