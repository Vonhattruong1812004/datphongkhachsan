<%- include("../partials/head") %>
<%- include("../partials/header") %>
<%
  const filters = payload?.filters || { result: "", q: "" };
  const items = payload?.items || [];
  const overview = payload?.overview || { total: items.length, pending: 0, approved: 0, rejected: 0, unverified: 0, needsAttention: 0 };
  const customer = selected?.customer || null;
  const verification = selected?.verification || null;
  const review = selected?.review || null;
  const history = selected?.history || [];
  const activeId = Number(selectedId || verification?.id || selected?.id || 0);
  const isLatest = selected?.isLatestForCustomer !== false;
  const roleId = Number(currentUser?.maVaiTro || 0);
  const dashboardHref = roleId === 2 ? "/dashboard/letan" : roleId === 1 ? "/dashboard/admin" : "/dashboard/quanly";
  const secondaryHref = roleId === 2 ? "/frontdesk/checkin" : "/manager/customers";
  const secondaryLabel = roleId === 2 ? "Check-in" : "CRM khách hàng";
  const badgeClass = (tone) => ({
    emerald: "ekyc-badge--ok",
    rose: "ekyc-badge--bad",
    amber: "ekyc-badge--wait",
    slate: "ekyc-badge--idle"
  }[tone || "slate"] || "ekyc-badge--idle");
  const keepParams = (id) => {
    const params = new URLSearchParams();
    if (id) params.set("id", String(id));
    if (filters.result) params.set("result", filters.result);
    if (filters.q) params.set("q", filters.q);
    return params.toString();
  };
%>
<style>
  :root {
    --ekyc-bg: #f4fbff;
    --ekyc-ink: #123247;
    --ekyc-strong: #0d2638;
    --ekyc-muted: #607789;
    --ekyc-soft: #f3f9fc;
    --ekyc-chip: #edf8ff;
    --ekyc-line: rgba(22, 78, 99, .16);
    --ekyc-table-line: rgba(22, 78, 99, .11);
    --ekyc-blue: #0284c7;
    --ekyc-sky: #38bdf8;
    --ekyc-teal: #0f766e;
    --ekyc-mint: #34d399;
    --ekyc-coral: #fb7185;
    --ekyc-violet: #8b5cf6;
    --ekyc-green: #059669;
    --ekyc-red: #dc2626;
    --ekyc-amber: #d97706;
    --ekyc-yellow: #f59e0b;
    --ekyc-shadow: 0 22px 54px rgba(15, 82, 112, .11);
    --ekyc-card-shadow: 0 12px 30px rgba(15, 82, 112, .075);
  }

  body {
    background:
      linear-gradient(115deg, rgba(56, 189, 248, .20) 0%, rgba(255, 255, 255, 0) 30%),
      linear-gradient(245deg, rgba(52, 211, 153, .18) 0%, rgba(255, 255, 255, 0) 34%),
      linear-gradient(35deg, rgba(251, 113, 133, .10) 0%, rgba(255, 255, 255, 0) 28%),
      linear-gradient(180deg, #f8fdff 0%, #eefaff 42%, #f7fff7 72%, #fff9ed 100%),
      var(--ekyc-bg);
    color: var(--ekyc-ink);
  }

  .ekyc-shell { max-width: 1320px; padding: 24px 18px 48px; }

  .ekyc-topbar {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 18px;
    align-items: center;
    margin-bottom: 16px;
    padding: 20px;
    border: 1px solid rgba(14, 165, 233, .18);
    border-radius: 8px;
    background:
      linear-gradient(120deg, rgba(2, 132, 199, .92), rgba(15, 118, 110, .82) 42%, rgba(245, 158, 11, .72)),
      linear-gradient(315deg, rgba(251, 113, 133, .45), rgba(255, 255, 255, 0) 46%),
      rgba(255, 255, 255, .94);
    box-shadow: var(--ekyc-shadow);
  }

  .ekyc-title-block { min-width: 0; }

  .ekyc-title-block::before {
    content: "QUẢN LÝ ĐỊNH DANH";
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 0 10px;
    margin-bottom: 10px;
    border-radius: 999px;
    border: 1px solid rgba(14, 165, 233, .22);
    background: rgba(255, 255, 255, .76);
    color: #075985;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: .08em;
  }

  .ekyc-title-block h1 {
    margin: 0 0 6px;
    font-size: clamp(25px, 2.7vw, 36px);
    line-height: 1.08;
    letter-spacing: 0;
    color: #ffffff;
    text-shadow: 0 2px 12px rgba(12, 74, 110, .18);
  }

  .ekyc-title-block p { max-width: 760px; margin: 0; color: rgba(255, 255, 255, .88); line-height: 1.55; }

  .ekyc-actions { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; justify-content: flex-end; }

  .ekyc-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    border: 1px solid var(--ekyc-line);
    border-radius: 8px;
    padding: 9px 14px;
    background: rgba(255, 255, 255, .96);
    color: var(--ekyc-ink);
    text-decoration: none;
    font-weight: 800;
    cursor: pointer;
    box-shadow: 0 8px 18px rgba(15, 82, 112, .055);
    transition: transform .16s ease, box-shadow .16s ease, border-color .16s ease;
  }

  .ekyc-btn:hover { transform: translateY(-1px); }

  .ekyc-btn:hover, .ekyc-btn:focus-visible {
    border-color: rgba(2, 132, 199, .45);
    box-shadow: 0 0 0 3px rgba(14, 165, 233, .13), 0 12px 24px rgba(15, 82, 112, .09);
    outline: none;
  }

  .ekyc-btn--primary {
    background: linear-gradient(135deg, #0ea5e9, #14b8a6 56%, #22c55e);
    border-color: rgba(2, 132, 199, .34);
    color: #fff;
    box-shadow: 0 14px 28px rgba(2, 132, 199, .2);
  }
  .ekyc-btn--ok {
    background: linear-gradient(135deg, #22c55e, #10b981, #059669);
    border-color: rgba(5, 150, 105, .34);
    color: #fff;
  }
  .ekyc-btn--bad {
    background: linear-gradient(135deg, #fb7185, #ef4444, #b91c1c);
    border-color: rgba(220, 38, 38, .34);
    color: #fff;
  }
  .ekyc-btn--wait {
    background: linear-gradient(135deg, #fff7ed, #fffbeb);
    border-color: #fbbf24;
    color: #9a3412;
  }
  .ekyc-btn[disabled] { opacity: .58; cursor: not-allowed; box-shadow: none; }

  .ekyc-metrics {
    display: grid;
    grid-template-columns: minmax(170px, 1.2fr) repeat(4, minmax(140px, 1fr));
    gap: 12px;
    margin-bottom: 16px;
  }

  .ekyc-metric, .ekyc-panel, .ekyc-queue-item, .ekyc-image-box, .ekyc-info-box {
    background:
      linear-gradient(135deg, rgba(255, 255, 255, .98), rgba(255, 255, 255, .90)),
      #fff;
    border: 1px solid var(--ekyc-line);
    border-radius: 8px;
    box-shadow: var(--ekyc-card-shadow);
  }

  .ekyc-metric {
    position: relative;
    min-height: 90px;
    padding: 16px;
    overflow: hidden;
  }

  .ekyc-metric::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--ekyc-blue), var(--ekyc-sky), var(--ekyc-mint), var(--ekyc-yellow));
  }

  .ekyc-metric:nth-child(1) { background: linear-gradient(135deg, rgba(224, 242, 254, .92), rgba(255, 255, 255, .96)); }
  .ekyc-metric:nth-child(2) { background: linear-gradient(135deg, rgba(255, 247, 237, .96), rgba(255, 255, 255, .96)); }
  .ekyc-metric:nth-child(3) { background: linear-gradient(135deg, rgba(254, 243, 199, .90), rgba(255, 255, 255, .96)); }
  .ekyc-metric:nth-child(4) { background: linear-gradient(135deg, rgba(220, 252, 231, .92), rgba(255, 255, 255, .96)); }
  .ekyc-metric:nth-child(5) { background: linear-gradient(135deg, rgba(255, 228, 230, .92), rgba(255, 255, 255, .96)); }

  .ekyc-metric span {
    display: block;
    color: var(--ekyc-muted);
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
  }
  .ekyc-metric strong { display: block; margin-top: 6px; font-size: 28px; line-height: 1; }

  .ekyc-layout {
    display: grid;
    grid-template-columns: minmax(340px, 395px) minmax(0, 1fr);
    gap: 16px;
    align-items: start;
  }

  .ekyc-panel { padding: 16px; }
  .ekyc-panel--queue {
    position: sticky;
    top: 14px;
    background:
      linear-gradient(180deg, rgba(224, 242, 254, .92), rgba(236, 253, 245, .70) 38%, rgba(255, 255, 255, .96)),
      #fff;
  }

  .ekyc-panel:not(.ekyc-panel--queue) {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, .98), rgba(240, 253, 250, .56)),
      #fff;
  }

  .ekyc-toolbar {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 10px;
    align-items: end;
    margin-bottom: 14px;
  }
  .ekyc-field label {
    display: block;
    margin-bottom: 6px;
    color: var(--ekyc-muted);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: .02em;
  }
  .ekyc-field input, .ekyc-field select, .ekyc-field textarea {
    width: 100%;
    min-height: 40px;
    border: 1px solid var(--ekyc-line);
    border-radius: 8px;
    padding: 9px 11px;
    background: rgba(255, 255, 255, .98);
    color: var(--ekyc-ink);
    font: inherit;
    box-sizing: border-box;
  }

  .ekyc-field textarea { min-height: 112px; resize: vertical; }

  .ekyc-field input:focus, .ekyc-field select:focus, .ekyc-field textarea:focus {
    border-color: rgba(2, 132, 199, .55);
    box-shadow: 0 0 0 3px rgba(14, 165, 233, .13);
    outline: none;
  }

  .ekyc-queue { display: grid; gap: 9px; max-height: calc(100vh - 330px); min-height: 360px; overflow: auto; padding-right: 3px; }

  .ekyc-queue-item {
    display: block;
    padding: 13px;
    color: inherit;
    text-decoration: none;
  }

  .ekyc-queue-item:hover, .ekyc-queue-item:focus-visible, .ekyc-queue-item.is-active {
    border-color: rgba(2, 132, 199, .5);
    box-shadow: 0 0 0 3px rgba(14, 165, 233, .11), 0 12px 28px rgba(15, 82, 112, .09);
    outline: none;
  }

  .ekyc-queue-item.is-active {
    background:
      linear-gradient(135deg, rgba(14, 165, 233, .18), rgba(52, 211, 153, .13) 58%, rgba(245, 158, 11, .12)),
      #fff;
  }

  .ekyc-queue-item:nth-child(3n + 1):not(.is-active) {
    background: linear-gradient(135deg, rgba(240, 249, 255, .88), rgba(255, 255, 255, .96));
  }

  .ekyc-queue-item:nth-child(3n + 2):not(.is-active) {
    background: linear-gradient(135deg, rgba(240, 253, 244, .88), rgba(255, 255, 255, .96));
  }

  .ekyc-queue-item:nth-child(3n):not(.is-active) {
    background: linear-gradient(135deg, rgba(255, 251, 235, .82), rgba(255, 255, 255, .96));
  }

  .ekyc-row { display: flex; justify-content: space-between; gap: 10px; align-items: flex-start; }
  .ekyc-muted { color: var(--ekyc-muted); }
  .ekyc-name { margin: 0; font-size: 16px; color: var(--ekyc-strong); }

  .ekyc-badge {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 5px 9px;
    font-size: 12px;
    font-weight: 900;
    white-space: nowrap;
  }

  .ekyc-badge--ok { background: linear-gradient(135deg, #bbf7d0, #dcfce7); color: #047857; border: 1px solid #86efac; }
  .ekyc-badge--bad { background: linear-gradient(135deg, #fecdd3, #fee2e2); color: #b91c1c; border: 1px solid #fda4af; }
  .ekyc-badge--wait { background: linear-gradient(135deg, #fde68a, #fef3c7); color: #92400e; border: 1px solid #fbbf24; }
  .ekyc-badge--idle { background: linear-gradient(135deg, #bae6fd, #e0f2fe); color: #0369a1; border: 1px solid #7dd3fc; }

  .ekyc-chip-row { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 9px; }

  .ekyc-chip {
    border-radius: 999px;
    padding: 4px 8px;
    background: linear-gradient(135deg, #e0f2fe, #ecfeff);
    border: 1px solid rgba(14, 165, 233, .14);
    color: #336072;
    font-size: 12px;
    font-weight: 800;
  }

  .ekyc-chip--warn {
    background: linear-gradient(135deg, #ffedd5, #fef3c7);
    border-color: #fdba74;
    color: #9a3412;
  }

  .ekyc-detail-head {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    flex-wrap: wrap;
    align-items: flex-start;
    margin-bottom: 14px;
    padding: 14px;
    border-radius: 8px;
    background:
      linear-gradient(120deg, rgba(224, 242, 254, .96), rgba(204, 251, 241, .86) 48%, rgba(254, 243, 199, .84)),
      var(--ekyc-soft);
    border: 1px solid var(--ekyc-line);
  }

  .ekyc-detail-head h2 { margin: 0 0 6px; font-size: 26px; letter-spacing: 0; color: var(--ekyc-strong); }
  .ekyc-status-stack { min-width: 190px; text-align: right; }
  .ekyc-image-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; }
  .ekyc-image-box, .ekyc-info-box { padding: 14px; }
  .ekyc-image-box strong, .ekyc-info-box > strong { color: var(--ekyc-strong); }

  .ekyc-image-box:nth-child(1) {
    background: linear-gradient(135deg, rgba(224, 242, 254, .98), rgba(255, 255, 255, .96));
  }

  .ekyc-image-box:nth-child(2) {
    background: linear-gradient(135deg, rgba(236, 253, 245, .98), rgba(255, 255, 255, .96));
  }

  .ekyc-image-box:nth-child(3) {
    background: linear-gradient(135deg, rgba(255, 247, 237, .98), rgba(255, 255, 255, .96));
  }

  .ekyc-image-box img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 8px;
    border: 1px solid var(--ekyc-line);
    display: block;
    background: linear-gradient(135deg, #e0f2fe, #dcfce7);
  }

  .ekyc-empty-img {
    aspect-ratio: 4 / 3;
    border-radius: 8px;
    display: grid;
    place-items: center;
    border: 1px dashed #cbd5e1;
    color: var(--ekyc-muted);
    background: linear-gradient(135deg, #e0f2fe, #ecfeff 48%, #fffbeb);
  }

  .ekyc-info-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 12px;
    margin-top: 12px;
  }
  .ekyc-kv {
    display: grid;
    grid-template-columns: 138px minmax(0, 1fr);
    gap: 8px 10px;
    font-size: 14px;
  }

  .ekyc-kv strong { color: var(--ekyc-muted); }
  .ekyc-history { display: grid; gap: 8px; margin-top: 10px; }
  .ekyc-history-item { border-top: 1px solid var(--ekyc-line); padding-top: 10px; }
  .ekyc-review-box {
    margin-top: 12px;
  }
  .ekyc-review-box form {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 280px;
    gap: 14px;
    align-items: end;
  }
  .ekyc-review-actions {
    display: grid;
    gap: 8px;
  }

  .ekyc-review-actions .ekyc-btn {
    justify-content: center;
    width: 100%;
  }

  .ekyc-flash {
    margin-bottom: 14px;
    padding: 12px 14px;
    border-radius: 8px;
    font-weight: 800;
  }
  .ekyc-flash--success { background: linear-gradient(135deg, #dcfce7, #ecfeff); color: #047857; border: 1px solid #86efac; }
  .ekyc-flash--error { background: linear-gradient(135deg, #ffe4e6, #fff1f2); color: #b91c1c; border: 1px solid #fda4af; }
  .ekyc-warning {
    margin: 10px 0;
    padding: 10px 12px;
    border-radius: 8px;
    background: linear-gradient(135deg, #fff7ed, #fef3c7);
    border: 1px solid #fdba74;
    color: #9a3412;
    font-weight: 800;
  }

  @media (max-width: 1080px) {
    .ekyc-topbar, .ekyc-layout { grid-template-columns: 1fr; }
    .ekyc-topbar { align-items: flex-start; }
    .ekyc-toolbar { grid-template-columns: 1fr; }
    .ekyc-metrics { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .ekyc-panel--queue { position: static; }
    .ekyc-queue { max-height: 520px; }
    .ekyc-review-box form { grid-template-columns: 1fr; align-items: stretch; }
    .ekyc-review-actions { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }

  @media (max-width: 760px) {
    .ekyc-shell { padding-left: 12px; padding-right: 12px; }
    .ekyc-image-grid, .ekyc-info-grid, .ekyc-metrics { grid-template-columns: 1fr; }
    .ekyc-kv { grid-template-columns: 1fr; }
    .ekyc-topbar { display: grid; }
    .ekyc-status-stack { width: 100%; text-align: left; }
    .ekyc-actions { justify-content: flex-start; }
    .ekyc-review-actions { grid-template-columns: 1fr; }
  }
</style>

<main class="container ekyc-shell">
  <section class="ekyc-topbar">
    <div class="ekyc-title-block">
      <h1>Duyệt eKYC</h1>
      <p>Queue hồ sơ mới nhất theo từng khách hàng, đồng bộ trực tiếp về trạng thái định danh dùng cho check-in.</p>
    </div>
    <div class="ekyc-actions">
      <a class="ekyc-btn" href="<%= dashboardHref %>">Dashboard</a>
      <a class="ekyc-btn" href="<%= secondaryHref %>"><%= secondaryLabel %></a>
      <a class="ekyc-btn ekyc-btn--primary" href="/api/ekyc/review-queue">JSON</a>
    </div>
  </section>

  <% if (flash) { %>
    <div class="ekyc-flash ekyc-flash--<%= flash.type === "error" ? "error" : "success" %>"><%= flash.message %></div>
  <% } %>

  <section class="ekyc-metrics" aria-label="Tổng quan eKYC">
    <article class="ekyc-metric"><span>Tổng latest</span><strong><%= overview.total || 0 %></strong></article>
    <article class="ekyc-metric"><span>Cần xử lý</span><strong style="color:var(--ekyc-amber)"><%= overview.needsAttention || 0 %></strong></article>
    <article class="ekyc-metric"><span>Đang chờ</span><strong style="color:var(--ekyc-amber)"><%= overview.pending || 0 %></strong></article>
    <article class="ekyc-metric"><span>Đã xác thực</span><strong style="color:var(--ekyc-green)"><%= overview.approved || 0 %></strong></article>
    <article class="ekyc-metric"><span>Thất bại</span><strong style="color:var(--ekyc-red)"><%= overview.rejected || 0 %></strong></article>
  </section>

  <section class="ekyc-layout">
    <aside class="ekyc-panel ekyc-panel--queue">
      <form class="ekyc-toolbar" method="get" action="/ekyc/review">
        <div class="ekyc-field">
          <label for="q">Tìm kiếm</label>
          <input id="q" name="q" value="<%= filters.q || "" %>" placeholder="Tên, email, SĐT, CCCD..." />
        </div>
        <div class="ekyc-field">
          <label for="result">Trạng thái</label>
          <select id="result" name="result">
            <option value="">Tất cả</option>
            <option value="DangXuLy" <%= filters.result === "DangXuLy" ? "selected" : "" %>>Đang xử lý</option>
            <option value="ThanhCong" <%= filters.result === "ThanhCong" ? "selected" : "" %>>Đã xác thực</option>
            <option value="ThatBai" <%= filters.result === "ThatBai" ? "selected" : "" %>>Thất bại</option>
            <option value="ChuaXacThuc" <%= filters.result === "ChuaXacThuc" ? "selected" : "" %>>Chưa xác thực</option>
          </select>
        </div>
        <div class="ekyc-actions">
          <button class="ekyc-btn ekyc-btn--primary" type="submit">Lọc</button>
          <a class="ekyc-btn" href="/ekyc/review">Reset</a>
        </div>
      </form>

      <div class="ekyc-row" style="margin:2px 0 10px">
        <strong>Danh sách hồ sơ</strong>
        <span class="ekyc-muted"><%= items.length %> dòng</span>
      </div>

      <div class="ekyc-queue">
        <% if (items.length) { %>
          <% items.forEach((item) => { %>
            <a class="ekyc-queue-item <%= Number(item.id) === activeId ? "is-active" : "" %>" href="/ekyc/review?<%= keepParams(item.id) %>">
              <div class="ekyc-row">
                <div>
                  <h3 class="ekyc-name"><%= item.customer_name %></h3>
                  <div class="ekyc-muted" style="margin-top:4px"><%= item.document_type || "-" %> · <%= item.document_number || "-" %></div>
                </div>
                <span class="ekyc-badge <%= badgeClass(item.tone) %>"><%= item.result_label %></span>
              </div>
              <div class="ekyc-muted" style="margin-top:8px;font-size:13px">
                <div><%= item.customer_phone || item.customer_email || "Chưa có liên hệ" %></div>
                <div><%= item.submitted_at || "Chưa rõ thời gian" %> · Tin cậy <%= item.confidence_label %></div>
              </div>
              <div class="ekyc-chip-row">
                <span class="ekyc-chip <%= item.image_count < 3 ? "ekyc-chip--warn" : "" %>">Ảnh <%= item.image_count %>/3</span>
                <% if (!item.is_document_match) { %><span class="ekyc-chip ekyc-chip--warn">Lệch CCCD</span><% } %>
                <% if (item.needs_attention) { %><span class="ekyc-chip ekyc-chip--warn">Cần xử lý</span><% } %>
              </div>
            </a>
          <% }) %>
        <% } else { %>
          <div class="ekyc-info-box ekyc-muted">Không có hồ sơ khớp bộ lọc.</div>
        <% } %>
      </div>
    </aside>

    <section class="ekyc-panel">
      <% if (selected && verification) { %>
        <div class="ekyc-detail-head">
          <div>
            <h2><%= customer?.name || "Khách hàng" %></h2>
            <div class="ekyc-muted"><%= customer?.email || "-" %> · <%= customer?.phone || "-" %></div>
            <% if (!isLatest) { %>
              <div class="ekyc-warning">Đây là hồ sơ cũ. Hồ sơ mới nhất là #<%= selected.latestEkycId %>.</div>
            <% } %>
          </div>
          <div class="ekyc-status-stack">
            <span class="ekyc-badge <%= badgeClass(review?.tone) %>"><%= review?.result_label || "Chưa xác thực" %></span>
            <div class="ekyc-muted" style="margin-top:7px">Khách: <%= customer?.ekyc_status_label || "Khách chưa xác thực" %></div>
            <div class="ekyc-muted">Tin cậy: <%= verification.confidence_label || "0%" %></div>
          </div>
        </div>

        <div class="ekyc-image-grid">
          <% [
            ["Mặt trước", verification.images?.front_url],
            ["Mặt sau", verification.images?.back_url],
            ["Selfie", verification.images?.selfie_url]
          ].forEach(([label, url]) => { %>
            <article class="ekyc-image-box">
              <strong><%= label %></strong>
              <div style="height:8px"></div>
              <% if (url) { %>
                <a href="<%= url %>" target="_blank" rel="noreferrer"><img src="<%= url %>" alt="<%= label %> eKYC của <%= customer?.name || "khách hàng" %>" /></a>
              <% } else { %>
                <div class="ekyc-empty-img">Chưa có ảnh</div>
              <% } %>
            </article>
          <% }) %>
        </div>

        <div class="ekyc-info-grid">
          <article class="ekyc-info-box">
            <strong>Đối chiếu giấy tờ</strong>
            <div class="ekyc-kv" style="margin-top:10px">
              <strong>Loại giấy tờ</strong><div><%= verification.document_type || "-" %></div>
              <strong>Số giấy tờ</strong><div><%= verification.document_number || "-" %></div>
              <strong>CCCD hồ sơ khách</strong><div><%= customer?.cccd || "-" %></div>
              <strong>Ngày gửi</strong><div><%= verification.submitted_at || "-" %></div>
              <strong>Ngày xác thực</strong><div><%= verification.verified_at || "-" %></div>
            </div>
            <% if (review && !review.is_document_match) { %>
              <div class="ekyc-warning">Số giấy tờ gửi lên khác CCCD đang lưu. Nếu duyệt, hệ thống sẽ đồng bộ CCCD theo hồ sơ này.</div>
            <% } %>
          </article>
          <article class="ekyc-info-box">
            <strong>Ghi chú</strong>
            <p class="ekyc-muted" style="line-height:1.7;margin-bottom:0"><%= verification.note || "Chưa có ghi chú." %></p>
          </article>
        </div>

        <article class="ekyc-info-box" style="margin-top:10px">
          <div class="ekyc-row">
            <strong>Lịch sử cùng khách</strong>
            <span class="ekyc-muted"><%= history.length %> lần gửi</span>
          </div>
          <div class="ekyc-history">
            <% if (history.length) { %>
              <% history.forEach((item) => { %>
                <div class="ekyc-history-item">
                  <div class="ekyc-row">
                    <div>
                      <strong>#<%= item.id %> · <%= item.document_type || "-" %> · <%= item.document_number || "-" %></strong>
                      <div class="ekyc-muted" style="font-size:13px;margin-top:4px">Gửi: <%= item.submitted_at || "-" %> · Xác thực: <%= item.verified_at || "-" %></div>
                    </div>
                    <span class="ekyc-badge <%= badgeClass(item.tone) %>"><%= item.result_label %></span>
                  </div>
                </div>
              <% }) %>
            <% } else { %>
              <div class="ekyc-muted">Chưa có lịch sử hồ sơ.</div>
            <% } %>
          </div>
        </article>

        <article class="ekyc-info-box ekyc-review-box">
          <form method="post" action="/ekyc/review">
            <input type="hidden" name="ma_ekyc" value="<%= verification.id %>" />
            <input type="hidden" name="result_filter" value="<%= filters.result || "" %>" />
            <input type="hidden" name="q_filter" value="<%= filters.q || "" %>" />
            <div class="ekyc-field">
              <label for="review_note">Ghi chú duyệt</label>
              <textarea id="review_note" name="review_note" placeholder="Ghi nhận đối chiếu giấy tờ, lý do từ chối hoặc yêu cầu khách gửi lại."></textarea>
            </div>
            <div class="ekyc-review-actions">
              <button class="ekyc-btn ekyc-btn--ok" type="submit" name="decision" value="approve" <%= !isLatest ? "disabled" : "" %>>Duyệt xác thực</button>
              <button class="ekyc-btn ekyc-btn--bad" type="submit" name="decision" value="reject" <%= !isLatest ? "disabled" : "" %>>Từ chối</button>
              <button class="ekyc-btn ekyc-btn--wait" type="submit" name="decision" value="pending" <%= !isLatest ? "disabled" : "" %>>Chờ xử lý</button>
            </div>
          </form>
        </article>
      <% } else { %>
        <div class="ekyc-info-box" style="min-height:360px;display:grid;place-items:center;text-align:center">
          <div>
            <h2>Chưa chọn hồ sơ</h2>
            <p class="ekyc-muted">Danh sách bên trái đang hiển thị hồ sơ mới nhất theo từng khách.</p>
          </div>
        </div>
      <% } %>
    </section>
  </section>
</main>
<%- include("../partials/footer") %>
