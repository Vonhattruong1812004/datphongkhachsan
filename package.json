{
  "name": "abc-resort-node",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch src/server.ts",
    "dev:client": "vite",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p tsconfig.json",
    "build:client": "vite build",
    "start": "node dist/server.js",
    "test": "tsx --test src/**/*.test.ts",
    "verify:db": "tsx src/scripts/verify-db.ts",
    "smoke": "tsx src/scripts/smoke.ts",
    "smoke:auth": "tsx src/scripts/smoke-auth.ts",
    "smoke:actors": "tsx src/scripts/smoke-actors.ts",
    "smoke:manager": "tsx src/scripts/smoke-manager.ts",
    "smoke:manager:rooms": "tsx src/scripts/smoke-manager-rooms.ts",
    "smoke:manager:promotions": "tsx src/scripts/smoke-manager-promotions.ts",
    "smoke:accounting": "tsx src/scripts/smoke-accounting.ts",
    "smoke:feedback": "tsx src/scripts/smoke-feedback.ts",
    "smoke:ekyc": "tsx src/scripts/smoke-ekyc.ts",
    "smoke:frontdesk": "tsx src/scripts/smoke-frontdesk.ts",
    "smoke:service": "tsx src/scripts/smoke-service.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "connect-pg-simple": "^10.0.0",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
